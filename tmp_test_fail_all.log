an>\n            </a>\n      </nav>\n    </div>\n  </div>\n\n  <!-- JavaScript SPA & Toggle Logic -->\n  <script>\n    document.addEventListener(\"DOMContentLoaded\", () => {\n      // SPA Navigation for preserving Fullscreen State\n      const bindReaderLinks = () => {\n        const links = document.querySelectorAll('a[href^=\"/books\"], a[href^=\"/libro\"]');\n        links.forEach(link => {\n          const href = link.getAttribute(\"href\");\n          if (!isReaderChapterUrl(href)) return;\n\n          // Clone to prevent duplicate event listeners\n          const newLink = link.cloneNode(true);\n          link.parentNode.replaceChild(newLink, link);\n\n          newLink.addEventListener(\"click\", (e) => {\n            const href = newLink.getAttribute(\"href\");\n            if (!isReaderChapterUrl(href)) return;\n\n            e.preventDefault();\n            navigateToChapter(href);\n          });\n        });\n      };\n\n      const isReaderChapterUrl = (href) => {\n        if (!href) return false;\n\n        const url = new URL(href, window.location.origin);\n        return url.origin === window.location.origin &&\n          (url.pathname === \"/libro\" ||\n            /^\\/libro\\/(?!gestione\\/)/.test(url.pathname) ||\n            /^\\/books\\/[^/]+$/.test(url.pathname) ||\n            /^\\/books\\/[^/]+\\/(?!gestione\\/).+/.test(url.pathname));\n      };\n\n      const navigateToChapter = (url) => {\n        fetch(url)\n          .then(res => res.text())\n          .then(htmlText => {\n            const parser = new DOMParser();\n            const doc = parser.parseFromString(htmlText, \"text/html\");\n            const newMain = doc.querySelector(\"main\");\n            const currentMain = document.querySelector(\"main\");\n            const newHeader = doc.querySelector(\".header-bar\");\n            const currentHeader = document.querySelector(\".header-bar\");\n\n            if (!newMain || !currentMain || !newHeader || !currentHeader) {\n              window.location.href = url;\n              return;\n            }\n\n            // Update document title and URL\n            document.title = doc.title;\n            history.pushState(null, \"\", url);\n\n            // Swap main container\n            currentMain.outerHTML = newMain.outerHTML;\n\n            // Swap header content\n            currentHeader.outerHTML = newHeader.outerHTML;\n\n            // Swap mobile drawer\n            const newDrawer = doc.querySelector(\"#mobile-toc-drawer\");\n            const currentDrawer = document.getElementById(\"mobile-toc-drawer\");\n            if (newDrawer && currentDrawer) {\n              currentDrawer.outerHTML = newDrawer.outerHTML;\n            }\n\n            // Re-bind listeners for the newly loaded elements\n            bindReaderLinks();\n            rebindToggles();\n          })\n          .catch(err => {\n            console.error(\"Errore durante la navigazione SPA:\", err);\n            // Fallback\n            window.location.href = url;\n          });\n      };\n\n      const rebindToggles = () => {\n        // Re-bind mobile TOC drawer logic\n        const toggleBtn = document.getElementById(\"mobile-toc-toggle\");\n        const closeBtn = document.getElementById(\"mobile-toc-close\");\n        const backdrop = document.getElementById(\"mobile-toc-backdrop\");\n        const drawer = document.getElementById(\"mobile-toc-drawer\");\n        const panel = document.getElementById(\"mobile-toc-panel\");\n\n        if (toggleBtn && drawer && panel) {\n          const showDrawer = () => {\n            drawer.classList.remove(\"hidden\");\n            setTimeout(() => {\n              panel.classList.remove(\"-translate-x-full\");\n            }, 20);\n          };\n\n          const hideDrawer = () => {\n            panel.classList.add(\"-translate-x-full\");\n            setTimeout(() => {\n              drawer.classList.add(\"hidden\");\n            }, 300);\n          };\n\n          toggleBtn.addEventListener(\"click\", showDrawer);\n          if (closeBtn) closeBtn.addEventListener(\"click\", hideDrawer);\n          if (backdrop) backdrop.addEventListener(\"click\", hideDrawer);\n        }\n\n        // Re-bind fullscreen controls\n        const fsToggle = document.getElementById(\"fullscreen-toggle\");\n        if (fsToggle) {\n          fsToggle.addEventListener(\"click\", () => {\n            if (!document.fullscreenElement) {\n              document.documentElement.requestFullscreen().catch(err => {\n                console.error(\"Errore attivando lo schermo intero:\", err.message);\n              });\n            } else {\n              document.exitFullscreen();\n            }\n          });\n          // Update button label\n          if (document.fullscreenElement) {\n            fsToggle.innerHTML = \"⛶ Esci\";\n          } else {\n            fsToggle.innerHTML = \"⛶ Schermo Intero\";\n          }\n        }\n\n        const fsExitFloating = document.getElementById(\"fullscreen-exit-floating\");\n        if (fsExitFloating) {\n          fsExitFloating.addEventListener(\"click\", () => {\n            if (document.fullscreenElement) {\n              document.exitFullscreen();\n            }\n          });\n        }\n      };\n\n      // Initial binding\n      bindReaderLinks();\n      rebindToggles();\n\n      // Listen for browser back/forward buttons\n      window.addEventListener(\"popstate\", () => {\n        if (isReaderChapterUrl(window.location.pathname)) {\n          navigateToChapter(window.location.pathname);\n        } else {\n          window.location.reload();\n        }\n      });\n    });\n  </script>\n\n</body>\n</html>\n" to include "Il tuo corpo ti accompagna ogni giorno".

