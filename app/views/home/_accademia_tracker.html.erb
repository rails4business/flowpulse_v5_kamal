<%
lesson_row = ->(number, title, slug, theme_color, description = nil) do
  theme_classes = {
    "sky" => { border: "border-sky-300", text: "text-sky-800", bg: "bg-sky-100", accent: "text-sky-600", focus: "focus:ring-sky-500" },
    "indigo" => { border: "border-indigo-300", text: "text-indigo-800", bg: "bg-indigo-100", accent: "text-indigo-600", focus: "focus:ring-indigo-500" },
    "blue" => { border: "border-blue-300", text: "text-blue-800", bg: "bg-blue-100", accent: "text-blue-600", focus: "focus:ring-blue-500" },
    "violet" => { border: "border-violet-300", text: "text-violet-800", bg: "bg-violet-100", accent: "text-violet-600", focus: "focus:ring-violet-500" },
    "emerald" => { border: "border-emerald-300", text: "text-emerald-800", bg: "bg-emerald-100", accent: "text-emerald-600", focus: "focus:ring-emerald-500" },
    "rose" => { border: "border-rose-300", text: "text-rose-850", bg: "bg-rose-100", accent: "text-rose-600", focus: "focus:ring-rose-500" },
    "amber" => { border: "border-amber-300", text: "text-amber-800", bg: "bg-amber-100", accent: "text-amber-600", focus: "focus:ring-amber-500" },
    "fuchsia" => { border: "border-fuchsia-300", text: "text-fuchsia-800", bg: "bg-fuchsia-100", accent: "text-fuchsia-600", focus: "focus:ring-fuchsia-500" },
    "green" => { border: "border-green-300", text: "text-green-800", bg: "bg-green-100", accent: "text-green-600", focus: "focus:ring-green-500" },
    "red" => { border: "border-red-300", text: "text-red-800", bg: "bg-red-100", accent: "text-red-600", focus: "focus:ring-red-500" },
    "orange" => { border: "border-orange-300", text: "text-orange-850", bg: "bg-orange-100", accent: "text-orange-600", focus: "focus:ring-orange-500" }
  }[theme_color] || { border: "border-slate-300", text: "text-slate-800", bg: "bg-slate-100", accent: "text-slate-600", focus: "focus:ring-slate-500" }
%>
  <div class="group/row flex flex-col lg:flex-row lg:items-center lg:justify-between py-2.5 px-3 border-b border-slate-100 hover:bg-slate-50/50 rounded-xl transition duration-150 gap-4">
    <!-- Left Column: Lesson Title -->
    <div class="flex items-center justify-between lg:justify-start gap-4 lg:w-5/12">
      <div class="flex items-center gap-3">
        <span class="text-xs font-bold text-slate-400 min-w-[48px] self-start mt-0.5">LEZ <%= number %></span>
        <div>
          <a href="/books/il-corpo-un-mondo-da-scoprire/<%= slug %>" class="text-sm font-semibold text-slate-800 hover:text-<%= theme_color %>-600 hover:underline transition">
            <%= title %>
          </a>
          <% if description.present? %>
            <p class="text-xs text-slate-500 mt-1 font-normal"><%= description %></p>
          <% end %>
        </div>
      </div>
      <a href="/books/il-corpo-un-mondo-da-scoprire/<%= slug %>" class="shrink-0 rounded-md py-0.5 px-2 text-[10px] font-bold bg-slate-100 text-slate-600 hover:<%= theme_classes[:bg] %> hover:<%= theme_classes[:text] %> transition uppercase tracking-wider self-start mt-0.5">
        Leggi →
      </a>
    </div>

    <!-- Right Column: Progress Tracker -->
    <div class="grid grid-cols-3 gap-2 lg:gap-3 lg:w-7/12 text-xs">
      <!-- Column 1: Informati -->
      <div class="flex flex-col gap-1 bg-white p-2 rounded-lg border border-slate-200/50 shadow-2xs hover:border-slate-350 transition">
        <div class="flex items-center gap-1.5 font-semibold text-slate-700">
          <input type="checkbox" class="rounded text-blue-600 border-slate-300 focus:ring-blue-500 w-3 h-3 cursor-pointer">
          <span class="text-[9px] tracking-wide uppercase text-slate-500">Informati</span>
        </div>
        <input type="date" class="bg-transparent border-0 p-0 text-[10px] text-slate-400 focus:ring-0 focus:outline-hidden w-full cursor-pointer" placeholder="Scegli data">
      </div>

      <!-- Column 2: Pratica -->
      <div class="flex flex-col gap-1 bg-white p-2 rounded-lg border border-slate-200/50 shadow-2xs hover:border-slate-350 transition">
        <div class="flex items-center justify-between font-semibold text-slate-700">
          <span class="text-[9px] tracking-wide uppercase text-slate-550">Pratica</span>
          <select class="bg-transparent border-0 p-0 text-[9px] text-slate-400 focus:ring-0 focus:outline-hidden cursor-pointer font-normal text-right">
            <option value="gruppo">Gruppo</option>
            <option value="indiv">Indiv.</option>
          </select>
        </div>
        <div class="flex gap-1.5 items-center justify-between">
          <input type="text" placeholder="Prof" class="bg-transparent border-0 border-b border-dashed border-slate-200 p-0 pb-0.5 text-[10px] text-slate-700 placeholder-slate-350 focus:ring-0 focus:border-blue-500 focus:outline-hidden w-[45%]">
          <input type="date" class="bg-transparent border-0 p-0 text-[10px] text-slate-400 focus:ring-0 focus:outline-hidden w-[50%] cursor-pointer">
        </div>
      </div>

      <!-- Column 3: Insegna -->
      <div class="flex flex-col gap-1 bg-white p-2 rounded-lg border border-slate-200/50 shadow-2xs hover:border-slate-355 transition">
        <div class="flex items-center justify-between font-semibold text-slate-700">
          <span class="text-[9px] tracking-wide uppercase text-slate-500">Insegna</span>
          <label class="flex items-center gap-0.5 text-[9px] text-slate-500 font-normal cursor-pointer">
            <input type="checkbox" class="rounded text-violet-600 border-slate-300 focus:ring-violet-500 w-2.5 h-2.5">
            <span>Cert.</span>
          </label>
        </div>
        <input type="date" class="bg-transparent border-0 p-0 text-[10px] text-slate-400 focus:ring-0 focus:outline-hidden w-full cursor-pointer" placeholder="Scegli data">
      </div>
    </div>
  </div>
<%
end
%>

<!-- TABS CONTROLLER (with overflow scroll on small screens) -->
<div class="flex justify-center mb-10 border-b border-slate-100 pb-8">
  <div class="inline-flex p-1 bg-slate-150 backdrop-blur-md rounded-2xl border border-slate-200 overflow-x-auto max-w-full whitespace-nowrap no-scrollbar gap-1 shadow-2xs">
    <button onclick="switchTrackerTab('dolore')" id="tab-tracker-btn-dolore" class="shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 text-slate-550 hover:text-slate-955">
      Stop al dolore
    </button>
    <button onclick="switchTrackerTab('prevenzione')" id="tab-tracker-btn-prevenzione" class="shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 text-slate-550 hover:text-slate-955">
      Prevenzione
    </button>
    <button onclick="switchTrackerTab('performance')" id="tab-tracker-btn-performance" class="shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 text-slate-550 hover:text-slate-955">
      Performance
    </button>
    <button onclick="switchTrackerTab('fisiologia')" id="tab-tracker-btn-fisiologia" class="shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50">
      Postura e Fisiologia
    </button>
    <button onclick="switchTrackerTab('benessere')" id="tab-tracker-btn-benessere" class="shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 text-slate-550 hover:text-slate-955">
      Benessere Integrato
    </button>
    <button onclick="switchTrackerTab('giardino')" id="tab-tracker-btn-giardino" class="shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 text-slate-550 hover:text-violet-750 flex items-center gap-1.5">
      <span id="tracker-giardino-lock-icon">🔒</span>
      <span>Il Giardino del Corpo</span>
    </button>
  </div>
</div>

<div class="space-y-12">
  
  <!-- TAB 1: Stop al Dolore (Hidden by default) -->
  <div id="tracker-sec-dolore" class="space-y-8 hidden">
    <div class="bg-blue-50/80 border border-blue-100/70 rounded-3xl p-6 text-center max-w-2xl mx-auto shadow-2xs">
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-blue-100 text-blue-700 text-lg font-bold mb-3">
        🩹
      </span>
      <h3 class="text-lg font-bold text-slate-900">Stop al dolore</h3>
      <p class="text-slate-655 mt-2 text-xs leading-relaxed max-w-lg mx-auto">
        Un percorso mirato per chi soffre di tensioni muscolari, rigidità articolare o dolori cronici. Impara le metodiche posturali per decongestionare le zone di sofferenza del corpo, rilasciare le catene in tensione e ristabilire un allineamento fisiologico indolore.
      </p>
    </div>
    <!-- Curated lessons for this path -->
    <div class="max-w-2xl mx-auto mt-6">
      <h4 class="text-xs font-bold text-slate-800 mb-4 px-3 uppercase tracking-wider">Tracciamento Lezioni Consigliate:</h4>
      <div class="space-y-2">
        <% lesson_row.call("04", "Postura e Fisiologia: Massaggio, Presenza & Autotrattamento", "metodiche-posturali-e-fisiologia", "blue", "Presa di coscienza corporea e autotrattamento.") %>
        <% lesson_row.call("06", "Punti di tensione", "igiene-posturale", "blue", "Identificare e rilasciare i punti critici di tensione del corpo.") %>
        <% lesson_row.call("11", "Sistema muscolo-scheletrico", "insegnamenti-fisioterapia", "blue", "Studio fisioterapico delle catene muscolari e scheletriche.") %>
        <% lesson_row.call("20", "Eliminare le disfunzioni", "osteopatia-ascolto-del-corpo", "blue", "I principi osteopatici per liberare le articolazioni bloccate.") %>
      </div>
    </div>
  </div>

  <!-- TAB 2: Prevenzione (Hidden by default) -->
  <div id="tracker-sec-prevenzione" class="space-y-8 hidden">
    <div class="bg-emerald-50/80 border border-emerald-100/70 rounded-3xl p-6 text-center max-w-2xl mx-auto shadow-2xs">
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-emerald-100 text-emerald-700 text-lg font-bold mb-3">
        🛡️
      </span>
      <h3 class="text-lg font-bold text-slate-900">Prevenzione</h3>
      <p class="text-slate-655 mt-2 text-xs leading-relaxed max-w-lg mx-auto">
        Prenditi cura della tua salute prima che insorgano problemi. Questo percorso ti insegna le corrette abitudini quotidiane, la mobilità articolare preventiva e l'ascolto fine dei segnali del corpo per mantenere vitalità e benessere nel lungo termine.
      </p>
    </div>
    <!-- Curated lessons for this path -->
    <div class="max-w-2xl mx-auto mt-6">
      <h4 class="text-xs font-bold text-slate-800 mb-4 px-3 uppercase tracking-wider">Tracciamento Lezioni Consigliate:</h4>
      <div class="space-y-2">
        <% lesson_row.call("05", "Mobilità articolare", "igiene-posturale", "emerald", "Mantenere le articolazioni mobili ed elastiche nel tempo.") %>
        <% lesson_row.call("09", "Sistema respiratorio", "insegnamenti-fisioterapia", "emerald", "La respirazione fisiologica come pilastro della prevenzione.") %>
        <% lesson_row.call("21", "Il sistema fasciale", "osteopatia-ascolto-del-corpo", "emerald", "Nutrire e preservare la salute dei tessuti connettivi fasciali.") %>
        <% lesson_row.call("25", "Le 2 circolazioni", "corpo-e-coscienza", "emerald", "Equilibrare i ritmi circolatori per ottimizzare il metabolismo organico.") %>
      </div>
    </div>
  </div>

  <!-- TAB 3: Performance (Hidden by default) -->
  <div id="tracker-sec-performance" class="space-y-8 hidden">
    <div class="bg-amber-50/80 border border-amber-100/70 rounded-3xl p-6 text-center max-w-2xl mx-auto shadow-2xs">
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-amber-100 text-amber-700 text-lg font-bold mb-3">
        ⚡
      </span>
      <h3 class="text-lg font-bold text-slate-900">Performance</h3>
      <p class="text-slate-655 mt-2 text-xs leading-relaxed max-w-lg mx-auto">
        Sblocca il massimo potenziale dal tuo corpo. Ottimizza la biomeccanica del movimento, incrementa la forza profonda e strutturale, e allena la coordinazione neuromuscolare avanzata per migliorare le prestazioni fisiche nello sport e nella vita di tutti i giorni.
      </p>
    </div>
    <!-- Curated lessons for this path -->
    <div class="max-w-2xl mx-auto mt-6">
      <h4 class="text-xs font-bold text-slate-800 mb-4 px-3 uppercase tracking-wider">Tracciamento Lezioni Consigliate:</h4>
      <div class="space-y-2">
        <% lesson_row.call("14", "Le 5 direzioni di movimento", "biomeccanica-comportamentale-gds", "amber", "Studio biomeccanico del gesto motorio integrato.") %>
        <% lesson_row.call("03", "Rinforzo muscolare strutturale", "valutare-lo-stato-di-salute", "amber", "Costruire forza profonda partendo dal centro del corpo.") %>
        <% lesson_row.call("07", "DNS (Stabilizzazione Neuromuscolare)", "cinque-aree-della-salute", "amber", "Attivazione neuromotoria basata sullo sviluppo evolutivo.") %>
        <% lesson_row.call("08", "Animal Flow", "cinque-aree-della-salute", "amber", "Coordinazione, agilità ed energia a corpo libero.") %>
      </div>
    </div>
  </div>

  <!-- SECTION 4: Postura e Fisiologia (Active by default) -->
  <div id="tracker-sec-fisiologia" class="space-y-8">
    
    <!-- Module 00: Intro -->
    <div class="py-4">
      <div class="flex justify-between items-baseline mb-2 flex-wrap gap-2">
        <div class="flex items-center gap-3">
          <span class="rounded-md bg-sky-100 text-sky-800 text-[10px] font-black uppercase px-2 py-0.5 tracking-wider">Modulo 00</span>
          <h3 class="text-xl font-bold text-slate-900">Intro: Basi & Fondamenti</h3>
        </div>
        <span class="text-xs font-semibold text-slate-400">4 Lezioni</span>
      </div>
      <div class="text-sm text-slate-500 mb-6">Il modulo introduttivo per comprendere la visione della postura e le basi fisiologiche.</div>

      <div class="flex flex-col gap-3 pl-4 md:pl-6 border-l-2 border-sky-300">
        <% lesson_row.call("01", "Perché La postura", "perche-iniziare-da-posturacorretta", "sky", "I principi delle migliori metodiche posturali, per imparare a leggere il corpo.") %>
        <% lesson_row.call("02", "Rosso Verde Blu", "affiancare-il-percorso-educativo", "sky", "Come usare il percorso. Rispettando il ruolo dei professionisti della salute e del benessere.") %>
        <% lesson_row.call("03", "Informati, Pratica, Insegna", "come-costruire-un-percorso", "sky", "Differenza tra insegnante e professionista formato nelle metodiche posturali.") %>
        <% lesson_row.call("04", "Postura e Fisiologia: Massaggio, Presenza & Autotrattamento", "metodiche-posturali-e-fisiologia", "sky", "Presa di coscienza corporea e autotrattamento.") %>
      </div>
    </div>

    <!-- Module 01: Igiene Posturale -->
    <div class="py-4">
      <div class="flex justify-between items-baseline mb-2 flex-wrap gap-2">
        <div class="flex items-center gap-3">
          <span class="rounded-md bg-indigo-100 text-indigo-800 text-[10px] font-black uppercase px-2 py-0.5 tracking-wider">Modulo 01</span>
          <h3 class="text-xl font-bold text-slate-900">Igiene Posturale</h3>
        </div>
        <span class="text-xs font-semibold text-slate-400">4 Lezioni</span>
      </div>
      <div class="text-sm text-slate-500 mb-6">I concetti essenziali per eliminare le abitudini posturali scorrette.</div>

      <div class="flex flex-col gap-3 pl-4 md:pl-6 border-l-2 border-indigo-300">
        <% lesson_row.call("05", "Mobilità articolare", "igiene-posturale", "indigo") %>
        <% lesson_row.call("06", "Punti di tensione", "igiene-posturale", "indigo") %>
        <% lesson_row.call("07", "Via di discesa", "igiene-posturale", "indigo") %>
        <% lesson_row.call("08", "Recettori sensoriali", "igiene-posturale", "indigo") %>
      </div>
    </div>

    <!-- Module 02: Fisioterapia -->
    <div class="py-4">
      <div class="flex justify-between items-baseline mb-2 flex-wrap gap-2">
        <div class="flex items-center gap-3">
          <span class="rounded-md bg-blue-100 text-blue-800 text-[10px] font-black uppercase px-2 py-0.5 tracking-wider">Modulo 02</span>
          <h3 class="text-xl font-bold text-slate-900">Principi di Fisioterapia</h3>
        </div>
        <span class="text-xs font-semibold text-slate-400">5 Lezioni</span>
      </div>
      <div class="text-sm text-slate-500 mb-6">Approccio biologico allo studio dei grandi sistemi vitali del corpo.</div>

      <div class="flex flex-col gap-3 pl-4 md:pl-6 border-l-2 border-blue-300">
        <% lesson_row.call("09", "Sistema respiratorio", "insegnamenti-fisioterapia", "blue") %>
        <% lesson_row.call("10", "Sistema nervoso e urogenitale", "insegnamenti-fisioterapia", "blue") %>
        <% lesson_row.call("11", "Sistema muscolo-scheletrico", "insegnamenti-fisioterapia", "blue") %>
        <% lesson_row.call("12", "Sistema cardiocircolatorio", "insegnamenti-fisioterapia", "blue") %>
        <% lesson_row.call("13", "Sistema linfatico e digerente", "insegnamenti-fisioterapia", "blue") %>
      </div>
    </div>

    <!-- Module 03: Biomeccanica (GDS) -->
    <div class="py-4">
      <div class="flex justify-between items-baseline mb-2 flex-wrap gap-2">
        <div class="flex items-center gap-3">
          <span class="rounded-md bg-violet-100 text-violet-800 text-[10px] font-black uppercase px-2 py-0.5 tracking-wider">Modulo 03</span>
          <h3 class="text-xl font-bold text-slate-900">Biomeccanica Comportamentale (GDS)</h3>
        </div>
        <span class="text-xs font-semibold text-slate-400">6 Lezioni</span>
      </div>
      <div class="text-sm text-slate-550 mb-6">Le 5 catene muscolari e il loro significato psicofisiologico.</div>

      <div class="flex flex-col gap-3 pl-4 md:pl-6 border-l-2 border-violet-300">
        <% lesson_row.call("14", "Le 5 direzioni di movimento", "biomeccanica-comportamentale-gds", "violet") %>
        <% lesson_row.call("15", "Catena AM (Flessione)", "biomeccanica-comportamentale-gds", "violet") %>
        <% lesson_row.call("16", "Catena AL (Rotazione interna)", "biomeccanica-comportamentale-gds", "violet") %>
        <% lesson_row.call("17", "Catena PM (Estensione)", "biomeccanica-comportamentale-gds", "violet") %>
        <% lesson_row.call("18", "Catena PL (Rotazione esterna)", "biomeccanica-comportamentale-gds", "violet") %>
        <% lesson_row.call("19", "Catene PA/AP (Rigido e lasso)", "biomeccanica-comportamentale-gds", "violet") %>
      </div>
    </div>

    <!-- Module 04: Osteopatia -->
    <div class="py-4">
      <div class="flex justify-between items-baseline mb-2 flex-wrap gap-2">
        <div class="flex items-center gap-3">
          <span class="rounded-md bg-emerald-100 text-emerald-800 text-[10px] font-black uppercase px-2 py-0.5 tracking-wider">Modulo 04</span>
          <h3 class="text-xl font-bold text-slate-900">Principi di Osteopatia</h3>
        </div>
        <span class="text-xs font-semibold text-slate-400">5 Lezioni</span>
      </div>
      <div class="text-sm text-slate-500 mb-6">I 5 sistemi osteopatici e la liberazione dalle disfunzioni articolari.</div>

      <div class="flex flex-col gap-3 pl-4 md:pl-6 border-l-2 border-emerald-300">
        <% lesson_row.call("20", "Eliminare le disfunzioni", "osteopatia-ascolto-del-corpo", "emerald") %>
        <% lesson_row.call("21", "Il sistema fasciale", "osteopatia-ascolto-del-corpo", "emerald") %>
        <% lesson_row.call("22", "Il sistema viscerale", "osteopatia-ascolto-del-corpo", "emerald") %>
        <% lesson_row.call("23", "Il sistema cranio-sacrale", "osteopatia-ascolto-del-corpo", "emerald") %>
        <% lesson_row.call("24", "Il sistema neurovegetativo", "osteopatia-ascolto-del-corpo", "emerald") %>
      </div>
    </div>

    <!-- Module 05: Bioritmi -->
    <div class="py-4">
      <div class="flex justify-between items-baseline mb-2 flex-wrap gap-2">
        <div class="flex items-center gap-3">
          <span class="rounded-md bg-rose-100 text-rose-800 text-[10px] font-black uppercase px-2 py-0.5 tracking-wider">Modulo 05</span>
          <h3 class="text-xl font-bold text-slate-900">Bioritmi Circadiani (Corpo & Coscienza)</h3>
        </div>
        <span class="text-xs font-semibold text-slate-400">6 Lezioni</span>
      </div>
      <div class="text-sm text-slate-500 mb-6">I sette parametri strutturali ed energetici della coscienza somatica.</div>

      <div class="flex flex-col gap-3 pl-4 md:pl-6 border-l-2 border-rose-300">
        <% lesson_row.call("25", "Le 2 circolazioni", "corpo-e-coscienza", "rose") %>
        <% lesson_row.call("26", "I 3 centri di gravità", "corpo-e-coscienza", "rose") %>
        <% lesson_row.call("27", "I 4 tipi di movimento", "corpo-e-coscienza", "rose") %>
        <% lesson_row.call("28", "I 5 elementi e il ritmo stagionale", "corpo-e-coscienza", "rose") %>
        <% lesson_row.call("29", "Le 6 coppie di meridiani", "corpo-e-coscienza", "rose") %>
        <% lesson_row.call("30", "I 7 centri neurolinfatici", "corpo-e-coscienza", "rose") %>
      </div>
    </div>
  </div>

  <!-- SECTION 5: Benessere Integrato -->
  <div id="tracker-sec-benessere" class="space-y-8 hidden">
    
    <!-- Modulo Intro Benessere: Intro -->
    <div class="py-4">
      <div class="flex justify-between items-baseline mb-2 flex-wrap gap-2">
        <div class="flex items-center gap-3">
          <span class="rounded-md bg-sky-100 text-sky-800 text-[10px] font-black uppercase px-2 py-0.5 tracking-wider">Intro</span>
          <h3 class="text-xl font-bold text-slate-900">Introduzione al Benessere Integrato</h3>
        </div>
        <span class="text-xs font-semibold text-slate-400">2 Lezioni</span>
      </div>
      <div class="text-sm text-slate-500 mb-6">La visione globale della salute e gli ambiti di applicazione del percorso.</div>

