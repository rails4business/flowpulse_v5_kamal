<script>
  function switchTrackerTab(tab) {
    const doloreBtn = document.getElementById('tab-tracker-btn-dolore');
    const prevenzioneBtn = document.getElementById('tab-tracker-btn-prevenzione');
    const performanceBtn = document.getElementById('tab-tracker-btn-performance');
    const fisiologiaBtn = document.getElementById('tab-tracker-btn-fisiologia');
    const benessereBtn = document.getElementById('tab-tracker-btn-benessere');
    const giardinoBtn = document.getElementById('tab-tracker-btn-giardino');
    
    const doloreSec = document.getElementById('tracker-sec-dolore');
    const prevenzioneSec = document.getElementById('tracker-sec-prevenzione');
    const performanceSec = document.getElementById('tracker-sec-performance');
    const fisiologiaSec = document.getElementById('tracker-sec-fisiologia');
    const benessereSec = document.getElementById('tracker-sec-benessere');
    const giardinoSec = document.getElementById('tracker-sec-giardino');
    
    // Reset buttons to inactive style
    resetTrackerTabBtnClass(doloreBtn);
    resetTrackerTabBtnClass(prevenzioneBtn);
    resetTrackerTabBtnClass(performanceBtn);
    resetTrackerTabBtnClass(fisiologiaBtn);
    resetTrackerTabBtnClass(benessereBtn);
    resetTrackerTabBtnClass(giardinoBtn);
    
    // Hide all sections
    doloreSec.classList.add('hidden');
    prevenzioneSec.classList.add('hidden');
    performanceSec.classList.add('hidden');
    fisiologiaSec.classList.add('hidden');
    benessereSec.classList.add('hidden');
    giardinoSec.classList.add('hidden');
    
    // Activate clicked tab
    if (tab === 'dolore') {
      doloreBtn.className = "shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50";
      doloreSec.classList.remove('hidden');
    } else if (tab === 'prevenzione') {
      prevenzioneBtn.className = "shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50";
      prevenzioneSec.classList.remove('hidden');
    } else if (tab === 'performance') {
      performanceBtn.className = "shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50";
      performanceSec.classList.remove('hidden');
    } else if (tab === 'fisiologia') {
      fisiologiaBtn.className = "shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50";
      fisiologiaSec.classList.remove('hidden');
    } else if (tab === 'benessere') {
      benessereBtn.className = "shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50";
      benessereSec.classList.remove('hidden');
    } else if (tab === 'giardino') {
      const isLocked = document.getElementById('tracker-giardino-lock-icon') !== null;
      if (isLocked) {
        giardinoBtn.className = "shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 bg-slate-100 text-slate-500 shadow-xs border border-slate-200/50";
      } else {
        giardinoBtn.className = "shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 bg-white text-violet-955 shadow-xs border border-violet-250/50";
      }
      giardinoSec.classList.remove('hidden');
    }
  }

  // Reset inactive tab button styling helper
  function resetTrackerTabBtnClass(btn) {
    const isLockedGiardino = btn.id === 'tab-tracker-btn-giardino' && document.getElementById('tracker-giardino-lock-icon') !== null;
    if (isLockedGiardino) {
      btn.className = "shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 text-slate-400 bg-slate-100/50 flex items-center gap-1.5";
    } else if (btn.id === 'tab-tracker-btn-giardino') {
      btn.className = "shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 text-slate-550 hover:text-slate-950";
    } else {
      btn.className = "shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 text-slate-550 hover:text-slate-955";
    }
  }

  function unlockTrackerGiardino() {
    const lockIcon = document.getElementById('tracker-giardino-lock-icon');
    const lockScreen = document.getElementById('tracker-giardino-lock-screen');
    const unlockedContent = document.getElementById('tracker-giardino-unlocked-content');
    const giardinoBtn = document.getElementById('tab-tracker-btn-giardino');
    
    // 1. Remove the lock icon from tab switcher button
    if (lockIcon) {
      lockIcon.remove();
    }
    
    // 2. Hide lock screen and reveal unlocked content
    if (lockScreen && unlockedContent) {
      lockScreen.classList.add('hidden');
      unlockedContent.classList.remove('hidden');
    }
    
    // 3. Update tab button appearance
    giardinoBtn.className = "shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition duration-200 bg-white text-violet-955 shadow-xs border border-violet-250/50";
    
    // Switch to tab
    switchTrackerTab('giardino');
  }
</script>
