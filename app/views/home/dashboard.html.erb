<% content_for :title, "Dashboard" %>
<% superadmin = Current.user&.superadmin? %>

<section class="dashboard-shell dashboard-shell--resources dashboard-shell--with-aside">
  <%= render "shared/dashboard_aside", current_section: :dashboard %>

  <main class="dashboard-main">
    <header class="dashboard-header">
      <p>Dashboard</p>
      <h1>Strumenti interni</h1>
      <span>Area interna per raccogliere viste, risorse e pagine di lavoro mentre l'app prende forma. Per ora i link operativi restano sbloccati solo al superadmin.</span>
    </header>

    <section class="dashboard-grid dashboard-grid--four">
      <% cards = [
        { number: "01", title: "Risorse", body: "Tab: Eventi, Transazioni, Contatti, Attenzione, Luoghi, Abilita, Energia.", path: resources_path },
        { number: "02", title: "Lavoro", body: "Creator, professionisti, attitudini, ruoli e servizi collegati ai progetti.", path: lavoro_path },
        { number: "03", title: "Salute", body: "Percorsi e corsi, con accesso rapido alla vista salute che stiamo costruendo.", path: salute_path },
        { number: "04", title: "Elenco pagine", body: "Inventario dei prototipi HTML e delle pagine controller gia agganciate.", path: elenco_pagine_path }
      ] %>

      <% cards.each do |card| %>
        <% if superadmin %>
          <%= link_to card[:path], class: "dashboard-card" do %>
            <span><%= card[:number] %></span>
            <h2><%= card[:title] %></h2>
            <p><%= card[:body] %></p>
          <% end %>
        <% else %>
          <div class="dashboard-card dashboard-card--locked">
            <span><%= card[:number] %></span>
            <h2><%= card[:title] %></h2>
            <p><%= card[:body] %></p>
            <strong>Disponibile quando sbloccato dal superadmin</strong>
          </div>
        <% end %>
      <% end %>
    </section>
  </main>
</section>
