<%
  projects = items.to_a
  summary_groups = [
    ["generaimpresa", "Progetti con GeneraImpresa"],
    ["historical_import", "Progetti precedenti a GeneraImpresa"]
  ]
  status_groups_by_origin = {
    "generaimpresa" => %w[all future in_progress launched repaid],
    "historical_import" => %w[open closed]
  }
  projects_for_status = lambda do |origin_projects, status|
    case status
    when "all"
      origin_projects
    when "repaid"
      origin_projects.select { |project| project_repaid?(project) }
    when "open"
      origin_projects.reject { |project| project["status"] == "launched" && project["operation_status"] == "concluded" }
    when "closed"
      origin_projects.select { |project| project["status"] == "launched" && project["operation_status"] == "concluded" }
    else
      origin_projects.select { |project| project["status"] == status }
    end
  end
%>

<div class="mt-8 flex flex-wrap justify-center gap-2" data-origin-filters>
  <% summary_groups.each do |origin, label| %>
    <button type="button"
            class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-slate-600 transition hover:border-emerald-300 hover:text-emerald-700 data-[active=true]:border-emerald-600 data-[active=true]:bg-emerald-600 data-[active=true]:text-white"
            data-origin-filter="<%= origin %>"
            data-active="<%= origin == "generaimpresa" %>">
      <%= label %>
      <span class="ml-1 opacity-70">(<%= projects.count { |project| project_generaimpresa_origin(project) == origin } %>)</span>
    </button>
  <% end %>
</div>

<% summary_groups.each do |origin, _label| %>
  <% origin_projects = projects.select { |project| project_generaimpresa_origin(project) == origin } %>
  <% status_groups_by_origin.fetch(origin).each do |status| %>
    <%= render "components/project_summary_group",
               projects: projects_for_status.call(origin_projects, status),
               origin: origin,
               status_filter: status %>
  <% end %>
<% end %>

<script>
  (() => {
    const root = document.getElementById("progetti-section");
    if (!root || root.dataset.summaryModalsReady === "true") return;
    root.dataset.summaryModalsReady = "true";

    root.querySelectorAll("[data-project-summary-open]").forEach((button) => {
      button.addEventListener("click", () => {
        const dialog = document.getElementById(button.getAttribute("aria-controls"));
        if (dialog) dialog.showModal();
      });
    });

    root.querySelectorAll("[data-project-summary-dialog]").forEach((dialog) => {
      dialog.querySelector("[data-project-summary-close]")?.addEventListener("click", () => dialog.close());
      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) dialog.close();
      });
    });
  })();
</script>
