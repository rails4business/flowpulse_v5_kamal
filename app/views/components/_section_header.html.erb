<div class="mx-auto max-w-3xl text-center">
  <% if data['kicker'].present? %>
    <p class="text-xs font-bold uppercase tracking-widest text-indigo-600">
      <%= inline_markdown(data['kicker']) %>
    </p>
  <% end %>

  <h2 class="mt-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
    <%= inline_markdown(data['title']) %>
  </h2>

  <% if data['subtitle'].present? %>
    <p class="mt-4 text-lg text-gray-600">
      <%= inline_markdown(data['subtitle']) %>
    </p>
  <% end %>
</div>
