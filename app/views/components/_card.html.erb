<a href="<%= item['route'] %>" class="group relative block h-full bg-white before:absolute before:inset-0 before:rounded-xl before:border-2 before:border-transparent before:transition-all hover:before:border-indigo-600 focus:outline-none focus:ring">
  <div class="h-full rounded-xl border border-gray-100 p-6 shadow-sm transition-all group-hover:bg-indigo-50 sm:p-8 flex flex-col justify-between">
    <div>
      <% if item['eyebrow'].present? %>
        <p class="text-xs font-bold uppercase tracking-widest text-indigo-500">
          <%= inline_markdown(item['eyebrow']) %>
        </p>
      <% end %>
      
      <h3 class="mt-4 text-xl font-bold text-gray-900 sm:text-2xl">
        <%= inline_markdown(item['title']) %>
      </h3>
      
      <% if item['description'].present? %>
        <p class="mt-4 text-sm text-gray-600 leading-relaxed">
          <%= inline_markdown(item['description']) %>
        </p>
      <% end %>
    </div>

    <% if item['cta'].present? %>
      <div class="mt-8 flex items-center justify-between border-t border-gray-100 pt-6">
        <span class="text-sm font-medium text-indigo-600 group-hover:underline">
          <%= inline_markdown(item['cta']) %>
        </span>
        
        <span class="rounded-full bg-indigo-600 p-2 text-white transition-transform group-hover:translate-x-1">
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </span>
      </div>
    <% end %>
  </div>
</a>
