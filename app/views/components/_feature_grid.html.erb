<div class="mt-8 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
  <% items.each do |key, item| %>
    <article class="block rounded-xl border border-gray-100 p-8 shadow-xl transition hover:border-indigo-500/10 hover:shadow-indigo-500/10 bg-white">
      <span class="inline-block rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-600 uppercase tracking-widest">
        <%= inline_markdown(item['label']) %>
      </span>
      <p class="mt-4 text-sm leading-relaxed text-gray-600">
        <%= inline_markdown(item['description']) %>
      </p>
    </article>
  <% end %>
</div>
