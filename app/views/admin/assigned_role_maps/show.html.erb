<% content_for :title, "Assigned roles" %>

<header class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
    <div>
      <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-blue-600">Audit assegnazioni</p>
      <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-slate-950 md:text-5xl">Assigned roles</h1>
      <span class="mt-4 block max-w-3xl text-base leading-7 text-slate-600">Utenti, ruoli reali assegnati e contesti collegati. Questa pagina separa i permessi effettivi dalla mappa delle route.</span>
    </div>

    <%= link_to "New", admin_new_assigned_role_map_path, class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2 text-sm font-extrabold text-white shadow-sm transition hover:bg-blue-700" %>
  </div>
</header>

<section class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
  <% RoleAssignment.roles.each do |role, _value| %>
    <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
      <span class="text-[10px] font-extrabold uppercase tracking-[0.14em] text-slate-400">Ruolo</span>
      <strong class="mt-2 block text-sm font-extrabold text-slate-950"><%= role.humanize %></strong>
      <span class="mt-1 block text-2xl font-extrabold text-blue-600"><%= @role_counts.fetch(role, 0) %></span>
    </article>
  <% end %>
</section>

<section class="mt-6 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
      <thead class="sticky top-0 z-10 bg-slate-50 text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500 shadow-[0_1px_0_rgba(226,232,240,1)]">
        <tr>
          <th class="px-4 py-3">Ruolo</th>
          <th class="px-4 py-3">Utente</th>
          <th class="px-4 py-3">Nome</th>
          <th class="px-4 py-3">Contesto</th>
          <th class="px-4 py-3">Parent</th>
          <th class="px-4 py-3">Creata</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% if @role_assignments.any? %>
          <% @role_assignments.each do |assignment| %>
            <tr class="align-top">
              <td class="whitespace-nowrap px-4 py-3 font-bold text-slate-950"><%= assignment.role.humanize %></td>
              <td class="whitespace-nowrap px-4 py-3 text-slate-600"><%= assignment.user.email_address %></td>
              <td class="px-4 py-3 text-slate-600"><%= assignment.display_name %></td>
              <td class="whitespace-nowrap px-4 py-3 text-slate-600">
                <% if assignment.context.present? %>
                  <%= assignment.context_type %> #<%= assignment.context_id %>
                <% else %>
                  Globale
                <% end %>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-slate-600">
                <% if assignment.parent.present? %>
                  #<%= assignment.parent_id %> <%= assignment.parent.role.humanize %>
                <% else %>
                  -
                <% end %>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-slate-600"><%= l(assignment.created_at, format: :short) %></td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="6" class="px-4 py-8 text-center text-sm font-semibold text-slate-500">Nessun ruolo assegnato.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
