<% content_for :title, "Dashboard Superadmin" %>
<% superadmin = Current.user&.superadmin? %>

<section class="grid gap-6 lg:grid-cols-[280px_minmax(0,1fr)]">
  <%= render "shared/dashboard_aside", current_section: :dashboard %>

  <main class="min-w-0">
    <header class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div>
        <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-blue-600">Dashboard Superadmin</p>
        <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-slate-950 md:text-5xl">Strumenti interni</h1>
        <span class="mt-4 block max-w-3xl text-base leading-7 text-slate-600">Area interna per raccogliere viste, risorse e pagine di lavoro mentre l'app prende forma. Il selettore ruolo serve a simulare gli assetti futuri senza aprire tutto a tutti.</span>
      </div>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <% cards = [
        { number: "01", title: "Risorse", body: "Tab: Eventi, Transazioni, Contatti, Attenzione, Luoghi, Abilita, Energia.", path: admin_risorse_index_path },
        { number: "02", title: "Domini", body: "Host pubblici, redirect canonici, action dedicate e HTML home temporaneo.", path: admin_domains_path },
        { number: "03", title: "Lavoro", body: "Creator, professionisti, attitudini, ruoli e servizi collegati ai progetti.", path: demo_lavoro_path },
        { number: "04", title: "Salute", body: "Percorsi e corsi, con accesso rapido alla vista salute che stiamo costruendo.", path: demo_salute_path },
        { number: "05", title: "Elenco pagine", body: "Inventario dei prototipi HTML e delle pagine controller gia agganciate.", path: admin_elenco_pagine_path }
      ] %>

      <% cards.each do |card| %>
        <% if superadmin %>
          <%= verified_link_to card[:path], class: "flex min-h-[230px] flex-col justify-between rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md" do %>
            <span class="text-sm font-extrabold tracking-[0.12em] text-blue-600"><%= card[:number] %></span>
            <div class="mt-6">
              <h2 class="text-2xl font-extrabold tracking-tight text-slate-950"><%= card[:title] %></h2>
              <p class="mt-3 text-sm leading-6 text-slate-600"><%= card[:body] %></p>
            </div>
          <% end %>
        <% else %>
          <div class="flex min-h-[230px] flex-col justify-between rounded-2xl border border-slate-200 bg-slate-100 p-6 text-slate-400">
            <span class="text-sm font-extrabold tracking-[0.12em]"><%= card[:number] %></span>
            <div class="mt-6">
              <h2 class="text-2xl font-extrabold tracking-tight"><%= card[:title] %></h2>
              <p class="mt-3 text-sm leading-6"><%= card[:body] %></p>
            </div>
            <strong class="mt-4 text-xs font-extrabold uppercase tracking-[0.14em] text-slate-500">Disponibile quando sbloccato dal superadmin</strong>
          </div>
        <% end %>
      <% end %>
    </section>
  </main>
</section>
