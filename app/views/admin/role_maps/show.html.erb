<% content_for :title, "Role map" %>

<header class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-blue-600">Audit ruoli</p>
      <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-slate-950 md:text-5xl">Role map</h1>
      <span class="mt-4 block max-w-3xl text-base leading-7 text-slate-600">Link, route e visibilita del menu divisi per ruolo. Questa pagina resta interna e serve a controllare cosa vede ogni ruolo prima di collegare nuovi engine.</span>
    </header>

    <section class="mt-6 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
          <thead class="sticky top-0 z-10 bg-slate-50 text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500 shadow-[0_1px_0_rgba(226,232,240,1)]">
            <tr>
              <th class="px-4 py-3">Ruolo</th>
              <th class="px-4 py-3">Link</th>
              <th class="px-4 py-3">Path</th>
              <th class="px-4 py-3">Engine</th>
              <th class="px-4 py-3">Demo</th>
              <th class="px-4 py-3">Mutating</th>
              <th class="px-4 py-3">Stato</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @roles.each do |role| %>
              <% FlowRoles::MenuRegistry.items_for_role(role).each do |item| %>
                <% resolved_path = resolve_dashboard_menu_path(item.path) %>
                <tr class="align-top">
                  <td class="whitespace-nowrap px-4 py-3 font-bold text-slate-950"><%= ruolo_label(role) %></td>
                  <td class="px-4 py-3">
                    <strong class="block text-slate-950"><%= item.title %></strong>
                    <span class="mt-1 block text-xs text-slate-500"><%= item.subtitle %></span>
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 font-mono text-xs text-slate-600"><%= resolved_path.presence || "-" %></td>
                  <td class="whitespace-nowrap px-4 py-3 text-slate-600"><%= item.engine %></td>
                  <td class="whitespace-nowrap px-4 py-3"><%= item.demo_visible ? "Si" : "No" %></td>
                  <td class="whitespace-nowrap px-4 py-3"><%= item.mutating ? "Si" : "No" %></td>
                  <td class="whitespace-nowrap px-4 py-3">
                    <% if resolved_path.present? %>
                      <span class="rounded-full bg-green-50 px-2.5 py-1 text-xs font-bold text-green-700">ok</span>
                    <% else %>
                      <span class="rounded-full bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-700"><%= item.locked_label.presence || "route da creare" %></span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
