<% content_for :title, @domain.hostname %>

<%= render "shell" do %>
  <header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-blue-600">Dominio #<%= @domain.id %></p>
      <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-slate-950"><%= @domain.hostname %></h1>
    </div>

    <div class="flex gap-2">
      <%= verified_link_to "Modifica", edit_admin_domain_path(@domain), class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-bold text-white hover:bg-blue-500" %>
      <%= button_to "Elimina", admin_domain_path(@domain), method: :delete, class: "rounded-lg border border-red-200 px-4 py-2 text-sm font-bold text-red-600 hover:bg-red-50", form: { data: { turbo_confirm: "Eliminare questo dominio?" } } %>
    </div>
  </header>

  <dl class="grid gap-4 rounded-xl border border-slate-200 bg-white p-6 sm:grid-cols-2">
    <div>
      <dt class="text-xs font-bold uppercase tracking-wide text-slate-500">Canonical host</dt>
      <dd class="mt-1 text-slate-950"><%= @domain.canonical_host.presence || "-" %></dd>
    </div>

    <div>
      <dt class="text-xs font-bold uppercase tracking-wide text-slate-500">Target Controller</dt>
      <dd class="mt-1 text-slate-950"><%= @domain.target_controller.presence || "-" %></dd>
    </div>
    <div>
      <dt class="text-xs font-bold uppercase tracking-wide text-slate-500">Target Action</dt>
      <dd class="mt-1 text-slate-950"><%= @domain.target_action.presence || "-" %></dd>
    </div>
    <div>
      <dt class="text-xs font-bold uppercase tracking-wide text-slate-500">Locale</dt>
      <dd class="mt-1 text-slate-950"><%= @domain.locale %></dd>
    </div>
    <div>
      <dt class="text-xs font-bold uppercase tracking-wide text-slate-500">Stato</dt>
      <dd class="mt-1 text-slate-950"><%= @domain.active? ? "Attivo" : "Disattivo" %></dd>
    </div>
  </dl>


<% end %>
