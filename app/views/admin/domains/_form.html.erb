<%= form_with model: [:admin, domain], class: "space-y-5 rounded-xl border border-slate-200 bg-white p-6" do |form| %>
  <% if domain.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">
      <p class="font-bold">Controlla i campi:</p>
      <ul class="mt-2 list-disc pl-5">
        <% domain.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= form.label :hostname, "Host", class: "text-sm font-bold text-slate-700" %>
      <%= form.text_field :hostname, class: "mt-2 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>

    <div>
      <%= form.label :canonical_host, "Canonical host", class: "text-sm font-bold text-slate-700" %>
      <%= form.text_field :canonical_host, class: "mt-2 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>


    <div>
      <%= form.label :target_controller, "Target controller", class: "text-sm font-bold text-slate-700" %>
      <%= form.text_field :target_controller, placeholder: "es. pages", class: "mt-2 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>

    <div>
      <%= form.label :target_action, "Target action", class: "text-sm font-bold text-slate-700" %>
      <%= form.text_field :target_action, placeholder: "es. markpostura", class: "mt-2 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>

    <div>
      <%= form.label :locale, "Locale", class: "text-sm font-bold text-slate-700" %>
      <%= form.text_field :locale, class: "mt-2 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>
  </div>


  <div class="flex flex-wrap gap-5">
    <label class="inline-flex items-center gap-2 text-sm font-bold text-slate-700">
      <%= form.check_box :primary, class: "h-4 w-4 rounded border-slate-300" %>
      Primario
    </label>

    <label class="inline-flex items-center gap-2 text-sm font-bold text-slate-700">
      <%= form.check_box :active, class: "h-4 w-4 rounded border-slate-300" %>
      Attivo
    </label>
  </div>

  <div class="flex gap-2">
    <%= form.submit "Salva", class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-bold text-white hover:bg-blue-500" %>
    <%= verified_link_to "Annulla", admin_domains_path, class: "rounded-lg border border-slate-200 px-4 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50" %>
  </div>
<% end %>
