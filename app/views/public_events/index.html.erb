<% content_for :title, "Esperienze" %>
<% active_label = @tabs.fetch(@active_tab).fetch(:label) %>
<% active_label_downcase = active_label.downcase %>

<section class="dashboard-shell dashboard-shell--public-events" data-controller="filter">
  <section class="experiences-hero">
    <div class="experiences-hero__intro">
      <p class="text-blue-600 font-black uppercase tracking-widest text-[10px] mb-2">Esplora il tuo benessere</p>
      <h1>Cosa vuoi fare oggi?</h1>
      
      <div class="mt-6 flex flex-wrap gap-3 items-center">
        <!-- Tasto Reset -->
       
        <!-- Dropdown Categorie -->
        <div class="relative inline-block text-left dropdown-container">
          <button data-action="filter#toggle" data-filter-type="category" class="flex items-center gap-2 px-6 py-2.5 rounded-full text-xs font-black uppercase tracking-widest transition-all bg-white border border-slate-200 text-slate-500 hover:border-blue-400 hover:text-blue-600">
            <span>Categoria: <strong class="text-slate-900" data-filter-target="currentCategory">Tutte</strong></span>
            <svg data-filter-target="categoryArrow" class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <div data-filter-target="categoryDropdown" class="hidden absolute left-0 top-full z-[100] mt-2 w-64 origin-top-left rounded-2xl bg-white p-2 shadow-2xl ring-1 ring-black ring-opacity-5 focus:outline-none dropdown-panel">
            <div class="p-2 border-b border-slate-50">
              <input type="text" placeholder="Cerca categoria..." data-action="filter#filter" data-filter-type="category" class="w-full px-3 py-2 bg-slate-50 border-none rounded-xl text-xs focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
            <div data-filter-target="categoryList" class="max-h-64 overflow-y-auto pt-1">
              <% [
                { icon: "🧘", label: "Meditazione" },
                { icon: "🚶", label: "Movimento" },
                { icon: "🌲", label: "Natura" },
                { icon: "🍴", label: "Cibo" },
                { icon: "🪗", label: "Musica" },
                { icon: "💙", label: "Postura" }
              ].each do |cat| %>
                <div data-action="filter#select" data-filter-type="category" data-value="<%= cat[:label] %>" class="flex items-center gap-3 px-3 py-2.5 hover:bg-blue-50 rounded-xl cursor-pointer transition-colors group/item">
                  <span class="text-lg"><%= cat[:icon] %></span>
                  <span class="text-xs font-bold text-slate-600 group-hover/item:text-blue-700"><%= cat[:label] %></span>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Dropdown Brand -->
        <div class="relative inline-block text-left dropdown-container">
          <button data-action="filter#toggle" data-filter-type="brand" class="flex items-center gap-2 px-6 py-2.5 rounded-full text-xs font-black uppercase tracking-widest transition-all bg-white border border-slate-200 text-slate-500 hover:border-emerald-400 hover:text-emerald-600">
            <span>Brand: <strong class="text-slate-900" data-filter-target="currentBrand">Tutti</strong></span>
            <svg data-filter-target="brandArrow" class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <div data-filter-target="brandDropdown" class="hidden absolute left-0 top-full z-[100] mt-2 w-64 origin-top-left rounded-2xl bg-white p-2 shadow-2xl ring-1 ring-black ring-opacity-5 focus:outline-none dropdown-panel">
            <div class="p-2 border-b border-slate-50">
              <input type="text" placeholder="Cerca brand..." data-action="filter#filter" data-filter-type="brand" class="w-full px-3 py-2 bg-slate-50 border-none rounded-xl text-xs focus:ring-2 focus:ring-emerald-500 outline-none">
            </div>
            <div data-filter-target="brandList" class="max-h-64 overflow-y-auto pt-1">
              <% [
                { icon: "💙", label: "PosturaCorretta" },
                { icon: "🗺️", label: "Flowpulse" },
                { icon: "🌿", label: "Giardino del Corpo" },
                { icon: "🏔️", label: "Inside Adventure" }
              ].each do |brand| %>
                <div data-action="filter#select" data-filter-type="brand" data-value="<%= brand[:label] %>" class="flex items-center gap-3 px-3 py-2.5 hover:bg-emerald-50 rounded-xl cursor-pointer transition-colors group/item">
                  <span class="text-lg"><%= brand[:icon] %></span>
                  <span class="text-xs font-bold text-slate-600 group-hover/item:text-emerald-700"><%= brand[:label] %></span>
                </div>
              <% end %>
            </div>
            
          </div>
      
      </div>
        <!-- Dropdown Professionisti -->
        <div class="relative inline-block text-left dropdown-container">
          <button data-action="filter#toggle" data-filter-type="professionisti" class="flex items-center gap-2 px-6 py-2.5 rounded-full text-xs font-black uppercase tracking-widest transition-all bg-white border border-slate-200 text-slate-500 hover:border-emerald-400 hover:text-emerald-600">
            <span>Professionisti: <strong class="text-slate-900" data-filter-target="currentProfessionista">Tutti</strong></span>
            <svg data-filter-target="professionistiArrow" class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <div data-filter-target="professionistiDropdown" class="hidden absolute left-0 top-full z-[100] mt-2 w-64 origin-top-left rounded-2xl bg-white p-2 shadow-2xl ring-1 ring-black ring-opacity-5 focus:outline-none dropdown-panel">
            <div class="p-2 border-b border-slate-50">
              <input type="text" placeholder="Cerca professionisti..." data-action="filter#filter" data-filter-type="professionisti" class="w-full px-3 py-2 bg-slate-50 border-none rounded-xl text-xs focus:ring-2 focus:ring-emerald-500 outline-none">
            </div>
            <div data-filter-target="professionistiList" class="max-h-64 overflow-y-auto pt-1">
              <% [
                { icon: "💙", label: "PosturaCorretta" },
                { icon: "🗺️", label: "Flowpulse" },
                { icon: "🌿", label: "Giardino del Corpo" },
                { icon: "🏔️", label: "Inside Adventure" }
              ].each do |professionista| %>
                <div data-action="filter#select" data-filter-type="professionisti" data-value="<%= professionista[:label] %>" class="flex items-center gap-3 px-3 py-2.5 hover:bg-emerald-50 rounded-xl cursor-pointer transition-colors group/item">
                  <span class="text-lg"><%= professionista[:icon] %></span>
                  <span class="text-xs font-bold text-slate-600 group-hover/item:text-emerald-700"><%= professionista[:label] %></span>
                </div>
              <% end %>
            </div>
            
          </div>
      
      </div>

       <!-- Dropdown Luoghi -->
        <div class="relative inline-block text-left dropdown-container">
          <button data-action="filter#toggle" data-filter-type="luoghi" class="flex items-center gap-2 px-6 py-2.5 rounded-full text-xs font-black uppercase tracking-widest transition-all bg-white border border-slate-200 text-slate-500 hover:border-emerald-400 hover:text-emerald-600">
            <span>Luoghi: <strong class="text-slate-900" data-filter-target="currentLuoghi">Tutti</strong></span>
            <svg data-filter-target="luoghiArrow" class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <div data-filter-target="professionistiDropdown" class="hidden absolute left-0 top-full z-[100] mt-2 w-64 origin-top-left rounded-2xl bg-white p-2 shadow-2xl ring-1 ring-black ring-opacity-5 focus:outline-none dropdown-panel">
            <div class="p-2 border-b border-slate-50">
              <input type="text" placeholder="Cerca professionisti..." data-action="filter#filter" data-filter-type="professionisti" class="w-full px-3 py-2 bg-slate-50 border-none rounded-xl text-xs focus:ring-2 focus:ring-emerald-500 outline-none">
            </div>
            <div data-filter-target="professionistiList" class="max-h-64 overflow-y-auto pt-1">
              <% [
                { icon: "💙", label: "PosturaCorretta" },
                { icon: "🗺️", label: "Flowpulse" },
                { icon: "🌿", label: "Giardino del Corpo" },
                { icon: "🏔️", label: "Inside Adventure" }
              ].each do |professionista| %>
                <div data-action="filter#select" data-filter-type="professionisti" data-value="<%= professionista[:label] %>" class="flex items-center gap-3 px-3 py-2.5 hover:bg-emerald-50 rounded-xl cursor-pointer transition-colors group/item">
                  <span class="text-lg"><%= professionista[:icon] %></span>
                  <span class="text-xs font-bold text-slate-600 group-hover/item:text-emerald-700"><%= professionista[:label] %></span>
                </div>
              <% end %>
            </div>
            
          </div>
      
      </div>
    </div>
  </section>



  <nav class="experiences-tabs" aria-label="Tab esperienze">
    <% @tabs.each do |key, tab| %>
      <%= verified_link_to tab.fetch(:label), esperienze_path(tab: key), class: "experiences-tab #{@active_tab == key ? "is-active" : ""}" %>
    <% end %>
     <button data-action="filter#reset" class="px-6 py-2.5 rounded-full text-xs font-black uppercase tracking-widest transition-all bg-slate-900 text-white shadow-lg">
          Tutti
        </button>

  </nav>


  
  <section class="events-panel experiences-panel">
    <% if @active_tab == "contenuti" %>
      <div id="panel-all" class="subtab-panel grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% @items.each do |content| %>
          <div class="group bg-white rounded-3xl border border-slate-200 overflow-hidden hover:border-blue-400 hover:shadow-xl transition-all cursor-pointer">
            <div class="relative aspect-video overflow-hidden bg-slate-100">
              <img src="<%= content[:thumbnail] %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
              <div class="absolute inset-0 bg-black/10 group-hover:bg-black/0 transition-colors"></div>
              
              <div class="absolute bottom-3 right-3 px-2 py-1 rounded-lg bg-black/60 backdrop-blur-sm text-white text-[10px] font-bold">
                <%= content[:duration] || content[:pages] %>
              </div>

              <% if content[:kind] == "video" %>
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                  <div class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center shadow-lg">
                    <div class="w-0 h-0 border-t-[8px] border-t-transparent border-l-[12px] border-l-blue-600 border-b-[8px] border-b-transparent ml-1"></div>
                  </div>
                </div>
              <% end %>
            </div>

            <div class="p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="px-2 py-1 rounded-md bg-slate-900 text-white text-[9px] font-black uppercase tracking-wider"><%= content[:brand] %></span>
                <span class="px-2 py-1 rounded-md bg-slate-100 text-slate-500 text-[9px] font-black uppercase tracking-wider"><%= content[:sub_brand] %></span>
              </div>
              <h3 class="text-lg font-black text-slate-900 leading-tight group-hover:text-blue-600 transition-colors"><%= content[:title] %></h3>
              <p class="text-sm text-slate-500 mt-2 line-clamp-2"><%= content[:description] %></p>
              
              <div class="mt-4 pt-4 border-t border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="text-lg"><%= content[:category_tags].first[:icon] %></span>
                  <span class="text-[10px] font-black uppercase tracking-widest text-slate-400"><%= content[:category_tags].first[:label] %></span>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest text-blue-600">Apri contenuto →</span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div id="panel-all" class="subtab-panel space-y-4">
        <% @items.each do |event| %>
        <%
          c = if event[:brand].to_s.include?("PosturaCorretta")
                { bg_l: "bg-blue-50", bg_d: "bg-blue-600", border: "border-blue-100", text: "text-blue-700", h_border: "hover:border-blue-400", h_shadow: "hover:shadow-blue-500/5", text_m: "text-blue-600" }
              elsif event[:brand].to_s.include?("Inside Adventure")
                { bg_l: "bg-emerald-50", bg_d: "bg-emerald-600", border: "border-emerald-100", text: "text-emerald-700", h_border: "hover:border-emerald-400", h_shadow: "hover:shadow-emerald-500/5", text_m: "text-emerald-600" }
              else
                { bg_l: "bg-rose-50", bg_d: "bg-rose-600", border: "border-rose-100", text: "text-rose-700", h_border: "hover:border-rose-400", h_shadow: "hover:shadow-rose-500/5", text_m: "text-rose-600" }
              end
        %>

        <%= verified_link_to esperienza_path(event[:id]), class: "group bg-white rounded-3xl border border-slate-200 p-5 flex gap-6 #{c[:h_border]} hover:shadow-xl #{c[:h_shadow]} transition-all" do %>

          <% if @active_tab == "percorsi" %>
            <div class="w-28 shrink-0 rounded-2xl <%= c[:bg_l] %> border <%= c[:border] %> text-center overflow-hidden flex flex-col h-fit">
              <div class="<%= c[:bg_d] %> text-white text-[10px] font-black py-1 uppercase tracking-widest">
                Percorso
              </div>

              <div class="py-4 bg-white">
                <div class="text-4xl font-black text-slate-900 leading-none">
                  <%= event[:lessons_count] || 4 %>
                </div>
                <div class="text-[9px] font-black text-slate-400 mt-1 uppercase tracking-widest">
                  lezioni
                </div>
              </div>

              <div class="border-t <%= c[:border] %> <%= c[:bg_l] %> px-3 py-3">
                <div class="text-xl font-black <%= c[:text_m] %> leading-none">
                  <%= event[:pricing] || event[:price_label] || "da 120€" %>
                </div>
                <div class="text-[8px] font-black text-slate-400 mt-1 uppercase tracking-widest">
                  base
                </div>
              </div>
            </div>

          <% elsif @active_tab == "corsi" %>
            <div class="w-28 shrink-0 rounded-2xl <%= c[:bg_l] %> border <%= c[:border] %> overflow-hidden h-fit">
              <div class="<%= c[:bg_d] %> px-3 py-2 text-white text-[10px] font-black uppercase tracking-widest text-center">Periodo corso</div>
              <div class="bg-white px-3 py-3 text-center">
                <div class="text-xs font-black uppercase tracking-widest <%= c[:text_m] %>"><%= event[:season_start] %></div>
                <div class="my-1 text-[10px] font-black uppercase tracking-[0.2em] text-slate-300">fino a</div>
                <div class="text-sm font-black uppercase tracking-widest text-slate-900"><%= event[:season_end] %></div>
              </div>
            </div>

          <% elsif @active_tab == "servizi" %>
            <div class="w-28 shrink-0 rounded-2xl <%= c[:bg_l] %> border <%= c[:border] %> overflow-hidden h-fit">
              <div class="<%= c[:bg_d] %> px-3 py-2 text-white text-[10px] font-black uppercase tracking-widest text-center">Prezzo</div>
              <div class="bg-white px-3 py-4 text-center">
                <div class="text-2xl font-black leading-tight text-slate-900"><%= event[:price_label] %></div>
                <div class="mt-2 text-[10px] font-black uppercase tracking-widest text-slate-400">a partire da</div>
              </div>
            </div>

          <% else %>
            <div class="w-20 shrink-0 rounded-2xl <%= c[:bg_l] %> border <%= c[:border] %> text-center overflow-hidden flex flex-col h-fit">
              <div class="<%= c[:bg_d] %> text-white text-[10px] font-black py-1 uppercase tracking-widest"><%= event[:month] %></div>
              <div class="py-3 bg-white">
                <div class="text-3xl font-black text-slate-900 leading-none"><%= event[:day] %></div>
                <div class="text-[9px] font-black text-slate-400 mt-1 uppercase tracking-widest"><%= event[:weekday] %></div>
              </div>
            </div>
          <% end %>

          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
              <div class="space-y-2">
                <div class="flex flex-wrap gap-2">
                  <span class="px-2.5 py-1 rounded-md bg-slate-900 text-white text-[10px] font-black uppercase tracking-wider"><%= event[:brand] %></span>
                  <% if event[:sub_brand].present? %>
                    <span class="px-2.5 py-1 rounded-md <%= c[:bg_l] %> <%= c[:text] %> border <%= c[:border] %> text-[10px] font-black uppercase tracking-wider"><%= event[:sub_brand] %></span>
                  <% end %>
                </div>

                <div class="flex flex-wrap gap-2">
                  <% (event[:category_tags] || []).each do |tag| %>
                    <span class="px-2 py-1 rounded-full bg-white border border-<%= tag[:color] %>-300 text-<%= tag[:color] %>-700 text-[9px] font-black uppercase flex items-center gap-1">
                      <span><%= tag[:icon] %></span>
                      <span><%= tag[:label] %></span>
                    </span>
                  <% end %>
                </div>
              </div>

              <div class="text-right">
                <div class="text-lg font-black text-slate-900 leading-none <%= c[:text_m] %>">
                  <%=
                    if @active_tab == "percorsi"
                      event[:pricing] || event[:price_label] || "da 120€"
                    elsif @active_tab == "corsi"
                      event[:pricing]
                    elsif @active_tab == "servizi"
                      event[:service_mode]
                    else
                      event[:time]
                    end
                  %>
                </div>

                <div class="text-[9px] font-bold text-slate-400 mt-1 uppercase tracking-widest">
                  <%=
                    if @active_tab == "percorsi"
                      "Prezzo base"
                    elsif @active_tab == "corsi"
                      "Quota corso"
                    elsif @active_tab == "servizi"
                      "Modalità"
                    else
                      "Orario previsto"
                    end
                  %>
                </div>
              </div>
            </div>

            <h2 class="text-xl font-black text-slate-900 leading-tight group-hover:<%= c[:text_m] %> transition-colors"><%= event[:title] %></h2>
            <p class="text-sm text-slate-500 mt-2 leading-relaxed line-clamp-2"><%= event[:description] %></p>

            <% if @active_tab == "corsi" && event[:weekly_slots].present? %>
              <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <span class="text-[10px] font-black uppercase tracking-widest text-slate-400">Disponibilità settimanale</span>
                  <span class="text-[10px] font-black uppercase tracking-widest <%= c[:text_m] %>">Ore corso</span>
                </div>
                <div class="mt-3 flex flex-wrap gap-2">
                  <% event[:weekly_slots].each do |slot| %>
                    <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1.5 text-[11px] font-bold text-slate-700">
                      <strong class="<%= c[:text_m] %>"><%= slot[:day] %></strong>
                      <span><%= slot[:time] %></span>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>

            <% if @active_tab == "percorsi" %>
              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-y-2 gap-x-4 mt-5 pt-4 border-t border-slate-100">
                <div>
                  <span class="block text-[8px] font-black text-slate-300 uppercase tracking-widest">Lezioni</span>
                  <span class="text-[11px] font-bold text-slate-600 truncate block"><%= event[:lessons_count] || 4 %> incontri</span>
                </div>

                <div>
                  <span class="block text-[8px] font-black text-slate-300 uppercase tracking-widest">Modalità</span>
                  <span class="text-[11px] font-bold text-slate-600 truncate block"><%= event[:mode_label] || "Auto / Pro / Gruppo" %></span>
                </div>

                <div>
                  <span class="block text-[8px] font-black text-slate-300 uppercase tracking-widest">Luogo</span>
                  <span class="text-[11px] font-bold text-slate-600 truncate block"><%= event[:location] %></span>
                </div>

                <div>
                  <span class="block text-[8px] font-black text-slate-300 uppercase tracking-widest">Domicilio</span>
                  <span class="text-[11px] font-bold text-slate-600 truncate block"><%= event[:home_extra] || "+ €/km" %></span>
                </div>

                <div>
                  <span class="block text-[8px] font-black text-slate-300 uppercase tracking-widest">Sala</span>
                  <span class="text-[11px] font-bold text-slate-600 truncate block"><%= event[:room_extra] || "+ costo centro" %></span>
                </div>

                <div class="text-right">
                  <span class="block text-[8px] font-black text-slate-300 uppercase tracking-widest">Stato</span>
                  <span class="text-[11px] font-black <%= c[:text_m] %>"><%= event[:participants] || "Attivabile" %></span>
                </div>
              </div>
            <% else %>
              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-y-2 gap-x-4 mt-5 pt-4 border-t border-slate-100">
                <div>
                  <span class="block text-[8px] font-black text-slate-300 uppercase tracking-widest">Struttura</span>
                  <span class="text-[11px] font-bold text-slate-600 truncate block"><%= event[:event_kind] %></span>
                </div>
                <div>
                  <span class="block text-[8px] font-black text-slate-300 uppercase tracking-widest">Format</span>
                  <span class="text-[11px] font-bold text-slate-600 truncate block"><%= event[:format] %></span>
                </div>
                <div>
                  <span class="block text-[8px] font-black text-slate-300 uppercase tracking-widest">Luogo</span>
                  <span class="text-[11px] font-bold text-slate-600 truncate block"><%= event[:location] %></span>
                </div>
                <div>
                  <span class="block text-[8px] font-black text-slate-300 uppercase tracking-widest">Organizzatore</span>
                  <span class="text-[11px] font-bold text-slate-600 truncate block"><%= event[:organizer] %></span>
                </div>
                <div class="text-right">
                  <span class="block text-[8px] font-black text-slate-300 uppercase tracking-widest">Disponibilità</span>
                  <span class="text-[11px] font-black <%= c[:text_m] %>"><%= event[:participants] %></span>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <div id="panel-categories" class="subtab-panel hidden">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <% [
          { icon: "🚶‍♂️", title: "Movimento", count: 4, color: "red" },
          { icon: "🍴", title: "Cibo", count: 2, color: "orange" },
          { icon: "🪗", title: "Musica", count: 3, color: "pink" },
          { icon: "🧘", title: "Meditazione", count: 1, color: "purple" },
          { icon: "🌲", title: "Natura", count: 5, color: "green" },
          { icon: "💙", title: "Postura", count: 4, color: "blue" },
          { icon: "💻", title: "Lavoro", count: 2, color: "amber" },
          { icon: "🗺️", title: "Mappe", count: 2, color: "slate" }
        ].each do |cat| %>
          <div class="bg-white rounded-2xl border border-slate-200 p-4 hover:border-<%= cat[:color] %>-400 transition-all cursor-pointer group text-center">
            <div class="text-3xl mb-2 group-hover:scale-110 transition-transform"><%= cat[:icon] %></div>
            <h3 class="text-sm font-black text-slate-900 leading-tight"><%= cat[:title] %></h3>
            <p class="text-[10px] font-bold text-slate-400 uppercase mt-1"><%= cat[:count] %> <%= active_label %></p>
          </div>
        <% end %>
      </div>

      <div class="p-8 border-2 border-dashed border-slate-200 rounded-3xl text-center">
        <p class="text-slate-400 font-bold text-sm uppercase tracking-widest">Seleziona una categoria per filtrare <%= active_label_downcase %></p>
      </div>
    </div>

    <div id="panel-brands" class="subtab-panel hidden">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <% [
          { id: "pc", icon: "💙", title: "PosturaCorretta", desc: "La tua guida per la salute del corpo.", color: "blue", events: 8 },
          { id: "gdc", icon: "🌿", title: "Giardino del Corpo", desc: "Esperienze in natura e rigenerazione.", color: "emerald", events: 5 },
          { id: "fp", icon: "🗺️", title: "Flowpulse", desc: "Mappe, sistemi e organizzazione.", color: "amber", events: 3 }
        ].each do |brand| %>
          <div class="bg-white rounded-3xl border border-slate-200 overflow-hidden hover:border-<%= brand[:color] %>-400 transition-all cursor-pointer group">
            <div class="bg-<%= brand[:color] %>-50 p-6 text-center border-b border-<%= brand[:color] %>-100">
              <div class="text-5xl mb-4 group-hover:scale-110 transition-transform"><%= brand[:icon] %></div>
              <h3 class="text-xl font-black text-<%= brand[:color] %>-900"><%= brand[:title] %></h3>
            </div>
            <div class="p-6">
              <p class="text-sm text-slate-600 leading-relaxed mb-4"><%= brand[:desc] %></p>
              <div class="flex items-center justify-between">
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest"><%= brand[:events] %> <%= active_label %> attivi</span>
                <span class="px-4 py-2 rounded-xl bg-slate-900 text-white text-[10px] font-black uppercase tracking-widest">Esplora</span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>
</section>