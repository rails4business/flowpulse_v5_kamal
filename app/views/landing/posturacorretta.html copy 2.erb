  <script>
    (() => {
      const root = document.currentScript.closest("[data-human-areas]");
      if (!root || root.dataset.humanAreasReady === "true") return;
      root.dataset.humanAreasReady = "true";

      const tabs = Array.from(root.querySelectorAll("[data-area-tab]"));
      const panels = Array.from(root.querySelectorAll("[data-area-panel]"));
      const activeClasses = ["z-[8]", "scale-110", "opacity-100", "shadow-xl", "ring-4", "ring-white/80"];

      function selectTab(tab, moveFocus = false) {
        tabs.forEach((item) => {
          const selected = item === tab;
          item.setAttribute("aria-selected", String(selected));
          item.tabIndex = selected ? 0 : -1;
          activeClasses.forEach((className) => item.classList.toggle(className, selected));
        });

        panels.forEach((panel) => {
          panel.classList.toggle("hidden", panel.id !== tab.getAttribute("aria-controls"));
        });

        if (moveFocus) tab.focus();
      }

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => selectTab(tab));
        tab.addEventListener("keydown", (event) => {
          if (!["ArrowDown", "ArrowUp", "Home", "End"].includes(event.key)) return;
          event.preventDefault();

          let nextIndex = index;
          if (event.key === "ArrowDown") nextIndex = (index + 1) % tabs.length;
          if (event.key === "ArrowUp") nextIndex = (index - 1 + tabs.length) % tabs.length;
          if (event.key === "Home") nextIndex = 0;
          if (event.key === "End") nextIndex = tabs.length - 1;
          selectTab(tabs[nextIndex], true);
        });
      });
    })();
  </script>
</section>
    <%= render "posturacorretta/footer" %>
</div>
