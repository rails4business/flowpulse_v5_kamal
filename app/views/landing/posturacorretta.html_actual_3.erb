<% content_for :title, "Accademia PosturaCorretta — Percorsi della Salute" %>
<% active_landing_tab = params[:tab].presence_in(%w[accademia eventi collabora]) || "accademia" %>

<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            pcblue: '#2563eb',
            pcink: '#0f172a'
          },
          boxShadow: {
            soft: '0 24px 70px rgba(15, 23, 42, 0.08)'
          }
        }
      }
    }
  </script>

  <style>
    html { scroll-behavior: smooth; }

    section[id],
    main[id] {
      scroll-margin-top: 5rem;
    }

    #percorso-dettaglio,
    #path-final-cta {
      scroll-margin-top: 8rem;
    }

    body {
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #ffffff;
    }

    .glass {
      background: rgba(255, 255, 255, .88);
      backdrop-filter: blur(18px);
    }

    .hero-image {
      background-image:
        linear-gradient(135deg, rgba(37, 99, 235, .10), rgba(15, 23, 42, .10)),
        url('https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=1200&q=80');
      background-size: cover;
      background-position: center;
    }

    .step-line::before {
      content: "";
      position: absolute;
      left: 1.12rem;
      top: 2.8rem;
      bottom: -2.6rem;
      width: 1px;
      background: #dbeafe;
    }

    .step-line:last-child::before { display: none; }

    .landing-tab-button[aria-selected="true"] { color: #fff; }
  </style>
<% end %>

<% content_for :landing_nav do %>
  <header class="sticky top-0 z-50 border-b border-slate-200/80 glass">
    <div class="mx-auto flex min-h-16 max-w-6xl flex-col gap-3 px-4 py-3 md:flex-row md:items-center md:justify-between md:px-6">
      <a href="#top" class="flex items-center gap-3" aria-label="PosturaCorretta home">
        <img src="https://ik.imagekit.io/posturacorretta/logo_pc_scontornato.png?updatedAt=1747975596766" alt="PosturaCorretta" class="h-7 w-auto">
      </a>

      <nav class="grid grid-cols-3 rounded-full bg-slate-100 p-1.5 text-center text-xs font-extrabold uppercase tracking-wide sm:text-sm md:w-auto md:min-w-[620px]" role="tablist" aria-label="Navigazione principale PosturaCorretta">
        <button type="button" class="landing-tab-button rounded-full px-2 py-2 transition md:px-5 <%= active_landing_tab == "accademia" ? "bg-blue-600 text-white shadow-sm" : "text-blue-700" %>" data-landing-tab="accademia" aria-selected="<%= active_landing_tab == "accademia" %>">
          Accademia
        </button>
        <button type="button" class="landing-tab-button rounded-full px-2 py-2 transition md:px-5 <%= active_landing_tab == "eventi" ? "bg-violet-700 text-white shadow-sm" : "text-violet-700" %>" data-landing-tab="eventi" aria-selected="<%= active_landing_tab == "eventi" %>">
          Eventi
        </button>
        <button type="button" class="landing-tab-button rounded-full px-2 py-2 transition md:px-5 <%= active_landing_tab == "collabora" ? "bg-orange-500 text-white shadow-sm" : "text-orange-600" %>" data-landing-tab="collabora" aria-selected="<%= active_landing_tab == "collabora" %>">
          Progetti<br class="sm:hidden"> / Collabora
        </button>
      </nav>
    </div>
  </header>
<% end %>

<div id="top" class="text-slate-900 antialiased">

  <!-- ACCADEMIA -->
  <div data-tab-panel="accademia" class="<%= "hidden" unless active_landing_tab == "accademia" %>">

    <!-- HERO -->
    <section class="px-5 py-16 md:py-24">
      <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[.95fr_1.05fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">
            Accademia PosturaCorretta
          </p>

          <h1 class="mt-5 max-w-5xl text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl md:leading-[1.03]">
            Una mappa per costruire
            <span class="text-blue-700">il tuo percorso della salute.</span>
          </h1>

          <p class="mt-8 max-w-3xl text-lg leading-8 text-slate-600">
            PosturaCorretta ti aiuta a orientarti tra dolore, prevenzione, benessere, conoscenza del corpo,
            rapporto corpo-ambiente e sviluppo del potenziale umano.
          </p>

          <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
            Non devi capire tutto subito. Parti dalla domanda più semplice: in cosa vuoi essere aiutato adesso?
          </p>

          <div class="mt-9 flex flex-wrap gap-3">
            <a href="#inizia" class="rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-700">
              Scegli il tuo percorso
            </a>
            <button type="button" data-jump-tab="eventi" class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-700 ring-1 ring-slate-200 hover:bg-slate-50">
              Guarda gli eventi
            </button>
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-3 shadow-soft">
          <div class="hero-image aspect-[16/10] rounded-[1.55rem]"></div>
        </div>
      </div>
    </section>

    <!-- PERCORSI -->
    <section id="inizia" class="border-y border-slate-200 bg-slate-50 px-5 py-20 md:py-24">
      <div class="mx-auto max-w-6xl">

        <div class="max-w-4xl">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">
            Percorsi dell'Accademia
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl md:leading-[1.04]">
            In cosa vuoi essere aiutato?
          </h2>

          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">
            Scegli l'area più vicina alla tua situazione. Ogni scelta apre una traccia: contenuti, strumenti,
            tappe, professionisti o attività da completare.
          </p>
        </div>

        <!-- SCELTA PERCORSO -->
        <div class="mt-12 grid gap-3 md:grid-cols-2 xl:grid-cols-7">

          <button data-path-tab="cura" class="pc-path-tab flex min-h-40 items-start gap-4 rounded-2xl border border-red-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-red-300 hover:shadow-md xl:col-span-1">
            <span class="mt-1 h-4 w-4 shrink-0 rounded-full bg-red-600 ring-4 ring-red-100"></span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-red-700">Cura</span>
              <span class="mt-2 block text-lg font-semibold leading-6 text-slate-950">Cura e Riabilitazione</span>
              <span class="mt-2 block text-sm leading-6 text-slate-600">Hai dolore, sintomi o una patologia?</span>
              <span class="mt-4 block text-sm font-semibold text-red-700">Apri percorso</span>
            </span>
          </button>

          <button data-path-tab="prevenzione" class="pc-path-tab flex min-h-40 items-start gap-4 rounded-2xl border border-orange-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-orange-300 hover:shadow-md xl:col-span-1">
            <span class="mt-1 h-4 w-4 shrink-0 rounded-full bg-orange-500 ring-4 ring-orange-100"></span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-orange-700">Prevenzione</span>
              <span class="mt-2 block text-lg font-semibold leading-6 text-slate-950">Prevenzione</span>
              <span class="mt-2 block text-sm leading-6 text-slate-600">Vuoi prevenire problemi legati a lavoro, sport o età?</span>
              <span class="mt-4 block text-sm font-semibold text-orange-700">Apri percorso</span>
            </span>
          </button>

          <button data-path-tab="performance" class="pc-path-tab flex min-h-40 items-start gap-4 rounded-2xl border border-yellow-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-yellow-300 hover:shadow-md xl:col-span-1">
            <span class="mt-1 h-4 w-4 shrink-0 rounded-full bg-yellow-400 ring-4 ring-yellow-100"></span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-yellow-700">Performance</span>
              <span class="mt-2 block text-lg font-semibold leading-6 text-slate-950">Performance</span>
              <span class="mt-2 block text-sm leading-6 text-slate-600">Vuoi migliorare lavoro, studio o capacità cognitive?</span>
              <span class="mt-4 block text-sm font-semibold text-yellow-700">Apri percorso</span>
            </span>
          </button>

          <button data-path-tab="benessere" class="pc-path-tab flex min-h-40 items-start gap-4 rounded-2xl border border-emerald-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-emerald-300 hover:shadow-md xl:col-span-1">
            <span class="mt-1 h-4 w-4 shrink-0 rounded-full bg-emerald-600 ring-4 ring-emerald-100"></span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Benessere</span>
              <span class="mt-2 block text-lg font-semibold leading-6 text-slate-950">Benessere Integrato</span>
              <span class="mt-2 block text-sm leading-6 text-slate-600">Vuoi migliorare salute, energia e qualità della vita?</span>
              <span class="mt-4 block text-sm font-semibold text-emerald-700">Apri percorso</span>
            </span>
          </button>

          <button data-path-tab="fisiologia" class="pc-path-tab flex min-h-40 items-start gap-4 rounded-2xl border border-blue-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-md xl:col-span-1">
            <span class="mt-1 h-4 w-4 shrink-0 rounded-full bg-blue-600 ring-4 ring-blue-100"></span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Fisiologia</span>
              <span class="mt-2 block text-lg font-semibold leading-6 text-slate-950">Postura e Fisiologia</span>
              <span class="mt-2 block text-sm leading-6 text-slate-600">Vuoi capire come funziona il corpo?</span>
              <span class="mt-4 block text-sm font-semibold text-blue-700">Apri percorso</span>
            </span>
          </button>

          <button data-path-tab="ambiente" class="pc-path-tab flex min-h-40 items-start gap-4 rounded-2xl border border-indigo-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-indigo-300 hover:shadow-md xl:col-span-1">
            <span class="mt-1 h-4 w-4 shrink-0 rounded-full bg-indigo-600 ring-4 ring-indigo-100"></span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-indigo-700">Ambiente</span>
              <span class="mt-2 block text-lg font-semibold leading-6 text-slate-950">Corpo e Ambiente</span>
              <span class="mt-2 block text-sm leading-6 text-slate-600">Vuoi comprendere il rapporto tra corpo e ambiente?</span>
              <span class="mt-4 block text-sm font-semibold text-indigo-700">Apri percorso</span>
            </span>
          </button>

          <button data-path-tab="potenziale" class="pc-path-tab flex min-h-40 items-start gap-4 rounded-2xl border border-violet-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-violet-300 hover:shadow-md xl:col-span-1">
            <span class="mt-1 h-4 w-4 shrink-0 rounded-full bg-violet-700 ring-4 ring-violet-100"></span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-violet-700">Potenziale</span>
              <span class="mt-2 block text-lg font-semibold leading-6 text-slate-950">Potenziale Umano</span>
              <span class="mt-2 block text-sm leading-6 text-slate-600">Vuoi scoprire il tuo potenziale?</span>
              <span class="mt-4 block text-sm font-semibold text-violet-700">Apri percorso</span>
            </span>
          </button>

        </div>

        <!-- CONTENUTO DINAMICO -->
        <div id="percorso-dettaglio" class="mt-14 grid gap-10 lg:grid-cols-[0.78fr_1.22fr]">

          <aside class="lg:sticky lg:top-28 lg:h-fit">
            <p id="path-kicker" class="text-xs font-semibold uppercase tracking-[0.22em] text-red-700">
              Cura e Riabilitazione
            </p>

            <h2 id="path-title" class="mt-4 text-3xl font-semibold tracking-tight text-slate-950 md:text-5xl md:leading-[1.05]">
              Dal dolore alla cura guidata.
            </h2>

            <p id="path-description" class="mt-5 text-lg leading-8 text-slate-600">
              Per chi parte da dolore, diagnosi, patologia o fase acuta.
            </p>
          </aside>

          <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-soft md:p-10">
            <div class="mb-10 border-b border-slate-100 pb-8">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Tappe consigliate</p>
              <h3 id="path-steps-title" class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">Segui il percorso con calma.</h3>
            </div>

            <div id="path-steps" class="space-y-10"></div>

            <div id="path-final-cta" class="mt-10 rounded-2xl border border-slate-100 bg-slate-50 p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Vuoi completare qualcosa?</p>
              <p id="path-bottom-text" class="mt-2 text-lg font-semibold text-slate-950">Inizia dal percorso più vicino alla tua situazione.</p>

              <a id="path-bottom-start-link" href="https://wa.me/393792891488?text=Ciao%2C%20vorrei%20iniziare%20un%20percorso%20con%20PosturaCorretta."
                target="_blank" rel="noopener noreferrer"
                class="mt-6 inline-flex w-full items-center justify-center rounded-2xl bg-red-600 px-8 py-5 text-base font-semibold text-white opacity-90 md:text-lg">
                Scrivi su WhatsApp →
              </a>
            </div>

            <div id="join-box" class="mt-10 rounded-[2rem] border border-red-200 bg-white p-7 shadow-sm">
              <p id="join-kicker" class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">
                Aderisci al progetto
              </p>

              <h3 id="join-title" class="mt-3 text-2xl font-semibold text-slate-950">
                Sei un professionista sanitario?
              </h3>

              <p id="join-description" class="mt-4 text-base leading-7 text-slate-600">
                Puoi integrare il percorso PosturaCorretta nei tuoi trattamenti e accompagnare le persone oltre la sola gestione del dolore.
              </p>

              <div id="join-tags" class="mt-5 flex flex-wrap gap-2"></div>

              <button id="join-link" type="button" data-jump-tab="collabora"
                class="mt-6 inline-flex rounded-full border border-red-200 px-5 py-3 text-sm font-semibold text-red-700 hover:bg-red-50">
                Scopri come aderire →
              </button>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- MANIFESTO BREVE -->
    <section class="bg-white px-5 py-20 md:py-24">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">
            La postura non è qualcosa da correggere, ma da comprendere
          </p>
          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl md:leading-[1.05]">
            Il corpo è un mondo da scoprire.
          </h2>
        </div>

        <div class="text-lg leading-8 text-slate-600">
          <p>
            Il percorso parte spesso dal dolore, ma non si ferma lì. Attraversa cura, prevenzione,
            performance, benessere, fisiologia, ambiente e potenziale umano.
          </p>
          <p class="mt-6">
            L'obiettivo è aiutare le persone a trovare il proprio punto di vista da cui osservare la salute,
            scegliere strumenti pratici e costruire un percorso sostenibile.
          </p>
        </div>
      </div>
    </section>
  </div>

  <!-- EVENTI -->
  <div data-tab-panel="eventi" class="<%= "hidden" unless active_landing_tab == "eventi" %>">
    <section id="eventi" class="border-t border-slate-200 bg-slate-50 px-5 py-20 md:py-24">
      <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-violet-700">
            Eventi e Community
          </p>
          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl md:leading-[1.04]">
            Eventi per vivere il percorso, non solo studiarlo.
          </h2>
          <p class="mt-6 text-lg leading-8 text-slate-600">
            Camminate, incontri, attività sul territorio, movimento, natura, musica, buon cibo,
            scambio trattamenti e momenti di comunità.
          </p>
          <div class="mt-8">
            <a href="https://wa.me/393792891488?text=Ciao%2C%20vorrei%20informazioni%20sui%20prossimi%20eventi%20PosturaCorretta."
               target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center rounded-2xl bg-violet-700 px-6 py-4 text-base font-semibold text-white transition hover:bg-violet-800 shadow-sm">
              Chiedi informazioni sugli eventi →
            </a>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <a href="https://www.youtube.com/posturacorretta" target="_blank" rel="noopener noreferrer" class="group rounded-[1.75rem] border border-slate-200 bg-white p-8 transition hover:-translate-y-1 hover:border-red-200 hover:shadow-xl">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-600">Video & Ricerca</p>
            <h3 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">YouTube</h3>
            <p class="mt-4 text-base leading-7 text-slate-600">Approfondimenti, esercizi, eventi e costruzione pubblica del progetto.</p>
            <div class="mt-6 flex items-center gap-2 text-sm font-semibold text-red-600">Vai al canale <span class="transition group-hover:translate-x-1">→</span></div>
          </a>

          <a href="https://www.instagram.com/posturacorretta" target="_blank" rel="noopener noreferrer" class="group rounded-[1.75rem] border border-slate-200 bg-white p-8 transition hover:-translate-y-1 hover:border-pink-200 hover:shadow-xl">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-pink-600">Community & Eventi</p>
            <h3 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">Instagram</h3>
            <p class="mt-4 text-base leading-7 text-slate-600">Dietro le quinte, caroselli, eventi e aggiornamenti quotidiani.</p>
            <div class="mt-6 flex items-center gap-2 text-sm font-semibold text-pink-600">Segui la pagina <span class="transition group-hover:translate-x-1">→</span></div>
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- COLLABORA -->
  <section id="collabora" data-tab-panel="collabora" class="<%= "hidden " unless active_landing_tab == "collabora" %>border-b border-slate-200 bg-slate-50 px-5 py-20 md:py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-orange-700">Progetti e Collaborazioni</p>
          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl md:leading-[1.04]">
            Aiutaci a costruire PosturaCorretta.
          </h2>
          <p class="mt-6 text-lg leading-8 text-slate-600">
            PosturaCorretta è anche un progetto aperto a professionisti, insegnanti, operatori,
            sviluppatori, creator, centri, spazi, eventi e persone che vogliono contribuire.
          </p>
          <div class="mt-8">
            <a href="https://wa.me/393792891488?text=Ciao%2C%20vorrei%20proporre%20una%20collaborazione%20per%20il%20progetto%20PosturaCorretta."
               target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center gap-2 rounded-2xl bg-orange-500 px-6 py-4 text-base font-semibold text-white transition hover:bg-orange-600 shadow-sm">
              Proponi una collaborazione su WhatsApp →
            </a>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="flex flex-col justify-between rounded-2xl border border-red-200 bg-white p-6">
            <div>
              <p class="text-sm font-semibold text-red-700">Professionisti sanitari</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">Fisioterapisti, medici, osteopati e figure sanitarie per cura, riabilitazione e percorsi complessi.</p>
            </div>
            <a href="https://wa.me/393792891488?text=Ciao%2C%20sono%20un%20professionista%20sanitario%20e%20vorrei%20collaborare%20con%20PosturaCorretta." target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex items-center justify-center rounded-xl bg-red-50 px-4 py-2.5 text-xs font-semibold text-red-700 transition hover:bg-red-100">Contatta →</a>
          </div>

          <div class="flex flex-col justify-between rounded-2xl border border-emerald-200 bg-white p-6">
            <div>
              <p class="text-sm font-semibold text-emerald-700">Benessere e prevenzione</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">Professionisti del movimento, trainer, operatori e facilitatori dello stile di vita.</p>
            </div>
            <a href="https://wa.me/393792891488?text=Ciao%2C%20mi%20occupo%20di%20benessere%20o%20prevenzione%20e%20vorrei%20collaborare%20con%20PosturaCorretta." target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex items-center justify-center rounded-xl bg-emerald-50 px-4 py-2.5 text-xs font-semibold text-emerald-700 transition hover:bg-emerald-100">Contatta →</a>
          </div>

          <div class="flex flex-col justify-between rounded-2xl border border-blue-200 bg-white p-6">
