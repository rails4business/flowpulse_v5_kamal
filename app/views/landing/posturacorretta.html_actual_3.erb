<script>
  (() => {
    const allowedTabs = ["accademia", "eventi", "collabora"];
    const buttons = document.querySelectorAll("[data-landing-tab]");
    const panels = document.querySelectorAll("[data-tab-panel]");
    const activeClasses = {
      accademia: ["bg-blue-600", "text-white", "shadow-sm"],
      eventi: ["bg-violet-700", "text-white", "shadow-sm"],
      collabora: ["bg-orange-500", "text-white", "shadow-sm"]
    };

    function activateLandingTab(tabKey, updateUrl = true) {
      const nextTab = allowedTabs.includes(tabKey) ? tabKey : "accademia";

      buttons.forEach((button) => {
        const active = button.dataset.landingTab === nextTab;
        button.setAttribute("aria-selected", active ? "true" : "false");
        button.classList.remove("bg-blue-600", "bg-violet-700", "bg-orange-500", "text-white", "shadow-sm");

        if (active) {
          button.classList.add(...activeClasses[nextTab]);
        }
      });

      panels.forEach((panel) => {
        panel.classList.toggle("hidden", panel.dataset.tabPanel !== nextTab);
      });

      if (updateUrl) {
        const url = new URL(window.location);
        url.searchParams.set("tab", nextTab);
        if (nextTab !== "accademia") url.searchParams.delete("path");
        window.history.replaceState({}, "", url);
        document.getElementById("top")?.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }

    buttons.forEach((button) => {
      button.addEventListener("click", () => activateLandingTab(button.dataset.landingTab));
    });

    document.querySelectorAll("[data-jump-tab]").forEach((button) => {
      button.addEventListener("click", () => activateLandingTab(button.dataset.jumpTab));
    });

    window.addEventListener("popstate", () => {
      const tab = new URLSearchParams(window.location.search).get("tab");
      activateLandingTab(tab, false);
    });
  })();
</script>
