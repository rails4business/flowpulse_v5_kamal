    <script>
      (() => {
        const root = document.currentScript.closest("[data-human-areas]");
        if (!root || root.dataset.humanAreasReady === "true") return;
        root.dataset.humanAreasReady = "true";

        const tabs = Array.from(root.querySelectorAll("[data-area-tab]"));
        const panels = Array.from(root.querySelectorAll("[data-area-panel]"));
        const activeClassesFor = (tab) => (tab.dataset.activeClasses || "").split(" ").filter(Boolean);

        function selectTab(tab, moveFocus = false) {
          tabs.forEach((item) => {
            const selected = item === tab;
            item.setAttribute("aria-selected", String(selected));
            item.tabIndex = selected ? 0 : -1;
            activeClassesFor(item).forEach((className) => item.classList.toggle(className, selected));
          });

          panels.forEach((panel) => {
            panel.classList.toggle("hidden", panel.id !== tab.getAttribute("aria-controls"));
          });

          if (moveFocus) tab.focus();
        }

        tabs.forEach((tab, index) => {
          tab.addEventListener("click", () => selectTab(tab));
          tab.addEventListener("keydown", (event) => {
            if (!["ArrowDown", "ArrowUp", "Home", "End"].includes(event.key)) return;
            event.preventDefault();

            let nextIndex = index;
            if (event.key === "ArrowDown") nextIndex = (index + 1) % tabs.length;
            if (event.key === "ArrowUp") nextIndex = (index - 1 + tabs.length) % tabs.length;
            if (event.key === "Home") nextIndex = 0;
            if (event.key === "End") nextIndex = tabs.length - 1;
            selectTab(tabs[nextIndex], true);
          });
        });

        root.querySelectorAll("[data-posture-tabs]").forEach((tabGroup) => {
          const postureTabs = Array.from(tabGroup.querySelectorAll("[data-posture-tab]"));
          const posturePanels = Array.from(tabGroup.querySelectorAll("[data-posture-panel]"));
          const activeTabClasses = ["border-blue-700", "text-blue-950"];
          const inactiveTabClasses = ["border-transparent", "text-slate-600"];

          function selectPostureTab(tab) {
            postureTabs.forEach((item) => {
              const selected = item === tab;
              item.setAttribute("aria-selected", String(selected));
              activeTabClasses.forEach((className) => item.classList.toggle(className, selected));
              inactiveTabClasses.forEach((className) => item.classList.toggle(className, !selected));
            });

            posturePanels.forEach((panel) => {
              panel.classList.toggle("hidden", panel.id !== tab.getAttribute("aria-controls"));
            });
          }

          postureTabs.forEach((tab) => {
            tab.addEventListener("click", () => selectPostureTab(tab));
          });
        });
      })();
    </script>
  </section>

  <!-- Secondo blocco: modi per iniziare -->
  <section class="border-t border-slate-200 bg-white px-5 py-14 md:py-20" aria-labelledby="start-title">
    <div class="mx-auto max-w-6xl">
      <header class="mx-auto max-w-3xl text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
          Da dove vuoi iniziare?
        </p>
        <h2 id="start-title" class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl">
          Conosci, pratica e partecipa.
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-600">
          Entra dall’Accademia, costruisci il tuo percorso oppure segui eventi,
          contenuti e progetti di PosturaCorretta.
        </p>
      </header>

      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
        <% quick_links.each do |link| %>
          <a href="<%= link.fetch(:path) %>" class="group flex h-full flex-col rounded-2xl border p-5 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-xl <%= link[:classes].presence || "border-blue-100 bg-white text-blue-700" %>">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-blue-700">
              <%= link.fetch(:eyebrow) %>
            </p>
            <h3 class="mt-2 text-lg font-semibold leading-6 text-slate-950">
              <%= link.fetch(:title) %>
            </h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              <%= link.fetch(:description) %>
            </p>
            <span class="mt-auto inline-flex items-center pt-5 text-sm font-semibold text-blue-700">
              <%= link.fetch(:cta) %>
              <span class="ml-1 transition group-hover:translate-x-1" aria-hidden="true">→</span>
            </span>
          </a>
        <% end %>
      </div>
    </div>
  </section>

  <%= render "posturacorretta/footer" %>
</div>
