                alt="Camminata PosturaCorretta">
            </div>
            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Natura</p>
              <h3 class="mt-2 text-2xl font-semibold text-slate-950">Camminata PosturaCorretta</h3>
            </div>
          </article>

          <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
