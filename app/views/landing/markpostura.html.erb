          </a>

          <div class="rounded-[2rem] border border-slate-200 bg-white/70 p-6 shadow-sm opacity-75" aria-disabled="true">
            <div class="flex items-center justify-between gap-3">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700">Libro</p>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-500">Coming soon</span>
