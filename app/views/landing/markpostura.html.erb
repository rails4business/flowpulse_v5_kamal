      <nav class="hidden items-center gap-6 text-sm font-semibold text-slate-600 md:flex">
        <a href="#come-posso-aiutarti" class="hover:text-slate-950">Come posso aiutarti?</a>
        <a href="#eventi" class="hover:text-slate-950">Eventi</a>
        <a href="#weekplan" class="hover:text-slate-950">Weekplan</a>
        <a href="#portfolio" class="hover:text-slate-950">Portfolio Progetti</a>
        <a href="#libro" class="hover:text-slate-950">Libro</a>
