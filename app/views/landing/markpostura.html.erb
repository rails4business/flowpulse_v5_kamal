  <main id="top">

    <!-- HERO -->
    <section class="relative overflow-hidden bg-slate-50 px-5 py-24 md:py-32">
      <div class="absolute inset-x-0 top-0 h-96 bg-gradient-to-b from-sky-100/80 to-transparent"></div>
