        <div class="mt-12 grid gap-6 lg:grid-cols-3">

          <!-- CARD -->
          <a href="https://posturacorretta.org" target="_blank" rel="noopener noreferrer"
            class="group overflow-hidden rounded-[2rem] border border-sky-100 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">

            <div class="aspect-[16/9] overflow-hidden bg-sky-100">
              <img src="https://ik.imagekit.io/posturacorretta/markpostura/home/percorso_salute.webp?tr=w-700,q-80,f-webp"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                alt="Percorso Salute">
            </div>

            <div class="p-7">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">
                01 · Salute
              </p>

              <h3 class="mt-3 text-3xl font-semibold text-slate-950">
                Percorso Salute
              </h3>

              <p class="mt-4 text-base leading-7 text-slate-600">
                Accademia posturacorretta Postura, fisioterapia.
              </p>
            </div>
          </a>

         
          <!-- CARD -->
          <a href="#portfolio"
            class="group overflow-hidden rounded-[2rem] border border-amber-100 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">

            <div class="aspect-[16/9] overflow-hidden bg-amber-100">
              <img src="https://ik.imagekit.io/posturacorretta/markpostura/home/progetti_e_software.webp?tr=w-700,q-80,f-webp"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                alt="Progetti e software">
            </div>

            <div class="p-7">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700">
                02 · Progetti
              </p>

              <h3 class="mt-3 text-3xl font-semibold text-slate-950">
                Progetti & Software
              </h3>

              <p class="mt-4 text-base leading-7 text-slate-600">
                Flowpulse, Rails4Business e strumenti digitali.
              </p>
            </div>
          </a>

           <!-- CARD -->
          <a href="#eventi"
            class="group overflow-hidden rounded-[2rem] border border-emerald-100 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">

            <div class="aspect-[16/9] overflow-hidden bg-emerald-100">
              <img src="https://ik.imagekit.io/posturacorretta/markpostura/home/eventi_esperienze.webp?tr=w-700,q-80,f-webp"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                alt="Eventi ed esperienze">
            </div>

            <div class="p-7">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-violet-700">
                03 · Esperienze
              </p>

              <h3 class="mt-3 text-3xl font-semibold text-slate-950">
                Eventi & Esperienze
