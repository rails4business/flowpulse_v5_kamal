    <!-- WEEKPLAN -->
    <section id="weekplan" class="border-y border-slate-200 bg-white px-5 py-20">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">

