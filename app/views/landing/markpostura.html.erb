              La mia storia
            </a>

          </div>
        </div>

        <div class="mx-auto w-full max-w-md overflow-hidden rounded-[2.5rem] border border-white/80 bg-white p-3 shadow-xl lg:mr-0">
          <img src="https://ik.imagekit.io/posturacorretta/markpostura/home/hero_mark_psotura.webp?tr=w-900,q-80,f-webp"
            class="aspect-[4/5] h-full w-full rounded-[2rem] object-cover"
            alt="Mark Postura">
        </div>
      </div>
    </section>

    <!-- TRE MONDI -->
    <section id="tre-mondi" class="bg-white px-5 py-20">
      <div class="mx-auto max-w-6xl">
        <!--div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-sky-700">
            La mappa
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-5xl">
            Tre mondi che si incontrano.
          </h2>

          <p class="mt-6 text-lg leading-8 text-slate-600">
            Salute, esperienze e strumenti digitali: una visione unica per orientare il percorso.
            Da qui puoi scegliere la porta più vicina al momento che stai vivendo.
          </p>
        </div-->

        <div class="mt-12 overflow-hidden rounded-[2.5rem] border border-slate-200 bg-slate-50 p-3 shadow-sm">
          <img src="https://ik.imagekit.io/posturacorretta/postura_3_mondi.png?updatedAt=1780744795143?tr=w-1400,q-85,f-webp"
            class="h-auto w-full rounded-[2rem] object-cover"
            alt="Mappa dei tre mondi di Mark Postura">
        </div>

        <div class="mt-10 flex justify-center">
          <a href="#come-posso-aiutarti"
            class="inline-flex items-center rounded-full bg-slate-950 px-7 py-4 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800">
            Scegli da dove iniziare
          </a>
        </div>
      </div>
