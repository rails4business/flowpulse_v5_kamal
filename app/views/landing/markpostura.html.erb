                alt="PosturaCorretta e forchetta">
            </div>
            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700">Corpo & Cibo</p>
              <h3 class="mt-2 text-2xl font-semibold text-slate-950">PosturaCorretta e forchetta</h3>
            </div>
          </article>

          <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
            <div class="aspect-[16/9] overflow-hidden bg-sky-100">
