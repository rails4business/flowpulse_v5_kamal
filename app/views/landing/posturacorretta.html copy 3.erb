          </a>
        </div>

        <section class="mt-8 rounded-[1.75rem] border border-slate-200 bg-white/90 p-5 shadow-sm xl:mt-7 xl:p-6" aria-labelledby="taxonomy-map-title">
         <div class="mt-5 grid gap-3 md:grid-cols-3">
            <% taxonomy_audiences.each do |_slug, audience| %>
              <article class="rounded-2xl border p-4 <%= audience.fetch("classes") %>">
                <p class="text-[10px] font-extrabold uppercase tracking-[0.16em] opacity-80"><%= audience.fetch("short_label") %></p>
                <h3 class="mt-1 text-base font-bold"><%= audience.fetch("label") %></h3>
                <p class="mt-2 text-xs leading-5 opacity-80"><%= audience.fetch("description") %></p>
              </article>
            <% end %>
          </div>
         

          

          <div class="mt-5 grid gap-3 lg:hidden">
            <% taxonomy_areas.each do |_slug, area| %>
              <details class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <summary class="cursor-pointer list-none">
                  <span class="text-[10px] font-extrabold uppercase tracking-[0.14em] text-slate-400"><%= area.fetch("element") %></span>
                  <span class="mt-1 block text-base font-bold text-slate-950"><%= area.fetch("label") %> · <%= area.fetch("imperative") %></span>
                  <span class="mt-1 block text-sm font-semibold text-slate-700"><%= area.fetch("title") %></span>
                  <span class="mt-1 block text-xs leading-5 text-slate-600"><%= area.fetch("description") %></span>
                </summary>
                <div class="mt-3 grid gap-2">
                  <% taxonomy_scopes.each do |scope_slug, scope| %>
                    <% linked = area.fetch("scopes", []).include?(scope_slug) %>
                    <div class="rounded-xl border p-3 text-xs <%= linked ? area.fetch("classes") : scope.fetch("classes") %>">
                      <span class="mb-1 inline-flex rounded-full border border-current/20 bg-white/60 px-2 py-0.5 text-[10px] font-extrabold uppercase tracking-wide"><%= scope.fetch("slug") %></span>
                      <strong class="block"><%= scope.fetch("title") %></strong>
                      <span class="mt-1 block font-semibold opacity-90"><%= scope.fetch("positive") %></span>
                      <span class="mt-1 block opacity-80"><%= linked ? area.fetch("action") : "Possibile collegamento futuro" %></span>
                      <span class="mt-1 block opacity-70"><%= scope.fetch("blockage") %></span>
                    </div>
                  <% end %>
                </div>
              </details>
            <% end %>
          </div>
        </section>
      </div>
