<% content_for :landing_nav do %>
  <%= render "posturacorretta/header" %>
<% end %>

<%
  taxonomies = @posturacorretta_taxonomies || {}
  taxonomy_audiences = taxonomies.fetch("audiences", {})
  taxonomy_areas = taxonomies.fetch("areas", {})
  taxonomy_scopes = taxonomies.fetch("scopes", {})
%>

<div id="top" class="text-slate-900 antialiased">
  <section class="flex min-h-[calc(100vh-4rem)] items-center px-5 py-10 md:py-12 xl:py-8">
      <div class="mx-auto w-full max-w-6xl">
        <div class="grid items-center gap-8 lg:grid-cols-[0.95fr_1.05fr] xl:gap-10">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">
              PosturaCorretta
            </p>
            <h1 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl md:leading-[1.05] xl:text-5xl">
              Trova la giusta posizione da cui osservare il mondo.
              <span class="mt-2 block text-blue-700">Inizia dalla salute!</span>
            </h1>
            <p class="mt-5 max-w-3xl text-base leading-7 text-slate-600 md:text-lg xl:mt-4">
             Partiamo dalle metodiche posturali per imparare a leggere il corpo, come si relaziona con l’ambiente per migliorare la nostra salute e la nostra vita.
            </p>
          </div>

          <div class="rounded-[2rem] border border-blue-100 bg-white p-3 shadow-soft xl:p-4">
            <img src="https://ik.imagekit.io/posturacorretta/img_home_postura_corretta.png?tr=w-1100,q-85" alt="PosturaCorretta: trova la giusta posizione da cui osservare il mondo" class="mx-auto aspect-[16/10] w-full rounded-[1.5rem] object-contain xl:max-h-[300px]">
          </div>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-2 xl:mt-7 xl:grid-cols-5">
                   <a href="<%= posturacorretta_accademia_path %>" class="group rounded-2xl border border-blue-100 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-blue-200 hover:shadow-xl xl:p-4 keychainify-checked">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Accademia</p>
            <h2 class="mt-2 text-lg font-semibold text-slate-955">Pratica</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600 xl:leading-5"> Con le metodiche posturali, comprendi e riattiva i sistemi del corpo.</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-blue-700 xl:mt-3">Inizia l'accademia <span class="ml-1 transition group-hover:translate-x-1">→</span></span>
          </a>
          <a href="<%= posturacorretta_percorso_path %>" class="group rounded-2xl border border-blue-100 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-blue-200 hover:shadow-xl xl:p-4 keychainify-checked">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Percorso</p>
            <h2 class="mt-2 text-lg font-semibold text-slate-955">Personalizzato</h2>
