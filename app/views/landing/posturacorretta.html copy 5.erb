    <!-- ─── TAPPA 3 · PosturaCorretta ─── -->
    <section id="posturacorretta" class="scroll-mt-24 bg-white px-5" aria-labelledby="posturacorretta-title" data-story-section>
      <div class="mx-auto max-w-6xl flex">
        <div class="relative w-[50px] md:w-[80px] flex-shrink-0 flex flex-col items-center">
          <div class="absolute top-0 bottom-0 w-[3px] bg-gradient-to-b from-indigo-300 to-indigo-500"></div>
          <div class="relative mt-16 md:mt-24 journey-step-marker bg-indigo-500">03</div>
        </div>
        <div class="flex-1 py-16 md:py-24 pl-5 md:pl-10">
          <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-indigo-600">Tappa 3 · La nostra prospettiva</p>
              <h2 id="posturacorretta-title" class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl">
                Cosa intendiamo con PosturaCorretta?
              </h2>
              <p class="mt-5 text-base leading-7 text-slate-600 md:text-lg md:leading-8">
                Non cerchiamo una posizione perfetta uguale per tutti. Cerchiamo la posizione
                più adatta da cui osservare la persona, comprendere ciò che sta vivendo e costruire il percorso successivo.
              </p>

              <div class="mt-8 grid gap-4 sm:grid-cols-2">
                <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6">
                  <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Quando si pensa alla postura</p>
                  <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-700">
                    <li>Stare dritti</li>
                    <li>Correggere una posizione</li>
                    <li>Schiena e articolazioni</li>
                    <li>Una forma ideale</li>
                  </ul>
                </article>
                <article class="rounded-[1.5rem] border border-blue-200 bg-blue-50 p-6">
                  <p class="text-xs font-bold uppercase tracking-wider text-blue-700">Cosa intendiamo noi</p>
                  <ul class="mt-4 space-y-3 text-sm font-medium leading-6 text-blue-950">
                    <li>Comprendere l'organizzazione</li>
                    <li>Osservare adattamenti e compensi</li>
                    <li>Corpo, fisiologia e ambiente</li>
                    <li>Una posizione adatta alla persona</li>
                  </ul>
                </article>
              </div>
            </div>

            <figure class="overflow-hidden rounded-[2rem] border border-blue-100 bg-blue-50/70 p-3 shadow-sm">
              <img
                src="https://ik.imagekit.io/posturacorretta/img_home_postura_corretta.png?tr=w-1100,q-85"
                alt="PosturaCorretta: partire dal corpo per ampliare lo sguardo sulla salute e sulla persona"
                class="aspect-[16/11] w-full rounded-[1.4rem] object-contain"
              >
            </figure>
          </div>

          <div class="mt-12 rounded-[2rem] bg-blue-950 px-6 py-9 text-center text-white shadow-xl md:px-10 md:py-12">
            <p class="text-2xl font-semibold tracking-tight md:text-3xl">
              Trova la giusta posizione da cui osservare il mondo.
            </p>
            <p class="mt-2 text-lg font-medium text-blue-200">Inizia dalla salute.</p>
          </div>

          <div class="mt-8 text-center md:text-left">
            <a href="#ambiti" class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 transition hover:text-blue-800">
              Prossima tappa: Ambiti <span aria-hidden="true">↓</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── TAPPA 4 · Ambiti (Chakra verticali & Accordion) ─── -->
    <section id="ambiti" class="scroll-mt-24 border-y border-slate-200 bg-gradient-to-b from-slate-50 to-white px-5" aria-labelledby="ambiti-title" data-story-section>
      <div class="mx-auto max-w-6xl flex">
        <div class="relative w-[50px] md:w-[80px] flex-shrink-0 flex flex-col items-center">
          <div class="absolute top-0 bottom-0 w-[3px] bg-gradient-to-b from-indigo-500 to-indigo-800"></div>
          <div class="relative mt-16 md:mt-24 journey-step-marker bg-indigo-600">04</div>
        </div>
        
        <div class="flex-1 py-16 md:py-24 pl-5 md:pl-10">
          <header class="max-w-3xl">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-indigo-700">Tappa 4 · Dal corpo alla persona</p>
            <h2 id="ambiti-title" class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl">
              Quali ambiti possiamo osservare partendo dalla postura?
            </h2>
            <p class="mt-5 text-base leading-7 text-slate-600 md:text-lg md:leading-8">
              Seleziona un ambito per esplorare come lo sguardo posturale può accompagnare
              salute, attività, apprendimento, benessere e relazione con l'ambiente.
            </p>
          </header>

          <!-- Chakra Component -->
          <div class="mt-10 lg:mt-16 lg:grid lg:grid-cols-[140px_1fr] lg:gap-12 xl:gap-20 lg:items-start" data-chakra-container>
            
            <!-- Colonna Spine (solo Desktop) -->
            <div class="hidden lg:flex chakra-spine relative flex-col items-center gap-5 pb-8" role="tablist">
              <% human_areas.each_with_index do |area, index| %>
                <button
                  type="button"
                  data-chakra-tab="<%= area.fetch(:slug) %>"
                  class="chakra-circle bg-gradient-to-br shadow-lg focus:outline-none focus-visible:ring-4 <%= area.fetch(:button_classes) %> <%= 'is-active' if index.zero? %>"
                  style="--chakra-glow: <%= area.fetch(:glow_color) %>"
                  role="tab"
                  aria-selected="<%= index.zero? %>"
                  tabindex="<%= index.zero? ? 0 : -1 %>"
                >
                  <%= area.fetch(:verb) %>
                </button>
              <% end %>
            </div>

            <!-- Colonna Pannelli (e Accordion Mobile) -->
            <div class="relative w-full lg:min-h-[40rem] flex flex-col gap-3 lg:block">
              <% human_areas.each_with_index do |area, index| %>
                
                <!-- MOBILE BUTTON (Accordion Header) -->
                <button 
                  type="button"
                  data-chakra-tab="<%= area.fetch(:slug) %>" 
                  class="mobile-chakra-btn lg:hidden w-full flex items-center gap-4 text-left p-3 rounded-2xl border border-slate-200 bg-white shadow-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-300 transition-all <%= 'is-active border-indigo-200 ring-2 ring-indigo-50' if index.zero? %>"
                  aria-expanded="<%= index.zero? %>"
                >
                  <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-white font-bold bg-gradient-to-br <%= area[:button_classes] %>">
                    <span class="text-[11px] uppercase tracking-wider"><%= area[:verb][0..2] %></span>
                  </div>
                  <div class="flex-1">
                     <div class="text-[10px] font-bold uppercase tracking-wider <%= area[:accent_classes] %>"><%= area[:verb] %></div>
                     <div class="font-bold text-slate-900 leading-tight mt-0.5"><%= area[:title] %></div>
                  </div>
                  <div class="chevron flex-shrink-0 w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 text-[10px] transition-transform duration-300">▼</div>
                </button>
                
                <!-- PANNELLO DETTAGLIO -->
                <article
                  id="panel-<%= area.fetch(:slug) %>"
                  data-chakra-panel="<%= area.fetch(:slug) %>"
                  class="chakra-panel-wrapper rounded-[1.75rem] border p-6 shadow-sm md:p-8 <%= area.fetch(:panel_classes) %> <%= 'is-active hidden' unless index.zero? %> <%= 'is-active' if index.zero? %>"
                  role="tabpanel"
                >
                  <span class="inline-flex rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.14em] <%= area.fetch(:badge_classes) %>">
                    <%= area.fetch(:verb) %>
                  </span>
                  <h3 class="mt-5 text-2xl font-semibold tracking-tight md:text-3xl <%= area.fetch(:title_classes) %>">
                    <%= area.fetch(:title) %>
                  </h3>
                  <p class="mt-4 text-base leading-7 <%= area.fetch(:copy_classes) %>">
                    <%= area.fetch(:description) %>
                  </p>
                  <p class="mt-5 text-sm font-semibold leading-6 <%= area.fetch(:accent_classes) %>">
                    <%= area.fetch(:topics) %>
                  </p>

                  <div class="mt-7 grid gap-3 sm:grid-cols-2">
                    <div class="rounded-2xl border border-white/70 bg-white/70 p-4 text-slate-900">
                      <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Espressione positiva</p>
                      <p class="mt-2 font-semibold"><%= area.fetch(:positive) %></p>
                    </div>
                    <div class="rounded-2xl border border-white/70 bg-white/70 p-4 text-slate-900">
                      <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Ciò che blocca</p>
                      <p class="mt-2 font-semibold"><%= area.fetch(:blockage) %></p>
                    </div>
                  </div>
                </article>
                
              <% end %>
            </div>

          </div>

          <div class="mt-12 text-center md:text-left">
            <a href="#iniziare" class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 transition hover:text-blue-800">
              Ultima tappa: Come iniziare <span aria-hidden="true">↓</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── TAPPA 5 · Come iniziare ─── -->
    <section id="iniziare" class="scroll-mt-24 bg-blue-950 px-5 text-white" aria-labelledby="iniziare-title" data-story-section>
      <div class="mx-auto max-w-6xl flex">
        <div class="relative w-[50px] md:w-[80px] flex-shrink-0 flex flex-col items-center">
          <div class="absolute top-0 h-[80px] md:h-[120px] w-[3px] bg-gradient-to-b from-indigo-800 to-transparent"></div>
          <div class="relative mt-16 md:mt-24 journey-step-marker journey-step-marker-dark bg-blue-400 text-blue-950">05</div>
        </div>
        <div class="flex-1 py-16 md:py-24 pl-5 md:pl-10">
          <header class="max-w-3xl">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-blue-300">Tappa 5 · Destinazione</p>
            <h2 id="iniziare-title" class="mt-3 text-3xl font-semibold tracking-tight md:text-5xl">
              Come vuoi iniziare?
            </h2>
            <p class="mt-5 text-base leading-7 text-blue-100 md:text-lg md:leading-8">
              Puoi conoscere il corpo attraverso l'Accademia, costruire un percorso personale
              oppure partecipare a eventi, contenuti e progetti di PosturaCorretta.
            </p>
          </header>

          <div class="mt-10 grid gap-4 lg:grid-cols-3">
            <article class="rounded-[1.75rem] border border-blue-700 bg-blue-900/70 p-6">
              <span class="inline-flex rounded-full bg-sky-400 px-3 py-1 text-xs font-bold uppercase tracking-wider text-sky-950">Informati</span>
              <h3 class="mt-5 text-2xl font-semibold">Conosci il corpo</h3>
              <p class="mt-3 text-sm leading-6 text-blue-100">Accademia, contenuti e metodiche per comprendere fisiologia, movimento e salute.</p>
            </article>
            <article class="rounded-[1.75rem] border border-emerald-600/60 bg-emerald-900/30 p-6">
              <span class="inline-flex rounded-full bg-emerald-400 px-3 py-1 text-xs font-bold uppercase tracking-wider text-emerald-950">Pratica</span>
              <h3 class="mt-5 text-2xl font-semibold">Costruisci il percorso</h3>
              <p class="mt-3 text-sm leading-6 text-blue-100">Parti dalla tua situazione, scegli gli step e trova l'accompagnamento più adatto.</p>
            </article>
            <article class="rounded-[1.75rem] border border-violet-600/60 bg-violet-900/30 p-6">
              <span class="inline-flex rounded-full bg-violet-300 px-3 py-1 text-xs font-bold uppercase tracking-wider text-violet-950">Insegna e partecipa</span>
              <h3 class="mt-5 text-2xl font-semibold">Entra nel progetto</h3>
              <p class="mt-3 text-sm leading-6 text-blue-100">Condividi competenze, porta i percorsi nel territorio oppure collabora alla loro crescita.</p>
            </article>
          </div>

          <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
            <% quick_links.each do |link| %>
              <a href="<%= link.fetch(:path) %>" class="group flex h-full flex-col rounded-2xl border border-white/15 bg-white p-5 text-slate-900 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-2xl">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-blue-700">
                  <%= link.fetch(:eyebrow) %>
                </p>
                <h3 class="mt-2 text-lg font-semibold leading-6 text-slate-950">
                  <%= link.fetch(:title) %>
                </h3>
                <p class="mt-3 text-sm leading-6 text-slate-600">
                  <%= link.fetch(:description) %>
                </p>
                <span class="mt-auto inline-flex items-center pt-5 text-sm font-semibold text-blue-700">
                  <%= link.fetch(:cta) %>
                  <span class="ml-1 transition group-hover:translate-x-1" aria-hidden="true">→</span>
                </span>
              </a>
            <% end %>
          </div>

          <div class="mt-12 border-t border-blue-800 pt-10">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-blue-300 md:text-center">A chi è rivolto</p>
            <div class="mt-6 grid gap-4 md:grid-cols-3">
              <% audiences.each do |audience| %>
                <article class="rounded-2xl border p-5 <%= audience.fetch(:classes) %>">
                  <span class="inline-flex rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider <%= audience.fetch(:badge_classes) %>">
                    <%= audience.fetch(:label) %>
                  </span>
                  <p class="mt-4 text-sm font-medium leading-6"><%= audience.fetch(:description) %></p>
                </article>
              <% end %>
            </div>
            <p class="mt-6 max-w-3xl text-sm leading-6 text-blue-200 md:mx-auto md:text-center">
              Ogni contenuto indica a chi è rivolto e quali competenze professionali sono necessarie per applicarlo.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%= render "posturacorretta/footer" %>

  <script>
    (() => {
      const root = document.currentScript.closest("[data-posturacorretta-home]");
      if (!root || root.dataset.posturacorrettaHomeReady === "true") return;
      root.dataset.posturacorrettaHomeReady = "true";

      // Chakra interattivi (Desktop Tabs & Mobile Accordion)
      const chakraContainer = root.querySelector("[data-chakra-container]");
      if (chakraContainer) {
        const tabs = Array.from(chakraContainer.querySelectorAll("[data-chakra-tab]"));
        const panels = Array.from(chakraContainer.querySelectorAll("[data-chakra-panel]"));

        function activateChakra(slug, focusDesktop = false) {
          // Update tabs
          tabs.forEach(tab => {
            const isMatch = tab.dataset.chakraTab === slug;
            tab.classList.toggle("is-active", isMatch);
            
            // Aria per desktop
            if (tab.classList.contains("chakra-circle")) {
              tab.setAttribute("aria-selected", isMatch);
              tab.tabIndex = isMatch ? 0 : -1;
            }
            // Aria per mobile
            if (tab.classList.contains("mobile-chakra-btn")) {
              tab.setAttribute("aria-expanded", isMatch);
            }
          });

          // Update panels
          panels.forEach(panel => {
            const isMatch = panel.dataset.chakraPanel === slug;
            if (isMatch) {
              panel.classList.remove("hidden"); // serve su mobile
              // setTimeout per dare tempo al browser di renderizzare prima di animare opacità se necessario
              setTimeout(() => panel.classList.add("is-active"), 10);
            } else {
              panel.classList.remove("is-active");
              panel.classList.add("hidden");
            }
          });
        }

        tabs.forEach(tab => {
          tab.addEventListener("click", () => {
            activateChakra(tab.dataset.chakraTab);
          });
          
          // Desktop keyboard navigation
          if (tab.classList.contains("chakra-circle")) {
            tab.addEventListener("keydown", (event) => {
              if (!["ArrowDown", "ArrowUp", "Home", "End"].includes(event.key)) return;
              event.preventDefault();
              
              const desktopTabs = tabs.filter(t => t.classList.contains("chakra-circle"));
              const index = desktopTabs.indexOf(tab);
              let nextIndex = index;
              
              if (event.key === "ArrowDown") nextIndex = (index + 1) % desktopTabs.length;
              if (event.key === "ArrowUp") nextIndex = (index - 1 + desktopTabs.length) % desktopTabs.length;
              if (event.key === "Home") nextIndex = 0;
              if (event.key === "End") nextIndex = desktopTabs.length - 1;
              
              const nextTab = desktopTabs[nextIndex];
              activateChakra(nextTab.dataset.chakraTab, true);
              nextTab.focus();
            });
          }
        });
      }

      // Evidenzia nell'indice la sezione che si sta leggendo
      const navLinks = Array.from(root.querySelectorAll("[data-story-link]"));
      const sections = Array.from(root.querySelectorAll("[data-story-section]"));

      function setActiveSection(id) {
        navLinks.forEach((link) => {
          const active = link.dataset.storyLink === id;
          const isCta = link.dataset.storyLink === "iniziare";
          link.setAttribute("aria-current", active ? "location" : "false");

          if (!isCta) {
            link.classList.toggle("bg-blue-50", active);
            link.classList.toggle("text-blue-800", active);
            link.classList.toggle("text-slate-600", !active);
          }
        });
      }

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver((entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (visible) setActiveSection(visible.target.id);
        }, { rootMargin: "-20% 0px -65% 0px", threshold: [0, 0.1, 0.25] });

        sections.forEach((section) => observer.observe(section));
      }
    })();
  </script>
</div>
