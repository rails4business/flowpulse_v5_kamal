        <!-- Contenuto -->
        <div class="flex-1 py-16 md:py-24 pl-5 md:pl-10">
          <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start lg:gap-16">
            <header>
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-blue-700">Tappa 1 · Il punto di partenza</p>
              <h2 id="postura-title" class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl">
                Cos'è la postura e perché partiamo da qui?
              </h2>
              <p class="mt-5 text-base leading-7 text-slate-600 md:text-lg md:leading-8">
                La postura non è soltanto il modo in cui stiamo seduti o in piedi.
                È il modo in cui il corpo si organizza, si muove e si adatta a ciò che viviamo.
              </p>
            </header>

            <div class="grid gap-4 sm:grid-cols-3">
              <article class="rounded-[1.5rem] border border-blue-100 bg-blue-50/70 p-5 md:p-6">
