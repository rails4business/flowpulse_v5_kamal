<div id="top" class="bg-white text-slate-900 antialiased" data-posturacorretta-home>

  <style>
    /* ── Journey Marker ── */
    .journey-step-marker {
      position: relative;
      z-index: 2;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-size: 16px;
      font-weight: 800;
      color: white;
      box-shadow: 0 0 0 5px white, 0 0 20px rgba(59,130,246,.2);
      transition: transform .3s, box-shadow .3s;
      flex-shrink: 0;
    }
    @media (min-width: 768px) {
      .journey-step-marker {
        width: 56px;
        height: 56px;
        font-size: 18px;
        box-shadow: 0 0 0 6px white, 0 0 28px rgba(59,130,246,.25);
      }
    }
    .journey-step-marker:hover {
      transform: scale(1.08);
    }
    
    /* ── Tappa 5 Dark Marker ── */
    .journey-step-marker-dark {
      box-shadow: 0 0 0 5px #172554, 0 0 20px rgba(96,165,250,.3);
    }
    @media (min-width: 768px) {
      .journey-step-marker-dark {
        box-shadow: 0 0 0 6px #172554, 0 0 28px rgba(96,165,250,.4);
      }
    }

    /* ── Chakra Desktop Spine ── */
    .chakra-spine::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 4px;
      background: linear-gradient(to bottom, #ef4444 0%, #f97316 14%, #f59e0b 28%, #10b981 42%, #0ea5e9 57%, #6366f1 71%, #8b5cf6 100%);
      transform: translateX(-50%);
      border-radius: 99px;
      opacity: .6;
    }

    .chakra-circle {
      position: relative;
      z-index: 2;
      width: 88px;
      height: 88px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-size: 15px;
      font-weight: 800;
      cursor: pointer;
      transition: transform .35s cubic-bezier(.34,1.56,.64,1), box-shadow .35s;
      flex-shrink: 0;
    }
    @media (min-width: 768px) {
      .chakra-circle { width: 100px; height: 100px; font-size: 16px; }
    }
    .chakra-circle:hover { transform: scale(1.12); }
    .chakra-circle.is-active {
      transform: scale(1.15);
      animation: chakra-pulse 2.5s ease-in-out infinite;
    }
    @keyframes chakra-pulse {
      0%, 100% { box-shadow: 0 0 0 5px white, 0 0 0 8px var(--chakra-glow), 0 0 24px var(--chakra-glow); }
      50%  { box-shadow: 0 0 0 5px white, 0 0 0 12px var(--chakra-glow), 0 0 40px var(--chakra-glow); }
    }
    
    /* ── Mobile Chakra Buttons ── */
    .mobile-chakra-btn.is-active .chevron { transform: rotate(180deg); }
    .mobile-chakra-btn.is-active { background-color: rgba(255, 255, 255, 0.7); }

    /* ── Chakra Panels (Desktop absolute vs Mobile flow) ── */
    .chakra-panel-wrapper.is-active {
      display: block !important;
    }
    @media (min-width: 1024px) {
      .chakra-panel-wrapper {
        position: absolute !important;
        inset: 0;
        display: block !important;
        opacity: 0;
        pointer-events: none;
        transform: translateY(12px);
        transition: opacity 0.4s ease, transform 0.4s ease;
      }
      .chakra-panel-wrapper.is-active {
        opacity: 1 !important;
        pointer-events: auto !important;
        transform: translateY(0) !important;
        z-index: 10;
      }
    }
  </style>

  <!-- Hero -->
  <section class="bg-gradient-to-b from-blue-50 via-white to-white px-5 pb-12 pt-14 md:pb-16 md:pt-20" aria-labelledby="home-title">
    <div class="mx-auto max-w-5xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">
        PosturaCorretta
      </p>

      <h1 id="home-title" class="mx-auto mt-4 max-w-4xl text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl md:leading-[1.03]">
        Trova la giusta posizione da cui osservare il mondo.
        <span class="mt-2 block text-blue-700">Inizia dalla salute.</span>
      </h1>

      <p class="mx-auto mt-6 max-w-3xl text-base leading-7 text-slate-600 md:text-lg md:leading-8">
        Partiamo dal corpo e dalle metodiche posturali per comprendere movimento,
        fisiologia e adattamenti. Da qui allarghiamo progressivamente lo sguardo
        alle attività, alle abitudini e all'ambiente in cui viviamo.
      </p>

      <!-- Mini-mappa del percorso -->
