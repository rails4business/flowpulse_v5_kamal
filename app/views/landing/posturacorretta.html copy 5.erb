          data-story-link="<%= item.fetch(:id) %>"
        >
          <span class="mr-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-slate-100 text-[10px] font-extrabold text-slate-500 <%= 'bg-white/20 text-white/90' if item[:cta] %>"><%= format('%02d', i + 1) %></span>
          <%= item.fetch(:label) %><%= " →" if item[:cta] %>
        </a>
      <% end %>
    </div>
  </nav>

  <main>
