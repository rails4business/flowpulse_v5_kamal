        <div class="flex items-center justify-center gap-0">
          <% journey_steps.each_with_index do |step, i| %>
            <a href="#<%= step[:id] %>"
               class="group relative flex flex-col items-center text-center focus:outline-none focus-visible:ring-4 focus-visible:ring-blue-200 rounded-xl px-1 py-2 transition hover:-translate-y-0.5"
               aria-label="Vai a <%= step[:label] %>"
            >
              <span class="flex h-10 w-10 items-center justify-center rounded-full text-xs font-extrabold text-white shadow-md transition group-hover:scale-110
                <%= i < 3 ? 'bg-blue-600' : (i == 3 ? 'bg-indigo-600' : 'bg-blue-950') %>
              ">
                <%= step[:number] %>
              </span>
              <span class="mt-2 text-[10px] font-semibold leading-tight text-slate-500 sm:text-xs"><%= step[:label] %></span>
            </a>
            <% unless i == journey_steps.length - 1 %>
              <span class="mx-1 hidden h-[2px] w-6 flex-shrink-0 rounded-full bg-gradient-to-r from-blue-200 to-blue-400 sm:block" aria-hidden="true"></span>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="#postura" class="inline-flex items-center justify-center rounded-full bg-blue-700 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-800 focus:outline-none focus-visible:ring-4 focus-visible:ring-blue-200">
          Inizia il percorso
          <span class="ml-2" aria-hidden="true">↓</span>
        </a>
        <a href="#iniziare" class="inline-flex items-center justify-center rounded-full border border-blue-200 bg-white px-6 py-3 text-sm font-semibold text-blue-800 shadow-sm transition hover:border-blue-300 hover:bg-blue-50 focus:outline-none focus-visible:ring-4 focus-visible:ring-blue-100">
          Vai all'ultima tappa
          <span class="ml-2" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Indice sticky -->
  <nav class="sticky top-0 z-40 border-y border-slate-200 bg-white/95 shadow-sm backdrop-blur" aria-label="Indice della pagina" data-story-nav>
    <div class="mx-auto flex max-w-6xl gap-1 overflow-x-auto px-4 py-2 sm:justify-center">
      <% story_nav.each_with_index do |item, i| %>
