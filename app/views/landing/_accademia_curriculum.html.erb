        <button onclick="switchCurriculumTab('dolore')" id="tab-btn-dolore" class="shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 text-slate-650 hover:text-slate-955">
          Stop al dolore
        </button>
        <button onclick="switchCurriculumTab('prevenzione')" id="tab-btn-prevenzione" class="shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 text-slate-650 hover:text-slate-955">
          Prevenzione
        </button>
        <button onclick="switchCurriculumTab('performance')" id="tab-btn-performance" class="shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 text-slate-650 hover:text-slate-955">
          Performance
        </button>
        <button onclick="switchCurriculumTab('fisiologia')" id="tab-btn-fisiologia" class="shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50">
          Postura e Fisiologia
        </button>
        <button onclick="switchCurriculumTab('benessere')" id="tab-btn-benessere" class="shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 text-slate-650 hover:text-slate-955">
          Benessere Integrato
        </button>
        <button onclick="switchCurriculumTab('giardino')" id="tab-btn-giardino" class="shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 text-slate-650 hover:text-violet-750 flex items-center gap-1.5">
          <span id="giardino-lock-icon">🔒</span>
          <span>Il Giardino del Corpo</span>
        </button>
      </div>
    </div>

    <!-- TAB 1: Stop al Dolore (Hidden by default) -->
    <div id="sec-dolore" class="space-y-8 hidden">
      <div class="bg-blue-50/80 border border-blue-100/70 rounded-3xl p-8 text-center max-w-2xl mx-auto shadow-2xs">
        <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-100 text-blue-700 text-xl font-bold mb-4">
          🩹
        </span>
        <h3 class="text-xl font-bold text-slate-900">Stop al dolore</h3>
        <p class="text-slate-655 mt-3 text-sm leading-relaxed max-w-lg mx-auto">
          Un percorso mirato per chi soffre di tensioni muscolari, rigidità articolare o dolori cronici. Impara le metodiche posturali per decongestionare le zone di sofferenza del corpo, rilasciare le catene in tensione e ristabilire un allineamento fisiologico indolore.
        </p>
      </div>
      <!-- Curated lessons for this path -->
      <div class="max-w-2xl mx-auto mt-8">
        <h4 class="text-sm font-bold text-slate-800 mb-4 px-3 uppercase tracking-wider">Lezioni Chiave Suggerite:</h4>
        <div class="flex flex-col gap-3 pl-4 border-l-2 border-blue-300">
          <% lesson_row.call("04", "Postura e Fisiologia: Massaggio, Presenza & Autotrattamento", "metodiche-posturali-e-fisiologia", "blue", "Presa di coscienza corporea e autotrattamento.") %>
          <% lesson_row.call("06", "Punti di tensione", "igiene-posturale", "blue", "Identificare e rilasciare i punti critici di tensione del corpo.") %>
          <% lesson_row.call("11", "Sistema muscolo-scheletrico", "insegnamenti-fisioterapia", "blue", "Studio fisioterapico delle catene muscolari e scheletriche.") %>
          <% lesson_row.call("20", "Eliminare le disfunzioni", "osteopatia-ascolto-del-corpo", "blue", "I principi osteopatici per liberare le articolazioni bloccate.") %>
        </div>
      </div>
    </div>

    <!-- TAB 2: Prevenzione (Hidden by default) -->
    <div id="sec-prevenzione" class="space-y-8 hidden">
      <div class="bg-emerald-50/80 border border-emerald-100/70 rounded-3xl p-8 text-center max-w-2xl mx-auto shadow-2xs">
        <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-emerald-100 text-emerald-700 text-xl font-bold mb-4">
          🛡️
        </span>
        <h3 class="text-xl font-bold text-slate-900">Prevenzione</h3>
        <p class="text-slate-655 mt-3 text-sm leading-relaxed max-w-lg mx-auto">
          Prenditi cura della tua salute prima che insorgano problemi. Questo percorso ti insegna le corrette abitudini quotidiane, la mobilità articolare preventiva e l'ascolto fine dei segnali del corpo per mantenere vitalità e benessere nel lungo termine.
        </p>
      </div>
      <!-- Curated lessons for this path -->
      <div class="max-w-2xl mx-auto mt-8">
        <h4 class="text-sm font-bold text-slate-800 mb-4 px-3 uppercase tracking-wider">Lezioni Chiave Suggerite:</h4>
        <div class="flex flex-col gap-3 pl-4 border-l-2 border-emerald-300">
          <% lesson_row.call("05", "Mobilità articolare", "igiene-posturale", "emerald", "Mantenere le articolazioni mobili ed elastiche nel tempo.") %>
          <% lesson_row.call("09", "Sistema respiratorio", "insegnamenti-fisioterapia", "emerald", "La respirazione fisiologica come pilastro della prevenzione.") %>
          <% lesson_row.call("21", "Il sistema fasciale", "osteopatia-ascolto-del-corpo", "emerald", "Nutrire e preservare la salute dei tessuti connettivi fasciali.") %>
          <% lesson_row.call("25", "Le 2 circolazioni", "corpo-e-coscienza", "emerald", "Equilibrare i ritmi circolatori per ottimizzare il metabolismo organico.") %>
        </div>
      </div>
    </div>

    <!-- TAB 3: Performance (Hidden by default) -->
    <div id="sec-performance" class="space-y-8 hidden">
      <div class="bg-amber-50/80 border border-amber-100/70 rounded-3xl p-8 text-center max-w-2xl mx-auto shadow-2xs">
