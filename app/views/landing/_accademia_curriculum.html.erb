<%# app/views/landing/_accademia_curriculum.html.erb %>
<%# Richiamo nel template: render "landing/accademia_curriculum" %>
<%
  academy_modules = @academy_modules || []
  academy_path = @academy_path || {}
  academy_areas = @academy_areas || []
  academy_teachers = @academy_teachers || {}
  academy_locations = @academy_locations || {}
  academy_summary = (@academy_curriculum || {}).fetch("summary", {})
  academy_lesson_count = academy_modules.sum { |academy_module| academy_module.fetch("lessons").size }
  active_area_slug = academy_areas.first&.fetch("slug", nil)
%>



<section id="academy-curriculum" aria-labelledby="academy-curriculum-title">
  <section class="hero" id="top">
    <div class="hero-inner">
      <div>
        <p class="eyebrow">Postura e fisiologia</p>
    <h1 id="academy-curriculum-title">
  Conosci il tuo corpo e <br> riattiva i tuoi sistemi fisiologici. 
</h1>

<p class="hero-copy">
  Scopri le basi delle principali metodiche utilizzate in ambito terapeutico,
  comprendine possibilità e limiti e scegli con maggiore consapevolezza il tuo
  percorso di salute.
</p>
        <div class="hero-actions">
          <button class="button primary" onclick="showAcademyMethod()" type="button">Come funziona l'accademia? 📖</button>
        </div>
      </div>
      <div class="summary" aria-label="Riepilogo del corso">
        <div><strong><%= academy_summary.fetch("participants", academy_modules.sum { |academy_module| academy_module.fetch("participants").to_i }) %></strong><span>Partecipanti</span></div>
        <div><strong><%= academy_summary.fetch("teachers", academy_teachers.size) %></strong><span>Insegnanti</span></div>
        <div><strong><%= academy_summary.fetch("centers", academy_locations.size) %></strong><span>Centri</span></div>
      </div>
    </div>
  </section>

  <main class="workspace" data-initial-area="<%= active_area_slug %>">
    <div class="toolbar">
      <% if academy_areas.first %>
        <% active_area = academy_areas.first %>
        <span class="area-badge">
          <span><%= active_area.fetch("title") %></span>
          <span class="area-count"><%= active_area.fetch("modules").size %> moduli</span>
        </span>
      <% end %>
      <label class="search"><span class="sr-only">Cerca modulo o lezione</span><input id="search" type="search" placeholder="Cerca un modulo o una lezione…"></label>
    </div>

    <div class="content-grid">
      <nav class="side" aria-label="Indice dei moduli">
        <p class="side-label">Indice del percorso</p>
        <% academy_modules.each_with_index do |academy_module, index| %>
          <a class="<%= "active" if index.zero? %>" href="#m<%= index %>" data-module-target="m<%= index %>">
            <span class="side-num"><%= academy_module.fetch("number") %></span>
            <span><%= academy_module.fetch("title") %></span>
            <span class="side-count"><%= academy_module.fetch("lessons").size %></span>
          </a>
        <% end %>
      </nav>

      <section>
        <div class="section-head" style="display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;">
          <div>
            <h2>Il programma</h2>
            <p>Apri un modulo per vedere lezioni, partecipanti, insegnanti e centri.</p>
          </div>
          <div class="legend" style="display: flex; align-items: center; gap: 8px;">
            <button class="button-utility" id="academyOpenAll" type="button" style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border: 1px solid #cbd5e1; border-radius: 8px; background: white; color: #475569; font-size: 11px; font-weight: 700; cursor: pointer; transition: all 0.15s ease;" onmouseover="this.style.borderColor='#94a3b8';this.style.background='#f8fafc';" onmouseout="this.style.borderColor='#cbd5e1';this.style.background='white';">
              📂 <span>Apri tutti i moduli</span>
            </button>
            <button class="button-utility" type="button" data-modal-template="academy-roster" style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border: 1px solid #cbd5e1; border-radius: 8px; background: white; color: #475569; font-size: 11px; font-weight: 700; cursor: pointer; transition: all 0.15s ease;" onmouseover="this.style.borderColor='#94a3b8';this.style.background='#f8fafc';" onmouseout="this.style.borderColor='#cbd5e1';this.style.background='white';">
              👥 <span>Tutti gli insegnanti</span>
            </button>
          </div>
        </div>
        <div class="module-list" id="moduleList">
          <%= render partial: "landing/academy/module",
                     collection: academy_modules,
                     as: :academy_module,
                     locals: { academy_teachers: academy_teachers, academy_locations: academy_locations } %>
        </div>
        <div class="empty" id="empty">Nessun modulo corrisponde alla ricerca.</div>
      </section>
    </div>
  </main>

  <div class="modal" id="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <div class="modal-card">
      <div class="modal-head"><h3 id="modalTitle">Insegnante</h3><button class="close" id="closeModal" aria-label="Chiudi">✕</button></div>
      <div class="modal-content" id="modalContent"></div>
    </div>
  </div>
  <template id="academy-roster" data-modal-title="Insegnanti dell'Accademia">
    <div class="roster-list" style="display: grid; gap: 16px;">
      <%
        module_titles = academy_modules.each_with_object({}) { |mod, h| h[mod.fetch("slug")] = mod.fetch("title") }
      %>
      <% academy_teachers.each_value do |teacher| %>
        <%= render "landing/academy/teacher_info", teacher: teacher, module_titles: module_titles %>
      <% end %>
    </div>
  </template>

  <% academy_teachers.each_value do |teacher| %>
    <%
      module_titles = academy_modules.each_with_object({}) { |mod, h| h[mod.fetch("slug")] = mod.fetch("title") }
    %>
    <template id="teacher-<%= teacher.fetch("slug") %>" data-modal-title="Insegnante">
      <%= render "landing/academy/teacher_info", teacher: teacher, module_titles: module_titles %>
      <div class="profile-meta" style="margin-top: 12px;">
        <span class="mode teach">Insegnante</span>
        <span class="mode">Dal <%= teacher.fetch("date") %></span>
        <span class="mode">Profilo verificato</span>
      </div>
    </template>
  <% end %>

  <% academy_locations.each_value do |location| %>
    <template id="location-<%= location.fetch("slug") %>" data-modal-title="<%= location.fetch("name") %>">
      <div class="profile">
        <span class="location-pin" style="width:72px;height:72px;font-size:25px">⌖</span>
        <div>
          <h4><%= location.fetch("name") %></h4>
          <p><%= location.fetch("city") %></p>
          <span class="mode practice"><%= location.fetch("type") %></span>
        </div>
      </div>
      <div class="profile-meta">
        <span class="mode">Modulo disponibile</span>
        <span class="mode info">Vedi calendario</span>
        <span class="mode">Contatta il centro</span>
      </div>
    </template>
  <% end %>

  <script>
  (() => {
    const root = document.getElementById('academy-curriculum');
    if (!root || root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';
    const moduleList = root.querySelector('#moduleList');
    const sideLinks = Array.from(root.querySelectorAll('.side a[data-module-target]'));

    let currentFilter = 'all';
    let currentArea = root.querySelector('.workspace')?.dataset.initialArea || 'all';
    const search = root.querySelector('#search');
    function setActiveModule(moduleId) {
      sideLinks.forEach(link => {
        link.classList.toggle('active', link.dataset.moduleTarget === moduleId);
      });
    }
    function applyFilters() {
      const q = search.value.trim().toLowerCase();
      let visible = 0;
      root.querySelectorAll('.module').forEach(el => {
        const matchesText = !q || el.dataset.search.includes(q);
        const matchesMode = currentFilter === 'all' || el.dataset.modes.split(' ').includes(currentFilter);
        const matchesArea = currentArea === 'all' || el.dataset.area === currentArea;
        el.hidden = !(matchesText && matchesMode && matchesArea);
        if (!el.hidden) visible++;
      });
      sideLinks.forEach(link => {
        const linkedModule = document.getElementById(link.dataset.moduleTarget);
        link.hidden = !linkedModule || linkedModule.hidden;
      });
      const activeLink = sideLinks.find(link => link.classList.contains('active'));
      const activeModule = activeLink ? document.getElementById(activeLink.dataset.moduleTarget) : null;
      if (!activeModule || activeModule.hidden) {
        const firstVisibleModule = root.querySelector('.module:not([hidden])');
        if (firstVisibleModule) setActiveModule(firstVisibleModule.id);
      }
      root.querySelector('#empty').style.display = visible ? 'none' : 'block';
    }
    search.addEventListener('input', applyFilters);
    root.querySelectorAll('.filter-tab').forEach(btn => btn.addEventListener('click', () => {
      root.querySelectorAll('.filter-tab').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active'); currentFilter = btn.dataset.filter; applyFilters();
    }));
    applyFilters();
    moduleList.addEventListener('click', e => {
      const top = e.target.closest('.module-top');
      const link = e.target.closest('a[href]');
      const tabBtn = e.target.closest('[data-module-tab]');
      const modalBtn = e.target.closest('[data-modal-template]');
      const lessonBtn = e.target.closest('[data-lesson-template]');
      if (modalBtn) { e.stopPropagation(); openTemplate(modalBtn.dataset.modalTemplate); return; }
      if (link) return;
      if (lessonBtn) { e.stopPropagation(); openTemplate(lessonBtn.dataset.lessonTemplate); return; }
      if (tabBtn) {
        e.stopPropagation();
        const card = tabBtn.closest('.module');
        card.querySelectorAll('.module-tab').forEach(btn => { btn.classList.toggle('active', btn === tabBtn); btn.setAttribute('aria-selected', btn === tabBtn); });
        card.querySelectorAll('.tab-panel').forEach(panel => panel.classList.toggle('active', panel.dataset.panel === tabBtn.dataset.moduleTab));
        return;
      }
      if (top) {
        const card = top.closest('.module');
        card.classList.toggle('open');
        top.querySelector('.chevron').setAttribute('aria-expanded', card.classList.contains('open'));
        setActiveModule(card.id);
      }
    });
    sideLinks.forEach(link => {
      link.addEventListener('click', () => {
        const card = document.getElementById(link.dataset.moduleTarget);
        if (!card) return;
        card.classList.add('open');
        card.querySelector('.chevron')?.setAttribute('aria-expanded', 'true');
        setActiveModule(card.id);
      });
    });

    function handleHashChange() {
      const hash = window.location.hash;
      if (!hash) return;
      const moduleId = hash.substring(1);
      const card = document.getElementById(moduleId);
      if (!card || !card.classList.contains('module')) return;
      card.classList.add('open');
      const chevron = card.querySelector('.chevron');
      if (chevron) chevron.setAttribute('aria-expanded', 'true');
      setActiveModule(moduleId);
    }
    window.addEventListener('hashchange', handleHashChange);
    handleHashChange();

    document.addEventListener("turbo:before-cache", () => {
      const r = document.getElementById('academy-curriculum');
      if (r) delete r.dataset.initialized;
    }, { once: true });
    root.querySelector('#academyOpenAll').addEventListener('click', e => {
      const opening = ![...root.querySelectorAll('.module:not([hidden])')].every(x=>x.classList.contains('open'));
      root.querySelectorAll('.module:not([hidden])').forEach(x=>{ x.classList.toggle('open', opening); x.querySelector('.chevron').setAttribute('aria-expanded', opening); });
      const label = opening ? 'Chiudi tutti i moduli' : 'Apri tutti i moduli';
      e.currentTarget.innerHTML = `📂 <span>${label}</span>`;
    });

    const modal = root.querySelector('#modal');
    const modalTitle = root.querySelector('#modalTitle');
    const modalContent = root.querySelector('#modalContent');
    function openModal(){ modal.classList.add('open'); document.body.style.overflow='hidden'; }
    function closeModal(){ modal.classList.remove('open'); document.body.style.overflow=''; }
    function openTemplate(templateId) {
      const template = document.getElementById(templateId);
      if (!template) return;
      modalTitle.textContent = template.dataset.modalTitle || template.content.querySelector('h1, h2, h3, h4')?.textContent || 'Dettaglio';
      modalContent.innerHTML = '';
      modalContent.appendChild(template.content.cloneNode(true));
      openModal();
    }
    root.addEventListener('click', e => {
      const modalBtn = e.target.closest('[data-modal-template]');
      if (!modalBtn || moduleList.contains(modalBtn)) return;
      e.preventDefault();
      openTemplate(modalBtn.dataset.modalTemplate);
    });
    window.showAcademyMethod = function() {
      modalTitle.textContent = "Come funziona l'accademia";
      modalContent.innerHTML = `
       <div
  class="academy-modal-method"
  style="
    font-family: Inter, sans-serif;
    line-height: 1.6;
    color: #475569;
  "
>
  <!-- INTRODUZIONE -->
  <div style="margin-bottom: 22px;">
    <span
      style="
        display: block;
        margin-bottom: 6px;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #2563eb;
      "
    >
      Diffondiamo la conoscenza delle metodiche posturali
    </span>

    <h3
      style="
        margin: 0 0 10px;
        font-size: 19px;
        line-height: 1.3;
        font-weight: 800;
        color: #1e293b;
      "
    >
      Una mappa per conoscere il corpo e orientarsi tra le metodiche
    </h3>

     <p style="margin: 0 0 10px; font-size: 13px;">
      L’Accademia propone un percorso generale, accessibile anche
      a chi parte da zero. Presenta le basi  delle principali metodiche posturali usate in ambito terapeutico, 
      con l'obiettivo di aiutare le persone a conoscere il proprio corpo, comprenderne possibilità e limiti e scegliere con maggiore consapevolezza il proprio percorso di salute.
    </p>

    <p style="margin: 0; font-size: 13px;">
      Gli insegnanti posturacorretta hanno appreso i principi base delle metodiche presenti nei moduli e 
      accompagnano lepersone con semplici esercizi che hanno il compito di riattivare i sistemi fisiologici e di far comprendere le differenze tra le metodiche.
      far conoscere come funziona il corpo e come le metodiche osservano e intervengono sui diversi sistemi fisiologici.
      Le persone in questo modo possono comprendere le differenze tra le metodiche e scegliere con maggiore consapevolezza cosa inserire nel proprio percorso di salute.
    </p>

  </div>

  <!-- I QUATTRO ELEMENTI -->
  <div
    style="
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
    "
  >
    <!-- PERSONA -->
    <div
      style="
        padding: 16px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
      "
    >
      <span
        style="
          display: block;
          margin-bottom: 5px;
          font-size: 10px;
          font-weight: 800;
          text-transform: uppercase;
          letter-spacing: 0.06em;
          color: #64748b;
        "
      >
        Per chi parte da zero
      </span>

      <h4
        style="
          margin: 0 0 7px;
          font-size: 14px;
          line-height: 1.35;
          color: #1e293b;
        "
      >
        La persona conosce e si orienta
      </h4>

      <p style="margin: 0; font-size: 12px;">
        Impara ad ascoltare il corpo, conosce i principi delle diverse
        metodiche e comprende quale approccio potrebbe essere più adatto
        nei diversi momenti del proprio percorso.
      </p>
    </div>

    <!-- METODICA -->
    <div
      style="
        padding: 16px;
        background: #faf5ff;
        border: 1px solid #e9d5ff;
        border-radius: 14px;
      "
    >
      <span
        style="
          display: block;
          margin-bottom: 5px;
          font-size: 10px;
          font-weight: 800;
          text-transform: uppercase;
          letter-spacing: 0.06em;
          color: #7c3aed;
        "
      >
        Metodiche e scuole
      </span>

      <h4
        style="
          margin: 0 0 7px;
          font-size: 14px;
          line-height: 1.35;
          color: #581c87;
        "
      >
        La metodica fa conoscere la propria visione
      </h4>

      <p style="margin: 0; font-size: 12px; color: #6b21a8;">
        Molte metodiche sono conosciute soprattutto dagli addetti ai lavori
        e arrivano alle persone soltanto come terapia. Nell’Accademia possono
        presentare i propri principi e far conoscere il loro modo di osservare
        il corpo.
      </p>
    </div>

    <!-- INSEGNANTE -->
    <div
      style="
        padding: 16px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 14px;
      "
    >
      <span
        style="
          display: block;
          margin-bottom: 5px;
          font-size: 10px;
          font-weight: 800;
          text-transform: uppercase;
          letter-spacing: 0.06em;
          color: #2563eb;
        "
      >
        Insegnanti PosturaCorretta
      </span>

      <h4
        style="
          margin: 0 0 7px;
          font-size: 14px;
          line-height: 1.35;
          color: #1e3a8a;
        "
      >
        L’insegnante presenta le basi
      </h4>

      <p style="margin: 0; font-size: 12px; color: #1e40af;">
        È formato dall’Accademia per accompagnare le persone, collegare i
        diversi principi e trasformare le informazioni in pratica. Non
        sostituisce lo specialista della singola metodica.
      </p>
    </div>

    <!-- PROFESSIONISTA -->
    <div
      style="
        padding: 16px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 14px;
      "
    >
      <span
        style="
          display: block;
          margin-bottom: 5px;
          font-size: 10px;
          font-weight: 800;
          text-transform: uppercase;
          letter-spacing: 0.06em;
          color: #059669;
        "
      >
        Professionisti delle metodiche
      </span>

      <h4
        style="
          margin: 0 0 7px;
          font-size: 14px;
          line-height: 1.35;
          color: #065f46;
        "
      >
        Il professionista approfondisce e interviene
      </h4>

      <p style="margin: 0; font-size: 12px; color: #047857;">
        È formato dalle scuole della propria metodica e ne approfondisce
        strumenti e applicazioni. Rappresenta il riferimento per valutazioni,
        trattamenti e interventi specifici, nell’ambito delle proprie
        competenze professionali.
      </p>
    </div>
  </div>

  <!-- COLLEGAMENTO -->
  <div
    style="
      margin-top: 16px;
      padding: 16px;
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 14px;
      text-align: center;
    "
  >
    <p
      style="
        margin: 0 0 8px;
        font-size: 12px;
        font-weight: 800;
        color: #1e293b;
      "
    >
      Conosci le basi
      <span style="padding: 0 5px; color: #94a3b8;">→</span>
      prova e comprendi
      <span style="padding: 0 5px; color: #94a3b8;">→</span>
      scegli come approfondire
    </p>

    <p
      style="
        max-width: 650px;
        margin: 0 auto;
        font-size: 12px;
        color: #64748b;
      "
    >
      PosturaCorretta crea un ponte: avvicina le persone alle metodiche,
      ne presenta i principi fondamentali e le mette in contatto con i
      professionisti formati dalle rispettive scuole.
    </p>
  </div>
</div>
      `;
      openModal();
    }
    root.querySelectorAll('[data-modal-template]').forEach(btn => {
      if (btn.closest('#moduleList')) return;
      btn.addEventListener('click', () => openTemplate(btn.dataset.modalTemplate));
    });
    root.querySelector('#closeModal').addEventListener('click', closeModal);
    modal.addEventListener('click', e=>{ if(e.target===modal) closeModal(); });
    document.addEventListener('keydown', e=>{ if(e.key==='Escape') closeModal(); });
  })();
  </script>
</section>
