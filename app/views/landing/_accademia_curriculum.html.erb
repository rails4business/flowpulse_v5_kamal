<script>
  function switchCurriculumTab(tab) {
    const doloreBtn = document.getElementById('tab-btn-dolore');
    const prevenzioneBtn = document.getElementById('tab-btn-prevenzione');
    const performanceBtn = document.getElementById('tab-btn-performance');
    const fisiologiaBtn = document.getElementById('tab-btn-fisiologia');
    const benessereBtn = document.getElementById('tab-btn-benessere');
    const giardinoBtn = document.getElementById('tab-btn-giardino');
    
    const doloreSec = document.getElementById('sec-dolore');
    const prevenzioneSec = document.getElementById('sec-prevenzione');
    const performanceSec = document.getElementById('sec-performance');
    const fisiologiaSec = document.getElementById('sec-fisiologia');
    const benessereSec = document.getElementById('sec-benessere');
    const giardinoSec = document.getElementById('sec-giardino');
    
    // Reset buttons to inactive style
    resetTabBtnClass(doloreBtn);
    resetTabBtnClass(prevenzioneBtn);
    resetTabBtnClass(performanceBtn);
    resetTabBtnClass(fisiologiaBtn);
    resetTabBtnClass(benessereBtn);
    resetTabBtnClass(giardinoBtn);
    
    // Hide all sections
    doloreSec.classList.add('hidden');
    prevenzioneSec.classList.add('hidden');
    performanceSec.classList.add('hidden');
    fisiologiaSec.classList.add('hidden');
    benessereSec.classList.add('hidden');
    giardinoSec.classList.add('hidden');
    
    // Activate clicked tab
    if (tab === 'dolore') {
      doloreBtn.className = "shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50";
      doloreSec.classList.remove('hidden');
    } else if (tab === 'prevenzione') {
      prevenzioneBtn.className = "shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50";
      prevenzioneSec.classList.remove('hidden');
    } else if (tab === 'performance') {
      performanceBtn.className = "shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50";
      performanceSec.classList.remove('hidden');
    } else if (tab === 'fisiologia') {
      fisiologiaBtn.className = "shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50";
      fisiologiaSec.classList.remove('hidden');
    } else if (tab === 'benessere') {
      benessereBtn.className = "shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 bg-white text-slate-900 shadow-xs border border-slate-200/50";
      benessereSec.classList.remove('hidden');
    } else if (tab === 'giardino') {
      const isLocked = document.getElementById('giardino-lock-icon') !== null;
      if (isLocked) {
        giardinoBtn.className = "shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 bg-slate-100 text-slate-500 shadow-xs border border-slate-200/50";
      } else {
        giardinoBtn.className = "shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 bg-white text-violet-955 shadow-xs border border-violet-250/50";
      }
      giardinoSec.classList.remove('hidden');
    }
  }

  function resetTabBtnClass(btn) {
    const isLockedGiardino = btn.id === 'tab-btn-giardino' && document.getElementById('giardino-lock-icon') !== null;
    if (isLockedGiardino) {
      btn.className = "shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 text-slate-400 bg-slate-100/50 flex items-center gap-1.5";
    } else if (btn.id === 'tab-btn-giardino') {
      btn.className = "shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 text-slate-600 hover:text-slate-955";
    } else {
      btn.className = "shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 text-slate-600 hover:text-slate-955";
    }
  }

  function unlockGiardino() {
    const lockIcon = document.getElementById('giardino-lock-icon');
    const lockScreen = document.getElementById('giardino-lock-screen');
    const unlockedContent = document.getElementById('giardino-unlocked-content');
    const giardinoBtn = document.getElementById('tab-btn-giardino');
    
    // 1. Remove the lock icon from tab switcher button
    if (lockIcon) {
      lockIcon.remove();
    }
    
    // 2. Hide lock screen and reveal unlocked content
    if (lockScreen && unlockedContent) {
      lockScreen.classList.add('hidden');
      unlockedContent.classList.remove('hidden');
    }
    
    // 3. Update tab button appearance
    giardinoBtn.className = "shrink-0 px-4 py-2.5 rounded-xl text-xs font-bold transition duration-200 bg-white text-violet-955 shadow-xs border border-violet-250/50";
    
    // Switch to tab
    switchCurriculumTab('giardino');
  }
</script>
