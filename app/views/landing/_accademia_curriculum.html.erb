<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }
  .no-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>

<%
lesson_row = ->(number, title, slug, theme_color, description = nil) do
  theme_classes = {
    "sky" => { bg: "bg-sky-100/70", text: "text-sky-850", hover: "hover:bg-sky-50/50", hover_text: "group-hover:text-sky-600" },
    "indigo" => { bg: "bg-indigo-100/70", text: "text-indigo-850", hover: "hover:bg-indigo-50/50", hover_text: "group-hover:text-indigo-600" },
    "blue" => { bg: "bg-blue-100/70", text: "text-blue-850", hover: "hover:bg-blue-50/50", hover_text: "group-hover:text-blue-600" },
    "violet" => { bg: "bg-violet-100/70", text: "text-violet-855", hover: "hover:bg-violet-50/50", hover_text: "group-hover:text-violet-600" },
    "emerald" => { bg: "bg-emerald-100/70", text: "text-emerald-850", hover: "hover:bg-emerald-50/50", hover_text: "group-hover:text-emerald-600" },
    "rose" => { bg: "bg-rose-100/70", text: "text-rose-850", hover: "hover:bg-rose-50/50", hover_text: "group-hover:text-rose-600" },
    "amber" => { bg: "bg-amber-100/70", text: "text-amber-850", hover: "hover:bg-amber-50/50", hover_text: "group-hover:text-amber-600" },
    "fuchsia" => { bg: "bg-fuchsia-100/70", text: "text-fuchsia-850", hover: "hover:bg-fuchsia-50/50", hover_text: "group-hover:text-fuchsia-600" },
    "green" => { bg: "bg-green-100/70", text: "text-green-850", hover: "hover:bg-green-50/50", hover_text: "group-hover:text-green-600" },
    "red" => { bg: "bg-red-100/70", text: "text-red-850", hover: "hover:bg-red-50/50", hover_text: "group-hover:text-red-600" },
    "orange" => { bg: "bg-orange-100/70", text: "text-orange-850", hover: "hover:bg-orange-50/50", hover_text: "group-hover:text-orange-600" }
  }[theme_color] || { bg: "bg-slate-100", text: "text-slate-855", hover: "hover:bg-slate-50/50", hover_text: "group-hover:text-slate-600" }
%>
  <a class="group text-black block py-2.5 px-3 <%= theme_classes[:hover] %> rounded-xl transition duration-200" href="/books/il-corpo-un-mondo-da-scoprire/<%= slug %>">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-xs font-bold text-slate-400 min-w-[48px] self-start mt-0.5">LEZ <%= number %></span>
        <div>
          <h5 class="text-sm font-semibold text-slate-800 <%= theme_classes[:hover_text] %> transition"><%= title %></h5>
          <% if description.present? %>
            <p class="text-xs text-slate-500 mt-1 font-normal"><%= description %></p>
          <% end %>
        </div>
      </div>
      <div class="flex items-center gap-2 self-start mt-0.5">
        <div class="rounded-sm py-0.5 px-2 text-[10px] inline-block font-semibold leading-normal <%= theme_classes[:bg] %> <%= theme_classes[:text] %> uppercase tracking-wider">Leggi Lezione →</div>
      </div>
    </div>
  </a>
<%
end
%>

<section id="acc-curriculum" class="border-t border-slate-100 bg-slate-50/60 py-16 px-5">
  <div class="mx-auto max-w-4xl">
    <div class="text-center mb-10">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-blue-700">
        Programma di Studio
      </p>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-955 md:text-5xl">
        Accademia
      </h1>
      <p class="mt-4 text-slate-600 max-w-2xl mx-auto">
        Tutti i moduli formativi e le lezioni dell'Accademia. Clicca su una lezione per aprirla direttamente nel libro digitale.
      </p>
    </div>

    <!-- TABS CONTROLLER (with overflow scroll on small screens) -->
