        <div class="flex justify-between items-baseline mb-2 flex-wrap gap-2">
          <div class="flex items-center gap-3">
            <span class="rounded-md bg-fuchsia-100 text-fuchsia-800 text-[10px] font-black uppercase px-2 py-0.5 tracking-wider">Modulo 07</span>
