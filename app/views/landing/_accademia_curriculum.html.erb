<section id="academy-curriculum" aria-labelledby="academy-curriculum-title">
  <section class="hero" id="top">
    <div class="hero-inner">
      <div>
        <p class="eyebrow">Postura e fisiologia</p>
        <h1 id="academy-curriculum-title">Un percorso da vivere, una competenza da trasmettere.</h1>
        <p class="hero-copy">Esplora moduli e lezioni, scegli come partecipare e incontra i professionisti formati in ogni area.</p>
        <div class="hero-actions">
          <button class="button secondary" id="academyOpenAll" type="button">Apri tutti i moduli</button>
          <button class="button primary" type="button" data-roster>Tutti i professionisti</button>
        </div>
      </div>
      <div class="summary" aria-label="Riepilogo del corso">
        <div><strong>8</strong><span>Moduli</span></div>
        <div><strong>38</strong><span>Lezioni</span></div>
        <div><strong>24</strong><span>Professionisti</span></div>
      </div>
    </div>
  </section>

  <main class="workspace">
    <div class="toolbar">
      <label class="search"><span class="sr-only">Cerca modulo o lezione</span><input id="search" type="search" placeholder="Cerca un modulo o una lezione…"></label>
      <div class="filter-tabs" role="group" aria-label="Filtra per modalità">
        <button class="filter-tab active" data-filter="all">Tutti</button>
        <button class="filter-tab" data-filter="self">Autonomia</button>
        <button class="filter-tab" data-filter="one">Singolo</button>
        <button class="filter-tab" data-filter="group">Gruppo</button>
      </div>
    </div>

    <div class="content-grid">
      <nav class="side" aria-label="Indice dei moduli">
        <p class="side-label">Indice del percorso</p>
        <a class="active" href="#m0"><span class="side-num">00</span><span>Introduzione</span><span class="side-count">4</span></a>
        <a href="#m1"><span class="side-num">01</span><span>Igiene posturale</span><span class="side-count">4</span></a>
        <a href="#m2"><span class="side-num">02</span><span>Fisioterapia</span><span class="side-count">5</span></a>
        <a href="#m3"><span class="side-num">03</span><span>Biomeccanica GDS</span><span class="side-count">6</span></a>
        <a href="#m4"><span class="side-num">04</span><span>Osteopatia</span><span class="side-count">5</span></a>
        <a href="#m5"><span class="side-num">05</span><span>Corpo e coscienza</span><span class="side-count">6</span></a>
        <a href="#m6"><span class="side-num">06</span><span>Kinesiologia</span><span class="side-count">4</span></a>
        <a href="#m7"><span class="side-num">07</span><span>Altre metodiche</span><span class="side-count">4</span></a>
      </nav>

      <section>
        <div class="section-head">
          <div><h2>Il programma</h2><p>Apri un modulo per vedere lezioni e persone formate.</p></div>
          <div class="legend"><span><i></i> Formazione completata</span><span>⌄ Apri modulo</span></div>
        </div>
        <div class="module-list" id="moduleList"></div>
        <div class="empty" id="empty">Nessun modulo corrisponde alla ricerca.</div>
      </section>
    </div>
  </main>

  <div class="modal" id="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <div class="modal-card">
      <div class="modal-head"><h3 id="modalTitle">Professionista formato</h3><button class="close" id="closeModal" aria-label="Chiudi">✕</button></div>
      <div class="modal-content" id="modalContent"></div>
    </div>
  </div>

  <script>
  (() => {
    const root = document.getElementById('academy-curriculum');
    if (!root || root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';
    const people = [
      {name:'Laura Bianchi', role:'Fisioterapista', img:'https://i.pravatar.cc/160?img=47', mode:'Gruppo', date:'Giugno 2026'},
      {name:'Andrea Rinaldi', role:'Osteopata', img:'https://i.pravatar.cc/160?img=12', mode:'Singolo', date:'Maggio 2026'},
      {name:'Sara Moretti', role:'Chinesiologa', img:'https://i.pravatar.cc/160?img=32', mode:'Gruppo', date:'Aprile 2026'},
      {name:'Paolo Ferri', role:'Fisioterapista', img:'https://i.pravatar.cc/160?img=11', mode:'Singolo', date:'Marzo 2026'},
      {name:'Giulia Conti', role:'Professionista del movimento', img:'https://i.pravatar.cc/160?img=45', mode:'Gruppo', date:'Febbraio 2026'},
      {name:'Matteo Romano', role:'Massoterapista', img:'https://i.pravatar.cc/160?img=14', mode:'Gruppo', date:'Gennaio 2026'}
    ];

    const modules = [
      {n:'00', id:'m0', title:'Intro: basi e fondamenti', desc:'La visione della postura e le basi fisiologiche del percorso.', modes:['self','one','group'], people:[0,1,2,3,4], lessons:[['Perché la postura','Le migliori metodiche per imparare a leggere il corpo.'],['Rosso, verde, blu','Come usare il percorso rispettando i ruoli professionali.'],['Informati, pratica, insegna','I diversi livelli di partecipazione.'],['Massaggio, presenza e autotrattamento','Presa di coscienza corporea e ascolto.']]},
      {n:'01', id:'m1', title:'Igiene Posturale', desc:'I concetti essenziali per trasformare le abitudini quotidiane.', modes:['self','one','group'], people:[0,2,3,4,5], lessons:[['Mobilità articolare','Recuperare possibilità di movimento.'],['Punti di tensione','Riconoscere e ascoltare le tensioni.'],['Vie di discesa','Accompagnare il corpo verso il rilascio.'],['Recettori sensoriali','Vista, appoggi e orientamento.']]},
      {n:'02', id:'m2', title:'Principi di Fisioterapia', desc:'Uno sguardo biologico ai grandi sistemi vitali del corpo.', modes:['self','group'], people:[0,1,3,5], lessons:[['Sistema respiratorio','Respirazione, torace e scambi.'],['Sistema nervoso e urogenitale','Regolazione, sensibilità e funzioni.'],['Sistema muscolo-scheletrico','Movimento, carico e adattamento.'],['Sistema cardiocircolatorio','Flussi e distribuzione.'],['Sistema linfatico e digerente','Drenaggio, nutrimento ed eliminazione.']]},
      {n:'03', id:'m3', title:'Biomeccanica Comportamentale (GDS)', desc:'Le catene muscolari e il loro significato psicofisiologico.', modes:['one','group'], people:[0,2,4,5], lessons:[['Le 5 direzioni di movimento','La mappa generale del metodo.'],['Catena AM','Flessione e protezione.'],['Catena AL','Rotazione interna e adattamento.'],['Catena PM','Estensione e verticalità.'],['Catena PL','Rotazione esterna e apertura.'],['Catene PA/AP','Tra controllo e rilascio.']]},
      {n:'04', id:'m4', title:'Principi di Osteopatia', desc:'Relazioni tra struttura, fascia, visceri e regolazione.', modes:['self','one'], people:[1,3,5], lessons:[['Eliminare le disfunzioni','Mobilità e capacità di adattamento.'],['Il sistema fasciale','Continuità e trasmissione delle tensioni.'],['Il sistema viscerale','Organi, spazi e movimento.'],['Il sistema cranio-sacrale','Ascolto e ritmi profondi.'],['Il sistema neurovegetativo','Equilibrio tra attivazione e recupero.']]},
      {n:'05', id:'m5', title:'Bioritmi: Corpo e Coscienza', desc:'I parametri strutturali ed energetici della coscienza somatica.', modes:['self','group'], people:[0,2,4,5], lessons:[['Le 2 circolazioni','Scambio tra dentro e fuori.'],['I 3 centri di gravità','Testa, torace e bacino.'],['I 4 tipi di movimento','Qualità e direzioni fondamentali.'],['I 5 elementi','Il ritmo stagionale.'],['Le 6 coppie di meridiani','Relazioni funzionali.'],['I 7 centri neurolinfatici','Una mappa di lettura corporea.']]},
      {n:'06', id:'m6', title:'Sequenza di Kinesiologia Applicata', desc:'Un processo ordinato di osservazione, test e riequilibrio.', modes:['one','group'], people:[1,2,3], lessons:[['Preparazione al test','Contesto e affidabilità.'],['Test muscolare','Ascoltare la risposta del sistema.'],['Localizzazione terapeutica','Cercare relazioni significative.'],['Riequilibrio e verifica','Intervenire e ritestare.']]},
      {n:'07', id:'m7', title:'Altre metodiche posturali', desc:'Confrontare mappe diverse senza perdere il filo del percorso.', modes:['self','group'], people:[0,1,2,3,4,5], lessons:[['Mézières e RPG','Le catene e l’allungamento globale.'],['Feldenkrais','Apprendimento attraverso il movimento.'],['Alexander e consapevolezza','Uso di sé e organizzazione.'],['Sintesi del percorso','Costruire la propria mappa integrata.']]}
    ];

    const modeLabel = {self:'Autonomia', one:'Singolo', group:'Gruppo'};
    const moduleList = root.querySelector('#moduleList');
    const avatar = (idx, extra='') => `<button class="avatar ${extra}" data-person="${idx}" aria-label="Apri il profilo di ${people[idx].name}"><img src="${people[idx].img}" alt="" onerror="this.style.display='none';this.parentNode.textContent='${people[idx].name.split(' ').map(x=>x[0]).join('')}'"></button>`;

    function renderModules() {
      moduleList.innerHTML = modules.map((m, mi) => `
        <article class="module ${mi === 1 ? 'open' : ''}" id="${m.id}" data-modes="${m.modes.join(' ')}" data-search="${(m.title+' '+m.desc+' '+m.lessons.flat().join(' ')).toLowerCase()}">
          <div class="module-top">
            <span class="module-index">${m.n}</span>
            <span class="module-title"><h3>${m.title}</h3><p>${m.desc}</p></span>
            <span class="modes">${m.modes.map(x=>`<span class="mode ${x}">${modeLabel[x]}</span>`).join('')}</span>
            <span class="professionals"><span class="avatars">${m.people.slice(0,3).reverse().map(i=>avatar(i)).join('')}<button class="avatar more" data-module="${mi}" aria-label="Vedi tutti i professionisti">+${Math.max(0,m.people.length-3)}</button></span></span>
            <button class="chevron" aria-label="Apri ${m.title}" aria-expanded="${mi === 1}">⌄</button>
          </div>
          <div class="module-body">
            <div class="lessons">
              <div class="body-title"><span>${m.lessons.length} lezioni</span><span>Contenuti del modulo</span></div>
              ${m.lessons.map((l,i)=>`<div class="lesson"><span class="lesson-num">${String(i+1).padStart(2,'0')}</span><span><strong>${l[0]}</strong><small>${l[1]}</small></span><span class="lesson-status">✓ disponibile</span></div>`).join('')}
            </div>
            <aside class="roster">
              <div class="body-title"><span>Professionisti formati</span></div>
              <div class="roster-list">${m.people.slice(0,3).map(i=>`<div class="person">${avatar(i)}<span><strong>${people[i].name}</strong><span>${people[i].role} · ${people[i].mode}</span></span></div>`).join('')}</div>
              <button class="view-all" data-module="${mi}">Vedi tutti (${m.people.length})</button>
            </aside>
          </div>
        </article>`).join('');
    }

    renderModules();
    let currentFilter = 'all';
    const search = root.querySelector('#search');
    function applyFilters() {
      const q = search.value.trim().toLowerCase();
      let visible = 0;
      root.querySelectorAll('.module').forEach(el => {
        const matchesText = !q || el.dataset.search.includes(q);
        const matchesMode = currentFilter === 'all' || el.dataset.modes.split(' ').includes(currentFilter);
        el.hidden = !(matchesText && matchesMode);
        if (!el.hidden) visible++;
      });
      root.querySelector('#empty').style.display = visible ? 'none' : 'block';
    }
    search.addEventListener('input', applyFilters);
    root.querySelectorAll('.filter-tab').forEach(btn => btn.addEventListener('click', () => {
      root.querySelectorAll('.filter-tab').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active'); currentFilter = btn.dataset.filter; applyFilters();
    }));
    moduleList.addEventListener('click', e => {
      const top = e.target.closest('.module-top');
      const personBtn = e.target.closest('[data-person]');
      const moduleBtn = e.target.closest('[data-module]');
      if (personBtn) { e.stopPropagation(); showPerson(+personBtn.dataset.person); return; }
      if (moduleBtn) { e.stopPropagation(); showRoster(+moduleBtn.dataset.module); return; }
      if (top) { const card = top.closest('.module'); card.classList.toggle('open'); top.querySelector('.chevron').setAttribute('aria-expanded', card.classList.contains('open')); }
    });
    root.querySelector('#academyOpenAll').addEventListener('click', e => {
      const opening = ![...root.querySelectorAll('.module:not([hidden])')].every(x=>x.classList.contains('open'));
      root.querySelectorAll('.module:not([hidden])').forEach(x=>{ x.classList.toggle('open', opening); x.querySelector('.chevron').setAttribute('aria-expanded', opening); });
      e.currentTarget.textContent = opening ? 'Chiudi tutti i moduli' : 'Apri tutti i moduli';
    });

    const modal = root.querySelector('#modal');
    const modalTitle = root.querySelector('#modalTitle');
    const modalContent = root.querySelector('#modalContent');
    function openModal(){ modal.classList.add('open'); document.body.style.overflow='hidden'; }
    function closeModal(){ modal.classList.remove('open'); document.body.style.overflow=''; }
    function showPerson(i) {
      const p = people[i]; modalTitle.textContent='Professionista formato';
      modalContent.innerHTML=`<div class="profile">${avatar(i)}<div><h4>${p.name}</h4><p>${p.role}</p><span class="mode ${p.mode==='Gruppo'?'group':'one'}">Formazione in ${p.mode.toLowerCase()}</span></div></div><div class="profile-meta"><span class="mode group">Completato</span><span class="mode">${p.date}</span><span class="mode">Profilo verificato</span></div>`;
      openModal();
    }
    function showRoster(mi) {
      const ids = mi === undefined ? people.map((_,i)=>i) : modules[mi].people;
      modalTitle.textContent = mi === undefined ? 'Professionisti dell’Accademia' : `Formati in ${modules[mi].title}`;
      modalContent.innerHTML=`<div class="roster-list">${ids.map(i=>`<div class="person" style="padding:8px 0;border-bottom:1px solid #edf1f6">${avatar(i)}<span><strong>${people[i].name}</strong><span>${people[i].role} · formazione in ${people[i].mode.toLowerCase()}</span></span></div>`).join('')}</div>`;
      openModal();
    }
    root.querySelector('[data-roster]').addEventListener('click',()=>showRoster());
    root.querySelector('#closeModal').addEventListener('click', closeModal);
    modal.addEventListener('click', e=>{ if(e.target===modal) closeModal(); });
    document.addEventListener('keydown', e=>{ if(e.key==='Escape') closeModal(); });
  })();
  </script>
</section>
