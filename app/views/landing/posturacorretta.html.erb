  };

  const colorClasses = {
    red: {
      text: "text-red-700",
      bg: "bg-red-600",
      soft: "bg-red-50",
      border: "border-red-200",
      activeBorder: "border-red-400",
      hover: "hover:bg-red-50",
      ring: "ring-red-500"
    },
    emerald: {
      text: "text-emerald-700",
      bg: "bg-emerald-600",
      soft: "bg-emerald-50",
      border: "border-emerald-200",
      activeBorder: "border-emerald-400",
      hover: "hover:bg-emerald-50",
      ring: "ring-emerald-500"
    },
    blue: {
      text: "text-blue-700",
      bg: "bg-blue-600",
      soft: "bg-blue-50",
      border: "border-blue-200",
      activeBorder: "border-blue-400",
      hover: "hover:bg-blue-50",
      ring: "ring-blue-500"
    },
    violet: {
      text: "text-violet-700",
      bg: "bg-violet-700",
      soft: "bg-violet-50",
      border: "border-violet-200",
      activeBorder: "border-violet-400",
      hover: "hover:bg-violet-50",
      ring: "ring-violet-500"
    }
  };

  const allowedPathTabs = ["rosso", "verde", "blu", "viola"];

  function renderPath(key) {
    const path = paths[key];
    const c = colorClasses[path.color];

    document.getElementById("path-kicker").textContent = path.kicker;
    document.getElementById("path-kicker").className =
      `text-xs font-semibold uppercase tracking-[0.22em] ${c.text}`;

    document.getElementById("path-title").textContent = path.title;
    document.getElementById("path-description").textContent = path.description;

    document.getElementById("join-box").className =
      `mt-10 rounded-[2rem] border ${c.border} bg-white p-7 shadow-sm`;

    document.getElementById("join-kicker").className =
      `text-xs font-semibold uppercase tracking-[0.18em] ${c.text}`;

    document.getElementById("join-title").textContent = path.joinTitle;
    document.getElementById("join-description").textContent = path.joinDescription;

    document.getElementById("join-link").className =
      `mt-6 inline-flex rounded-full border ${c.border} px-5 py-3 text-sm font-semibold ${c.text} ${c.hover}`;

    document.getElementById("path-bottom-start-link").className =
      `mt-6 inline-flex w-full items-center justify-center rounded-2xl ${c.bg} px-8 py-5 text-base font-semibold text-white opacity-90 md:text-lg`;
    document.getElementById("path-bottom-text").textContent =
      `Inizia dal ${path.kicker.toLowerCase()}.`;
    document.getElementById("path-bottom-start-link").href =
      `https://wa.me/393792891488?text=${encodeURIComponent(`Ciao, vorrei iniziare dal ${path.kicker.toLowerCase()} di PosturaCorretta.`)}`;

    const joinTags = document.getElementById("join-tags");
    joinTags.innerHTML = path.joinTags.map(tag => `
      <span class="rounded-full ${c.soft} px-3 py-1 text-xs font-medium ${c.text}">
        ${tag}
      </span>
    `).join("");

    const container = document.getElementById("path-steps");
    container.innerHTML = "";

    path.steps.forEach((step, index) => {
      const [label, title, description, tags, modules = []] = step;

      container.innerHTML += `
        <article class="${index < path.steps.length - 1 ? "step-line" : ""} relative cursor-pointer rounded-2xl pl-14 pr-3 py-2 transition hover:bg-slate-50" data-scroll-to-cta="true">
          <div class="absolute left-0 top-0 grid h-9 w-9 place-items-center rounded-full ${c.bg} text-sm font-semibold text-white">
            ${index + 1}
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] ${c.text}">
              ${label}
            </p>

            <h3 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">
              ${title}
            </h3>

            ${description ? `
              <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">
                ${description}
              </p>
            ` : ""}

            <div class="mt-4 flex flex-wrap gap-2">
              ${tags.map(tag => `
                <span class="rounded-full ${c.soft} px-3 py-1 text-xs font-medium ${c.text}">
                  ${tag}
                </span>
              `).join("")}
            </div>

            ${modules.length ? `
              <div class="mt-6 grid gap-3">
                ${modules.map(([moduleNumber, moduleTitle, moduleItems]) => `
                  <div class="rounded-2xl border ${c.border} bg-white p-4">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] ${c.text}">
                      ${moduleNumber}
                    </p>
                    <h4 class="mt-1 text-base font-semibold text-slate-950">
                      ${moduleTitle}
                    </h4>
                    ${moduleItems.length ? `
                      <ul class="mt-3 grid gap-1 text-sm leading-6 text-slate-600 sm:grid-cols-2">
                        ${moduleItems.map(item => `<li>• ${item}</li>`).join("")}
                      </ul>
                    ` : ""}
                  </div>
                `).join("")}
              </div>
            ` : ""}
          </div>
        </article>
      `;
    });

    document.querySelectorAll("[data-scroll-to-cta]").forEach(step => {
      step.addEventListener("click", () => {
        document.getElementById("path-final-cta")?.scrollIntoView({
          behavior: "smooth",
          block: "center"
        });
      });
    });

    document.querySelectorAll(".pc-tab").forEach(tab => {
      tab.classList.remove(
        "ring-2",
        "ring-red-500",
        "ring-emerald-500",
        "ring-blue-500",
        "ring-violet-500",
        "bg-red-50",
        "bg-emerald-50",
        "bg-blue-50",
        "bg-violet-50",
        "border-red-400",
        "border-emerald-400",
        "border-blue-400",
        "border-violet-400",
        "shadow-md"
      );
      tab.classList.add("bg-white");
    });

    const activeTab = document.querySelector(`[data-tab="${key}"]`);
    activeTab.classList.remove("bg-white");
    activeTab.classList.add("ring-2", c.ring, c.soft, c.activeBorder, "shadow-md");
  }

  function getInitialTab() {
    const params = new URLSearchParams(window.location.search);
    const urlPath = params.get("path");
    const legacyUrlTab = params.get("tab");

    if (allowedPathTabs.includes(urlPath)) {
      localStorage.setItem("posturacorretta_active_path", urlPath);
      return urlPath;
    }

    if (allowedPathTabs.includes(legacyUrlTab)) {
      localStorage.setItem("posturacorretta_active_path", legacyUrlTab);
      return legacyUrlTab;
    }

    const savedPath = localStorage.getItem("posturacorretta_active_path");

    if (allowedPathTabs.includes(savedPath)) {
      return savedPath;
    }

    return "rosso";
  }

  function updatePathState(key) {
    const url = new URL(window.location);
    url.searchParams.set("tab", "salute");
    url.searchParams.set("path", key);
    window.history.replaceState({}, "", url);
    localStorage.setItem("posturacorretta_active_path", key);
  }

  function scrollToPathDetail() {
    document.getElementById("percorso-dettaglio")?.scrollIntoView({
      behavior: "smooth",
      block: "start"
    });
  }

  document.querySelectorAll(".pc-tab").forEach(tab => {
    tab.addEventListener("click", () => {
      const key = tab.dataset.tab;
      renderPath(key);
      updatePathState(key);
      scrollToPathDetail();
    });
  });

  const initialPath = getInitialTab();
  renderPath(initialPath);

  if (new URLSearchParams(window.location.search).has("path")) {
    window.setTimeout(scrollToPathDetail, 120);
  }
</script>


