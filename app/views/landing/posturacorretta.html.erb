              Inizia ora →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- MODALE DETTAGLI PERCORSO -->
  <div id="path-modal" class="fixed inset-0 z-50 hidden overflow-y-auto bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="relative w-full max-w-3xl rounded-[2rem] border border-slate-100 bg-white p-6 shadow-2xl md:p-10 flex flex-col max-h-[90vh]">
      
      <!-- Close button -->
      <button id="close-modal-btn" type="button" class="absolute right-6 top-6 grid h-10 w-10 place-items-center rounded-full bg-slate-50 text-slate-500 hover:bg-slate-100 hover:text-slate-800 transition">
        ✕
      </button>

      <!-- Modal Content (Scrollable) -->
      <div class="overflow-y-auto flex-1 pr-2">
        <p id="modal-path-kicker" class="text-xs font-semibold uppercase tracking-[0.22em] text-red-700">
          Cura e Riabilitazione
        </p>

        <h2 id="modal-path-title" class="mt-4 text-2xl font-semibold tracking-tight text-slate-950 md:text-3xl">
          Dal dolore alla cura guidata.
        </h2>

        <p id="modal-path-description" class="mt-4 text-base leading-7 text-slate-600">
          Per chi parte da dolore, sintomi, diagnosi, patologia o fase acuta.
        </p>

        <div class="mt-8 border-t border-slate-100 pt-6">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Tappe consigliate</p>
          <h3 id="modal-path-steps-title" class="mt-1 text-lg font-semibold text-slate-950">Segui il percorso con calma.</h3>
        </div>

        <div id="modal-path-steps" class="mt-6 space-y-8"></div>

        <!-- Join Box (for professionals) -->
        <div id="modal-join-box" class="mt-8 rounded-2xl border border-slate-100 bg-slate-50 p-6">
          <p id="modal-join-kicker" class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">
            Aderisci al progetto
          </p>
          <h3 id="modal-join-title" class="mt-2 text-lg font-semibold text-slate-950">
            Sei un professionista?
          </h3>
          <p id="modal-join-description" class="mt-3 text-sm leading-6 text-slate-600">
            Puoi collaborare e integrare il percorso PosturaCorretta.
          </p>
          <div id="modal-join-tags" class="mt-4 flex flex-wrap gap-2"></div>
        </div>
      </div>

      <!-- Action Footer -->
      <div class="mt-6 border-t border-slate-100 pt-6 flex flex-col sm:flex-row gap-3">
        <button id="modal-select-btn" type="button" class="flex-1 rounded-xl bg-blue-600 px-6 py-3.5 text-sm font-semibold text-white hover:bg-blue-700 transition">
          Seleziona questo percorso
        </button>
        <button id="modal-cancel-btn" type="button" class="rounded-xl border border-slate-200 bg-white px-6 py-3.5 text-sm font-semibold text-slate-600 hover:bg-slate-50 transition">
          Chiudi
        </button>
      </div>

    </div>
  </div>

</div>

  <!-- ACCADEMIA -->
  <div id="accademia" data-tab-panel="accademia" class="<%= "hidden" unless active_landing_tab == "accademia" %>">
    <section class="px-5 py-12 md:py-16">
      <div class="mx-auto grid max-w-6xl items-center gap-10 lg:grid-cols-[.95fr_1.05fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">
            Accademia PosturaCorretta
          </p>

          <h1 class="mt-5 max-w-5xl text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl md:leading-[1.03]">
            Lezioni, strumenti e mappe per
            <span class="text-blue-700">imparare a leggere il corpo</span>
