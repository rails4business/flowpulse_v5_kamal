        <button type="button" class="landing-tab-button rounded-full px-2 py-2 transition md:px-5 <%= active_landing_tab == "salute" ? "bg-blue-600 text-white shadow-sm" : "text-blue-700" %>" data-landing-tab="salute" aria-selected="<%= active_landing_tab == "salute" %>">
          Percorso<br class="sm:hidden"> Salute
        </button>
        <button type="button" class="landing-tab-button rounded-full px-2 py-2 transition md:px-5 <%= active_landing_tab == "collabora" ? "bg-orange-500 text-white shadow-sm" : "text-orange-600" %>" data-landing-tab="collabora" aria-selected="<%= active_landing_tab == "collabora" %>">
