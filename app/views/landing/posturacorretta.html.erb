<% content_for :title, "Accademia PosturaCorretta — Percorsi della Salute" %>
<% active_landing_tab = params[:tab].presence_in(%w[home percorso accademia eventi filosofia collabora]) || "home" %>

<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            pcblue: '#2563eb',
            pcink: '#0f172a'
          },
          boxShadow: {
            soft: '0 24px 70px rgba(15, 23, 42, 0.08)'
          }
        }
      }
    }
  </script>

  <style>
    html { scroll-behavior: smooth; }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(4px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in {
      animation: fadeIn 0.25s ease-out forwards;
    }

    summary::-webkit-details-marker { display: none; }
    summary { list-style: none; }

    section[id],
    main[id] {
      scroll-margin-top: 5rem;
    }

    #percorso-dettaglio,
    #path-final-cta {
      scroll-margin-top: 8rem;
    }

    body {
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #ffffff;
    }

    .glass {
      background: rgba(255, 255, 255, .88);
      backdrop-filter: blur(18px);
    }

    .hero-image-accademia {
      background-image:
        linear-gradient(135deg, rgba(37, 99, 235, .10), rgba(15, 23, 42, .10)),
        url('https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=1200&q=80');
      background-size: cover;
      background-position: center;
    }

    .hero-image-percorso {
      background-image:
        linear-gradient(135deg, rgba(37, 99, 235, .10), rgba(15, 23, 42, .10)),
        url('/images/percorso_hero.png');
      background-size: cover;
      background-position: center;
    }

    .step-line::before {
      content: "";
      position: absolute;
      left: 1.12rem;
      top: 2.8rem;
      bottom: -2.6rem;
      width: 1px;
      background: #dbeafe;
    }

    .step-line:last-child::before { display: none; }

  </style>
<% end %>

<% content_for :landing_nav do %>
  <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
    <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
      <a href="?tab=home#home" data-landing-tab="home" class="flex items-center gap-3" aria-label="PosturaCorretta home">
        <img
          src="https://ik.imagekit.io/posturacorretta/logo_pc_scontornato.png?updatedAt=1747975596766"
          alt="PosturaCorretta"
          class="h-8 w-auto">
      </a>

      <nav class="hidden items-center gap-7 md:flex" aria-label="Navigazione principale PosturaCorretta">
        <a href="?tab=home#home"
           data-landing-tab="home"
           aria-selected="<%= active_landing_tab == "home" %>"
           class="landing-tab-button border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= active_landing_tab == "home" ? "border-blue-600 text-blue-700" : "border-transparent text-slate-700 hover:border-blue-200 hover:text-blue-700" %>">
          Home
        </a>

        <a href="?tab=percorso#percorso"
           data-landing-tab="percorso"
           aria-selected="<%= active_landing_tab == "percorso" %>"
           class="landing-tab-button border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= active_landing_tab == "percorso" ? "border-blue-600 text-blue-700" : "border-transparent text-slate-700 hover:border-blue-200 hover:text-blue-700" %>">
          Percorso personalizzato
        </a>

        <a href="?tab=accademia#accademia"
           data-landing-tab="accademia"
           aria-selected="<%= active_landing_tab == "accademia" %>"
           class="landing-tab-button border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= active_landing_tab == "accademia" ? "border-blue-600 text-blue-700" : "border-transparent text-slate-700 hover:border-blue-200 hover:text-blue-700" %>">
          Accademia
        </a>

        <a href="?tab=eventi#eventi"
           data-landing-tab="eventi"
           aria-selected="<%= active_landing_tab == "eventi" %>"
           class="landing-tab-button border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= active_landing_tab == "eventi" ? "border-blue-600 text-blue-700" : "border-transparent text-slate-700 hover:border-blue-200 hover:text-blue-700" %>">
          Eventi e Community
        </a>

        <a href="?tab=filosofia#filosofia"
           data-landing-tab="filosofia"
           aria-selected="<%= active_landing_tab == "filosofia" %>"
           class="landing-tab-button border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= active_landing_tab == "filosofia" ? "border-blue-600 text-blue-700" : "border-transparent text-slate-700 hover:border-blue-200 hover:text-blue-700" %>">
          Libro e Visione
        </a>

        <a href="?tab=collabora#collabora"
           data-landing-tab="collabora"
           aria-selected="<%= active_landing_tab == "collabora" %>"
           class="landing-tab-button border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= active_landing_tab == "collabora" ? "border-blue-600 text-blue-700" : "border-transparent text-slate-700 hover:border-blue-200 hover:text-blue-700" %>">
          Progetti in corso
        </a>
      </nav>
    </div>
  </header>
<% end %>

<div id="top" class="text-slate-900 antialiased">

  <!-- HOME -->
  <div id="home" data-tab-panel="home" class="<%= "hidden" unless active_landing_tab == "home" %>">
    <section class="flex min-h-[calc(100vh-4rem)] items-center px-5 py-10 md:py-12 xl:py-8">
      <div class="mx-auto w-full max-w-6xl">
        <div class="grid items-center gap-8 lg:grid-cols-[0.95fr_1.05fr] xl:gap-10">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">
              PosturaCorretta
            </p>
            <h1 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl md:leading-[1.05] xl:text-5xl">
