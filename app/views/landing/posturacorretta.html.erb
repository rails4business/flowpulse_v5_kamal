        <button type="button" class="landing-tab-button rounded-full px-2 py-2 transition md:px-5 <%= active_landing_tab == "about" ? "bg-slate-950 text-white shadow-sm" : "text-slate-700" %>" data-landing-tab="about" aria-selected="<%= active_landing_tab == "about" %>">
