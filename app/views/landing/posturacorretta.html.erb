              </a>
            </div>
          </div>

          <div class="rounded-[2rem] border border-slate-200 bg-white p-3 shadow-soft">
            <div class="hero-image-accademia aspect-[16/10] rounded-[1.55rem]"></div>
          </div>
        </div>

        <!-- TABS PERCORSO -->
        <section id="acc-percorso" class="bg-white rounded-[2.5rem] border border-slate-200 p-6 shadow-sm md:p-10 my-12">
          <div class="text-center">
            <p class="text-sm font-black uppercase tracking-[0.2em] text-sky-700">
              Accademia
            </p>

            <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 md:text-4xl">
