<% content_for :landing_nav do %>
  <%= render "posturacorretta/header" %>
<% end %>

<%
  quick_links = posturacorretta_home_quick_links

  find_quick_link = ->(*needles) do
    quick_links.find do |link|
      text = [link[:eyebrow], link[:title], link[:description]].compact.join(" ").downcase
      needles.any? { |needle| text.include?(needle.downcase) }
    end
  end

  path_for = ->(fallback, *needles) do
    find_quick_link.call(*needles)&.fetch(:path, fallback) || fallback
  end

  main_options = [
    {
      eyebrow: "Conosci • Pratica • Insegna",
      title: "Accademia",
      description: "Impara a conoscere il corpo e la fisiologia attraverso le principali metodiche posturali, partendo anche da zero.",
      cta: "Scopri l’Accademia",
      path: path_for.call("/posturacorretta/accademia", "accadem"),
      classes: "border-blue-200 bg-gradient-to-br from-blue-50 via-white to-sky-50",
      icon_classes: "bg-blue-700 text-white",
      eyebrow_classes: "text-blue-700",
      cta_classes: "text-blue-700"
    },
    {
      eyebrow: "Dalla situazione agli step",
      title: "Percorso",
      description: "Osserva cosa sta accadendo, orientati tra le possibilità e costruisci un percorso personale con l’aiuto più adatto.",
      cta: "Inizia il tuo percorso",
      path: path_for.call("/posturacorretta/percorso", "percor"),
      classes: "border-emerald-200 bg-gradient-to-br from-emerald-50 via-white to-teal-50",
      icon_classes: "bg-emerald-600 text-white",
      eyebrow_classes: "text-emerald-700",
      cta_classes: "text-emerald-700"
    }
  ]

  other_options = [
 
    {
      title: "Contenuti",
      eyebrow: "Informati",
      description: "Video, articoli, guide ed esercizi per approfondire postura, fisiologia e salute.",
      cta: "Guarda i contenuti",
      path: path_for.call("/posturacorretta/contenuti", "contenut", "youtube"),
      classes: "border-sky-200 bg-sky-50",
      accent_classes: "text-sky-700"
    },
    {
      title: "Libro",
      eyebrow: "La visione",
      description: "Il corpo, un mondo da scoprire: dalla salute alla relazione con ciò che ci circonda.",
      cta: "Scopri il libro",
      path: path_for.call("/posturacorretta/libro", "libro"),
      classes: "border-violet-200 bg-violet-50",
      accent_classes: "text-violet-700"
    },
       {
      title: "Metodiche",
      eyebrow: "Approcci",
      description: "Conosci e confronta le diverse mappe utilizzate per osservare e lavorare con il corpo.",
      cta: "Esplora le metodiche",
      path: "#domanda-metodiche",
      classes: "border-indigo-200 bg-indigo-50",
      accent_classes: "text-indigo-700"
    },
    {
      title: "Eventi",
      eyebrow: "Partecipa",
      description: "Incontri, esperienze e attività per conoscere persone, luoghi e pratiche sul territorio.",
      cta: "Vedi gli eventi",
      path: path_for.call("/posturacorretta/eventi", "event"),
      classes: "border-amber-200 bg-amber-50",
      accent_classes: "text-amber-700"
    },
    {
      title: "Progetti",
      eyebrow: "Collabora",
      description: "Segui ciò che sta nascendo, proponi il tuo contributo oppure entra nel gruppo di lavoro.",
      cta: "Scopri i progetti",
      path: path_for.call("/posturacorretta/progetti", "progett"),
      classes: "border-rose-200 bg-rose-50",
      accent_classes: "text-rose-700"
    }
  ]

  audiences = [
    {
      label: "Professionisti sanitari",
      description: "Cura, valutazione, terapia e riabilitazione.",
      classes: "border-red-200 bg-red-50 text-red-900",
      badge_classes: "bg-red-600 text-white"
    },
    {
      label: "Professionisti del benessere",
      description: "Movimento, prevenzione, benessere e servizi alla persona.",
      classes: "border-emerald-200 bg-emerald-50 text-emerald-900",
      badge_classes: "bg-emerald-600 text-white"
    },
    {
      label: "Aperto a tutti",
      description: "Informazione, pratica, consapevolezza e autonomia.",
      classes: "border-sky-200 bg-sky-50 text-sky-900",
      badge_classes: "bg-sky-600 text-white"
    }
  ]
%>

<div id="top" class="bg-white text-slate-900 antialiased" data-posturacorretta-home>
  <main>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-blue-50 via-white to-white px-5 py-14 md:py-20" aria-labelledby="home-title" data-questions>
    

         <div class="mx-auto max-w-6xl">
        <header class="mx-auto max-w-3xl text-center">
         <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">
        Con l'aiuto delle metodiche posturali
      </p>

      <h1 id="home-title" class="mx-auto mt-4 max-w-4xl text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl md:leading-[1.03]">
        Trova la giusta posizione da cui osservare il mondo.
        <span class="mt-2 block text-blue-700">Inizia dalla salute.</span>
      </h1>
         
        </header>

        <div class="mt-12 grid gap-8 lg:grid-cols-[1.08fr_0.92fr] lg:items-start lg:gap-12">
          <!-- Accordion -->
          <div class="space-y-4">
            <article id="domanda-postura" class="overflow-hidden rounded-[1.5rem] border border-blue-200 bg-white shadow-sm" data-question-item>
              <h3>
                <button
                  type="button"
                  class="flex w-full items-center gap-4 p-5 text-left md:p-6"
                  aria-expanded="true"
                  aria-controls="risposta-postura"
                  data-question-button
                >
                  <span class="flex h-11 w-11 flex-none items-center justify-center rounded-2xl bg-blue-700 text-xl font-semibold text-white">?</span>
                  <span class="flex-1 text-lg font-semibold text-slate-950 md:text-xl">Perché partire dalla postura in un percorso di salute?</span>
                  <span class="flex h-9 w-9 flex-none items-center justify-center rounded-full bg-blue-50 text-blue-700 transition-transform" data-question-chevron>
                    <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" /></svg>
                  </span>
                </button>
              </h3>

              <div id="risposta-postura" class="border-t border-blue-100 px-5 pb-6 pt-5 md:px-6" data-question-panel>
                <p class="text-base leading-7 text-slate-600">
                  La postura non è soltanto il modo in cui stiamo seduti o in piedi.
                  È il modo in cui il corpo si organizza, si muove e si adatta a ciò che viviamo.
                </p>

                <div class="mt-5 grid gap-3 sm:grid-cols-3">
                  <div class="rounded-2xl bg-blue-50 p-4">
                    <p class="font-semibold text-blue-950">Organizzazione</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">Come collaborano le parti del corpo.</p>
                  </div>
                  <div class="rounded-2xl bg-sky-50 p-4">
                    <p class="font-semibold text-sky-950">Adattamento</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">Come rispondiamo a carichi e abitudini.</p>
                  </div>
                  <div class="rounded-2xl bg-indigo-50 p-4">
                    <p class="font-semibold text-indigo-950">Relazione</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">Come movimento, respiro e percezione interagiscono.</p>
                  </div>
                </div>

                <p class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm font-medium leading-6 text-slate-700">
                  Partiamo dalla postura perché il corpo è un punto di osservazione concreto da cui riconoscere ciò che sta accadendo.
                </p>
              </div>
            </article>

            <article id="domanda-metodiche" class="scroll-mt-24 overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-sm" data-question-item>
              <h3>
                <button
                  type="button"
                  class="flex w-full items-center gap-4 p-5 text-left md:p-6"
                  aria-expanded="false"
                  aria-controls="risposta-metodiche"
                  data-question-button
                >
                  <span class="flex h-11 w-11 flex-none items-center justify-center rounded-2xl bg-indigo-600 text-xl font-semibold text-white">?</span>
                  <span class="flex-1 text-lg font-semibold text-slate-950 md:text-xl">Come possono le metodiche posturali aiutarti a costruire un percorso integrato?</span>
                  <span class="flex h-9 w-9 flex-none items-center justify-center rounded-full bg-slate-100 text-slate-500 transition-transform" data-question-chevron>
                    <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" /></svg>
                  </span>
                </button>
              </h3>

              <div id="risposta-metodiche" class="hidden border-t border-slate-100 px-5 pb-6 pt-5 md:px-6" data-question-panel>
                <p class="text-base leading-7 text-slate-600">
                  Sono approcci diversi che aiutano a osservare, educare o trattare il corpo.
                  Ogni metodica mette in evidenza relazioni differenti e può essere utile in momenti diversi del percorso.
                </p>

                <div class="mt-5 grid gap-3 sm:grid-cols-2">
                  <div class="rounded-2xl border border-slate-200 p-4">
                    <p class="font-semibold text-slate-950">Osservare</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">Movimento, tono, appoggi, respirazione e compensi.</p>
                  </div>
                  <div class="rounded-2xl border border-slate-200 p-4">
                    <p class="font-semibold text-slate-950">Conoscere</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">Comprendere il corpo e partecipare al percorso.</p>
                  </div>
                  <div class="rounded-2xl border border-slate-200 p-4">
                    <p class="font-semibold text-slate-950">Praticare</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">Esercizi, esperienze e trattamenti appropriati.</p>
                  </div>
                  <div class="rounded-2xl border border-slate-200 p-4">
                    <p class="font-semibold text-slate-950">Integrare</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">Confrontare le prospettive e scegliere l’aiuto adatto.</p>
                  </div>
                </div>

                <p class="mt-5 text-sm leading-6 text-slate-500">
                  Le metodiche non sostituiscono diagnosi e cure sanitarie: ogni pratica deve essere proposta dalla figura competente.
                </p>
              </div>
            </article>

            <article id="domanda-posturacorretta" class="overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-sm" data-question-item>
              <h3>
                <button
                  type="button"
                  class="flex w-full items-center gap-4 p-5 text-left md:p-6"
                  aria-expanded="false"
                  aria-controls="risposta-posturacorretta"
                  data-question-button
                >
                  <span class="flex h-11 w-11 flex-none items-center justify-center rounded-2xl bg-violet-600 text-xl font-semibold text-white">?</span>
                  <span class="flex-1 text-lg font-semibold text-slate-950 md:text-xl">Cosa intendiamo quando parliamo di PosturaCorretta?</span>
                  <span class="flex h-9 w-9 flex-none items-center justify-center rounded-full bg-slate-100 text-slate-500 transition-transform" data-question-chevron>
                    <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" /></svg>
                  </span>
                </button>
              </h3>

              <div id="risposta-posturacorretta" class="hidden border-t border-slate-100 px-5 pb-6 pt-5 md:px-6" data-question-panel>
                <p class="text-base leading-7 text-slate-600">
                  Non cerchiamo una posizione perfetta uguale per tutti. Cerchiamo la posizione
                  più adatta da cui osservare la persona, comprendere ciò che sta vivendo e costruire il percorso successivo.
                </p>

                <div class="mt-5 grid gap-3 sm:grid-cols-2">
                  <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Quando si pensa alla postura</p>
                    <p class="mt-3 text-sm leading-6 text-slate-700">Stare dritti, correggere una posizione, occuparsi soltanto di schiena e articolazioni.</p>
                  </div>
                  <div class="rounded-2xl border border-blue-200 bg-blue-50 p-4">
                    <p class="text-xs font-bold uppercase tracking-wider text-blue-700">Cosa intendiamo noi</p>
                    <p class="mt-3 text-sm font-medium leading-6 text-blue-950">Osservare organizzazione, adattamenti, fisiologia e relazione con le attività e l’ambiente.</p>
                  </div>
                </div>

                <blockquote class="mt-5 rounded-2xl bg-blue-950 p-5 text-white">
                  <p class="text-lg font-semibold">Trova la giusta posizione da cui osservare il mondo.</p>
                  <p class="mt-1 text-sm font-medium text-blue-200">Inizia dalla salute.</p>
                </blockquote>
              </div>
            </article>
          </div>

          <!-- Immagine della postura sempre visibile -->
          <figure class="overflow-hidden rounded-[2rem] border border-blue-100 bg-white p-3 shadow-sm lg:sticky lg:top-24">
            <img
              src="https://ik.imagekit.io/posturacorretta/img_home_postura_corretta.png?tr=w-1100,q-85"
              alt="PosturaCorretta: partire dal corpo per ampliare lo sguardo sulla salute e sulla persona"
              class="aspect-[16/12] w-full rounded-[1.4rem] object-contain"
            >
            <figcaption class="px-3 pb-3 pt-4 text-center text-sm leading-6 text-slate-500">
              Dal corpo alla salute, fino alla relazione con le attività e ciò che ci circonda.
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- Come iniziare -->
    <section id="iniziare" class="scroll-mt-8 bg-blue-950 px-5 py-16 text-white md:py-24" aria-labelledby="iniziare-title">
      <div class="mx-auto max-w-6xl">
        <header class="mx-auto max-w-3xl text-center">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-blue-300">Come iniziare</p>
          <h2 id="iniziare-title" class="mt-3 text-3xl font-semibold tracking-tight md:text-5xl">
            Scegli il tuo punto d’ingresso
          </h2>
          <p class="mt-5 text-base leading-7 text-blue-100 md:text-lg md:leading-8">
            Parti dall’Accademia per conoscere e praticare oppure dal Percorso
            per orientarti a partire dalla tua situazione.
          </p>
        </header>

        <!-- Due scelte principali -->
        <div class="mt-10 grid gap-5 md:grid-cols-2">
          <% main_options.each_with_index do |option, index| %>
            <a href="<%= option.fetch(:path) %>" class="group relative flex min-h-[18rem] flex-col overflow-hidden rounded-[2rem] border p-7 text-slate-900 shadow-lg transition duration-300 hover:-translate-y-1 hover:shadow-2xl md:p-8 <%= option.fetch(:classes) %>">
              <span class="flex h-12 w-12 items-center justify-center rounded-2xl <%= option.fetch(:icon_classes) %>" aria-hidden="true">
                <% if index.zero? %>
                  <!-- Icona Accademia -->
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>
                <% else %>
                  <!-- Icona Percorso -->
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
                <% end %>
              </span>
              <p class="mt-6 text-xs font-bold uppercase tracking-[0.17em] <%= option.fetch(:eyebrow_classes) %>">
                <%= option.fetch(:eyebrow) %>
              </p>
              <h3 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950"><%= option.fetch(:title) %></h3>
              <p class="mt-4 max-w-xl text-base leading-7 text-slate-600"><%= option.fetch(:description) %></p>
              <span class="mt-auto inline-flex items-center pt-7 text-sm font-semibold <%= option.fetch(:cta_classes) %>">
                <%= option.fetch(:cta) %>
                <span class="ml-1 transition group-hover:translate-x-1" aria-hidden="true">→</span>
              </span>
            </a>
          <% end %>
        </div>

        <!-- Cinque possibilità complementari -->
        <div class="mt-12">
          <div class="flex items-center gap-4">
            <div class="h-px flex-1 bg-blue-800"></div>
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-blue-300">Puoi anche esplorare</p>
            <div class="h-px flex-1 bg-blue-800"></div>
          </div>

          <div class="mt-7 flex flex-wrap justify-center gap-4">
            <% other_options.each do |option| %>
              <a href="<%= option.fetch(:path) %>" class="group flex h-full min-h-[15rem] w-full sm:w-[calc(50%-0.5rem)] md:w-[calc(33.333%-0.75rem)] lg:flex-1 lg:min-w-[180px] flex-col rounded-[1.5rem] border p-5 text-slate-900 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-xl <%= option.fetch(:classes) %>">
                <p class="text-xs font-bold uppercase tracking-[0.15em] <%= option.fetch(:accent_classes) %>">
                  <%= option.fetch(:eyebrow) %>
                </p>
                <h3 class="mt-2 text-xl font-semibold tracking-tight text-slate-950"><%= option.fetch(:title) %></h3>
                <p class="mt-3 text-sm leading-6 text-slate-600"><%= option.fetch(:description) %></p>
                <span class="mt-auto inline-flex items-center pt-5 text-sm font-semibold <%= option.fetch(:accent_classes) %>">
                  <%= option.fetch(:cta) %>
                  <span class="ml-1 transition group-hover:translate-x-1" aria-hidden="true">→</span>
                </span>
              </a>
            <% end %>
          </div>
        </div>

        <!-- Pubblici -->
        <div class="mt-14 border-t border-blue-800 pt-10">
          <p class="text-center text-xs font-bold uppercase tracking-[0.18em] text-blue-300">A chi è rivolto</p>
          <div class="mt-6 grid gap-4 md:grid-cols-3">
            <% audiences.each do |audience| %>
              <article class="rounded-2xl border p-5 <%= audience.fetch(:classes) %>">
                <span class="inline-flex rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider <%= audience.fetch(:badge_classes) %>">
                  <%= audience.fetch(:label) %>
                </span>
                <p class="mt-4 text-sm font-medium leading-6"><%= audience.fetch(:description) %></p>
              </article>
            <% end %>
          </div>
          <p class="mx-auto mt-6 max-w-3xl text-center text-sm leading-6 text-blue-200">
            Ogni contenuto indica a chi è rivolto e quali competenze professionali sono necessarie per applicarlo.
          </p>
        </div>
      </div>
    </section>
  </main>

  <%= render "posturacorretta/footer" %>

  <script>
    (() => {
      const root = document.currentScript.closest("[data-posturacorretta-home]");
      if (!root || root.dataset.posturacorrettaHomeReady === "true") return;
      root.dataset.posturacorrettaHomeReady = "true";

      root.querySelectorAll("[data-questions]").forEach((questionsRoot) => {
        const items = Array.from(questionsRoot.querySelectorAll("[data-question-item]"));

        function setQuestion(activeItem) {
          items.forEach((item) => {
            const button = item.querySelector("[data-question-button]");
            const panel = item.querySelector("[data-question-panel]");
            const chevron = item.querySelector("[data-question-chevron]");
            const open = item === activeItem;

            button.setAttribute("aria-expanded", String(open));
            panel.classList.toggle("hidden", !open);
            item.classList.toggle("border-blue-200", open);
            item.classList.toggle("ring-4", open);
            item.classList.toggle("ring-blue-50", open);
            chevron.classList.toggle("rotate-180", open);
          });
        }

        items.forEach((item) => {
          const button = item.querySelector("[data-question-button]");
          button.addEventListener("click", () => {
            const alreadyOpen = button.getAttribute("aria-expanded") === "true";
            if (alreadyOpen) {
              button.setAttribute("aria-expanded", "false");
              item.querySelector("[data-question-panel]").classList.add("hidden");
              item.querySelector("[data-question-chevron]").classList.remove("rotate-180");
              item.classList.remove("ring-4", "ring-blue-50");
            } else {
              setQuestion(item);
            }
          });
        });

        // Se si arriva alla pagina con un'ancora, apre la domanda corrispondente.
        function openQuestionFromHash() {
          if (!window.location.hash) return;
          const target = questionsRoot.querySelector(window.location.hash);
          if (target && target.matches("[data-question-item]")) setQuestion(target);
        }

        window.addEventListener("hashchange", openQuestionFromHash);
        openQuestionFromHash();
      });
    })();
  </script>
</div>
