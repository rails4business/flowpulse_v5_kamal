              class="mx-auto aspect-[16/10] w-full rounded-[1.5rem] object-contain xl:max-h-[300px]">
          </div>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-2 xl:mt-7 xl:grid-cols-5">
          <a href="?tab=percorso#percorso" data-landing-tab="percorso" class="group rounded-2xl border border-blue-100 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-blue-200 hover:shadow-xl xl:p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Percorso</p>
            <h2 class="mt-2 text-lg font-semibold text-slate-950">Personalizzato</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600 xl:leading-5">Scegli gli aspetti della salute su cui vuoi lavorare e costruisci il percorso più adatto a te.</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-blue-700 xl:mt-3">Inizia<span class="ml-1 transition group-hover:translate-x-1">→</span></span>
          </a>

          <a href="?tab=accademia#accademia" data-landing-tab="accademia" class="group rounded-2xl border border-blue-100 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-blue-200 hover:shadow-xl xl:p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Accademia</p>
            <h2 class="mt-2 text-lg font-semibold text-slate-950">Impara</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600 xl:leading-5"> Con le metodiche posturali, comprendi e riattiva i sistemi del corpo.</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-blue-700 xl:mt-3">Inizia l'accademia <span class="ml-1 transition group-hover:translate-x-1">→</span></span>
          </a>

          <a href="?tab=eventi#eventi" data-landing-tab="eventi" class="group rounded-2xl border border-blue-100 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-blue-200 hover:shadow-xl xl:p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Eventi e Community</p>
            <h2 class="mt-2 text-lg font-semibold text-slate-950">Vivi il percorso</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600 xl:leading-5">Incontri, camminate, attività e momenti di comunità sul territorio.</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-blue-700 xl:mt-3">Guarda <span class="ml-1 transition group-hover:translate-x-1">→</span></span>
          </a>
          <a href="?tab=filosofia#filosofia" data-landing-tab="filosofia" class="group rounded-2xl border border-blue-100 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-blue-200 hover:shadow-xl xl:p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Il libro</p>
            <h2 class="mt-2 text-lg font-semibold text-slate-950">Il corpo, un mondo da scoprire</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600 xl:leading-5">Dalla PosturaCorretta all'agriturismo rigenerativo Il Giardino del Corpo.</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-blue-700 xl:mt-3">Scopri il libro <span class="ml-1 transition group-hover:translate-x-1">→</span></span>
          </a>

          <a href="?tab=collabora#collabora" data-landing-tab="collabora" class="group rounded-2xl border border-blue-100 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-blue-200 hover:shadow-xl xl:p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Progetti</p>
            <h2 class="mt-2 text-lg font-semibold text-slate-950">In corso</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600 xl:leading-5">Aggiornamenti, cantieri aperti e prossimi sviluppi del progetto.</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-blue-700 xl:mt-3">Leggi gli aggiornamenti <span class="ml-1 transition group-hover:translate-x-1">→</span></span>
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- PERCORSO -->
  <!-- PERCORSO -->
<div id="percorso" data-tab-panel="percorso" class="<%= "hidden" unless active_landing_tab == "percorso" %>">

  <section class="flex min-h-[calc(100vh-4rem)] items-center px-5 py-6 md:py-10">
    <div class="mx-auto w-full max-w-6xl">
      <div class="grid gap-8 lg:grid-cols-[1.25fr_0.75fr] lg:items-stretch xl:gap-12">

        <!-- LEFT COLUMN: HERO TEXT + CHOICE CARDS -->
        <div class="flex flex-col justify-between space-y-6">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">
              Percorso personalizzato
            </p>

            <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 md:text-5xl md:leading-[1.05]">
              Costruisci <span class="text-blue-700">il tuo percorso</span>
            </h1>

            <p class="mt-4 text-base leading-7 text-slate-600">
              Con le metodiche posturali abbiamo scelto di mettere al centro il corpo. Seleziona uno o più bisogni della tua situazione attuale per tracciare il tuo percorso di salute personalizzato.
            </p>
          </div>

          <!-- CHOICE FORM -->
          <div class="border-t border-slate-200 pt-6">
            <h2 class="text-lg font-semibold tracking-tight text-slate-950">
              In cosa vuoi essere aiutato?
            </h2>

            <!-- 7 CHOICE CARDS -->
            <div class="mt-4 grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-2 xl:grid-cols-3">
              <button type="button" data-choice="Cura e Riabilitazione" data-path-key="cura"
                class="pc-choice rounded-2xl border border-red-200 bg-white p-4 text-left transition hover:-translate-y-0.5 hover:shadow-md">
                <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-red-700">Cura</p>
                <h3 class="mt-1 text-base font-semibold text-slate-950 leading-5">Cura e Riabilitazione</h3>
                <p class="mt-1.5 text-xs text-slate-500">Hai dolore, sintomi o una patologia?</p>
              </button>

              <button type="button" data-choice="Prevenzione" data-path-key="prevenzione"
                class="pc-choice rounded-2xl border border-orange-200 bg-white p-4 text-left transition hover:-translate-y-0.5 hover:shadow-md">
                <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-orange-700">Prevenzione</p>
                <h3 class="mt-1 text-base font-semibold text-slate-950 leading-5">Prevenzione</h3>
                <p class="mt-1.5 text-xs text-slate-500">Lavoro, sport o età?</p>
              </button>

              <button type="button" data-choice="Performance" data-path-key="performance"
                class="pc-choice rounded-2xl border border-yellow-200 bg-white p-4 text-left transition hover:-translate-y-0.5 hover:shadow-md">
                <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-yellow-700">Performance</p>
                <h3 class="mt-1 text-base font-semibold text-slate-950 leading-5">Performance</h3>
                <p class="mt-1.5 text-xs text-slate-500">Lavoro, studio o IA?</p>
              </button>

              <button type="button" data-choice="Benessere Integrato" data-path-key="benessere"
                class="pc-choice rounded-2xl border border-emerald-200 bg-white p-4 text-left transition hover:-translate-y-0.5 hover:shadow-md">
                <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-emerald-700">Benessere</p>
                <h3 class="mt-1 text-base font-semibold text-slate-950 leading-5">Benessere Integrato</h3>
                <p class="mt-1.5 text-xs text-slate-500">Salute, energia e qualità della vita?</p>
              </button>

              <button type="button" data-choice="Postura e Fisiologia" data-path-key="fisiologia"
                class="pc-choice rounded-2xl border border-blue-200 bg-white p-4 text-left transition hover:-translate-y-0.5 hover:shadow-md">
                <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-blue-700">Fisiologia</p>
                <h3 class="mt-1 text-base font-semibold text-slate-950 leading-5">Postura e Fisiologia</h3>
                <p class="mt-1.5 text-xs text-slate-500">Capire come funziona il corpo?</p>
              </button>

              <button type="button" data-choice="Corpo e Ambiente" data-path-key="ambiente"
                class="pc-choice rounded-2xl border border-indigo-200 bg-white p-4 text-left transition hover:-translate-y-0.5 hover:shadow-md">
                <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-indigo-700">Ambiente</p>
                <h3 class="mt-1 text-base font-semibold text-slate-950 leading-5">Corpo e Ambiente</h3>
                <p class="mt-1.5 text-xs text-slate-500">Rapporto tra corpo e ambiente?</p>
              </button>

              <button type="button" data-choice="Potenziale Umano" data-path-key="potenziale"
                class="pc-choice rounded-2xl border border-violet-200 bg-white p-4 text-left transition hover:-translate-y-0.5 hover:shadow-md sm:col-span-2 md:col-span-1 lg:col-span-2 xl:col-span-1">
                <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-violet-700">Potenziale</p>
                <h3 class="mt-1 text-base font-semibold text-slate-950 leading-5">Potenziale Umano</h3>
                <p class="mt-1.5 text-xs text-slate-500">Vuoi scoprire il tuo potenziale?</p>
              </button>
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN: HERO IMAGE + SUMMARY BOX -->
        <div class="flex flex-col justify-between space-y-6 lg:h-full">
          <div class="flex-1 rounded-[2rem] border border-slate-200 bg-white p-3 shadow-soft min-h-[220px] lg:min-h-0">
            <div class="hero-image-percorso h-full w-full rounded-[1.55rem]"></div>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-col justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
