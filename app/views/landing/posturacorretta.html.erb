      steps: [
        ["In costruzione", "Vuoi completare qualcosa in quest'area?", "Stiamo preparando contenuti sul rapporto corpo-ambiente, microcosmo-macrocosmo, natura, territorio e tradizioni.", ["Ambiente", "Tradizioni", "Stagioni"]]
      ]
    },

    potenziale: {
      color: "violet",
      kicker: "Potenziale Umano",
      title: "Scopri e coltiva le tue potenzialità.",
      description: "Per chi vuole esplorare le sfere dell'essere umano: corpo, emozioni, relazioni, creatività, espressione, modelli e crescita armonica.",
      joinTitle: "Vuoi proporre un'esperienza o un modello?",
      joinDescription: "Puoi contribuire con pratiche, eventi, modelli educativi, laboratori, musica, arte, movimento e percorsi di crescita.",
      joinTags: ["Creatività", "Relazioni", "Espressione", "Crescita"],
      stepsTitle: "Percorso in costruzione.",
      steps: [
        ["In costruzione", "Vuoi completare qualcosa in quest'area?", "Stiamo preparando contenuti ed esperienze per esplorare le sfere dell'essere umano e il potenziale personale.", ["Potenziale", "Espressione", "Armonia"]]
      ]
    }
  };

  const colorClasses = {
    red: { text: "text-red-700", bg: "bg-red-600", bgHover: "hover:bg-red-700", soft: "bg-red-50", border: "border-red-200" },
    orange: { text: "text-orange-700", bg: "bg-orange-500", bgHover: "hover:bg-orange-600", soft: "bg-orange-50", border: "border-orange-200" },
    yellow: { text: "text-yellow-700", bg: "bg-yellow-400", bgHover: "hover:bg-yellow-500", soft: "bg-yellow-50", border: "border-yellow-200" },
    emerald: { text: "text-emerald-700", bg: "bg-emerald-600", bgHover: "hover:bg-emerald-700", soft: "bg-emerald-50", border: "border-emerald-200" },
    blue: { text: "text-blue-700", bg: "bg-blue-600", bgHover: "hover:bg-blue-700", soft: "bg-blue-50", border: "border-blue-200" },
    indigo: { text: "text-indigo-700", bg: "bg-indigo-600", bgHover: "hover:bg-indigo-700", soft: "bg-indigo-50", border: "border-indigo-200" },
    violet: { text: "text-violet-700", bg: "bg-violet-700", bgHover: "hover:bg-violet-800", soft: "bg-violet-50", border: "border-violet-200" }
  };

  (() => {
    const cards = document.querySelectorAll("#percorso .pc-choice");
    const outputText = document.getElementById("selected-paths-text");
    const waLink = document.getElementById("start-whatsapp-link");
    const selectedChoices = new Set();

    // Modal elements
    const modal = document.getElementById("path-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const cancelModalBtn = document.getElementById("modal-cancel-btn");
    const selectModalBtn = document.getElementById("modal-select-btn");

    let modalActiveKey = null;
    let modalActiveChoice = null;

    function updateWhatsappText() {
      const values = Array.from(selectedChoices);
      outputText.textContent = values.length ? values.join(", ") : "Nessuna area selezionata.";
      const msg = values.length
        ? `Ciao, vorrei iniziare un percorso con PosturaCorretta. Le aree che mi interessano sono: ${values.join(", ")}.`
        : "Ciao, vorrei iniziare un percorso con PosturaCorretta.";
      waLink.href = `https://wa.me/393792891488?text=${encodeURIComponent(msg)}`;
    }

    function openModal(key, choice) {
      modalActiveKey = key;
      modalActiveChoice = choice;
      const path = academyPaths[key];
      const c = colorClasses[path.color];

      // Populate text details
      document.getElementById("modal-path-kicker").textContent = path.kicker;
      document.getElementById("modal-path-kicker").className = `text-xs font-semibold uppercase tracking-[0.22em] ${c.text}`;
      document.getElementById("modal-path-title").textContent = path.title;
      document.getElementById("modal-path-description").textContent = path.description;
      document.getElementById("modal-path-steps-title").textContent = path.stepsTitle;

      // Populate Steps
      const stepsContainer = document.getElementById("modal-path-steps");
      stepsContainer.innerHTML = "";
      path.steps.forEach((step, index) => {
        const [label, title, description, tags, modules = []] = step;
        stepsContainer.innerHTML += `
          <article class="relative pl-14 py-1">
            <div class="absolute left-0 top-0 grid h-9 w-9 place-items-center rounded-full ${c.bg} text-sm font-semibold text-white">
              ${index + 1}
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] ${c.text}">${label}</p>
              <h3 class="mt-1 text-lg font-semibold tracking-tight text-slate-950">${title}</h3>
              ${description ? `<p class="mt-2 text-sm leading-6 text-slate-600">${description}</p>` : ""}
              <div class="mt-3 flex flex-wrap gap-2">
                ${tags.map(tag => `<span class="rounded-full ${c.soft} px-2.5 py-0.5 text-xs font-medium ${c.text}">${tag}</span>`).join("")}
              </div>
              ${modules.length ? `
                <div class="mt-4 grid gap-2.5">
                  ${modules.map(([mNumber, mTitle, mItems]) => `
                    <div class="rounded-xl border ${c.border} bg-white p-3.5">
                      <p class="text-[10px] font-semibold uppercase tracking-[0.18em] ${c.text}">${mNumber}</p>
                      <h4 class="mt-0.5 text-sm font-semibold text-slate-950">${mTitle}</h4>
                      ${mItems.length ? `
                        <ul class="mt-2 grid gap-0.5 text-xs leading-5 text-slate-600 sm:grid-cols-2">
                          ${mItems.map(item => `<li>• ${item}</li>`).join("")}
                        </ul>
                      ` : ""}
                    </div>
                  `).join("")}
                </div>
              ` : ""}
            </div>
          </article>
        `;
      });

      // Populate Join Box
      document.getElementById("modal-join-box").className = `mt-8 rounded-2xl border ${c.border} bg-slate-50 p-6`;
      document.getElementById("modal-join-kicker").className = `text-xs font-semibold uppercase tracking-[0.18em] ${c.text}`;
      document.getElementById("modal-join-title").textContent = path.joinTitle;
      document.getElementById("modal-join-description").textContent = path.joinDescription;
      const joinTags = document.getElementById("modal-join-tags");
      joinTags.innerHTML = path.joinTags.map(tag => `
        <span class="rounded-full ${c.soft} px-2.5 py-0.5 text-xs font-medium ${c.text}">${tag}</span>
      `).join("");

      // Select button colors
      selectModalBtn.className = `flex-1 rounded-xl px-6 py-3.5 text-sm font-semibold text-white transition ${c.bg} ${c.bgHover}`;
      selectModalBtn.textContent = `Seleziona: ${path.kicker}`;

      // Open modal
      modal.classList.remove("hidden");
      document.body.classList.add("overflow-hidden");
    }

    function closeModal() {
      modal.classList.add("hidden");
      document.body.classList.remove("overflow-hidden");
      modalActiveKey = null;
      modalActiveChoice = null;
    }

    // Select button inside modal
    selectModalBtn.addEventListener("click", () => {
      if (modalActiveChoice) {
        selectedChoices.add(modalActiveChoice);
        const card = document.querySelector(`[data-choice="${modalActiveChoice}"]`);
        if (card) {
          card.classList.remove("bg-white");
          card.classList.add("ring-2", "ring-blue-600", "bg-blue-50");
        }
        updateWhatsappText();
      }
      closeModal();
    });

    cards.forEach(card => {
      card.addEventListener("click", () => {
        const choice = card.dataset.choice;
        const key = card.dataset.pathKey;

        if (selectedChoices.has(choice)) {
          // If already selected, click immediately deselects it without modal opening
          selectedChoices.delete(choice);
          card.classList.remove("ring-2", "ring-blue-600", "bg-blue-50");
          card.classList.add("bg-white");
          updateWhatsappText();
        } else {
          // Open details modal
          openModal(key, choice);
        }
      });
    });

    closeModalBtn.addEventListener("click", closeModal);
    cancelModalBtn.addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    updateWhatsappText();
  })();
</script>

<script>
  (() => {
    const allowedTabs = ["home", "percorso", "accademia", "eventi", "filosofia", "collabora"];
    const tabTriggers = document.querySelectorAll("[data-landing-tab]");
    const navButtons = document.querySelectorAll(".landing-tab-button[data-landing-tab]");
    const panels = document.querySelectorAll("[data-tab-panel]");
    const navStateClasses = [
      "border-blue-600", "border-transparent", "text-blue-700", "text-slate-700",
      "hover:border-blue-200", "hover:text-blue-700"
    ];

    function activateLandingTab(tabKey, updateUrl = true) {
      const nextTab = allowedTabs.includes(tabKey) ? tabKey : "home";

      navButtons.forEach((button) => {
        const active = button.dataset.landingTab === nextTab;
        button.setAttribute("aria-selected", active ? "true" : "false");
        button.classList.remove(...navStateClasses);

        button.classList.add(active ? "border-blue-600" : "border-transparent", active ? "text-blue-700" : "text-slate-700");
        if (!active) button.classList.add("hover:border-blue-200", "hover:text-blue-700");
      });

      panels.forEach((panel) => {
        panel.classList.toggle("hidden", panel.dataset.tabPanel !== nextTab);
      });

      if (updateUrl) {
        const url = new URL(window.location);
        url.searchParams.set("tab", nextTab);
        if (nextTab !== "percorso") url.searchParams.delete("path");
        url.hash = nextTab;
        window.history.replaceState({}, "", url);
        document.getElementById("top")?.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }

    tabTriggers.forEach((trigger) => {
      trigger.addEventListener("click", (event) => {
        event.preventDefault();
        activateLandingTab(trigger.dataset.landingTab);
      });
    });

    document.querySelectorAll("[data-jump-tab]").forEach((button) => {
      button.addEventListener("click", () => activateLandingTab(button.dataset.jumpTab));
    });

    window.addEventListener("popstate", () => {
      const tab = new URLSearchParams(window.location.search).get("tab");
      activateLandingTab(tab, false);
    });
  })();
</script>

<script>
  (() => {
    const statusTabs = document.querySelectorAll("[data-project-tab]");
    const articles = document.querySelectorAll("[data-project-status]");
    const activeClasses = ["bg-orange-500", "text-white"];
    const inactiveClasses = ["text-slate-600", "hover:bg-orange-50", "hover:text-orange-700"];

    function activateProjectStatus(status) {
      statusTabs.forEach((tab) => {
        const active = tab.dataset.projectTab === status;
        tab.setAttribute("aria-selected", active ? "true" : "false");
        tab.classList.remove(...activeClasses, ...inactiveClasses);
        tab.classList.add(...(active ? activeClasses : inactiveClasses));
      });

      articles.forEach((article) => {
        const visible = article.dataset.projectStatus === status;
        article.classList.toggle("hidden", !visible);
        if (!visible) article.open = false;
      });
    }

    statusTabs.forEach((tab) => {
      tab.addEventListener("click", () => activateProjectStatus(tab.dataset.projectTab));
    });

    activateProjectStatus("in-corso");
  })();
</script>
