<% content_for :title, "PosturaCorretta — Percorso della Salute" %>
<% active_landing_tab = params[:tab].presence_in(%w[salute collabora eventi about]) || "salute" %>

<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            pcblue: '#2563eb',
            pcink: '#0f172a'
          },
          boxShadow: {
            soft: '0 24px 70px rgba(15, 23, 42, 0.08)'
          }
        }
      }
    }
  </script>

  <style>
    html { scroll-behavior: smooth; }

    section[id],
    main[id] {
      scroll-margin-top: 5rem;
    }

    #percorso-dettaglio,
    #path-final-cta {
      scroll-margin-top: 8rem;
    }

    body {
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #ffffff;
    }

    .glass {
      background: rgba(255, 255, 255, .88);
      backdrop-filter: blur(18px);
    }

    .hero-image {
      background-image:
        linear-gradient(135deg, rgba(37, 99, 235, .10), rgba(15, 23, 42, .10)),
        url('https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=1200&q=80');
      background-size: cover;
      background-position: center;
    }

    .path-image {
      background-image:
        linear-gradient(135deg, rgba(37, 99, 235, .08), rgba(15, 23, 42, .06)),
        url('https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=900&q=80');
      background-size: cover;
      background-position: center;
    }

    .step-line::before {
      content: "";
      position: absolute;
      left: 1.12rem;
      top: 2.8rem;
      bottom: -2.6rem;
      width: 1px;
      background: #dbeafe;
    }

    .step-line:last-child::before { display: none; }

    .landing-tab-button[aria-selected="true"] { color: #fff; }
  </style>
<% end %>

<% content_for :landing_nav do %>
