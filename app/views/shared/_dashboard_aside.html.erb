<% superadmin = Current.user&.superadmin? %>
<% items = [
  { key: :dashboard, title: "Dashboard Superadmin", subtitle: "Panoramica interna", path: admin_dashboard_path },
{ key: :resources, title: "Risorse", subtitle: "Eventi, transazioni, contatti", path: admin_risorse_index_path },
  { key: :lavoro, title: "Lavoro", subtitle: "Creator, ruoli, attitudini, servizi", path: lavoro_path },
  { key: :salute, title: "Salute", subtitle: "Percorsi e corsi", path: salute_path },
  { key: :pages, title: "Elenco pagine", subtitle: "Prototipi e viste collegate", path: admin_elenco_pagine_path },
  { key: :weekplan, title: "Weekplan", subtitle: "Planner settimanale HTML", path: "/viste_html/6_weekplan.html" }
] %>

<aside class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm lg:sticky lg:top-24 lg:self-start">
  <div class="border-b border-slate-100 pb-4">
    <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">Workspace</p>
    <h2 class="mt-2 text-xl font-extrabold text-slate-950">Dashboard</h2>
    <span class="mt-2 block text-sm text-slate-500"><%= superadmin ? "Vista attiva: #{active_dashboard_role_label}" : "Vista attiva: Viaggiatori" %></span>
  </div>

  <nav class="mt-4 grid gap-2" aria-label="Navigazione dashboard">
    <% items.each do |item| %>
      <% active = current_section == item[:key] %>
      <% base_classes = "block rounded-xl border px-4 py-3 transition" %>
      <% active_classes = "border-slate-900 bg-slate-900 text-white" %>
      <% open_classes = "border-slate-200 bg-slate-50 text-slate-900 hover:border-slate-300 hover:bg-slate-100" %>
      <% locked_classes = "border-slate-200 bg-slate-50 text-slate-400" %>
      <% item_classes = [base_classes, (active ? active_classes : (superadmin ? open_classes : locked_classes))].join(" ") %>

      <% if superadmin %>
        <%= link_to item[:path], class: item_classes do %>
          <strong class="block text-sm font-extrabold"><%= item[:title] %></strong>
          <span class="mt-1 block text-sm <%= active ? 'text-slate-200' : 'text-slate-500' %>"><%= item[:subtitle] %></span>
        <% end %>
      <% elsif active %>
        <div class="<%= item_classes %>">
          <strong class="block text-sm font-extrabold"><%= item[:title] %></strong>
          <span class="mt-1 block text-sm text-slate-200"><%= item[:subtitle] %></span>
        </div>
      <% else %>
        <div class="<%= item_classes %>">
          <strong class="block text-sm font-extrabold"><%= item[:title] %></strong>
          <span class="mt-1 block text-sm text-slate-400"><%= item[:subtitle] %></span>
          <em class="mt-2 block text-xs font-bold uppercase tracking-[0.14em] text-slate-400 not-italic">Bloccato</em>
        </div>
      <% end %>
    <% end %>
  </nav>

  <% if superadmin %>
    <div class="mt-4 border-t border-slate-100 pt-4">
      <strong class="block text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">Simula dashboard</strong>
      <%= form_with url: dashboard_role_path, method: :patch, class: "mt-3" do %>
        <%= select_tag :role, options_for_select(available_dashboard_roles.map { |value, label| [label, value] }, active_dashboard_role), class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-900", onchange: "this.form.requestSubmit()" %>
      <% end %>
    </div>
  <% end %>
</aside>
