<div class="flex items-center gap-3">
  <button
    id="openSidebarButton"
    data-dashboard-mobile-toggle
    type="button"
    class="rounded-xl border border-slate-200 p-2 text-slate-600 hover:bg-slate-100 lg:hidden"
    aria-label="Apri menu"
  >
    <span aria-hidden="true">☰</span>
  </button>

  <div>
    <p class="text-sm text-slate-500"><%= dashboard_context.fetch(:eyebrow) %></p>
    <strong class="block text-lg font-bold leading-tight text-slate-950"><%= dashboard_context.fetch(:title) %></strong>
  </div>
</div>

<div class="flex items-center gap-2">
  <%= verified_link_to "Dashboard", dashboard_home_path, class: "hidden rounded-xl border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100 sm:block" %>

  <% if authenticated? %>
    <details class="relative">
      <summary class="flex cursor-pointer list-none items-center justify-center rounded-full border border-slate-200 bg-white p-0 text-slate-600 hover:bg-slate-100" aria-label="Apri menu profilo">
        <span class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-900 text-sm font-bold text-white">
          <%= (Current.user.profile&.display_name || Current.user.email_address).first.upcase %>
        </span>
      </summary>
      <div class="absolute right-0 z-50 mt-2 w-56 rounded-xl border border-slate-200 bg-white p-2 shadow-lg">
        <div class="px-3 py-2">
          <p class="text-sm font-semibold text-slate-950"><%= Current.user.profile&.display_name.presence || "Profilo" %></p>
          <p class="truncate text-xs text-slate-500"><%= Current.user.email_address %></p>
        </div>
        <div class="my-1 border-t border-slate-100"></div>
        <%= verified_link_to "Profilo", profile_path, class: "block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
        <div class="my-1 border-t border-slate-100"></div>
        <%= button_to "Esci", session_path, method: :delete, class: "w-full rounded-lg px-3 py-2 text-left text-sm font-medium text-red-600 hover:bg-red-50" %>
      </div>
    </details>
  <% end %>
</div>
