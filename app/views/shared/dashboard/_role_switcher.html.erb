<% aside_context = dashboard_aside_context(local_assigns[:current_section]) %>

<div class="flex-none border-t border-slate-100 p-4 space-y-2">
  <% if Current.user&.can_switch_roles? %>
    <%= form_with url: dashboard_role_path, method: :patch, class: "block", data: { turbo: false } do %>
      <%= select_tag :role,
        options_for_select(Current.user.ruoli_attivabili.map { |role| [ruolo_label(role), role] }, Current.user.active_role),
        class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
        onchange: "this.form.submit()" %>
    <% end %>
  <% end %>

  <% if Current.user %>
    <%
      mapped_role = Current.user.active_role
      role_assignment_role = case mapped_role
      when "creator" then :creator_of_worlds
      when "admin" then :segreteria_amministrativa
      else mapped_role.to_sym
      end

      assignments = if Current.user.superadmin_user?
        RoleAssignment.where(role: role_assignment_role)
      else
        Current.user.role_assignments.where(role: role_assignment_role)
      end
    %>

    <% if assignments.size > 1 %>
      <%= form_with url: dashboard_channel_path, method: :patch, class: "block", data: { turbo: false } do %>
        <div class="relative">
          <%= select_tag :role_assignment_id,
            options_for_select(assignments.map { |ra| [ra.display_name, ra.id] }, Current.user.current_role_assignment_id),
            class: "w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
            onchange: "this.form.submit()" %>
        </div>
      <% end %>
    <% elsif assignments.size == 1 %>
      <div class="px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-xs font-semibold text-slate-500 truncate flex items-center gap-1.5" title="<%= assignments.first.display_name %>">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <%= assignments.first.display_name %>
      </div>
    <% end %>
  <% end %>
</div>
