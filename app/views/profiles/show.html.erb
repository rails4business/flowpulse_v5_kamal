<div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-soft">
    <!-- Header -->
    <div class="border-b border-slate-100 bg-slate-50/50 px-6 py-6 sm:px-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-4">
          <span class="flex h-14 w-14 items-center justify-center rounded-full bg-blue-600 text-lg font-bold text-white shadow-sm ring-4 ring-blue-50">
            <%= (@profile&.display_name.presence || @user.email_address).first.upcase %>
          </span>
          <div>
            <h1 class="text-xl font-bold tracking-tight text-slate-900"><%= @profile&.display_name.presence || "Il tuo Profilo" %></h1>
            <p class="text-sm text-slate-500"><%= @user.email_address %></p>
          </div>
        </div>
        <div>
          <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-1 text-xs font-semibold text-blue-700">
            ID: #<%= @user.id %>
          </span>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="px-6 py-8 sm:px-8">
      <h2 class="text-base font-semibold leading-7 text-slate-900 mb-6">Informazioni Utente (Current.user)</h2>
      <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
        <div class="sm:col-span-1">
          <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">User ID</dt>
          <dd class="mt-1 text-sm font-mono text-slate-900 bg-slate-50 px-2.5 py-1.5 rounded-lg border border-slate-200 inline-block"><%= @user.id %></dd>
        </div>
        <div class="sm:col-span-1">
          <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Email Address</dt>
          <dd class="mt-1 text-sm text-slate-900 font-medium"><%= @user.email_address %></dd>
        </div>
        <div class="sm:col-span-1">
          <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Ruolo Attivo</dt>
          <dd class="mt-1 text-sm text-slate-900 font-medium"><%= @user.active_role.to_s.humanize %></dd>
        </div>
        <div class="sm:col-span-1">
          <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Superadmin?</dt>
          <dd class="mt-1 text-sm">
            <% if @user.superadmin %>
              <span class="inline-flex items-center rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Sì</span>
            <% else %>
              <span class="inline-flex items-center rounded-full bg-slate-50 px-2 py-0.5 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-500/10">No</span>
            <% end %>
          </dd>
        </div>
      </dl>

      <div class="my-8 border-t border-slate-100"></div>

      <h2 class="text-base font-semibold leading-7 text-slate-900 mb-6">Dettagli Profilo (Current.user.profile)</h2>
      <% if @profile %>
        <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
          <div class="sm:col-span-1">
            <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Profile ID</dt>
            <dd class="mt-1 text-sm font-mono text-slate-900 bg-slate-50 px-2.5 py-1.5 rounded-lg border border-slate-200 inline-block">#<%= @profile.id %></dd>
          </div>
          <div class="sm:col-span-1">
            <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Nome Display</dt>
            <dd class="mt-1 text-sm text-slate-900 font-medium"><%= @profile.display_name.presence || "Non impostato" %></dd>
          </div>
          <div class="sm:col-span-1">
            <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Nome</dt>
            <dd class="mt-1 text-sm text-slate-900 font-medium"><%= @profile.first_name.presence || "Non impostato" %></dd>
          </div>
          <div class="sm:col-span-1">
            <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Cognome</dt>
            <dd class="mt-1 text-sm text-slate-900 font-medium"><%= @profile.last_name.presence || "Non impostato" %></dd>
          </div>
          <div class="sm:col-span-1">
            <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Ruolo Profilo</dt>
            <dd class="mt-1 text-sm text-slate-900 font-medium"><%= @profile.role.presence || "Non impostato" %></dd>
          </div>
          <div class="sm:col-span-1">
            <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Creato il</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= l(@profile.created_at, format: :long) rescue @profile.created_at %></dd>
          </div>
        </dl>
      <% else %>
        <div class="rounded-xl bg-amber-50 p-4 border border-amber-200">
          <div class="flex">
            <div class="text-amber-800">
              <p class="text-sm font-medium">Nessun record di profilo associato a questo utente.</p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
