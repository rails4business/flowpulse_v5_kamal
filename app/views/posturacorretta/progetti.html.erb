<% provide :title, "Progetti — PosturaCorretta" %>
<% content_for :landing_nav do %>
  <%= render "posturacorretta/header" %>
<% end %>

<style>
  #progetti-section {
    --ink: #0f172a;
    --muted: #64748b;
    --paper: #f8fafc;
    --card: #ffffff;
    --line: #e2e8f0;
    --green: #0f766e;
    --lime: #14b8a6;
    --orange: #f59e0b;
    --blue: #4f46e5;
    --shadow: 0 10px 28px rgba(15, 23, 42, .07);
    min-height: calc(100vh - 4rem);
    background: var(--paper);
    color: var(--ink);
  }

  #progetti-section * { box-sizing: border-box; }
  #progetti-section button,
  #progetti-section input,
  #progetti-section select { font: inherit; }
  #progetti-section button { cursor: pointer; }

  #progetti-section .shell { min-height: calc(100vh - 4rem); }
  #progetti-section .main { max-width: 1240px; margin: 0 auto; padding: 30px 24px 64px; min-width: 0; }
  #progetti-section .topbar { display: flex; justify-content: space-between; align-items: center; gap: 20px; margin-bottom: 24px; }
  #progetti-section .eyebrow { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .14em; font-weight: 800; }
  #progetti-section .topbar h1 { margin: 4px 0 0; font-size: clamp(28px, 4vw, 42px); font-weight: 850; letter-spacing: -.04em; }
  #progetti-section .tool-badge { display: inline-flex; align-items: center; gap: 8px; padding: 9px 12px; border: 1px solid var(--line); border-radius: 999px; background: white; color: #334155; font-size: 12px; font-weight: 800; }
  #progetti-section .tool-badge span { display: grid; place-items: center; width: 24px; height: 24px; border-radius: 999px; background: #ccfbf1; color: #0f766e; }

  #progetti-section .hero { display: grid; grid-template-columns: minmax(0, 1.25fr) auto; gap: 24px; align-items: center; overflow: hidden; position: relative; padding: 28px; border-radius: 18px; background: linear-gradient(135deg, #0f766e, #14532d); color: white; box-shadow: var(--shadow); }
  #progetti-section .hero::after { content: ""; position: absolute; right: -80px; top: -95px; width: 230px; height: 230px; border: 48px solid rgba(204, 251, 241, .14); border-radius: 999px; }
  #progetti-section .hero h2 { position: relative; z-index: 1; margin: 6px 0 10px; max-width: 680px; font-size: clamp(26px, 4vw, 38px); line-height: 1.05; font-weight: 850; letter-spacing: -.04em; }
  #progetti-section .hero p { position: relative; z-index: 1; max-width: 760px; margin: 0; color: #d1fae5; line-height: 1.6; }
  #progetti-section .hero-actions { position: relative; z-index: 1; display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 10px; }

  #progetti-section .btn { display: inline-flex; align-items: center; justify-content: center; gap: 7px; border: 1px solid var(--line); border-radius: 11px; background: white; color: var(--ink); padding: 10px 14px; font-size: 13px; font-weight: 800; transition: .18s ease; }
  #progetti-section .btn:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(15, 23, 42, .08); }
  #progetti-section .btn.primary { background: #14b8a6; border-color: #14b8a6; color: white; }
  #progetti-section .btn.dark { background: rgba(15, 23, 42, .22); border-color: rgba(255, 255, 255, .28); color: white; }

  #progetti-section .company-bar { display: grid; grid-template-columns: auto minmax(0, 1fr) auto; gap: 14px; align-items: center; margin: 18px 0; padding: 14px; border: 1px solid var(--line); border-radius: 16px; background: white; box-shadow: 0 1px 3px rgba(15, 23, 42, .04); }
  #progetti-section .company-bar-head strong { display: block; font-size: 13px; }
  #progetti-section .company-bar-head span { display: block; margin-top: 2px; color: var(--muted); font-size: 11px; }
  #progetti-section .company-list { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 1px; }
  #progetti-section .company,
  #progetti-section .add-company { flex: 0 0 auto; display: inline-flex; align-items: center; gap: 10px; border: 1px solid var(--line); border-radius: 999px; background: #f8fafc; color: #475569; padding: 8px 11px; font-size: 12px; font-weight: 800; }
  #progetti-section .company span:last-child { display: grid; place-items: center; min-width: 22px; height: 22px; border-radius: 999px; background: white; color: #64748b; font-size: 11px; }
  #progetti-section .company.active { background: #0f766e; border-color: #0f766e; color: white; }
  #progetti-section .company.active span:last-child { color: #0f766e; }
  #progetti-section .add-company { background: white; color: #0f766e; }

  #progetti-section .stats { display: grid; gap: 14px; margin: 18px 0 26px; }
  #progetti-section .stat { border: 1px solid var(--line); border-radius: 16px; background: white; padding: 18px; box-shadow: 0 1px 3px rgba(15, 23, 42, .04); }
  #progetti-section .stat small { color: var(--muted); font-size: 11px; font-weight: 750; text-transform: uppercase; letter-spacing: .08em; }
  #progetti-section .stat strong { display: block; margin-top: 8px; font-size: 26px; font-weight: 850; letter-spacing: -.04em; }
  #progetti-section .stat-sub { display: block; margin-top: 2px; color: var(--muted); font-size: 12px; font-weight: 700; }

  #progetti-section .section-head { display: flex; align-items: end; justify-content: space-between; gap: 16px; margin: 22px 0 14px; }
  #progetti-section .section-head h3 { margin: 4px 0 0; font-size: 24px; font-weight: 850; letter-spacing: -.03em; }
  #progetti-section .filters { display: flex; flex-wrap: wrap; gap: 8px; }
  #progetti-section .filter { border: 1px solid var(--line); border-radius: 999px; background: white; color: var(--muted); padding: 8px 12px; font-size: 12px; font-weight: 800; }
  #progetti-section .filter.active { background: var(--ink); border-color: var(--ink); color: white; }

  #progetti-section .projects { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
  #progetti-section .project { border: 1px solid var(--line); border-radius: 16px; background: white; padding: 18px; box-shadow: 0 1px 3px rgba(15, 23, 42, .05); transition: .18s ease; }
  #progetti-section .project:hover { transform: translateY(-1px); border-color: #cbd5e1; box-shadow: var(--shadow); }
  #progetti-section .project-top,
  #progetti-section .project-foot,
  #progetti-section .funding-row,
  #progetti-section .panel-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  #progetti-section .badge { display: inline-flex; border: 1px solid #ccfbf1; border-radius: 999px; background: #f0fdfa; color: #0f766e; padding: 4px 8px; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: .07em; }
  #progetti-section .badge.orange { background: #fffbeb; color: #b45309; border-color: #fde68a; }
  #progetti-section .badge.blue { background: #eef2ff; color: #4338ca; border-color: #c7d2fe; }
  #progetti-section .status { color: var(--muted); font-size: 12px; font-weight: 700; }
  #progetti-section .project h4 { margin: 12px 0 6px; font-size: 19px; line-height: 1.2; font-weight: 850; letter-spacing: -.025em; }
  #progetti-section .project-desc { min-height: 42px; color: var(--muted); font-size: 13px; line-height: 1.5; }
  #progetti-section .simple-funding { margin-top: 14px; padding-top: 14px; border-top: 1px solid #f1f5f9; }
  #progetti-section .funding-row { margin-bottom: 7px; font-size: 12px; }
  #progetti-section .progress { height: 7px; overflow: hidden; border-radius: 999px; background: #e2e8f0; }
  #progetti-section .progress span { display: block; height: 100%; border-radius: inherit; background: #14b8a6; }
  #progetti-section .simple-funding small { display: block; margin-top: 7px; color: var(--muted); font-size: 11px; }
  #progetti-section .next-action { margin-top: 13px; border: 1px solid #f1f5f9; border-radius: 10px; background: #f8fafc; padding: 10px 11px; }
  #progetti-section .next-action span { display: block; color: var(--muted); font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: .08em; }
  #progetti-section .next-action strong { display: block; margin-top: 3px; color: #334155; font-size: 13px; }
  #progetti-section .project-foot { margin-top: 14px; }
  #progetti-section .open { border: 0; background: transparent; color: #0f766e; font-size: 12px; font-weight: 850; }
  #progetti-section .empty { grid-column: 1 / -1; border: 1px dashed #cbd5e1; border-radius: 16px; background: white; padding: 44px; color: var(--muted); text-align: center; }

  #progetti-section dialog { width: min(860px, calc(100vw - 28px)); max-height: 88vh; overflow: auto; border: 0; border-radius: 20px; padding: 0; background: white; box-shadow: 0 30px 100px rgba(15, 23, 42, .28); }
  #progetti-section dialog::backdrop { background: rgba(15, 23, 42, .55); backdrop-filter: blur(4px); }
  #progetti-section .modal-head,
  #progetti-section .modal-foot { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 18px 22px; border-bottom: 1px solid var(--line); }
  #progetti-section .modal-foot { border-top: 1px solid var(--line); border-bottom: 0; justify-content: flex-end; }
  #progetti-section .modal-head h3 { margin: 0; font-size: 22px; font-weight: 850; letter-spacing: -.025em; }
  #progetti-section .close { border: 0; background: transparent; color: #64748b; font-size: 25px; line-height: 1; }
  #progetti-section .modal-body { padding: 22px; }
  #progetti-section .form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
  #progetti-section .field { display: grid; gap: 7px; }
  #progetti-section .field.full,
  #progetti-section .form-section.full { grid-column: 1 / -1; }
  #progetti-section .field label { font-size: 12px; font-weight: 850; }
  #progetti-section .field input,
  #progetti-section .field select { width: 100%; border: 1px solid var(--line); border-radius: 10px; background: white; padding: 10px 11px; color: var(--ink); }
  #progetti-section .form-section { border: 1px solid var(--line); border-radius: 14px; background: #f8fafc; padding: 12px; }
  #progetti-section .form-section summary { display: flex; justify-content: space-between; cursor: pointer; font-size: 13px; font-weight: 850; }
  #progetti-section .inner-grid { margin-top: 13px; }
  #progetti-section .stage-current,
  #progetti-section .detail-kpi { border: 1px solid var(--line); border-radius: 14px; background: #f8fafc; padding: 14px; }
  #progetti-section .stage-current small,
  #progetti-section .detail-kpi small { display: block; color: var(--muted); font-size: 10px; font-weight: 850; text-transform: uppercase; letter-spacing: .08em; }
  #progetti-section .stage-current strong,
  #progetti-section .detail-kpi strong { display: block; margin-top: 5px; font-size: 20px; font-weight: 850; }
  #progetti-section .detail-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin: 14px 0; }
  #progetti-section .tabs { display: flex; gap: 7px; margin: 16px 0 0; border-bottom: 1px solid var(--line); }
  #progetti-section .tab { border: 0; border-bottom: 2px solid transparent; background: transparent; color: var(--muted); padding: 10px 12px; font-size: 12px; font-weight: 850; }
  #progetti-section .tab.active { border-bottom-color: #0f766e; color: #0f766e; }
  #progetti-section .tab-panel { display: none; padding-top: 16px; }
  #progetti-section .tab-panel.active { display: block; }
  #progetti-section .table-wrap { overflow-x: auto; margin-top: 12px; border: 1px solid var(--line); border-radius: 14px; }
  #progetti-section .ledger { width: 100%; border-collapse: collapse; font-size: 12px; }
  #progetti-section .ledger th,
  #progetti-section .ledger td { padding: 11px 12px; border-bottom: 1px solid #f1f5f9; text-align: left; white-space: nowrap; }
  #progetti-section .ledger th { background: #f8fafc; color: #64748b; font-size: 10px; text-transform: uppercase; letter-spacing: .08em; }
  #progetti-section .positive { color: #0f766e; font-weight: 850; }
  #progetti-section .note { margin-top: 12px; color: var(--muted); font-size: 12px; line-height: 1.5; }

  @media (max-width: 860px) {
    #progetti-section .main { padding: 22px 14px 48px; }
    #progetti-section .topbar,
    #progetti-section .section-head,
    #progetti-section .hero { grid-template-columns: 1fr; align-items: start; }
    #progetti-section .hero-actions { justify-content: flex-start; }
    #progetti-section .company-bar { grid-template-columns: 1fr; }
    #progetti-section .stats { grid-template-columns: 1fr !important; }
    #progetti-section .projects,
    #progetti-section .form-grid,
    #progetti-section .detail-summary { grid-template-columns: 1fr; }
    #progetti-section .filters { overflow-x: auto; flex-wrap: nowrap; padding-bottom: 2px; }
  }
</style>

<div id="progetti-section">
  <div class="shell">
    <main class="main">
      <header class="topbar">
        <div>
          <div class="eyebrow">PosturaCorretta / progetti</div>
          <h1 id="companyTitle">PosturaCorretta</h1>
        </div>
        <div class="tool-badge"><span>G</span> GeneraImpresa</div>
      </header>
      <section class="hero">
        <div>
          <div class="eyebrow" style="color:#a9c1b4">Progetti</div>
          <h2>Trasforma le idee in progetti sostenibili.</h2>
          <p>Definisci cosa crei, quanto costa, chi lo realizza e cosa può generare. Poi raccogli capitale o tempo prima di dare il via.</p>
        </div>
        <div class="hero-actions">
          <button class="btn dark" id="exportBtn">Esporta dati</button>
          <button class="btn primary" id="newProject">＋ Nuovo progetto</button>
        </div>
      </section>
      <section class="company-bar" aria-label="Filtra i progetti per area">
        <div class="company-bar-head">
          <strong>Aree progettuali</strong>
          <span>Filtra i progetti</span>
        </div>
        <div class="company-list" id="companies"></div>
        <button class="add-company" id="addCompany">＋ Nuova area</button>
      </section>
      <section class="stats" style="grid-template-columns:repeat(3,1fr)">
        <div class="stat">
          <small>Progetti attivi</small>
          <strong id="activeCount">0</strong>
        </div>
        <div class="stat">
          <small>Risorse raccolte</small>
          <strong id="fundedTotal">€ 0</strong>
        </div>
        <div class="stat">
          <small>Ricavi previsti / anno</small>
          <strong id="revenueTotal">€ 0</strong>
        </div>
      </section>
      <div class="section-head">
        <div>
          <div class="eyebrow">Decisioni e avanzamento</div>
          <h3>Progetti</h3>
        </div>
        <div class="filters">
          <button class="filter active" data-filter="all">Tutti</button>
          <button class="filter" data-filter="Raccolta">In raccolta</button>
          <button class="filter" data-filter="Attivo">Attivi</button>
          <button class="filter" data-filter="Idea">Da valutare</button>
        </div>
      </div>
      <section class="projects" id="projects"></section>
    </main>
  </div>

  <dialog id="projectDialog">
    <form method="dialog" id="projectForm">
      <div class="modal-head">
        <h3>Nuovo progetto</h3>
        <button class="close" value="cancel" aria-label="Chiudi">×</button>
      </div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="field full">
            <label>Nome del progetto</label>
            <input name="name" required placeholder="Es. Accademia online">
          </div>
          <div class="field">
            <label>Cosa crea?</label>
            <select name="type">
              <option>Servizio</option>
              <option>Prodotto</option>
              <option>App</option>
              <option>Evento</option>
              <option>Contenuto</option>
              <option>Altro</option>
            </select>
          </div>
          <div class="field">
            <label>Stato</label>
            <select name="status">
              <option>Idea</option>
              <option>Raccolta</option>
              <option>Attivo</option>
            </select>
          </div>
          <div class="field full">
            <label>Risultato concreto</label>
            <input name="output" required placeholder="Cosa esisterà alla fine del progetto?">
          </div>
          <details class="form-section full">
            <summary>Economia e raccolta <span>Apri</span></summary>
            <div class="form-grid inner-grid">
              <div class="field">
                <label>Costi iniziali (€)</label>
                <input name="initial" type="number" min="0" value="10000">
              </div>
              <div class="field">
                <label>Manutenzione annua (€)</label>
                <input name="maintenance" type="number" min="0" value="1200">
              </div>
              <div class="field">
                <label>Ricavi previsti annui (€)</label>
                <input name="revenue" type="number" min="0" value="18000">
              </div>
              <div class="field">
                <label>Fondi già raccolti (€)</label>
                <input name="funded" type="number" min="0" value="0">
              </div>
              <div class="field">
                <label>Dash già raccolti</label>
                <input name="fundedDash" type="number" min="0" step="0.01" value="0">
              </div>
              <div class="field">
                <label>Valore interno di 1 Dash (€)</label>
                <input name="dashRate" type="number" min="0" step="0.01" value="100">
              </div>
            </div>
          </details>
          <details class="form-section full">
            <summary>Organizzazione <span>Apri</span></summary>
            <div class="form-grid inner-grid">
              <div class="field">
                <label>Numero di step</label>
                <input name="steps" type="number" min="1" value="5">
              </div>
              <div class="field">
                <label>Responsabile</label>
                <input name="owner" placeholder="Da assegnare">
              </div>
            </div>
          </details>
        </div>
      </div>
      <div class="modal-foot">
        <button class="btn" value="cancel">Annulla</button>
        <button class="btn primary" value="default" id="saveProject">Crea progetto</button>
      </div>
    </form>
  </dialog>

  <dialog id="companyDialog">
    <form method="dialog" id="companyForm">
      <div class="modal-head">
        <h3>Nuova area progettuale</h3>
        <button class="close" value="cancel">×</button>
      </div>
      <div class="modal-body">
        <div class="field">
          <label>Nome area</label>
          <input name="company" required placeholder="Nome della nuova area progettuale">
        </div>
      </div>
      <div class="modal-foot">
        <button class="btn" value="cancel">Annulla</button>
        <button class="btn primary" value="default" id="saveCompany">Aggiungi</button>
      </div>
    </form>
  </dialog>

  <dialog id="detailDialog" class="detail-dialog">
    <div class="modal-head">
      <div>
        <div class="eyebrow">Ciclo economico del progetto</div>
        <h3 id="detailTitle">Progetto</h3>
      </div>
      <button class="close" onclick="detailDialog.close()">×</button>
    </div>
    <div class="modal-body" id="detailBody"></div>
    <div class="modal-foot">
      <button class="btn" onclick="detailDialog.close()">Chiudi</button>
    </div>
  </dialog>

  <script>
    const seed=[
      {id:1,company:'PosturaCorretta',name:'Accademia PosturaCorretta',type:'Servizio',status:'Attivo',output:'Percorso formativo online e in presenza',initial:18000,maintenance:4200,revenue:42000,funded:17000,fundedDash:10,dashRate:100,steps:8,done:5,owner:'Marco',people:['MB','AV','+2']},
      {id:2,company:'PosturaCorretta',name:'Il corpo, un mondo da scoprire',type:'Prodotto',status:'Raccolta',output:'Libro e percorso di ingresso all’ecosistema',initial:9300,maintenance:600,revenue:24000,funded:5600,fundedDash:5,dashRate:100,steps:6,done:3,owner:'Marco',people:['MB','ED']},
      {id:3,company:'Flowpulse',name:'1Impegno',type:'App',status:'Raccolta',output:'Agenda condivisa per eventi, servizi e referral',initial:32000,maintenance:7800,revenue:54000,funded:11400,fundedDash:10,dashRate:100,steps:12,done:4,owner:'Da assegnare',people:['MB','?']},
      {id:4,company:'Flowpulse',name:'Rails4Business',type:'Servizio',status:'Idea',output:'Percorso e linee guida per collaboratori digitali',initial:7500,maintenance:1800,revenue:15000,funded:800,fundedDash:0,dashRate:100,steps:7,done:1,owner:'Marco',people:['MB']},
      {id:5,company:'Il Giardino del Corpo',name:'Primo evento rigenerativo',type:'Evento',status:'Idea',output:'Un’esperienza pilota di una giornata',initial:4800,maintenance:0,revenue:7200,funded:700,fundedDash:5,dashRate:100,steps:9,done:2,owner:'Da assegnare',people:['MB','?']}
    ];
    let data=JSON.parse(localStorage.getItem('genera-projects')||'null')||seed;
    let companies=JSON.parse(localStorage.getItem('genera-companies')||'null')||['PosturaCorretta','Flowpulse','Il Giardino del Corpo'];
    let selected=companies[0], filter='all';
    const eur=n=>new Intl.NumberFormat('it-IT',{style:'currency',currency:'EUR',maximumFractionDigits:0}).format(n);
    
    function persist(){
      localStorage.setItem('genera-projects',JSON.stringify(data));
      localStorage.setItem('genera-companies',JSON.stringify(companies));
    }
    
    function renderCompanies(){
      document.querySelector('#companies').innerHTML=companies.map(c=>`<button class="company ${c===selected?'active':''}" data-company="${c}"><span>${c}</span><span>${data.filter(p=>p.company===c).length}</span></button>`).join('');
      document.querySelectorAll('[data-company]').forEach(b=>b.onclick=()=>{
        selected=b.dataset.company;
        filter='all';
        render();
      });
    }
    
    function render(){
      renderCompanies();
      document.querySelector('#companyTitle').textContent=selected;
      const all=data.filter(p=>p.company===selected),
            view=all.filter(p=>filter==='all'||p.status===filter),
            euro=all.reduce((s,p)=>s+p.funded,0),
            dash=all.reduce((s,p)=>s+(p.fundedDash||0),0);
      document.querySelector('#activeCount').textContent=all.filter(p=>p.status==='Attivo').length;
      document.querySelector('#fundedTotal').innerHTML=`${eur(euro)} <span class="stat-sub">+ ${dash.toLocaleString('it-IT')} DASH</span>`;
      document.querySelector('#revenueTotal').textContent=eur(all.reduce((s,p)=>s+p.revenue,0));
      document.querySelector('#projects').innerHTML=view.length?view.map(card).join(''):'<div class="empty">Nessun progetto in questa sezione.</div>';
    }
    
    function card(p){
      ensureFinance(p);
      const dash=p.fundedDash||0,
            rate=p.dashRate||100,
            equivalent=p.funded+dash*rate,
            pc=Math.min(100,Math.round(equivalent/p.initial*100)||0),
            ready=pc>=100&&p.owner!=='Da assegnare',
            next=p.owner==='Da assegnare'?'Assegna un responsabile':pc<100?'Completa la raccolta':p.done<p.steps?'Continua la realizzazione':'Gestisci rendite e quote',
            cls=p.type==='App'?'blue':p.status==='Raccolta'?'orange':'';
      return `<article class="project"><div class="project-top"><span class="badge ${cls}">${p.type}</span><span class="status">${ready?'● Pronto':p.status}</span></div><h4>${p.name}</h4><div class="project-desc">${p.output}</div><div class="simple-funding"><div class="funding-row"><span>Raccolta</span><strong>${pc}% di ${eur(p.initial)}</strong></div><div class="progress"><span style="width:${pc}%"></span></div><small>${eur(p.funded)} + ${dash.toLocaleString('it-IT')} DASH</small></div><div class="next-action"><span>Prossimo passo</span><strong>${next}</strong></div><div class="project-foot"><small style="color:var(--muted)">${p.done}/${p.steps} step · ${p.owner}</small><button class="open" onclick="openProject(${p.id})">Apri progetto &rarr;</button></div></article>`;
    }
    
    function ensureFinance(p){
      if(p.capitalRepaid==null) p.capitalRepaid=Math.round(p.initial*(p.status==='Attivo'?.45:0));
      if(!p.shares) p.shares=[{name:'Marco',kind:'Denaro',units:60,paid:p.funded*.6,returns:0},{name:'Collaboratori',kind:'Tempo',units:25,paid:p.initial*.25,returns:0},{name:'Riserva progetto',kind:'Impresa',units:15,paid:0,returns:0}];
      if(!p.monthly) p.monthly=[];
      if(!p.saleOffers) p.saleOffers=[];
    }
    
    function openProject(id){
      const p=data.find(x=>x.id===id);
      ensureFinance(p);
      window.currentProject=id;
      document.querySelector('#detailTitle').textContent=p.name;
      renderDetail(p);
      document.querySelector('#detailDialog').showModal();
    }
    
    function renderDetail(p){
      const totalDistributed=p.monthly.reduce((s,m)=>s+m.distributed,0),
            remaining=Math.max(0,p.initial-p.capitalRepaid),
            stage=p.funded+(p.fundedDash||0)*(p.dashRate||100)<p.initial?'Raccolta fondi':p.capitalRepaid<p.initial?'Restituzione del capitale':'Rendita e scambio quote';
      document.querySelector('#detailBody').innerHTML=`
        <div class="stage-current"><small>Fase attuale</small><strong>${stage}</strong></div>
        <div class="detail-summary">
          <div class="detail-kpi"><small>Da restituire</small><strong>${eur(remaining)}</strong></div>
          <div class="detail-kpi"><small>Restituito</small><strong>${eur(p.capitalRepaid)}</strong></div>
          <div class="detail-kpi"><small>Utili distribuiti</small><strong>${eur(totalDistributed)}</strong></div>
        </div>
        <div class="tabs">
          <button class="tab active" onclick="showTab(event,'capital')">Quote</button>
          <button class="tab" onclick="showTab(event,'months')">Mesi e utili</button>
          <button class="tab" onclick="showTab(event,'market')">Compravendita</button>
        </div>
        <section class="tab-panel active" id="capital">
          <div class="panel-head"><h4>Registro dei possessori</h4><button class="btn primary" onclick="repayCapital()">＋ Registra restituzione</button></div>
          <div class="table-wrap">
            <table class="ledger">
              <thead><tr><th>Possessore</th><th>Origine</th><th>Quote</th><th>Valore conferito</th><th>Restituzioni</th><th>Utili ricevuti</th></tr></thead>
              <tbody>${p.shares.map(s=>`<tr><td><strong>${s.name}</strong></td><td>${s.kind}</td><td>${s.units} (${s.units}%)</td><td>${eur(s.paid)}</td><td>${eur(Math.min(s.paid,p.capitalRepaid*s.units/100))}</td><td class="positive">${eur(totalDistributed*s.units/100)}</td></tr>`).join('')}</tbody>
            </table>
          </div>
          <div class="note">Le quote determinano la distribuzione degli utili; prestiti, quote e lavoro investito restano registrati come conferimenti distinti.</div>
        </section>
        <section class="tab-panel" id="months">
          <div class="panel-head"><h4>Risultati e distribuzioni</h4><button class="btn primary" onclick="addMonth()">＋ Registra mese</button></div>
          <div class="table-wrap">
            <table class="ledger">
              <thead><tr><th>Mese</th><th>Ricavi</th><th>Costi</th><th>Riserva</th><th>Restituzione</th><th>Utile distribuito</th></tr></thead>
              <tbody>${p.monthly.length?p.monthly.map(m=>`<tr><td><strong>${m.month}</strong></td><td>${eur(m.revenue)}</td><td>${eur(m.costs)}</td><td>${eur(m.reserve)}</td><td>${eur(m.repayment)}</td><td class="positive">${eur(m.distributed)}</td></tr>`).join(''):'<tr><td colspan="6">Nessun mese registrato.</td></tr>'}</tbody>
            </table>
          </div>
          <div class="note">Ordine del flusso: ricavi &rarr; costi &rarr; riserva &rarr; restituzione del capitale &rarr; utile distribuibile ai possessori delle quote.</div>
        </section>
        <section class="tab-panel" id="market">
          <div class="panel-head"><h4>Mercato interno delle quote</h4><button class="btn primary" onclick="sellShares()">＋ Metti in vendita</button></div>
          <div class="table-wrap">
            <table class="ledger">
              <thead><tr><th>Venditore</th><th>Quote</th><th>Prezzo €</th><th>Prezzo Dash</th><th>Stato</th><th></th></tr></thead>
              <tbody>${p.saleOffers.length?p.saleOffers.map((o,i)=>`<tr><td>${o.seller}</td><td>${o.units}</td><td>${eur(o.euro)}</td><td>${o.dash} DASH</td><td>${o.status}</td><td><button class="open" onclick="buyShares(${i})">Acquista</button></td></tr>`).join(''):'<tr><td colspan="6">Nessuna quota attualmente in vendita.</td></tr>'}</tbody>
            </table>
          </div>
          <div class="note">Ogni passaggio conserva venditore, acquirente, quantità, prezzo e data. La nuova distribuzione decorre dal periodo successivo al trasferimento.</div>
        </section>`;
    }
    
    function showTab(e,id){
      document.querySelectorAll('.tab,.tab-panel').forEach(x=>x.classList.remove('active'));
      e.currentTarget.classList.add('active');
      document.querySelector('#'+id).classList.add('active');
    }
    
    function repayCapital(){
      const p=data.find(x=>x.id===currentProject),
            amount=Number(prompt('Importo restituito agli investitori (€):','1000'));
      if(amount>0){
        p.capitalRepaid=Math.min(p.initial,p.capitalRepaid+amount);
        persist();
        render();
        renderDetail(p);
      }
    }
    
    function addMonth(){
      const p=data.find(x=>x.id===currentProject),
            month=prompt('Mese del rendiconto:','Luglio 2026');
      if(!month) return;
      const revenue=Number(prompt('Ricavi del mese (€):','5000'))||0,
            costs=Number(prompt('Costi del mese (€):','1800'))||0,
            reserve=Math.max(0,Number(prompt('Somma trattenuta come riserva (€):','500'))||0),
            repayment=Math.min(Math.max(0,p.initial-p.capitalRepaid),Math.max(0,Number(prompt('Capitale restituito questo mese (€):','1000'))||0)),
            distributed=Math.max(0,revenue-costs-reserve-repayment);
      p.capitalRepaid+=repayment;
      p.monthly.push({month,revenue,costs,reserve,repayment,distributed});
      persist();
      render();
      renderDetail(p);
    }
    
    function sellShares(){
      const p=data.find(x=>x.id===currentProject),
            seller=prompt('Chi vende le quote?','Marco');
      if(!seller) return;
      const units=Number(prompt('Numero di quote:','5'))||0,
            euro=Number(prompt('Prezzo totale in euro:','500'))||0,
            dash=Number(prompt('Oppure prezzo totale in Dash:','5'))||0;
      if(units>0){
        p.saleOffers.push({seller,units,euro,dash,status:'Disponibile'});
        persist();
        renderDetail(p);
      }
    }
    
    function buyShares(i){
      const p=data.find(x=>x.id===currentProject),
            o=p.saleOffers[i],
            buyer=prompt('Nome dell’acquirente:');
      if(!buyer) return;
      o.status='Venduta a '+buyer;
      const owner=p.shares.find(s=>s.name===o.seller);
      if(owner) owner.units=Math.max(0,owner.units-o.units);
      const existing=p.shares.find(s=>s.name===buyer);
      if(existing) existing.units+=o.units;
      else p.shares.push({name:buyer,kind:'Acquisto quote',units:o.units,paid:o.euro||o.dash*(p.dashRate||100),returns:0});
      persist();
      renderDetail(p);
    }
    
    document.querySelectorAll('.filter').forEach(b=>b.onclick=()=>{
      filter=b.dataset.filter;
      document.querySelectorAll('.filter').forEach(x=>x.classList.toggle('active',x===b));
      render();
    });
    
    const pd=document.querySelector('#projectDialog');
    document.querySelector('#newProject').onclick=()=>pd.showModal();
    document.querySelector('#saveProject').onclick=e=>{
      const f=document.querySelector('#projectForm');
      if(!f.reportValidity()){
        e.preventDefault();
        return;
      }
      const v=Object.fromEntries(new FormData(f));
      data.push({
        id:Date.now(),
        company:selected,
        name:v.name,
        type:v.type,
        status:v.status,
        output:v.output,
        initial:+v.initial,
        maintenance:+v.maintenance,
        revenue:+v.revenue,
        funded:+v.funded,
        fundedDash:+v.fundedDash,
        dashRate:+v.dashRate,
        steps:+v.steps,
        done:0,
        owner:v.owner||'Da assegnare',
        people:[v.owner? v.owner.split(' ').map(x=>x[0]).join('').slice(0,2).toUpperCase():'?']
      });
      persist();
      setTimeout(()=>{
        f.reset();
        render();
      },0);
    };
    
    const cd=document.querySelector('#companyDialog');
    document.querySelector('#addCompany').onclick=()=>cd.showModal();
    document.querySelector('#saveCompany').onclick=e=>{
      const f=document.querySelector('#companyForm');
      if(!f.reportValidity()){
        e.preventDefault();
        return;
      }
      const n=new FormData(f).get('company').trim();
      if(n&&!companies.includes(n)){
        companies.push(n);
        selected=n;
        persist();
      }
      setTimeout(()=>{
        f.reset();
        render();
      },0);
    };
    
    document.querySelector('#exportBtn').onclick=()=>{
      const blob=new Blob([JSON.stringify({companies,projects:data},null,2)],{type:'application/json'}),
            a=document.createElement('a');
      a.href=URL.createObjectURL(blob);
      a.download='generaimpresa-dati.json';
      a.click();
      URL.revokeObjectURL(a.href);
    };
    
    render();
  </script>
</div>
