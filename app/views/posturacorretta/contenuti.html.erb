<div id="top" class="bg-slate-50 text-slate-900 antialiased">
  <section class="border-t border-slate-100 px-5 py-12 md:py-16 min-h-[calc(100vh-4rem)]">
    <div class="mx-auto max-w-4xl">
      <header class="max-w-2xl">
        <p class="text-xs font-black uppercase tracking-[0.22em] text-blue-700">PosturaCorretta Blog</p>
        <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950 md:text-5xl">Articoli e approfondimenti</h1>
        <p class="mt-4 text-base leading-relaxed text-slate-600">Cerca un argomento oppure esplora il blog per categoria.</p>

        <label class="relative mt-6 block max-w-lg">
          <span class="sr-only">Cerca nel blog</span>
          <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400">⌕</span>
          <input id="blog-search" type="search" placeholder="Cerca un argomento…" class="w-full rounded-2xl border border-slate-200 bg-white py-3.5 pl-11 pr-4 text-sm shadow-sm outline-none transition focus:border-blue-400 focus:ring-4 focus:ring-blue-100">
        </label>
      </header>

      <nav class="mt-9 border-b border-slate-200" aria-label="Categorie del blog">
        <div class="flex gap-2 overflow-x-auto pb-3 no-scrollbar">
          <% blog_categories.each_with_index do |(key, category), index| %>
            <button type="button" onclick="switchBlogCategory('<%= key %>')" id="blog-tab-<%= key %>" class="blog-tab shrink-0 rounded-full px-4 py-2.5 text-xs font-bold transition <%= index.zero? ? 'bg-slate-950 text-white shadow-sm' : 'bg-white text-slate-600 border border-slate-200 hover:border-slate-300 hover:text-slate-950' %>">
              <%= category[:label] %>
            </button>
          <% end %>
        </div>
      </nav>

      <% blog_categories.each_with_index do |(key, category), category_index| %>
        <% colors = blog_color_classes.fetch(category[:color]) %>
        <section id="blog-section-<%= key %>" class="blog-section pt-8 <%= 'hidden' unless category_index.zero? %>" data-category="<%= key %>">
          <div class="border-b border-slate-200 pb-6">
            <p class="text-[10px] font-black uppercase tracking-[0.18em] <%= colors[:text] %>"><%= category[:eyebrow] %></p>
            <div class="mt-1 flex flex-wrap items-end justify-between gap-3">
              <div>
                <h2 class="text-2xl font-black text-slate-950"><%= category[:label] %></h2>
                <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600"><%= category[:description] %></p>
              </div>
              <span class="visible-count text-xs font-semibold text-slate-400"><%= category[:articles].size %> articoli</span>
            </div>
          </div>

          <div class="mt-5 flex gap-2 overflow-x-auto pb-2 no-scrollbar" aria-label="Sottocategorie">
            <button type="button" onclick="filterBlogSubcategory('<%= key %>', 'all', this)" class="subcategory-button active-subcategory whitespace-nowrap rounded-full bg-slate-900 px-3.5 py-2 text-xs font-bold text-white">Tutti</button>
            <% category[:subcategories].each do |subcategory| %>
              <button type="button" onclick="filterBlogSubcategory('<%= key %>', '<%= subcategory %>', this)" class="subcategory-button whitespace-nowrap rounded-full px-3.5 py-2 text-xs font-semibold text-slate-500 hover:bg-white hover:text-slate-950"><%= subcategory %></button>
            <% end %>
          </div>

          <div class="mt-3 divide-y divide-slate-200" id="article-list-<%= key %>">
            <% category[:articles].each do |article| %>
              <a href="/books/il-corpo-un-mondo-da-scoprire/<%= article[:slug] %>" class="blog-article group grid gap-3 py-6 transition sm:grid-cols-[1fr_auto] sm:items-center" data-subcategory="<%= article[:subcategory] %>" data-search="<%= [article[:title], article[:excerpt], article[:subcategory]].join(' ').downcase %>">
                <div>
                  <div class="flex items-center gap-2 text-[10px] font-black uppercase tracking-wider <%= colors[:text] %>">
                    <span><%= article[:subcategory] %></span>
                    <span class="text-slate-300">·</span>
                    <span class="font-semibold normal-case tracking-normal text-slate-400"><%= article[:time] %></span>
                  </div>
                  <h3 class="mt-1.5 text-lg font-black text-slate-900 transition <%= colors[:hover] %>"><%= article[:title] %></h3>
                  <p class="mt-1.5 max-w-2xl text-sm leading-relaxed text-slate-500"><%= article[:excerpt] %></p>
                </div>
                <span class="text-slate-300 transition group-hover:translate-x-1 group-hover:text-slate-700">→</span>
              </a>
            <% end %>
          </div>

          <div class="blog-empty hidden border-t border-slate-200 py-12 text-center">
            <p class="font-black text-slate-900">Nessun articolo trovato</p>
            <p class="mt-2 text-sm text-slate-500">Prova con un'altra parola o sottocategoria.</p>
          </div>
        </section>
      <% end %>
    </div>
  </section>

  <%= render "posturacorretta/footer" %>
</div>

<script>
  let activeBlogCategory = "dolore";
  const activeSubcategories = {};

  window.switchBlogCategory = function(key) {
    const selectedSection = document.getElementById(`blog-section-${key}`);
    const selectedTab = document.getElementById(`blog-tab-${key}`);
    if (!selectedSection || !selectedTab) return;

    activeBlogCategory = key;
    document.querySelectorAll(".blog-section").forEach(section => section.classList.add("hidden"));
    document.querySelectorAll(".blog-tab").forEach(tab => {
      tab.className = "blog-tab shrink-0 rounded-full px-4 py-2.5 text-xs font-bold transition bg-white text-slate-600 border border-slate-200 hover:border-slate-300 hover:text-slate-950";
    });

    selectedSection.classList.remove("hidden");
    selectedTab.className = "blog-tab shrink-0 rounded-full px-4 py-2.5 text-xs font-bold transition bg-slate-950 text-white shadow-sm";
    applyBlogFilters();

    const url = new URL(window.location);
    url.searchParams.set("categoria", key);
    history.replaceState({}, "", url);
  };

  window.filterBlogSubcategory = function(category, subcategory, button) {
    activeSubcategories[category] = subcategory;
    const section = document.getElementById(`blog-section-${category}`);
    section.querySelectorAll(".subcategory-button").forEach(item => {
      item.classList.remove("bg-slate-900", "text-white", "active-subcategory");
      item.classList.add("text-slate-600");
    });
    button.classList.add("bg-slate-900", "text-white", "active-subcategory");
    button.classList.remove("text-slate-600");
    applyBlogFilters();
  };

  function applyBlogFilters() {
    const section = document.getElementById(`blog-section-${activeBlogCategory}`);
    if (!section) return;

    const query = document.getElementById("blog-search").value.trim().toLowerCase();
    const subcategory = activeSubcategories[activeBlogCategory] || "all";
    let visible = 0;

    section.querySelectorAll(".blog-article").forEach(article => {
      const matchesSubcategory = subcategory === "all" || article.dataset.subcategory === subcategory;
      const matchesSearch = !query || article.dataset.search.includes(query);
      const shouldShow = matchesSubcategory && matchesSearch;
      article.classList.toggle("hidden", !shouldShow);
      if (shouldShow) visible += 1;
    });

    section.querySelector(".visible-count").textContent = `${visible} ${visible === 1 ? "articolo" : "articoli"}`;
    section.querySelector(".blog-empty").classList.toggle("hidden", visible !== 0);
  }

  document.addEventListener("DOMContentLoaded", () => {
    document.getElementById("blog-search").addEventListener("input", applyBlogFilters);
    const params = new URLSearchParams(window.location.search);
    const requestedCategory = params.get("categoria") || params.get("subtab") || "dolore";
    window.switchBlogCategory(document.getElementById(`blog-tab-${requestedCategory}`) ? requestedCategory : "dolore");
  });
</script>
