<div id="top" class="bg-slate-100 text-slate-900 antialiased">
  <section class="border-t border-slate-200/70 px-4 py-10 md:px-6 md:py-16 min-h-[calc(100vh-4rem)]">
    <div class="mx-auto max-w-5xl">
      <header class="max-w-2xl">
        <p class="text-xs font-black uppercase tracking-[0.22em] text-blue-700">PosturaCorretta Blog</p>
        <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950 md:text-5xl">Articoli e approfondimenti</h1>
        <p class="mt-4 text-base leading-relaxed text-slate-600">Cerca un argomento oppure esplora il blog per categoria.</p>

      </header>

      <div class="mt-8 rounded-3xl border border-slate-200 bg-white p-3 shadow-sm md:p-4">
        <label class="relative block">
          <span class="sr-only">Cerca nel blog</span>
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400">
            <circle cx="11" cy="11" r="7" stroke-width="2"></circle>
            <path d="m20 20-3.5-3.5" stroke-width="2" stroke-linecap="round"></path>
          </svg>
          <input id="blog-search" type="search" placeholder="Cerca nella categoria selezionata…" class="w-full rounded-2xl border-0 bg-slate-100 py-3.5 pl-12 pr-4 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:bg-white focus:ring-2 focus:ring-blue-500/30">
        </label>

        <nav class="mt-3 border-t border-slate-100 pt-3" aria-label="Categorie del blog">
          <div class="flex gap-2 overflow-x-auto no-scrollbar">
            <% blog_categories.each_with_index do |(key, category), index| %>
              <button type="button" onclick="switchBlogCategory('<%= key %>')" id="blog-tab-<%= key %>" class="blog-tab shrink-0 rounded-full px-4 py-2.5 text-xs font-bold transition <%= index.zero? ? 'bg-slate-950 text-white shadow-sm' : 'bg-slate-50 text-slate-600 hover:bg-slate-100 hover:text-slate-950' %>">
                <%= category[:label] %>
              </button>
            <% end %>
          </div>
        </nav>
      </div>

      <% blog_categories.each_with_index do |(key, category), category_index| %>
        <% colors = blog_color_classes.fetch(category[:color]) %>
        <section id="blog-section-<%= key %>" class="blog-section pt-6 md:pt-8 <%= 'hidden' unless category_index.zero? %>" data-category="<%= key %>">
          <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
            <div class="p-6 md:p-8">
              <p class="text-[10px] font-black uppercase tracking-[0.18em] <%= colors[:text] %>"><%= category[:eyebrow] %></p>
              <div class="mt-1 flex flex-wrap items-start justify-between gap-4">
                <div>
                  <h2 class="text-2xl font-black text-slate-950"><%= category[:label] %></h2>
                  <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600"><%= category[:description] %></p>
                </div>
                <span class="visible-count rounded-full bg-slate-100 px-3 py-1.5 text-xs font-bold text-slate-500"><%= category[:articles].size %> articoli</span>
              </div>
            </div>

            <div class="flex gap-2 overflow-x-auto border-t border-slate-100 bg-slate-50/70 px-6 py-4 no-scrollbar md:px-8" aria-label="Sottocategorie">
              <button type="button" onclick="filterBlogSubcategory('<%= key %>', 'all', this)" class="subcategory-button active-subcategory whitespace-nowrap rounded-full bg-slate-900 px-3.5 py-2 text-xs font-bold text-white">Tutti</button>
              <% category[:subcategories].each do |subcategory| %>
                <button type="button" onclick="filterBlogSubcategory('<%= key %>', '<%= subcategory %>', this)" class="subcategory-button whitespace-nowrap rounded-full bg-white px-3.5 py-2 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-200 transition hover:ring-slate-300 hover:text-slate-950"><%= subcategory %></button>
              <% end %>
            </div>
          </div>

          <div class="mt-5 grid gap-4 md:grid-cols-2" id="article-list-<%= key %>">
            <% category[:articles].each do |article| %>
              <% creator = postura_creators.fetch(article[:author]) %>
              <% is_video = article[:format] == "video" %>
              <% article_href = is_video ? postura_youtube_url : "/books/il-corpo-un-mondo-da-scoprire/#{article[:slug]}" %>
              <a href="<%= article_href %>" <%= 'target="_blank" rel="noopener noreferrer"'.html_safe if is_video %> class="blog-article group flex min-h-64 flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md md:p-6" data-subcategory="<%= article[:subcategory] %>" data-search="<%= [article[:title], article[:excerpt], article[:subcategory], creator[:name], article[:format]].join(' ').downcase %>">
                <div>
                  <div class="flex items-center justify-between gap-3">
                    <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[10px] font-black uppercase tracking-wider <%= is_video ? 'bg-red-50 text-red-700' : 'bg-blue-50 text-blue-700' %>">
                      <% if is_video %>
                        <svg aria-hidden="true" viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5"><path d="M5.5 4.8a1 1 0 0 1 1.52-.85l7.2 4.7a1 1 0 0 1 0 1.7l-7.2 4.7A1 1 0 0 1 5.5 14.2V4.8Z"></path></svg>
                        Video
                      <% else %>
                        <svg aria-hidden="true" viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5"><path d="M4 2.75A1.75 1.75 0 0 1 5.75 1h5.19c.47 0 .91.19 1.24.51l3.3 3.31c.33.33.52.77.52 1.24v11.19A1.75 1.75 0 0 1 14.25 19h-8.5A1.75 1.75 0 0 1 4 17.25V2.75Zm3 5.5c-.41 0-.75.34-.75.75s.34.75.75.75h6A.75.75 0 0 0 13 8.25H7Zm0 3.5c-.41 0-.75.34-.75.75s.34.75.75.75h6a.75.75 0 0 0 0-1.5H7Z"></path></svg>
                        Post
                      <% end %>
                    </span>
                    <span class="truncate text-[10px] font-black uppercase tracking-wider <%= colors[:text] %>"><%= article[:subcategory] %></span>
                  </div>
                  <h3 class="mt-4 text-lg font-black leading-snug text-slate-900 transition <%= colors[:hover] %>"><%= article[:title] %></h3>
                  <p class="mt-2 text-sm leading-relaxed text-slate-500"><%= article[:excerpt] %></p>
                </div>
                <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-4">
                  <div class="flex min-w-0 items-center gap-2.5">
                    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-[10px] font-black <%= creator[:color] %>"><%= creator[:initials] %></span>
                    <div class="min-w-0">
                      <p class="truncate text-xs font-bold text-slate-700"><%= creator[:name] %></p>
                      <p class="text-[10px] text-slate-400"><%= article[:time] %> <%= is_video ? 'di visione' : 'di lettura' %></p>
                    </div>
                  </div>
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-slate-100 text-slate-500 transition group-hover:bg-slate-900 group-hover:text-white"><%= is_video ? '↗' : '→' %></span>
                </div>
              </a>
            <% end %>
          </div>

          <div class="blog-empty mt-5 hidden rounded-2xl border border-dashed border-slate-300 bg-white py-12 text-center">
            <p class="font-black text-slate-900">Nessun articolo trovato</p>
            <p class="mt-2 text-sm text-slate-500">Prova con un'altra parola o sottocategoria.</p>
          </div>
        </section>
      <% end %>

      <section class="mt-12 border-t border-slate-200 pt-10 md:mt-16 md:pt-12" aria-labelledby="creators-title">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.2em] text-blue-700">Professionisti e autori</p>
          <h2 id="creators-title" class="mt-2 text-2xl font-black text-slate-950 md:text-3xl">Creator PosturaCorretta</h2>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600">Le persone che contribuiscono ai post, ai video e agli approfondimenti del progetto.</p>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <% postura_creators.each_value do |creator| %>
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
              <span class="flex h-11 w-11 items-center justify-center rounded-full text-xs font-black <%= creator[:color] %>"><%= creator[:initials] %></span>
              <h3 class="mt-4 text-sm font-black text-slate-900"><%= creator[:name] %></h3>
              <p class="mt-1 text-xs leading-relaxed text-slate-500"><%= creator[:role] %></p>
            </article>
          <% end %>
        </div>
      </section>

      <section class="mt-10 border-t border-slate-200 pt-10 md:mt-12 md:pt-12" aria-labelledby="social-title">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">Video, aggiornamenti e community</p>
          <h2 id="social-title" class="mt-2 text-2xl font-black text-slate-950 md:text-3xl">Continua a seguirci</h2>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600">Scegli il canale più adatto al modo in cui preferisci seguire PosturaCorretta.</p>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <a href="<%= postura_youtube_url %>" target="_blank" rel="noopener noreferrer" class="group flex min-h-64 flex-col rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-red-200 hover:shadow-lg md:p-8">
            <div class="flex items-center justify-between">
              <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-red-50 text-red-600">
                <svg aria-hidden="true" viewBox="0 0 20 20" fill="currentColor" class="h-6 w-6"><path d="M18.6 5.2a2.25 2.25 0 0 0-1.58-1.6C15.62 3.2 10 3.2 10 3.2s-5.62 0-7.02.4A2.25 2.25 0 0 0 1.4 5.2 23.5 23.5 0 0 0 1 10a23.5 23.5 0 0 0 .4 4.8 2.25 2.25 0 0 0 1.58 1.6c1.4.4 7.02.4 7.02.4s5.62 0 7.02-.4a2.25 2.25 0 0 0 1.58-1.6A23.5 23.5 0 0 0 19 10a23.5 23.5 0 0 0-.4-4.8ZM8.2 13V7l5.2 3-5.2 3Z"></path></svg>
              </span>
              <span class="text-xs font-bold uppercase tracking-[0.16em] text-red-600">Video e ricerca</span>
            </div>
            <h3 class="mt-6 text-2xl font-black tracking-tight text-slate-950">YouTube</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">Approfondimenti, esercizi, eventi e costruzione pubblica del progetto.</p>
            <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-5 text-sm font-bold text-red-600">
              <span>Vai al canale</span>
              <span class="transition group-hover:translate-x-1">↗</span>
            </div>
          </a>

          <a href="https://www.instagram.com/posturacorretta" target="_blank" rel="noopener noreferrer" class="group flex min-h-64 flex-col rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-pink-200 hover:shadow-lg md:p-8">
            <div class="flex items-center justify-between">
              <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-pink-50 text-pink-600">
                <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-6 w-6"><rect x="3" y="3" width="18" height="18" rx="5" stroke-width="2"></rect><circle cx="12" cy="12" r="4" stroke-width="2"></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle></svg>
              </span>
              <span class="text-xs font-bold uppercase tracking-[0.16em] text-pink-600">Community ed eventi</span>
            </div>
            <h3 class="mt-6 text-2xl font-black tracking-tight text-slate-950">Instagram</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">Dietro le quinte, caroselli, eventi e aggiornamenti quotidiani.</p>
            <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-5 text-sm font-bold text-pink-600">
              <span>Segui la pagina</span>
              <span class="transition group-hover:translate-x-1">↗</span>
            </div>
          </a>
        </div>
      </section>
    </div>
  </section>

  <%= render "posturacorretta/footer" %>
</div>

<script>
  let activeBlogCategory = "dolore";
  const activeSubcategories = {};

  window.switchBlogCategory = function(key) {
    const selectedSection = document.getElementById(`blog-section-${key}`);
    const selectedTab = document.getElementById(`blog-tab-${key}`);
    if (!selectedSection || !selectedTab) return;

    activeBlogCategory = key;
    document.querySelectorAll(".blog-section").forEach(section => section.classList.add("hidden"));
    document.querySelectorAll(".blog-tab").forEach(tab => {
      tab.className = "blog-tab shrink-0 rounded-full px-4 py-2.5 text-xs font-bold transition bg-slate-50 text-slate-600 hover:bg-slate-100 hover:text-slate-950";
    });

    selectedSection.classList.remove("hidden");
    selectedTab.className = "blog-tab shrink-0 rounded-full px-4 py-2.5 text-xs font-bold transition bg-slate-950 text-white shadow-sm";
    applyBlogFilters();

    const url = new URL(window.location);
    url.searchParams.set("categoria", key);
    history.replaceState({}, "", url);
  };

  window.filterBlogSubcategory = function(category, subcategory, button) {
    activeSubcategories[category] = subcategory;
    const section = document.getElementById(`blog-section-${category}`);
    section.querySelectorAll(".subcategory-button").forEach(item => {
      item.className = "subcategory-button whitespace-nowrap rounded-full bg-white px-3.5 py-2 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-200 transition hover:ring-slate-300 hover:text-slate-950";
    });
    button.className = "subcategory-button active-subcategory whitespace-nowrap rounded-full bg-slate-900 px-3.5 py-2 text-xs font-bold text-white";
    applyBlogFilters();
  };

  function applyBlogFilters() {
    const section = document.getElementById(`blog-section-${activeBlogCategory}`);
    if (!section) return;

    const query = document.getElementById("blog-search").value.trim().toLowerCase();
    const subcategory = activeSubcategories[activeBlogCategory] || "all";
    let visible = 0;

    section.querySelectorAll(".blog-article").forEach(article => {
      const matchesSubcategory = subcategory === "all" || article.dataset.subcategory === subcategory;
      const matchesSearch = !query || article.dataset.search.includes(query);
      const shouldShow = matchesSubcategory && matchesSearch;
      article.classList.toggle("hidden", !shouldShow);
      if (shouldShow) visible += 1;
    });

    section.querySelector(".visible-count").textContent = `${visible} ${visible === 1 ? "articolo" : "articoli"}`;
    section.querySelector(".blog-empty").classList.toggle("hidden", visible !== 0);
  }

  document.addEventListener("DOMContentLoaded", () => {
    document.getElementById("blog-search").addEventListener("input", applyBlogFilters);
    const params = new URLSearchParams(window.location.search);
    const requestedCategory = params.get("categoria") || params.get("subtab") || "dolore";
    window.switchBlogCategory(document.getElementById(`blog-tab-${requestedCategory}`) ? requestedCategory : "dolore");
  });
</script>