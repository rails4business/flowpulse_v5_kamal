    dialog{border:0;border-radius:20px;padding:0;width:min(760px,calc(100vw - 30px));background:var(--card);box-shadow:0 30px 100px rgba(0,0,0,.25)}dialog::backdrop{background:rgba(13,28,20,.55);backdrop-filter:blur(4px)}.modal-head{padding:22px 24px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center}.modal-head h3{margin:0;font:700 24px Georgia,serif}.close{border:0;background:transparent;font-size:23px}.modal-body{padding:22px 24px}.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:15px}.field{display:grid;gap:7px}.field.full{grid-column:1/-1}.field label{font-size:12px;font-weight:800}.field input,.field select{border:1px solid var(--line);border-radius:10px;background:white;padding:11px;width:100%}.modal-foot{padding:16px 24px;border-top:1px solid var(--line);display:flex;justify-content:flex-end;gap:9px}.empty{grid-column:1/-1;padding:50px;text-align:center;color:var(--muted)}
