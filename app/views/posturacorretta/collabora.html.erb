ign-items:center;gap:10px;z-index:1}.btn{border:1px solid var(--line);background:var(--card);color:var(--ink);border-radius:10px;padding:11px 15px;font-weight:700}.btn.primary{background:var(--lime);border-color:var(--lime);color:#183829}.btn.dark{background:#1f4937;border-color:#4d705f;color:white}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:13px;margin:18px 0 28px}.stat{background:var(--card);border:1px solid var(--line);border-radius:15px;padding:17px}.stat small{color:var(--muted)}.stat strong{display:block;font:700 25px Georgia,serif;margin-top:8px}.stat .delta{font-size:11px;color:var(--green);margin-left:5px}.section-head{display:flex;justify-content:space-between;align-items:end;gap:15px;margin:24px 0 14px}.section-head h3{font-size:20px;margin:0}.filters{display:flex;gap:8px}.filter{padding:8px 12px;border-radius:999px;border:1px solid var(--line);background:transparent;color:var(--muted)}.filter.active{background:var(--ink);color:white;border-color:var(--ink)}.projects{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}.project{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:20px;box-shadow:0 6px 24px rgba(35,48,39,.04);transition:.2s}.project:hover{transform:translateY(-2px);box-shadow:var(--shadow)}.project-top{display:flex;justify-content:space-between;gap:12px}.badge{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.07em;padding:6px 9px;border-radius:999px;background:#e8eee9;color:var(--green);display:inline-block}.badge.orange{background:#fff0d9;color:#945a10}.badge.blue{background:#e7edf7;color:#435d88}.status{font-size:12px;color:var(--muted)}.project h4{font:700 22px Georgia,serif;margin:13px 0 7px}.project-desc{color:var(--muted);font-size:14px;line-height:1.5;min-height:42px}.numbers{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:14px 0;margin:17px 0}.number small{display:block