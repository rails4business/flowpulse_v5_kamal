  <title>Progetti — PosturaCorretta</title>
  <style>
    :root{--ink:#17211b;--muted:#68716b;--paper:#f3f1e9;--card:#fffdf7;--line:#dcd9ce;--green:#184f39;--lime:#c9f26b;--orange:#f2a23a;--red:#c4553d;--blue:#5e78a5;--shadow:0 14px 45px rgba(35,48,39,.08)}
