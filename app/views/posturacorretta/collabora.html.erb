<body>
  <div class="shell">
    <main class="main">
      <header class="topbar">
        <div>
          <div class="eyebrow">PosturaCorretta / progetti</div>
          <h1 id="companyTitle">PosturaCorretta</h1>
        </div>
        <div class="tool-badge"><span>G</span> GeneraImpresa</div>
      </header>
      <section class="hero">
        <div><div class="eyebrow" style="color:#a9c1b4">Progetti</div><h2>Trasforma le idee in progetti sostenibili.</h2><p>Definisci cosa crei, quanto costa, chi lo realizza e cosa può generare. Poi raccogli capitale o tempo prima di dare il via.</p></div>
        <div class="hero-actions"><button class="btn dark" id="exportBtn">Esporta dati</button><button class="btn primary" id="newProject">＋ Nuovo progetto</button></div>
      </section>
      <section class="company-bar" aria-label="Filtra i progetti per area">
        <div class="company-bar-head">
          <strong>Aree progettuali</strong>
          <span>Filtra i progetti</span>
        </div>
        <div class="company-list" id="companies"></div>
        <button class="add-company" id="addCompany">＋ Nuova area</button>
      </section>
      <section class="stats" style="grid-template-columns:repeat(3,1fr)">
        <div class="stat"><small>Progetti attivi</small><strong id="activeCount">0</strong></div>
        <div class="stat"><small>Risorse raccolte</small><strong id="fundedTotal">€ 0</strong></div>
        <div class="stat"><small>Ricavi previsti / anno</small><strong id="revenueTotal">€ 0</strong></div>
      </section>
      <div class="section-head"><div><div class="eyebrow">Decisioni e avanzamento</div><h3>Progetti</h3></div><div class="filters"><button class="filter active" data-filter="all">Tutti</button><button class="filter" data-filter="Raccolta">In raccolta</button><button class="filter" data-filter="Attivo">Attivi</button><button class="filter" data-filter="Idea">Da valutare</button></div></div>
      <section class="projects" id="projects"></section>
    </main>
  </div>

  <dialog id="projectDialog">
    <form method="dialog" id="projectForm">
      <div class="modal-head"><h3>Nuovo progetto</h3><button class="close" value="cancel" aria-label="Chiudi">×</button></div>
      <div class="modal-body"><div class="form-grid">
        <div class="field full"><label>Nome del progetto</label><input name="name" required placeholder="Es. Accademia online"></div>
        <div class="field"><label>Cosa crea?</label><select name="type"><option>Servizio</option><option>Prodotto</option><option>App</option><option>Evento</option><option>Contenuto</option><option>Altro</option></select></div>
        <div class="field"><label>Stato</label><select name="status"><option>Idea</option><option>Raccolta</option><option>Attivo</option></select></div>
        <div class="field full"><label>Risultato concreto</label><input name="output" required placeholder="Cosa esisterà alla fine del progetto?"></div>
        <details class="form-section full"><summary>Economia e raccolta <span>Apri</span></summary><div class="form-grid inner-grid">
          <div class="field"><label>Costi iniziali (€)</label><input name="initial" type="number" min="0" value="10000"></div>
          <div class="field"><label>Manutenzione annua (€)</label><input name="maintenance" type="number" min="0" value="1200"></div>
          <div class="field"><label>Ricavi previsti annui (€)</label><input name="revenue" type="number" min="0" value="18000"></div>
          <div class="field"><label>Fondi già raccolti (€)</label><input name="funded" type="number" min="0" value="0"></div>
          <div class="field"><label>Dash già raccolti</label><input name="fundedDash" type="number" min="0" step="0.01" value="0"></div>
          <div class="field"><label>Valore interno di 1 Dash (€)</label><input name="dashRate" type="number" min="0" step="0.01" value="100"></div>
        </div></details>
        <details class="form-section full"><summary>Organizzazione <span>Apri</span></summary><div class="form-grid inner-grid">
          <div class="field"><label>Numero di step</label><input name="steps" type="number" min="1" value="5"></div>
          <div class="field"><label>Responsabile</label><input name="owner" placeholder="Da assegnare"></div>
        </div></details>
      </div></div>
      <div class="modal-foot"><button class="btn" value="cancel">Annulla</button><button class="btn primary" value="default" id="saveProject">Crea progetto</button></div>
    </form>
  </dialog>
  <dialog id="companyDialog"><form method="dialog" id="companyForm"><div class="modal-head"><h3>Nuova area progettuale</h3><button class="close" value="cancel">×</button></div><div class="modal-body"><div class="field"><label>Nome area</label><input name="company" required placeholder="Nome della nuova area progettuale"></div></div><div class="modal-foot"><button class="btn" value="cancel">Annulla</button><button class="btn primary" value="default" id="saveCompany">Aggiungi</button></div></form></dialog>
  <dialog id="detailDialog" class="detail-dialog">
    <div class="modal-head"><div><div class="eyebrow">Ciclo economico del progetto</div><h3 id="detailTitle">Progetto</h3></div><button class="close" onclick="detailDialog.close()">×</button></div>
    <div class="modal-body" id="detailBody"></div>
    <div class="modal-foot"><button class="btn" onclick="detailDialog.close()">Chiudi</button></div>
  </dialog>
  <script>
    const seed=[
      {id:1,company:'PosturaCorretta',name:'Accademia PosturaCorretta',type:'Servizio',status:'Attivo',output:'Percorso formativo online e in presenza',initial:18000,maintenance:4200,revenue:42000,funded:17000,fundedDash:10,dashRate:100,steps:8,done:5,owner:'Marco',people:['MB','AV','+2']},
      {id:2,company:'PosturaCorretta',name:'Il corpo, un mondo da scoprire',type:'Prodotto',status:'Raccolta',output:'Libro e percorso di ingresso all’ecosistema',initial:9300,maintenance:600,revenue:24000,funded:5600,fundedDash:5,dashRate:100,steps:6,done:3,owner:'Marco',people:['MB','ED']},
      {id:3,company:'Flowpulse',name:'1Impegno',type:'App',status:'Raccolta',output:'Agenda condivisa per eventi, servizi e referral',initial:32000,maintenance:7800,revenue:54000,funded:11400,fundedDash:10,dashRate:100,steps:12,done:4,owner:'Da assegnare',people:['MB','?']},
      {id:4,company:'Flowpulse',name:'Rails4Business',type:'Servizio',status:'Idea',output:'Percorso e linee guida per collaboratori digitali',initial:7500,maintenance:1800,revenue:15000,funded:800,fundedDash:0,dashRate:100,steps:7,done:1,owner:'Marco',people:['MB']},
      {id:5,company:'Il Giardino del Corpo',name:'Primo evento rigenerativo',type:'Evento',status:'Idea',output:'Un’esperienza pilota di una giornata',initial:4800,maintenance:0,revenue:7200,funded:700,fundedDash:5,dashRate:100,steps:9,done:2,owner:'Da assegnare',people:['MB','?']}
    ];
    let data=JSON.parse(localStorage.getItem('genera-projects')||'null')||seed;
    let companies=JSON.parse(localStorage.getItem('genera-companies')||'null')||['PosturaCorretta','Flowpulse','Il Giardino del Corpo'];
    let selected=companies[0], filter='all'; const eur=n=>new Intl.NumberFormat('it-IT',{style:'currency',currency:'EUR',maximumFractionDigits:0}).format(n);
    function persist(){localStorage.setItem('genera-projects',JSON.stringify(data));localStorage.setItem('genera-companies',JSON.stringify(companies))}
    function renderCompanies(){document.querySelector('#companies').innerHTML=companies.map(c=>`<button class="company ${c===selected?'active':''}" data-company="${c}"><span>${c}</span><span>${data.filter(p=>p.company===c).length}</span></button>`).join('');document.querySelectorAll('[data-company]').forEach(b=>b.onclick=()=>{selected=b.dataset.company;filter='all';render()})}
    function render(){renderCompanies();document.querySelector('#companyTitle').textContent=selected;const all=data.filter(p=>p.company===selected), view=all.filter(p=>filter==='all'||p.status===filter),euro=all.reduce((s,p)=>s+p.funded,0),dash=all.reduce((s,p)=>s+(p.fundedDash||0),0);document.querySelector('#activeCount').textContent=all.filter(p=>p.status==='Attivo').length;document.querySelector('#fundedTotal').innerHTML=`${eur(euro)} <span class="stat-sub">+ ${dash.toLocaleString('it-IT')} DASH</span>`;document.querySelector('#revenueTotal').textContent=eur(all.reduce((s,p)=>s+p.revenue,0));document.querySelector('#projects').innerHTML=view.length?view.map(card).join(''):'<div class="empty">Nessun progetto in questa sezione.</div>'}
    function card(p){ensureFinance(p);const dash=p.fundedDash||0,rate=p.dashRate||100,equivalent=p.funded+dash*rate,pc=Math.min(100,Math.round(equivalent/p.initial*100)||0),ready=pc>=100&&p.owner!=='Da assegnare',next=p.owner==='Da assegnare'?'Assegna un responsabile':pc<100?'Completa la raccolta':p.done<p.steps?'Continua la realizzazione':'Gestisci rendite e quote',cls=p.type==='App'?'blue':p.status==='Raccolta'?'orange':'';return `<article class="project"><div class="project-top"><span class="badge ${cls}">${p.type}</span><span class="status">${ready?'● Pronto':p.status}</span></div><h4>${p.name}</h4><div class="project-desc">${p.output}</div><div class="simple-funding"><div class="funding-row"><span>Raccolta</span><strong>${pc}% di ${eur(p.initial)}</strong></div><div class="progress"><span style="width:${pc}%"></span></div><small>${eur(p.funded)} + ${dash.toLocaleString('it-IT')} DASH</small></div><div class="next-action"><span>Prossimo passo</span><strong>${next}</strong></div><div class="project-foot"><small style="color:var(--muted)">${p.done}/${p.steps} step · ${p.owner}</small><button class="open" onclick="openProject(${p.id})">Apri progetto →</button></div></article>`}
    function ensureFinance(p){if(p.capitalRepaid==null)p.capitalRepaid=Math.round(p.initial*(p.status==='Attivo'?.45:0));if(!p.shares)p.shares=[{name:'Marco',kind:'Denaro',units:60,paid:p.funded*.6,returns:0},{name:'Collaboratori',kind:'Tempo',units:25,paid:p.initial*.25,returns:0},{name:'Riserva progetto',kind:'Impresa',units:15,paid:0,returns:0}];if(!p.monthly)p.monthly=[];if(!p.saleOffers)p.saleOffers=[]}
    function openProject(id){const p=data.find(x=>x.id===id);ensureFinance(p);window.currentProject=id;document.querySelector('#detailTitle').textContent=p.name;renderDetail(p);document.querySelector('#detailDialog').showModal()}
    function renderDetail(p){const totalDistributed=p.monthly.reduce((s,m)=>s+m.distributed,0),remaining=Math.max(0,p.initial-p.capitalRepaid),stage=p.funded+(p.fundedDash||0)*(p.dashRate||100)<p.initial?'Raccolta fondi':p.capitalRepaid<p.initial?'Restituzione del capitale':'Rendita e scambio quote';document.querySelector('#detailBody').innerHTML=`
      <div class="stage-current"><small>Fase attuale</small><strong>${stage}</strong></div>
      <div class="detail-summary"><div class="detail-kpi"><small>Da restituire</small><strong>${eur(remaining)}</strong></div><div class="detail-kpi"><small>Restituito</small><strong>${eur(p.capitalRepaid)}</strong></div><div class="detail-kpi"><small>Utili distribuiti</small><strong>${eur(totalDistributed)}</strong></div></div>
      <div class="tabs"><button class="tab active" onclick="showTab(event,'capital')">Quote</button><button class="tab" onclick="showTab(event,'months')">Mesi e utili</button><button class="tab" onclick="showTab(event,'market')">Compravendita</button></div>
      <section class="tab-panel active" id="capital"><div class="panel-head"><h4>Registro dei possessori</h4><button class="btn primary" onclick="repayCapital()">＋ Registra restituzione</button></div><div class="table-wrap"><table class="ledger"><thead><tr><th>Possessore</th><th>Origine</th><th>Quote</th><th>Valore conferito</th><th>Restituzioni</th><th>Utili ricevuti</th></tr></thead><tbody>${p.shares.map(s=>`<tr><td><strong>${s.name}</strong></td><td>${s.kind}</td><td>${s.units} (${s.units}%)</td><td>${eur(s.paid)}</td><td>${eur(Math.min(s.paid,p.capitalRepaid*s.units/100))}</td><td class="positive">${eur(totalDistributed*s.units/100)}</td></tr>`).join('')}</tbody></table></div><div class="note">Le quote determinano la distribuzione degli utili; prestiti, quote e lavoro investito restano registrati come conferimenti distinti.</div></section>
      <section class="tab-panel" id="months"><div class="panel-head"><h4>Risultati e distribuzioni</h4><button class="btn primary" onclick="addMonth()">＋ Registra mese</button></div><div class="table-wrap"><table class="ledger"><thead><tr><th>Mese</th><th>Ricavi</th><th>Costi</th><th>Riserva</th><th>Restituzione</th><th>Utile distribuito</th></tr></thead><tbody>${p.monthly.length?p.monthly.map(m=>`<tr><td><strong>${m.month}</strong></td><td>${eur(m.revenue)}</td><td>${eur(m.costs)}</td><td>${eur(m.reserve)}</td><td>${eur(m.repayment)}</td><td class="positive">${eur(m.distributed)}</td></tr>`).join(''):'<tr><td colspan="6">Nessun mese registrato.</td></tr>'}</tbody></table></div><div class="note">Ordine del flusso: ricavi → costi → riserva → restituzione del capitale → utile distribuibile ai possessori delle quote.</div></section>
      <section class="tab-panel" id="market"><div class="panel-head"><h4>Mercato interno delle quote</h4><button class="btn primary" onclick="sellShares()">＋ Metti in vendita</button></div><div class="table-wrap"><table class="ledger"><thead><tr><th>Venditore</th><th>Quote</th><th>Prezzo €</th><th>Prezzo Dash</th><th>Stato</th><th></th></tr></thead><tbody>${p.saleOffers.length?p.saleOffers.map((o,i)=>`<tr><td>${o.seller}</td><td>${o.units}</td><td>${eur(o.euro)}</td><td>${o.dash} DASH</td><td>${o.status}</td><td><button class="open" onclick="buyShares(${i})">Acquista</button></td></tr>`).join(''):'<tr><td colspan="6">Nessuna quota attualmente in vendita.</td></tr>'}</tbody></table></div><div class="note">Ogni passaggio conserva venditore, acquirente, quantità, prezzo e data. La nuova distribuzione decorre dal periodo successivo al trasferimento.</div></section>`}
    function showTab(e,id){document.querySelectorAll('.tab,.tab-panel').forEach(x=>x.classList.remove('active'));e.currentTarget.classList.add('active');document.querySelector('#'+id).classList.add('active')}
    function repayCapital(){const p=data.find(x=>x.id===currentProject),amount=Number(prompt('Importo restituito agli investitori (€):','1000'));if(amount>0){p.capitalRepaid=Math.min(p.initial,p.capitalRepaid+amount);persist();render();renderDetail(p)}}
    function addMonth(){const p=data.find(x=>x.id===currentProject),month=prompt('Mese del rendiconto:','Luglio 2026');if(!month)return;const revenue=Number(prompt('Ricavi del mese (€):','5000'))||0,costs=Number(prompt('Costi del mese (€):','1800'))||0,reserve=Math.max(0,Number(prompt('Somma trattenuta come riserva (€):','500'))||0),repayment=Math.min(Math.max(0,p.initial-p.capitalRepaid),Math.max(0,Number(prompt('Capitale restituito questo mese (€):','1000'))||0)),distributed=Math.max(0,revenue-costs-reserve-repayment);p.capitalRepaid+=repayment;p.monthly.push({month,revenue,costs,reserve,repayment,distributed});persist();render();renderDetail(p)}
    function sellShares(){const p=data.find(x=>x.id===currentProject),seller=prompt('Chi vende le quote?','Marco');if(!seller)return;const units=Number(prompt('Numero di quote:','5'))||0,euro=Number(prompt('Prezzo totale in euro:','500'))||0,dash=Number(prompt('Oppure prezzo totale in Dash:','5'))||0;if(units>0){p.saleOffers.push({seller,units,euro,dash,status:'Disponibile'});persist();renderDetail(p)}}
    function buyShares(i){const p=data.find(x=>x.id===currentProject),o=p.saleOffers[i],buyer=prompt('Nome dell’acquirente:');if(!buyer)return;o.status='Venduta a '+buyer;const owner=p.shares.find(s=>s.name===o.seller);if(owner)owner.units=Math.max(0,owner.units-o.units);const existing=p.shares.find(s=>s.name===buyer);if(existing)existing.units+=o.units;else p.shares.push({name:buyer,kind:'Acquisto quote',units:o.units,paid:o.euro||o.dash*(p.dashRate||100),returns:0});persist();renderDetail(p)}
    document.querySelectorAll('.filter').forEach(b=>b.onclick=()=>{filter=b.dataset.filter;document.querySelectorAll('.filter').forEach(x=>x.classList.toggle('active',x===b));render()});
    const pd=document.querySelector('#projectDialog');document.querySelector('#newProject').onclick=()=>pd.showModal();document.querySelector('#saveProject').onclick=e=>{const f=document.querySelector('#projectForm');if(!f.reportValidity()){e.preventDefault();return}const v=Object.fromEntries(new FormData(f));data.push({id:Date.now(),company:selected,name:v.name,type:v.type,status:v.status,output:v.output,initial:+v.initial,maintenance:+v.maintenance,revenue:+v.revenue,funded:+v.funded,fundedDash:+v.fundedDash,dashRate:+v.dashRate,steps:+v.steps,done:0,owner:v.owner||'Da assegnare',people:[v.owner? v.owner.split(' ').map(x=>x[0]).join('').slice(0,2).toUpperCase():'?']});persist();setTimeout(()=>{f.reset();render()},0)};
    const cd=document.querySelector('#companyDialog');document.querySelector('#addCompany').onclick=()=>cd.showModal();document.querySelector('#saveCompany').onclick=e=>{const f=document.querySelector('#companyForm');if(!f.reportValidity()){e.preventDefault();return}const n=new FormData(f).get('company').trim();if(n&&!companies.includes(n)){companies.push(n);selected=n;persist()}setTimeout(()=>{f.reset();render()},0)};
    document.querySelector('#exportBtn').onclick=()=>{const blob=new Blob([JSON.stringify({companies,projects:data},null,2)],{type:'application/json'}),a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='generaimpresa-dati.json';a.click();URL.revokeObjectURL(a.href)};
    render();
  </script>
</body>
</html>
