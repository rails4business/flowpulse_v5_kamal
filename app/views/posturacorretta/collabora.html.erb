<% content_for :landing_nav do %>
  <%= render "posturacorretta/header" %>
<% end %>

<div id="top" class="text-slate-900 antialiased">

  <!-- PROGETTI IN CORSO -->
  <section class="border-t border-slate-200 bg-slate-50 px-5 py-20 md:py-24 min-h-[calc(100vh-4rem)]">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-4xl">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-orange-700">Progetti in corso</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-955 md:text-6xl md:leading-[1.04]">
          Il cantiere vivo di PosturaCorretta.
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">
          Qui raccogliamo aggiornamenti, idee operative e progetti aperti. Ogni scheda si apre come un articolo: cosa stiamo costruendo, a che punto siamo e come partecipare.
        </p>
      </div>

      <div class="mt-10 flex flex-wrap gap-2 rounded-2xl bg-white p-2 shadow-sm ring-1 ring-slate-200">
        <button type="button" data-project-tab="in-corso" aria-selected="true" class="project-status-tab rounded-xl bg-orange-500 px-4 py-2.5 text-sm font-semibold text-white transition">
          In corso
        </button>
        <button type="button" data-project-tab="pianificazione" aria-selected="false" class="project-status-tab rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-600 transition hover:bg-orange-50 hover:text-orange-700">
          In pianificazione
        </button>
        <button type="button" data-project-tab="idee" aria-selected="false" class="project-status-tab rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-600 transition hover:bg-orange-50 hover:text-orange-700">
          Idee future
        </button>
        <button type="button" data-project-tab="realizzati" aria-selected="false" class="project-status-tab rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-600 transition hover:bg-orange-50 hover:text-orange-700">
          Realizzati
        </button>
      </div>

      <div class="mt-12 space-y-4">
        <details data-project-status="in-corso" class="project-article group rounded-2xl border border-blue-100 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-6">
            <span>
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">In sviluppo</span>
              <span class="mt-2 block text-2xl font-semibold tracking-tight text-slate-950">Accademia PosturaCorretta</span>
              <span class="mt-3 block text-sm leading-6 text-slate-600">Percorsi, lezioni e strumenti per leggere il corpo attraverso le metodiche posturali.</span>
            </span>
            <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Apri</span>
          </summary>
          <article class="mt-6 border-t border-slate-100 pt-6 text-base leading-7 text-slate-600">
            <p>
              L'Accademia è il cuore didattico del progetto: un luogo dove trasformare esperienza, ricerca e pratica in percorsi comprensibili. L'obiettivo è aiutare le persone a partire dalla propria situazione concreta e costruire una strada progressiva.
            </p>
            <p class="mt-4">
              Stiamo organizzando contenuti, esercizi, mappe e collegamenti con professionisti, eventi e strumenti digitali. Chi vuole contribuire può farlo come insegnante, operatore, autore o tester dei percorsi.
            </p>
          </article>
        </details>

        <details data-project-status="pianificazione" class="project-article group rounded-2xl border border-emerald-100 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-6">
            <span>
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Concept</span>
              <span class="mt-2 block text-2xl font-semibold tracking-tight text-slate-950">Il Giardino del Corpo</span>
              <span class="mt-3 block text-sm leading-6 text-slate-600">Agriturismo rigenerativo, natura, corpo, salute e comunità.</span>
            </span>
            <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">Apri</span>
          </summary>
          <article class="mt-6 border-t border-slate-100 pt-6 text-base leading-7 text-slate-600">
            <p>
              Il Giardino del Corpo è l'estensione concreta della visione del libro: uno spazio in cui la salute non viene solo spiegata, ma vissuta attraverso ambiente, movimento, alimentazione, relazioni e pratiche rigenerative.
            </p>
            <p class="mt-4">
              Il progetto è ancora in costruzione: stiamo raccogliendo idee, alleanze, competenze e possibili luoghi. È pensato per ospitare eventi, ritiri, laboratori, percorsi e momenti di comunità.
            </p>
          </article>
        </details>

        <details data-project-status="in-corso" class="project-article group rounded-2xl border border-violet-100 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-6">
            <span>
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-violet-700">Attivo</span>
              <span class="mt-2 block text-2xl font-semibold tracking-tight text-slate-950">Eventi e Community</span>
              <span class="mt-3 block text-sm leading-6 text-slate-600">Camminate, incontri, laboratori e momenti condivisi sul territorio.</span>
            </span>
            <span class="rounded-full bg-violet-50 px-3 py-1 text-xs font-semibold text-violet-700">Apri</span>
          </summary>
          <article class="mt-6 border-t border-slate-100 pt-6 text-base leading-7 text-slate-600">
            <p>
              Gli eventi servono a portare il percorso fuori dallo schermo: camminare, incontrarsi, sperimentare, ascoltare il corpo e costruire relazioni. La community nasce proprio da questi momenti pratici.
            </p>
            <p class="mt-4">
              Cerchiamo persone, spazi e collaboratori per proporre attività legate a movimento, natura, musica, buon cibo, cultura e scambio di competenze.
            </p>
          </article>
        </details>

        <details data-project-status="pianificazione" class="project-article group rounded-2xl border border-orange-100 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-6">
            <span>
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-orange-700">Piattaforma</span>
              <span class="mt-2 block text-2xl font-semibold tracking-tight text-slate-950">FlowPulse e rete dei domini</span>
              <span class="mt-3 block text-sm leading-6 text-slate-600">La struttura digitale per pubblicare percorsi, nodi, iscrizioni e comunità tematiche.</span>
            </span>
            <span class="rounded-full bg-orange-50 px-3 py-1 text-xs font-semibold text-orange-700">Apri</span>
          </summary>
          <article class="mt-6 border-t border-slate-100 pt-6 text-base leading-7 text-slate-600">
            <p>
              FlowPulse è il motore digitale che permette di organizzare domini, nodi, contenuti, ruoli, iscrizioni e percorsi. PosturaCorretta diventa così uno dei mondi pubblicati dentro una rete più ampia.
            </p>
            <p class="mt-4">
              Qui servono sviluppatori, creator, copywriter, designer, persone operative e partner che vogliono contribuire alla parte software, editoriale e organizzativa.
            </p>
            <a href="https://wa.me/393792891488?text=Ciao%2C%20vorrei%20collaborare%20a%20un%20progetto%20in%20corso%20di%20PosturaCorretta."
               target="_blank" rel="noopener noreferrer"
               class="mt-6 inline-flex rounded-full bg-orange-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-orange-600">
              Proponi una collaborazione
            </a>
          </article>
        </details>

        <details data-project-status="idee" class="project-article group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-6">
            <span>
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-700">Idea futura</span>
              <span class="mt-2 block text-2xl font-semibold tracking-tight text-slate-950">Rete di luoghi rigenerativi</span>
              <span class="mt-3 block text-sm leading-6 text-slate-600">Unire spazi, professionisti e comunità locali intorno a salute, natura e cultura del corpo.</span>
            </span>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">Apri</span>
          </summary>
          <article class="mt-6 border-t border-slate-100 pt-6 text-base leading-7 text-slate-600">
            <p>
              L'idea è creare una rete fisica di luoghi rigenerativi associati a PosturaCorretta, dove le persone possano soggiornare per brevi periodi, praticare le metodiche posturali, alimentarsi in modo biologico e naturale e staccare dalla vita digitale frenetica.
            </p>
          </article>
        </details>
      </div>

    </div>
  </section>

  <%= render "posturacorretta/footer" %>
</div>

<script>
  (() => {
    const tabs = document.querySelectorAll(".project-status-tab");
    const articles = document.querySelectorAll(".project-article");

    tabs.forEach(tab => {
      tab.addEventListener("click", () => {
        const targetStatus = tab.dataset.projectTab;

        // Reset tab styles
        tabs.forEach(t => {
          t.setAttribute("aria-selected", "false");
          t.className = "project-status-tab rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-600 transition hover:bg-orange-50 hover:text-orange-700";
        });

        // Set active tab style
        tab.setAttribute("aria-selected", "true");
        tab.className = "project-status-tab rounded-xl bg-orange-500 px-4 py-2.5 text-sm font-semibold text-white transition";

        // Filter articles
        articles.forEach(article => {
          const status = article.dataset.projectStatus;
          if (targetStatus === "realizzati") {
            // Nothing in realized yet
            article.classList.add("hidden");
          } else if (status === targetStatus) {
            article.classList.remove("hidden");
          } else {
            article.classList.add("hidden");
          }
        });
      });
    });

    // Trigger filter initially to show 'in-corso'
    const activeTab = document.querySelector(".project-status-tab[aria-selected='true']");
    if (activeTab) {
      activeTab.click();
    }
  })();
</script>
