            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                Hai selezionato
              </p>

              <p id="selected-paths-text" class="mt-2 min-h-12 text-sm font-semibold leading-6 text-slate-950">
                Nessuna area selezionata.
              </p>
            </div>

            <a id="start-whatsapp-link"
               href="https://wa.me/393792891488?text=Ciao%2C%20vorrei%20iniziare%20un%20percorso%20con%20PosturaCorretta."
               target="_blank"
               rel="noopener noreferrer"
               class="mt-4 inline-flex w-full items-center justify-center rounded-xl bg-blue-600 px-5 py-3.5 text-sm font-semibold text-white hover:bg-blue-700 transition">
              Inizia ora →
            </a>
          </div>
        </div>

