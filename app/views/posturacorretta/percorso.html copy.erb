              <span class="text-2xl">🌱</span>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-wider text-indigo-600">Integrazione</p>
                <h4 class="text-base font-bold text-slate-900 group-hover:text-indigo-655 transition">Benessere Integrato</h4>
              </div>
            </div>
            <p class="mt-3 text-xs text-slate-500 leading-relaxed">Nutrizione cosciente, fitoterapia tradizionale, aspetti psicosomatici ed emotivi.</p>
          </a>

          <!-- Card 6: Il Giardino del Corpo -->
          <a href="<%= posturacorretta_contenuti_path %>?subtab=giardino" class="group text-left p-6 bg-white rounded-2xl border border-slate-200 hover:border-violet-300 hover:shadow-md transition block">
            <div class="flex items-center gap-3">
              <span class="text-2xl">🔒</span>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-wider text-violet-600">Esperienza</p>
                <h4 class="text-base font-bold text-slate-900 group-hover:text-violet-655 transition">Il Giardino del Corpo</h4>
              </div>
            </div>
