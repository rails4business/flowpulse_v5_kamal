            <div class="flex items-center gap-3">
              <span class="text-2xl">🩹</span>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-wider text-red-600">Fase Acuta</p>
                <h4 class="text-base font-bold text-slate-900 group-hover:text-red-655 transition">Stop al dolore</h4>
              </div>
            </div>
            <p class="mt-3 text-xs text-slate-500 leading-relaxed">Risolvi la fase acuta, decongestiona le catene in tensione e ritrova un allineamento indolore.</p>
          </button>

          <!-- Card 2: Prevenzione -->
          <button type="button" onclick="const btn = document.querySelector('[data-path-key=prevenzione]'); if(btn) btn.click();" class="group text-left p-6 bg-white rounded-2xl border border-slate-200 hover:border-emerald-300 hover:shadow-md transition">
