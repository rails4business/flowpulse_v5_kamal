          <!-- Card 5: Benessere Integrato -->
          <a href="<%= posturacorretta_contenuti_path %>?subtab=benessere" class="group text-left p-6 bg-white rounded-2xl border border-slate-200 hover:border-indigo-300 hover:shadow-md transition block">
