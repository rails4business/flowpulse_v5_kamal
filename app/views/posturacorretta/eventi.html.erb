              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/35 to-transparent"></div>
              
              <!-- Event Count Badge -->
              <div class="absolute left-4 top-4 z-10 rounded-xl bg-violet-700 px-3.5 py-1.5 text-xs font-bold text-white shadow-sm">
                ${count} ${count === 1 ? 'Evento' : 'Eventi'}
              </div>

              <!-- Bottom Text Overlay -->
              <div class="absolute inset-x-0 bottom-0 z-10 flex flex-col p-5 md:p-6">
                <span class="text-[10px] font-black uppercase tracking-wider text-violet-300">📍 Località</span>
                <h3 class="mt-1 text-lg font-black text-white leading-snug group-hover:text-violet-200 transition">
                  ${p.name}
                </h3>
                <p class="mt-1.5 text-xs text-slate-300 line-clamp-2 leading-relaxed">
                  ${p.description}
                </p>
              </div>
            </button>
          `;
        }).join("");
      }
      return;
    }

    // 2. TEACHERS RENDERING
    if (currentMacroTab === "teachers") {
      const filteredTeachers = teachers.filter(t => {
        if (!query) return true;
        return t.name.toLowerCase().includes(query) || t.role.toLowerCase().includes(query) || t.description.toLowerCase().includes(query);
