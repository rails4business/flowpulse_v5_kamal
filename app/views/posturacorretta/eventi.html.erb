    },
    {
      key: "studio-pc",
      name: "Studio PosturaCorretta, Bergamo",
      description: "Seminari teorico-pratico di anatomia esperienziale e catene GDS.",
      image: "https://images.unsplash.com/photo-1528605248644-14dd04022da1?auto=format&fit=crop&q=80&w=800"
