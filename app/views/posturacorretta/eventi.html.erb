      if (filteredTeachers.length === 0) {
        grid.classList.add("hidden");
        emptyState.classList.remove("hidden");
      } else {
        emptyState.classList.add("hidden");
        grid.classList.remove("hidden");

        grid.innerHTML = filteredTeachers.map(t => {
          const count = getEventCountForTeacher(t.name);
          return `
            <button type="button" onclick="filterByTeacher('${t.name}')" class="group relative aspect-[16/11] w-full overflow-hidden rounded-lg border border-slate-200 bg-slate-950 text-left shadow-sm transition duration-300 hover:border-slate-300 hover:shadow-md sm:aspect-[5/4] lg:aspect-[4/5] focus:outline-none">
              <img src="${t.image}" alt="${t.name}" class="absolute inset-0 h-full w-full object-cover object-center opacity-100 transition duration-500 group-hover:scale-105 group-hover:opacity-90" loading="lazy">
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/40 to-transparent"></div>
              
              <!-- Event Count Badge -->
              <div class="absolute left-4 top-4 z-10 rounded-xl bg-violet-700 px-3.5 py-1.5 text-xs font-bold text-white shadow-sm">
                Presenza in ${count} ${count === 1 ? 'evento' : 'eventi'}
              </div>

              <!-- Bottom Text Overlay -->
              <div class="absolute inset-x-0 bottom-0 z-10 flex flex-col p-5 md:p-6">
                <span class="text-[10px] font-black uppercase tracking-wider text-violet-300">${t.role}</span>
                <h3 class="mt-1 text-lg font-black text-white leading-snug group-hover:text-violet-200 transition">
                  ${t.name}
                </h3>
                <p class="mt-1.5 text-xs text-slate-300 line-clamp-2 leading-relaxed">
                  ${t.description}
                </p>
              </div>
            </button>
          `;
        }).join("");
      }
      return;
    }

    // 3. EVENTS RENDERING
    const filteredEvents = events.filter(e => {
      // Temporal Tab Filter
      if (e.type !== currentTemporalTab) return false;

      // Date Picker Filter
      if (dateFilter) {
        if (currentTemporalTab === "future") {
          if (e.date < dateFilter) return false;
        } else {
          if (e.date > dateFilter) return false;
        }
      }

      // Location filter
      if (selectedLocation && e.locationKey !== selectedLocation.key) return false;

      // Teacher filter
      if (selectedTeacher && !e.teachers.includes(selectedTeacher)) return false;

      // Search Query filter
      if (query) {
        const matchesTitle = e.title.toLowerCase().includes(query);
        const matchesDesc = e.description.toLowerCase().includes(query);
        const matchesLoc = e.location.toLowerCase().includes(query);
        const matchesTeachers = e.teachers.some(t => t.toLowerCase().includes(query));
        if (!matchesTitle && !matchesDesc && !matchesLoc && !matchesTeachers) return false;
      }

      return true;
    });

    if (filteredEvents.length === 0) {
      grid.classList.add("hidden");
      emptyState.classList.remove("hidden");
    } else {
      emptyState.classList.add("hidden");
      grid.classList.remove("hidden");

      grid.innerHTML = filteredEvents.map(e => `
        <button type="button" onclick="openEventModal(${e.id})" class="group relative aspect-[16/11] w-full overflow-hidden rounded-lg border border-slate-200 bg-slate-950 text-left shadow-sm transition duration-300 hover:border-slate-300 hover:shadow-md sm:aspect-[5/4] lg:aspect-[4/5] focus:outline-none">
          <img src="${e.image}" alt="${e.title}" class="absolute inset-0 h-full w-full object-cover object-center opacity-100 transition duration-500 group-hover:scale-105 group-hover:opacity-90" loading="lazy">
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/35 to-transparent"></div>
          
          <!-- Top date badge overlay -->
          <div class="absolute left-4 top-4 z-10 rounded-xl bg-white/90 px-3.5 py-1.5 text-xs font-bold text-slate-800 shadow-sm backdrop-blur-md">
            ${e.formattedDate}
          </div>

          <!-- Top hover helper overlay -->
          <div class="absolute right-4 top-4 z-10 rounded-xl bg-white/25 px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider text-white opacity-0 backdrop-blur-md transition-opacity duration-300 group-hover:opacity-100">
            Leggi Programma 🔎
          </div>

          <!-- Bottom Text Overlay -->
          <div class="absolute inset-x-0 bottom-0 z-10 flex flex-col p-5 md:p-6">
            <span onclick="event.stopPropagation(); filterByLocation('${e.locationKey}', '${e.location}')" class="text-[10px] font-black uppercase tracking-wider text-violet-300 hover:text-violet-200 cursor-pointer transition select-none self-start">
              📍 ${e.location}
            </span>
            <h3 class="mt-1.5 text-lg font-black text-white leading-snug group-hover:text-violet-200 transition line-clamp-2">
              ${e.title}
            </h3>
            <p class="mt-2 text-xs text-slate-300 line-clamp-3 leading-relaxed">
              ${e.description}
            </p>
          </div>
        </button>
      `).join("");
    }
  }

  window.renderEvents = renderEvents;

  window.openEventModal = function(id) {
    const event = events.find(e => e.id === id);
    if (!event) return;
    const modal = document.getElementById("event-modal");
    const card = document.getElementById("event-modal-card");
    const content = document.getElementById("event-modal-content");
    const registerBtn = document.getElementById("event-modal-register-btn");

    content.innerHTML = `
      <div class="grid gap-6 md:grid-cols-[160px_1fr]">
        <div class="hidden aspect-[4/3] w-full cursor-pointer overflow-hidden rounded-xl bg-slate-100 shadow-sm md:block" onclick="filterByLocation('${event.locationKey}', '${event.location}')" title="Filtra per questo luogo">
          <img src="${event.image}" alt="${event.title}" class="h-full w-full object-cover hover:scale-[1.02] transition duration-300">
        </div>
        <div>
          <button type="button" onclick="event.stopPropagation(); filterByLocation('${event.locationKey}', '${event.location}')" class="inline-flex rounded-full bg-violet-100 px-3 py-1 text-[10px] font-black uppercase tracking-wider text-violet-700 transition hover:bg-violet-200" title="Filtra per questo luogo">
            📍 ${event.location}
          </button>
          <h2 class="mt-2.5 text-2xl font-black leading-snug text-slate-950">${event.title}</h2>
          <div class="flex items-center gap-2 mt-3 text-xs text-slate-500 font-semibold">
            <span>📅 Data dell'evento:</span>
            <span class="text-slate-800 font-bold">${event.formattedDate}</span>
          </div>
        </div>
      </div>

      <!-- Description -->
      <div class="border-t border-slate-100 pt-5">
        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Descrizione</h4>
        <p class="text-sm leading-relaxed text-slate-655">${event.description}</p>
      </div>

      <!-- Teachers -->
      <div class="border-t border-slate-100 pt-5">
        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-2.5">Insegnanti e Conduttori presenti</h4>
        <div class="flex flex-wrap gap-2">
          ${event.teachers.map(teacher => `
            <button type="button" onclick="event.stopPropagation(); filterByTeacher('${teacher}')" class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 hover:bg-slate-200 border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 transition" title="Filtra eventi con questo professionista">
              👤 ${teacher}
            </button>
          `).join("")}
        </div>
      </div>

      <!-- Detailed Program -->
      <div class="border-t border-slate-100 pt-5">
        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-3">Programma della giornata</h4>
        <ul class="space-y-3">
          ${event.program.map(step => {
            const parts = step.split(" — ");
            if (parts.length === 2) {
              return `
                <li class="flex items-start gap-3 text-sm">
                  <span class="font-bold text-violet-700 whitespace-nowrap bg-violet-50 rounded-lg px-2.5 py-1 text-xs mt-0.5 border border-violet-100/50">${parts[0]}</span>
                  <span class="text-slate-600 mt-1 leading-normal">${parts[1]}</span>
                </li>
              `;
            } else {
              return `
                <li class="flex items-start gap-3 text-sm text-slate-600">
                  <span class="text-violet-700 mt-1">•</span>
                  <span class="leading-normal">${step}</span>
                </li>
              `;
            }
          }).join("")}
        </ul>
      </div>
    `;

    // Configure Register button URL
    registerBtn.href = `https://wa.me/393792891488?text=${encodeURIComponent(event.waText)}`;

    // Show modal and run entrance animation
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    document.body.style.overflow = "hidden";
    setTimeout(() => {
      card.classList.remove("scale-95", "opacity-0");
      card.classList.add("scale-100", "opacity-100");
    }, 10);
  };

  window.closeEventModal = function() {
    const modal = document.getElementById("event-modal");
    const card = document.getElementById("event-modal-card");

    card.classList.remove("scale-100", "opacity-100");
    card.classList.add("scale-95", "opacity-0");
    
    setTimeout(() => {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      document.body.style.overflow = "";
    }, 300);
  };

  window.filterByLocation = function(key, name) {
    selectedLocation = { key, name };
    selectedTeacher = null;
    closeEventModal();
    switchMacroTab("events");
  };

  window.filterByTeacher = function(name) {
    selectedTeacher = name;
    selectedLocation = null;
    closeEventModal();
    switchMacroTab("events");
  };

  window.clearFilters = function() {
    selectedLocation = null;
    selectedTeacher = null;
    renderEvents();
  };

  window.switchMacroTab = function(tab) {
    currentMacroTab = tab;

    // Highlight macro tab button active state
    const macroTabs = ["events", "places", "teachers"];
    macroTabs.forEach(t => {
      const btn = document.getElementById(`tab-macro-${t}`);
      if (t === tab) {
        btn.className = "macro-tab shrink-0 rounded-full px-5 py-2.5 text-xs font-bold transition bg-slate-950 text-white shadow-sm";
      } else {
        btn.className = "macro-tab shrink-0 rounded-full px-5 py-2.5 text-xs font-bold transition bg-white text-slate-600 border border-slate-200 hover:border-slate-350 hover:text-slate-950";
      }
    });

    // Toggle sub controls row visibility & update search bar placeholder
    const subControlsRow = document.getElementById("sub-controls-row");
    const searchInput = document.getElementById("event-search-input");
    
    if (tab === "events") {
      subControlsRow.classList.remove("hidden");
      subControlsRow.classList.add("flex");
      searchInput.placeholder = "Cerca eventi...";
    } else {
      subControlsRow.classList.add("hidden");
      subControlsRow.classList.remove("flex");
      if (tab === "places") {
        searchInput.placeholder = "Cerca luoghi...";
      } else {
        searchInput.placeholder = "Cerca Conduttori...";
      }
    }

    // Trigger render with opacity transition animation
    const grid = document.getElementById("events-grid");
    grid.style.opacity = 0;
    setTimeout(() => {
      renderEvents();
      grid.style.opacity = 1;
    }, 150);
  };

  window.switchTemporalTab = function(tab) {
    currentTemporalTab = tab;

    // Toggle sub temporal tabs styles
    const futureBtn = document.getElementById("tab-temp-future");
    const pastBtn = document.getElementById("tab-temp-past");
    const dateLabel = document.getElementById("filter-date-label");

    if (tab === "future") {
      futureBtn.className = "temp-tab shrink-0 rounded-full px-4 py-2 text-xs font-bold transition bg-slate-900 text-white shadow-sm";
      pastBtn.className = "temp-tab shrink-0 rounded-full px-4 py-2 text-xs font-bold transition bg-white text-slate-600 border border-slate-200 hover:border-slate-350 hover:text-slate-950";
      dateLabel.textContent = "Mostra dal:";
    } else {
      pastBtn.className = "temp-tab shrink-0 rounded-full px-4 py-2 text-xs font-bold transition bg-slate-900 text-white shadow-sm";
      futureBtn.className = "temp-tab shrink-0 rounded-full px-4 py-2 text-xs font-bold transition bg-white text-slate-600 border border-slate-200 hover:border-slate-350 hover:text-slate-950";
      dateLabel.textContent = "Mostra fino al:";
    }

    // Trigger render
    const grid = document.getElementById("events-grid");
    grid.style.opacity = 0;
    setTimeout(() => {
      renderEvents();
      grid.style.opacity = 1;
    }, 150);
  };

  window.clearDateFilter = function() {
    document.getElementById("event-date-filter").value = "";
    renderEvents();
  };

  function initializeEventsPage() {
    const dateFilter = document.getElementById("event-date-filter");
    const modal = document.getElementById("event-modal");
    if (!dateFilter || !modal) return;

    if (dateFilter.dataset.eventsInitialized !== "true") {
      dateFilter.addEventListener("change", renderEvents);
      dateFilter.dataset.eventsInitialized = "true";
    }

    if (modal.dataset.eventsInitialized !== "true") {
      modal.addEventListener("click", function(e) {
        if (e.target === this) {
          closeEventModal();
        }
      });
      modal.dataset.eventsInitialized = "true";
    }

    renderEvents();
  }

  document.addEventListener("DOMContentLoaded", initializeEventsPage);
  document.addEventListener("turbo:load", initializeEventsPage);
})();
</script>
