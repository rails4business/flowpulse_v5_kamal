  let currentTemporalTab = "future"; // 'future', 'past'
  let selectedLocation = null; // { key, name }
  let selectedTeacher = null; // string

  // Helper count logic
  const getEventCountForPlace = (key) => events.filter(e => e.locationKey === key).length;
  const getEventCountForTeacher = (name) => events.filter(e => e.teachers.includes(name)).length;

  function renderEvents() {
    const grid = document.getElementById("events-grid");
    const emptyState = document.getElementById("events-empty");
    const dateFilter = document.getElementById("event-date-filter").value;
    const query = document.getElementById("event-search-input").value.trim().toLowerCase();

    // Toggle active filters bar visibility
    const filterBar = document.getElementById("active-filters-bar");
    const filterTagText = document.getElementById("filter-tag-text");
    if ((selectedLocation || selectedTeacher) && currentMacroTab === "events") {
      filterBar.classList.remove("hidden");
      filterBar.classList.add("flex");
      if (selectedLocation) {
        filterTagText.innerHTML = `📍 Luogo: <strong>${selectedLocation.name}</strong>`;
      } else {
        filterTagText.innerHTML = `👤 Professionista: <strong>${selectedTeacher}</strong>`;
      }
    } else {
      filterBar.classList.add("hidden");
      filterBar.classList.remove("flex");
    }

    // 1. PLACES RENDERING
    if (currentMacroTab === "places") {
      const filteredPlaces = places.filter(p => {
        if (!query) return true;
        return p.name.toLowerCase().includes(query) || p.description.toLowerCase().includes(query);
      });

      if (filteredPlaces.length === 0) {
        grid.classList.add("hidden");
        emptyState.classList.remove("hidden");
      } else {
        emptyState.classList.add("hidden");
        grid.classList.remove("hidden");

        grid.innerHTML = filteredPlaces.map(p => {
          const count = getEventCountForPlace(p.key);
          return `
            <button type="button" onclick="filterByLocation('${p.key}', '${p.name}')" class="group relative aspect-[16/11] w-full overflow-hidden rounded-lg border border-slate-200 bg-slate-950 text-left shadow-sm transition duration-300 hover:border-slate-300 hover:shadow-md sm:aspect-[5/4] lg:aspect-[4/5] focus:outline-none">
