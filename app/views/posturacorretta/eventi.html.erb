<% content_for :landing_nav do %>
  <%= render "posturacorretta/header" %>
<% end %>

<div id="top" class="text-slate-900 antialiased">

  <!-- EVENTI -->
  <section class="border-t border-slate-200 bg-slate-50 px-5 py-20 md:py-24 min-h-[calc(100vh-4rem)] flex items-center">
    <div class="mx-auto w-full max-w-6xl">
      <div class="grid gap-12 items-center lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-violet-700">
            Eventi e Community
          </p>
          <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-955 md:text-6xl md:leading-[1.04]">
            Eventi per vivere il percorso, non solo studiarlo.
          </h1>
          <p class="mt-6 text-lg leading-8 text-slate-600">
            Camminate, incontri, attività sul territorio, movimento, natura, musica, buon cibo, scambio trattamenti e momenti di comunità.
          </p>
          <div class="mt-8">
            <a href="https://wa.me/393792891488?text=Ciao%2C%20vorrei%20informazioni%20sui%20prossimi%20eventi%20PosturaCorretta."
               target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center rounded-2xl bg-violet-750 px-6 py-4 text-base font-semibold text-white transition hover:bg-violet-850 shadow-sm">
              Chiedi informazioni sugli eventi →
            </a>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <a href="https://www.youtube.com/posturacorretta" target="_blank" rel="noopener noreferrer" class="group rounded-[1.75rem] border border-slate-200 bg-white p-8 transition hover:-translate-y-1 hover:border-red-200 hover:shadow-xl">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-600">Video & Ricerca</p>
            <h3 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">YouTube</h3>
            <p class="mt-4 text-base leading-7 text-slate-600">Approfondimenti, esercizi, eventi e costruzione pubblica del progetto.</p>
            <div class="mt-6 flex items-center gap-2 text-sm font-semibold text-red-600">Vai al canale <span class="transition group-hover:translate-x-1">→</span></div>
          </a>

          <a href="https://www.instagram.com/posturacorretta" target="_blank" rel="noopener noreferrer" class="group rounded-[1.75rem] border border-slate-200 bg-white p-8 transition hover:-translate-y-1 hover:border-pink-200 hover:shadow-xl">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-pink-600">Community & Eventi</p>
            <h3 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">Instagram</h3>
            <p class="mt-4 text-base leading-7 text-slate-600">Dietro le quinte, caroselli, eventi e aggiornamenti quotidiani.</p>
            <div class="mt-6 flex items-center gap-2 text-sm font-semibold text-pink-600">Segui la pagina <span class="transition group-hover:translate-x-1">→</span></div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <%= render "posturacorretta/footer" %>
</div>
