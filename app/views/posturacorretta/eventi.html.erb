    }
  ];

  const places = [
    {
      key: "clusone",
      name: "Clusone (BG)",
      description: "Camminate montane e mobilità nei boschi della Val Seriana.",
      image: "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&q=80&w=800"
    },
    {
      key: "parco-colli",
      name: "Parco dei Colli, Bergamo",
      description: "Pratiche all'aperto, stabilizzazione DNS ed Animal Flow a due passi dalla città.",
      image: "https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&q=80&w=800"
    },
    {
      key: "toscana",
      name: "Il Giardino del Corpo, Toscana",
      description: "Ritiro somatico e percorsi di benessere integrato in agriturismo rigenerativo.",
