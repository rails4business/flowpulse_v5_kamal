<% content_for :landing_nav do %>
  <%= render "posturacorretta/header" %>
<% end %>

<div id="top" class="text-slate-900 antialiased bg-slate-50">

  <!-- HERO SECTION -->
  <section class="px-5 pt-16 pb-12 text-center">
    <div class="mx-auto w-full max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-violet-700">
        Eventi e Community
      </p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-5xl md:leading-[1.05]">
        Eventi per vivere il percorso, non solo studiarlo.
      </h1>
      <p class="mt-4 text-base leading-relaxed text-slate-600 max-w-2xl mx-auto">
        Clicca su un evento per visualizzare il programma dettagliato e prenotare il tuo posto.
      </p>
    </div>
  </section>

  <!-- EVENTI INTERACTIVE GRID SECTION -->
  <section class="px-5 pb-20">
    <div class="mx-auto w-full max-w-5xl">
      
      <!-- Top Level Tabs & Search Bar -->
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-slate-200 pb-5 mb-6">
        <!-- Macro Tabs -->
        <div class="flex gap-2" role="group" aria-label="Sezione principale">
          <button type="button" onclick="switchMacroTab('events')" id="tab-macro-events" class="macro-tab shrink-0 rounded-full px-5 py-2.5 text-xs font-bold transition bg-slate-950 text-white shadow-sm">
            Tutti gli Eventi
          </button>
          <button type="button" onclick="switchMacroTab('places')" id="tab-macro-places" class="macro-tab shrink-0 rounded-full px-5 py-2.5 text-xs font-bold transition bg-white text-slate-600 border border-slate-200 hover:border-slate-350 hover:text-slate-950">
            Luoghi
          </button>
          <button type="button" onclick="switchMacroTab('teachers')" id="tab-macro-teachers" class="macro-tab shrink-0 rounded-full px-5 py-2.5 text-xs font-bold transition bg-white text-slate-600 border border-slate-200 hover:border-slate-350 hover:text-slate-950">
            Conduttori
          </button>
        </div>

        <!-- Search Bar Input -->
        <div class="relative w-full md:max-w-xs">
          <span class="absolute inset-y-0 left-3.5 flex items-center text-slate-400 select-none pointer-events-none">🔍</span>
          <input type="text" id="event-search-input" oninput="renderEvents()" placeholder="Cerca eventi..." class="w-full rounded-xl border border-slate-200 bg-white py-2 pl-9 pr-4 text-xs text-slate-700 outline-none transition focus:border-blue-400 focus:ring-4 focus:ring-blue-100">
        </div>
      </div>

      <!-- Sub Level Controls Row (Temporal Filters) -->
      <div id="sub-controls-row" class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pb-6 mb-8 border-b border-slate-100">
        <!-- Sub-Tabs (Temporal) -->
        <div class="flex gap-2" role="group" aria-label="Filtro temporale">
          <button type="button" onclick="switchTemporalTab('future')" id="tab-temp-future" class="temp-tab shrink-0 rounded-full px-4 py-2 text-xs font-bold transition bg-slate-900 text-white shadow-sm">
            Prossimi
          </button>
          <button type="button" onclick="switchTemporalTab('past')" id="tab-temp-past" class="temp-tab shrink-0 rounded-full px-4 py-2 text-xs font-bold transition bg-white text-slate-600 border border-slate-200 hover:border-slate-350 hover:text-slate-950">
            Passati
          </button>
        </div>

        <!-- Date Filter Inputs -->
        <div class="flex items-center gap-3 self-end sm:self-auto" id="date-filter-container">
          <span class="text-xs font-bold uppercase tracking-wider text-slate-500" id="filter-date-label">Mostra dal:</span>
          <input type="date" id="event-date-filter" class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs text-slate-700 outline-none transition focus:border-blue-400 focus:ring-4 focus:ring-blue-100">
          <button type="button" onclick="clearDateFilter()" class="text-xs font-bold text-slate-400 hover:text-slate-600">Azzera</button>
        </div>
      </div>

      <!-- Active Filters Bar -->
      <div id="active-filters-bar" class="hidden flex-wrap items-center gap-2 mb-6 -mt-2">
        <span class="text-xs text-slate-500 font-bold uppercase tracking-wider">Filtri attivi:</span>
        <span id="filter-tag" class="inline-flex items-center gap-1.5 rounded-xl border border-violet-200 bg-violet-50 px-3 py-1.5 text-xs font-bold text-violet-700 shadow-sm">
          <span id="filter-tag-text">📍 Clusone</span>
          <button type="button" onclick="clearFilters()" class="select-none text-sm font-black text-violet-500 hover:text-violet-800 focus:outline-none">×</button>
        </span>
      </div>

      <!-- Events Grid -->
      <div id="events-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 transition-opacity duration-200">
        <!-- Cards dynamically inserted here -->
      </div>

      <!-- Empty State -->
      <div id="events-empty" class="hidden rounded-lg border border-dashed border-slate-300 bg-white py-16 text-center">
        <span class="text-3xl">📅</span>
        <p class="mt-4 font-bold text-slate-900 text-lg">Nessun evento trovato</p>
        <p class="mt-2 text-sm text-slate-500">Prova a cambiare il filtro della data o passa alla scheda degli eventi passati.</p>
      </div>

      <!-- General WhatsApp CTA -->
      <div class="mt-16 text-center">
        <p class="text-sm text-slate-500 mb-4">Vuoi proporre un evento o ricevere aggiornamenti diretti?</p>
        <a href="https://wa.me/393792891488?text=Ciao%2C%20vorrei%20informazioni%20sui%20prossimi%20eventi%20PosturaCorretta."
           target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center justify-center rounded-lg bg-violet-700 px-8 py-4 text-base font-semibold text-white shadow-sm transition hover:bg-violet-800 active:scale-[0.98]">
          Contattaci su WhatsApp →
        </a>
      </div>

    </div>
  </section>

  <!-- MODALE DETTAGLI EVENTO -->
  <div id="event-modal" class="fixed inset-0 z-50 hidden bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="relative flex max-h-[90vh] w-full max-w-2xl scale-95 flex-col rounded-lg border border-slate-100 bg-white p-6 opacity-0 shadow-2xl transition-all duration-300 md:p-8" id="event-modal-card">
      
      <!-- Close icon -->
      <button type="button" onclick="closeEventModal()" class="absolute top-5 right-5 text-slate-400 hover:text-slate-600 text-2xl font-bold focus:outline-none transition">
        ✕
      </button>

      <!-- Modal Content Body -->
      <div class="overflow-y-auto pr-1 flex-1 scrollbar-thin">
        <div class="flex flex-col gap-6" id="event-modal-content">
          <!-- Dynamically inserted details -->
        </div>
      </div>

      <!-- Footer Buttons -->
      <div class="mt-6 border-t border-slate-100 pt-6 flex flex-col sm:flex-row gap-3">
        <a id="event-modal-register-btn" href="#" target="_blank" rel="noopener noreferrer" class="inline-flex flex-1 items-center justify-center rounded-xl bg-violet-700 px-6 py-3.5 text-sm font-bold text-white shadow-sm transition hover:bg-violet-800 active:scale-[0.98]">
          Iscriviti ora su WhatsApp →
        </a>
        <button type="button" onclick="closeEventModal()" class="rounded-xl border border-slate-200 bg-white px-6 py-3.5 text-sm font-semibold text-slate-600 hover:bg-slate-50 transition">
          Chiudi
        </button>
      </div>

    </div>
  </div>

  <%= render "posturacorretta/footer" %>
</div>

<script>
