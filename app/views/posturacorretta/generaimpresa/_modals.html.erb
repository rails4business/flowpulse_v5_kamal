<style>
dialog {
  margin: auto;
  border-radius: 1rem;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  border: none;
  padding: 0;
  width: min(860px, calc(100vw - 2rem));
  max-height: 85vh;
}
dialog::backdrop { background: rgba(17, 24, 39, 0.6); backdrop-filter: blur(4px); }
</style>

<dialog id="projectDialog" class="bg-white">
  <form method="dialog" id="projectForm" class="flex flex-col h-full">
    <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
      <h3 class="text-xl font-bold text-gray-900">Nuovo progetto</h3>
      <button class="text-gray-400 hover:text-gray-600 focus:outline-none transition" value="cancel" aria-label="Chiudi">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <div class="overflow-y-auto px-6 py-6 flex-1">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-gray-700">Nome del progetto</label>
          <input name="name" required placeholder="Es. Accademia online" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-3 border">
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Cosa crea?</label>
          <select name="type" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-3 border bg-white">
            <option>Servizio</option>
            <option>Prodotto</option>
            <option>App</option>
            <option>Evento</option>
            <option>Contenuto</option>
            <option>Altro</option>
          </select>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Stato</label>
          <select name="status" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-3 border bg-white">
            <option>Idea</option>
            <option>Raccolta</option>
            <option>Attivo</option>
          </select>
        </div>
        
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-gray-700">Risultato concreto</label>
          <input name="output" required placeholder="Cosa esisterà alla fine del progetto?" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-3 border">
        </div>

        <details class="group sm:col-span-2 border border-gray-100 bg-gray-50 rounded-lg">
          <summary class="flex cursor-pointer items-center justify-between px-4 py-3 font-medium text-gray-900">
            <span>Economia e raccolta</span>
            <span class="transition group-open:-rotate-180">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </span>
          </summary>
          <div class="border-t border-gray-200 px-4 py-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div><label class="block text-xs font-medium text-gray-700">Costi iniziali (€)</label><input name="initial" type="number" min="0" value="10000" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-2 border"></div>
            <div><label class="block text-xs font-medium text-gray-700">Manutenzione annua (€)</label><input name="maintenance" type="number" min="0" value="1200" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-2 border"></div>
            <div><label class="block text-xs font-medium text-gray-700">Ricavi previsti annui (€)</label><input name="revenue" type="number" min="0" value="18000" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-2 border"></div>
            <div><label class="block text-xs font-medium text-gray-700">Fondi già raccolti (€)</label><input name="funded" type="number" min="0" value="0" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-2 border"></div>
            <div><label class="block text-xs font-medium text-gray-700">Dash già raccolti</label><input name="fundedDash" type="number" min="0" step="0.01" value="0" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-2 border"></div>
            <div><label class="block text-xs font-medium text-gray-700">Valore interno di 1 Dash (€)</label><input name="dashRate" type="number" min="0" step="0.01" value="100" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-2 border"></div>
          </div>
        </details>

        <details class="group sm:col-span-2 border border-gray-100 bg-gray-50 rounded-lg">
          <summary class="flex cursor-pointer items-center justify-between px-4 py-3 font-medium text-gray-900">
            <span>Organizzazione</span>
            <span class="transition group-open:-rotate-180">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </span>
          </summary>
          <div class="border-t border-gray-200 px-4 py-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div><label class="block text-xs font-medium text-gray-700">Numero di step</label><input name="steps" type="number" min="1" value="5" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-2 border"></div>
            <div><label class="block text-xs font-medium text-gray-700">Responsabile</label><input name="owner" placeholder="Da assegnare" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-2 border"></div>
          </div>
        </details>
      </div>
    </div>
    
    <div class="flex items-center justify-end gap-3 border-t border-gray-100 px-6 py-4 bg-gray-50">
      <button class="rounded-md px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-200 transition" value="cancel">Annulla</button>
      <button class="rounded-md bg-indigo-600 px-5 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 transition" value="default" id="saveProject">Crea progetto</button>
    </div>
  </form>
</dialog>

<dialog id="companyDialog" class="bg-white">
  <form method="dialog" id="companyForm" class="flex flex-col h-full">
    <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
      <h3 class="text-xl font-bold text-gray-900">Nuova area</h3>
      <button class="text-gray-400 hover:text-gray-600 focus:outline-none transition" value="cancel">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
    <div class="px-6 py-6">
      <label class="block text-sm font-medium text-gray-700">Nome area</label>
      <input name="company" required placeholder="Nome della nuova area progettuale" class="mt-1 w-full rounded-md border-gray-200 shadow-sm sm:text-sm p-3 border">
    </div>
    <div class="flex items-center justify-end gap-3 border-t border-gray-100 px-6 py-4 bg-gray-50">
      <button class="rounded-md px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-200 transition" value="cancel">Annulla</button>
      <button class="rounded-md bg-indigo-600 px-5 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 transition" value="default" id="saveCompany">Aggiungi</button>
    </div>
  </form>
</dialog>

<dialog id="detailDialog" class="bg-white">
  <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">Ciclo economico del progetto</p>
      <h3 class="mt-1 text-xl font-bold text-gray-900" id="detailTitle">Progetto</h3>
    </div>
    <button class="text-gray-400 hover:text-gray-600 focus:outline-none transition" onclick="detailDialog.close()">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>
  <div class="px-6 py-6 overflow-y-auto" id="detailBody" style="max-height: 60vh;"></div>
  <div class="flex items-center justify-end gap-3 border-t border-gray-100 px-6 py-4 bg-gray-50">
    <button class="rounded-md px-5 py-2 text-sm font-medium text-gray-600 hover:bg-gray-200 transition" onclick="detailDialog.close()">Chiudi</button>
  </div>
</dialog>
