  <script>
    const seed=[
      {id:1,company:'PosturaCorretta',name:'Accademia PosturaCorretta',type:'Servizio',status:'Attivo',output:'Percorso formativo online e in presenza',initial:18000,maintenance:4200,revenue:42000,funded:17000,fundedDash:10,dashRate:100,steps:8,done:5,owner:'Marco',people:['MB','AV','+2']},
      {id:2,company:'PosturaCorretta',name:'Il corpo, un mondo da scoprire',type:'Prodotto',status:'Raccolta',output:'Libro e percorso di ingresso all’ecosistema',initial:9300,maintenance:600,revenue:24000,funded:5600,fundedDash:5,dashRate:100,steps:6,done:3,owner:'Marco',people:['MB','ED']},
      {id:3,company:'Flowpulse',name:'1Impegno',type:'App',status:'Raccolta',output:'Agenda condivisa per eventi, servizi e referral',initial:32000,maintenance:7800,revenue:54000,funded:11400,fundedDash:10,dashRate:100,steps:12,done:4,owner:'Da assegnare',people:['MB','?']},
      {id:4,company:'Flowpulse',name:'Rails4Business',type:'Servizio',status:'Idea',output:'Percorso e linee guida per collaboratori digitali',initial:7500,maintenance:1800,revenue:15000,funded:800,fundedDash:0,dashRate:100,steps:7,done:1,owner:'Marco',people:['MB']},
      {id:5,company:'Il Giardino del Corpo',name:'Primo evento rigenerativo',type:'Evento',status:'Idea',output:'Un’esperienza pilota di una giornata',initial:4800,maintenance:0,revenue:7200,funded:700,fundedDash:5,dashRate:100,steps:9,done:2,owner:'Da assegnare',people:['MB','?']}
    ];
    let data=JSON.parse(localStorage.getItem('genera-projects')||'null')||seed;
    let companies=JSON.parse(localStorage.getItem('genera-companies')||'null')||['PosturaCorretta','Flowpulse','Il Giardino del Corpo'];
    let selected=companies[0], filter='all';
    const eur=n=>new Intl.NumberFormat('it-IT',{style:'currency',currency:'EUR',maximumFractionDigits:0}).format(n);
    
    function persist(){
      localStorage.setItem('genera-projects',JSON.stringify(data));
      localStorage.setItem('genera-companies',JSON.stringify(companies));
    }
    
    function renderCompanies(){
      document.querySelector('#companies').innerHTML=companies.map(c=>{
        const isActive = c===selected;
        const count = data.filter(p=>p.company===c).length;
        const btnClass = isActive ? "shrink-0 inline-flex items-center gap-2 rounded-full bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition" : "shrink-0 inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition";
        const countClass = isActive ? "inline-flex items-center justify-center rounded-full bg-indigo-500 px-2 py-0.5 text-xs text-white" : "inline-flex items-center justify-center rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-500";
        return `<button class="company ${btnClass}" data-company="${c}"><span>${c}</span><span class="${countClass}">${count}</span></button>`;
      }).join('');
      
      document.querySelectorAll('[data-company]').forEach(b=>b.onclick=()=>{
        selected=b.dataset.company;
        filter='all';
        // Reset filters UI
        document.querySelectorAll('.filter').forEach(f => {
          if(f.dataset.filter === 'all') {
            f.className = "filter active shrink-0 rounded-md bg-indigo-100 px-3 py-2 text-sm font-medium text-indigo-700 transition";
          } else {
            f.className = "filter shrink-0 rounded-md px-3 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition";
          }
        });
        render();
      });
    }
    
    function render(){
      renderCompanies();
      document.querySelector('#companyTitle').textContent=selected;
      const all=data.filter(p=>p.company===selected),
            view=all.filter(p=>filter==='all'||p.status===filter),
            euro=all.reduce((s,p)=>s+p.funded,0),
            dash=all.reduce((s,p)=>s+(p.fundedDash||0),0);
      document.querySelector('#activeCount').textContent=all.filter(p=>p.status==='Attivo').length;
      document.querySelector('#fundedTotal').innerHTML=`${eur(euro)} <span class="block mt-1 text-sm text-gray-400 font-medium">+ ${dash.toLocaleString('it-IT')} DASH</span>`;
      document.querySelector('#revenueTotal').textContent=eur(all.reduce((s,p)=>s+p.revenue,0));
      document.querySelector('#projects').innerHTML=view.length?view.map(card).join(''):'<div class="col-span-full border-2 border-dashed border-gray-200 rounded-2xl bg-white p-12 text-center text-gray-500 font-medium">Nessun progetto in questa sezione.</div>';
    }
    
    function card(p){
      ensureFinance(p);
      const dash=p.fundedDash||0,
            rate=p.dashRate||100,
            equivalent=p.funded+dash*rate,
            pc=Math.min(100,Math.round(equivalent/p.initial*100)||0),
            ready=pc>=100&&p.owner!=='Da assegnare',
            next=p.owner==='Da assegnare'?'Assegna un responsabile':pc<100?'Completa la raccolta':p.done<p.steps?'Continua la realizzazione':'Gestisci rendite e quote',
            cls=p.type==='App'?'bg-blue-100 text-blue-700 border-blue-200':p.status==='Raccolta'?'bg-amber-100 text-amber-700 border-amber-200':'bg-emerald-100 text-emerald-700 border-emerald-200';
            
      return `
        <article class="flex flex-col rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
          <div class="flex items-center justify-between">
            <span class="inline-flex items-center justify-center rounded-full border px-2.5 py-0.5 text-xs font-semibold uppercase tracking-widest ${cls}">${p.type}</span>
            <span class="text-xs font-bold text-gray-500 uppercase tracking-widest">${ready?'● Pronto':p.status}</span>
          </div>
          <h4 class="mt-4 text-xl font-extrabold text-gray-900">${p.name}</h4>
          <p class="mt-2 min-h-[3rem] text-sm leading-relaxed text-gray-600">${p.output}</p>
          
          <div class="mt-6 pt-5 border-t border-gray-100">
            <div class="flex items-center justify-between text-sm">
              <span class="text-gray-500 font-medium">Raccolta</span>
              <strong class="font-bold text-gray-900">${pc}% di ${eur(p.initial)}</strong>
            </div>
            <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-gray-100">
              <div class="h-2 rounded-full bg-indigo-500" style="width:${pc}%"></div>
            </div>
            <small class="mt-2 block text-xs font-medium text-gray-500">${eur(p.funded)} + ${dash.toLocaleString('it-IT')} DASH</small>
          </div>
          
          <div class="mt-5 rounded-xl border border-gray-100 bg-gray-50 p-4">
            <span class="block text-xs font-semibold uppercase tracking-widest text-gray-400">Prossimo passo</span>
            <strong class="mt-1 block text-sm font-bold text-gray-800">${next}</strong>
          </div>
          
          <div class="mt-5 flex items-center justify-between">
            <small class="text-xs font-semibold text-gray-400">${p.done}/${p.steps} step · ${p.owner}</small>
            <button class="text-sm font-bold text-indigo-600 hover:text-indigo-800 transition" onclick="openProject(${p.id})">Apri progetto &rarr;</button>
          </div>
        </article>
      `;
    }
    
    function ensureFinance(p){
      if(p.capitalRepaid==null) p.capitalRepaid=Math.round(p.initial*(p.status==='Attivo'?.45:0));
      if(!p.shares) p.shares=[{name:'Marco',kind:'Denaro',units:60,paid:p.funded*.6,returns:0},{name:'Collaboratori',kind:'Tempo',units:25,paid:p.initial*.25,returns:0},{name:'Riserva progetto',kind:'Impresa',units:15,paid:0,returns:0}];
      if(!p.monthly) p.monthly=[];
      if(!p.saleOffers) p.saleOffers=[];
    }
    
    function openProject(id){
      const p=data.find(x=>x.id===id);
      ensureFinance(p);
      window.currentProject=id;
      document.querySelector('#detailTitle').textContent=p.name;
      renderDetail(p);
      document.querySelector('#detailDialog').showModal();
    }
    
    function renderDetail(p){
      const totalDistributed=p.monthly.reduce((s,m)=>s+m.distributed,0),
            remaining=Math.max(0,p.initial-p.capitalRepaid),
            stage=p.funded+(p.fundedDash||0)*(p.dashRate||100)<p.initial?'Raccolta fondi':p.capitalRepaid<p.initial?'Restituzione del capitale':'Rendita e scambio quote';
      
      document.querySelector('#detailBody').innerHTML=`
        <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
          <small class="block text-xs font-semibold uppercase tracking-widest text-gray-500">Fase attuale</small>
          <strong class="mt-1 block text-xl font-bold text-indigo-600">${stage}</strong>
        </div>
        
        <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
            <small class="block text-xs font-semibold uppercase tracking-widest text-gray-500">Da restituire</small>
            <strong class="mt-1 block text-lg font-bold text-gray-900">${eur(remaining)}</strong>
          </div>
          <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
            <small class="block text-xs font-semibold uppercase tracking-widest text-gray-500">Restituito</small>
            <strong class="mt-1 block text-lg font-bold text-gray-900">${eur(p.capitalRepaid)}</strong>
          </div>
          <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
            <small class="block text-xs font-semibold uppercase tracking-widest text-gray-500">Utili distribuiti</small>
            <strong class="mt-1 block text-lg font-bold text-gray-900">${eur(totalDistributed)}</strong>
          </div>
        </div>
        
        <div class="mt-8 border-b border-gray-200">
          <nav class="-mb-px flex gap-6" aria-label="Tabs">
            <button class="tab active shrink-0 border-b-2 border-indigo-500 px-1 py-3 text-sm font-medium text-indigo-600" onclick="showTab(event,'capital')">Quote</button>
            <button class="tab shrink-0 border-b-2 border-transparent px-1 py-3 text-sm font-medium text-gray-500 hover:border-gray-300 hover:text-gray-700 transition" onclick="showTab(event,'months')">Mesi e utili</button>
            <button class="tab shrink-0 border-b-2 border-transparent px-1 py-3 text-sm font-medium text-gray-500 hover:border-gray-300 hover:text-gray-700 transition" onclick="showTab(event,'market')">Compravendita</button>
          </nav>
        </div>
        
        <div class="mt-6">
          <section class="tab-panel block" id="capital">
            <div class="flex items-center justify-between mb-4">
              <h4 class="font-bold text-gray-900">Registro dei possessori</h4>
              <button class="rounded-md bg-indigo-100 px-3 py-1.5 text-xs font-bold text-indigo-700 hover:bg-indigo-200 transition" onclick="repayCapital()">＋ Registra restituzione</button>
            </div>
            <div class="overflow-hidden rounded-lg border border-gray-200 shadow-sm">
              <table class="min-w-full divide-y divide-gray-200 bg-white text-sm text-left">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-3 font-semibold text-gray-900">Possessore</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Origine</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Quote</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Valore conferito</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Restituzioni</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Utili ricevuti</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  ${p.shares.map(s=>`<tr>
                    <td class="px-4 py-3 font-bold text-gray-900">${s.name}</td>
                    <td class="px-4 py-3 text-gray-700">${s.kind}</td>
                    <td class="px-4 py-3 text-gray-700">${s.units} (${s.units}%)</td>
                    <td class="px-4 py-3 text-gray-700">${eur(s.paid)}</td>
                    <td class="px-4 py-3 text-gray-700">${eur(Math.min(s.paid,p.capitalRepaid*s.units/100))}</td>
                    <td class="px-4 py-3 font-bold text-indigo-600">${eur(totalDistributed*s.units/100)}</td>
                  </tr>`).join('')}
                </tbody>
              </table>
            </div>
            <p class="mt-3 text-xs text-gray-500 leading-relaxed">Le quote determinano la distribuzione degli utili; prestiti, quote e lavoro investito restano registrati come conferimenti distinti.</p>
          </section>
          
          <section class="tab-panel hidden" id="months">
            <div class="flex items-center justify-between mb-4">
              <h4 class="font-bold text-gray-900">Risultati e distribuzioni</h4>
              <button class="rounded-md bg-indigo-100 px-3 py-1.5 text-xs font-bold text-indigo-700 hover:bg-indigo-200 transition" onclick="addMonth()">＋ Registra mese</button>
            </div>
            <div class="overflow-hidden rounded-lg border border-gray-200 shadow-sm">
              <table class="min-w-full divide-y divide-gray-200 bg-white text-sm text-left">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-3 font-semibold text-gray-900">Mese</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Ricavi</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Costi</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Riserva</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Restituzione</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Utile distribuito</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  ${p.monthly.length?p.monthly.map(m=>`<tr>
                    <td class="px-4 py-3 font-bold text-gray-900">${m.month}</td>
                    <td class="px-4 py-3 text-gray-700">${eur(m.revenue)}</td>
                    <td class="px-4 py-3 text-gray-700">${eur(m.costs)}</td>
                    <td class="px-4 py-3 text-gray-700">${eur(m.reserve)}</td>
                    <td class="px-4 py-3 text-gray-700">${eur(m.repayment)}</td>
                    <td class="px-4 py-3 font-bold text-indigo-600">${eur(m.distributed)}</td>
                  </tr>`).join(''):'<tr><td colspan="6" class="px-4 py-6 text-center text-gray-500">Nessun mese registrato.</td></tr>'}
                </tbody>
              </table>
            </div>
            <p class="mt-3 text-xs text-gray-500 leading-relaxed">Ordine del flusso: ricavi &rarr; costi &rarr; riserva &rarr; restituzione del capitale &rarr; utile distribuibile ai possessori delle quote.</p>
          </section>
          
          <section class="tab-panel hidden" id="market">
            <div class="flex items-center justify-between mb-4">
              <h4 class="font-bold text-gray-900">Mercato interno delle quote</h4>
              <button class="rounded-md bg-indigo-100 px-3 py-1.5 text-xs font-bold text-indigo-700 hover:bg-indigo-200 transition" onclick="sellShares()">＋ Metti in vendita</button>
            </div>
            <div class="overflow-hidden rounded-lg border border-gray-200 shadow-sm">
              <table class="min-w-full divide-y divide-gray-200 bg-white text-sm text-left">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-3 font-semibold text-gray-900">Venditore</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Quote</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Prezzo €</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Prezzo Dash</th>
                    <th class="px-4 py-3 font-semibold text-gray-900">Stato</th>
                    <th class="px-4 py-3 font-semibold text-gray-900"></th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  ${p.saleOffers.length?p.saleOffers.map((o,i)=>`<tr>
                    <td class="px-4 py-3 text-gray-900">${o.seller}</td>
                    <td class="px-4 py-3 text-gray-700">${o.units}</td>
                    <td class="px-4 py-3 text-gray-700">${eur(o.euro)}</td>
                    <td class="px-4 py-3 text-gray-700">${o.dash} DASH</td>
                    <td class="px-4 py-3 text-gray-700">${o.status}</td>
                    <td class="px-4 py-3 text-right"><button class="text-indigo-600 font-bold hover:text-indigo-800 transition" onclick="buyShares(${i})">Acquista</button></td>
                  </tr>`).join(''):'<tr><td colspan="6" class="px-4 py-6 text-center text-gray-500">Nessuna quota attualmente in vendita.</td></tr>'}
                </tbody>
              </table>
            </div>
            <p class="mt-3 text-xs text-gray-500 leading-relaxed">Ogni passaggio conserva venditore, acquirente, quantità, prezzo e data. La nuova distribuzione decorre dal periodo successivo al trasferimento.</p>
          </section>
        </div>
      `;
    }
    
    function showTab(e,id){
      // Reset all tabs
      document.querySelectorAll('.tab').forEach(x=>{
        x.className = "tab shrink-0 border-b-2 border-transparent px-1 py-3 text-sm font-medium text-gray-500 hover:border-gray-300 hover:text-gray-700 transition";
      });
      document.querySelectorAll('.tab-panel').forEach(x=>{
        x.classList.add('hidden');
        x.classList.remove('block');
      });
      
      // Set active tab
      e.currentTarget.className = "tab active shrink-0 border-b-2 border-indigo-500 px-1 py-3 text-sm font-medium text-indigo-600 transition";
      const target = document.querySelector('#'+id);
      target.classList.remove('hidden');
      target.classList.add('block');
    }
    
    function repayCapital(){
      const p=data.find(x=>x.id===currentProject),
            amount=Number(prompt('Importo restituito agli investitori (€):','1000'));
      if(amount>0){
        p.capitalRepaid=Math.min(p.initial,p.capitalRepaid+amount);
        persist();
        render();
        renderDetail(p);
      }
    }
    
    function addMonth(){
      const p=data.find(x=>x.id===currentProject),
            month=prompt('Mese del rendiconto:','Luglio 2026');
      if(!month) return;
      const revenue=Number(prompt('Ricavi del mese (€):','5000'))||0,
            costs=Number(prompt('Costi del mese (€):','1800'))||0,
            reserve=Math.max(0,Number(prompt('Somma trattenuta come riserva (€):','500'))||0),
            repayment=Math.min(Math.max(0,p.initial-p.capitalRepaid),Math.max(0,Number(prompt('Capitale restituito questo mese (€):','1000'))||0)),
            distributed=Math.max(0,revenue-costs-reserve-repayment);
      p.capitalRepaid+=repayment;
      p.monthly.push({month,revenue,costs,reserve,repayment,distributed});
      persist();
      render();
      renderDetail(p);
    }
    
    function sellShares(){
      const p=data.find(x=>x.id===currentProject),
            seller=prompt('Chi vende le quote?','Marco');
      if(!seller) return;
      const units=Number(prompt('Numero di quote:','5'))||0,
            euro=Number(prompt('Prezzo totale in euro:','500'))||0,
            dash=Number(prompt('Oppure prezzo totale in Dash:','5'))||0;
      if(units>0){
        p.saleOffers.push({seller,units,euro,dash,status:'Disponibile'});
        persist();
        renderDetail(p);
      }
    }
    
    function buyShares(i){
      const p=data.find(x=>x.id===currentProject),
            o=p.saleOffers[i],
            buyer=prompt('Nome dell’acquirente:');
      if(!buyer) return;
      o.status='Venduta a '+buyer;
      const owner=p.shares.find(s=>s.name===o.seller);
      if(owner) owner.units=Math.max(0,owner.units-o.units);
      const existing=p.shares.find(s=>s.name===buyer);
      if(existing) existing.units+=o.units;
      else p.shares.push({name:buyer,kind:'Acquisto quote',units:o.units,paid:o.euro||o.dash*(p.dashRate||100),returns:0});
      persist();
      renderDetail(p);
    }
    
    // JS for filters click
    document.querySelectorAll('.filter').forEach(b=>b.onclick=()=>{
      filter=b.dataset.filter;
      document.querySelectorAll('.filter').forEach(x=>{
        if(x===b) {
          x.className = "filter active shrink-0 rounded-md bg-indigo-100 px-3 py-2 text-sm font-medium text-indigo-700 transition";
        } else {
          x.className = "filter shrink-0 rounded-md px-3 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition";
        }
      });
      render();
    });
    
    const pd=document.querySelector('#projectDialog');
    document.querySelector('#newProject').onclick=()=>pd.showModal();
    document.querySelector('#saveProject').onclick=e=>{
      const f=document.querySelector('#projectForm');
      if(!f.reportValidity()){
        e.preventDefault();
        return;
      }
      const v=Object.fromEntries(new FormData(f));
      data.push({
        id:Date.now(),
        company:selected,
        name:v.name,
        type:v.type,
        status:v.status,
        output:v.output,
        initial:+v.initial,
        maintenance:+v.maintenance,
        revenue:+v.revenue,
        funded:+v.funded,
        fundedDash:+v.fundedDash,
        dashRate:+v.dashRate,
        steps:+v.steps,
        done:0,
        owner:v.owner||'Da assegnare',
        people:[v.owner? v.owner.split(' ').map(x=>x[0]).join('').slice(0,2).toUpperCase():'?']
      });
      persist();
      setTimeout(()=>{
        f.reset();
        pd.close();
        render();
      },0);
    };
    
    const cd=document.querySelector('#companyDialog');
    document.querySelector('#addCompany').onclick=()=>cd.showModal();
    document.querySelector('#saveCompany').onclick=e=>{
      const f=document.querySelector('#companyForm');
      if(!f.reportValidity()){
        e.preventDefault();
        return;
      }
      const n=new FormData(f).get('company').trim();
      if(n&&!companies.includes(n)){
        companies.push(n);
        selected=n;
        persist();
      }
      setTimeout(()=>{
        f.reset();
        cd.close();
        render();
      },0);
    };
    
    document.querySelector('#exportBtn').onclick=()=>{
      const blob=new Blob([JSON.stringify({companies,projects:data},null,2)],{type:'application/json'}),
            a=document.createElement('a');
      a.href=URL.createObjectURL(blob);
      a.download='generaimpresa-dati.json';
      a.click();
      URL.revokeObjectURL(a.href);
    };
    
    render();
  </script>
