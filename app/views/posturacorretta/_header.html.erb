<%
  is_home = current_page?(posturacorretta_path) || current_page?("/posturacorretta")
  is_accademia = current_page?(posturacorretta_accademia_path) rescue false
  is_percorso = current_page?(posturacorretta_percorso_path) rescue false
   is_eventi = current_page?(posturacorretta_eventi_path) rescue false
   is_contenuti = current_page?(posturacorretta_contenuti_path) rescue false
  is_metodiche = request.path.start_with?(posturacorretta_metodiche_path) rescue false
 is_filosofia = current_page?(posturacorretta_filosofia_path) rescue false
 
  is_progetti = current_page?(posturacorretta_progetti_path) rescue false
  
%>

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex h-16 items-center justify-between px-6">
    <!-- Logo -->
    <a href="<%= posturacorretta_path %>" class="flex items-center gap-3 shrink-0 animate-fade-in" aria-label="PosturaCorretta home">
      <img
        src="https://ik.imagekit.io/posturacorretta/logo_pc_scontornato.png?updatedAt=1747975596766"
        alt="PosturaCorretta"
        class="h-8 w-auto"
        onerror="this.style.display='none';this.nextElementSibling.classList.remove('hidden');">
      <span class="hidden text-lg font-extrabold tracking-tight text-blue-700">PosturaCorretta</span>
    </a>

    <!-- Desktop Inline Nav Links (Shortened, hidden on mobile) -->
    <nav class="hidden md:flex items-center gap-4 lg:gap-6" aria-label="Navigazione principale PosturaCorretta">
      <a href="<%= posturacorretta_path %>"
         class="border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= is_home ? "border-blue-600 text-blue-700" : "border-transparent text-slate-600 hover:border-blue-200 hover:text-blue-700" %>">
        Home
      </a>
      <a href="<%= posturacorretta_accademia_path %>"
         class="border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= is_accademia ? "border-blue-600 text-blue-700" : "border-transparent text-slate-600 hover:border-blue-200 hover:text-blue-700" %>">
        Accademia
      </a>
      <a href="<%= posturacorretta_percorso_path %>"
         class="border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= is_percorso ? "border-blue-600 text-blue-700" : "border-transparent text-slate-600 hover:border-blue-200 hover:text-blue-700" %>">
        Percorso
      </a>
      
      <a href="<%= posturacorretta_contenuti_path %>"
         class="border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= is_contenuti ? "border-blue-600 text-blue-700" : "border-transparent text-slate-600 hover:border-blue-200 hover:text-blue-700" %>">
        Contenuti
      </a>
      <a href="<%= posturacorretta_eventi_path %>"
         class="border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= is_eventi ? "border-blue-600 text-blue-700" : "border-transparent text-slate-600 hover:border-blue-200 hover:text-blue-700" %>">
        Eventi
      </a>
      
      <a href="<%= posturacorretta_metodiche_path %>"
         class="border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= is_metodiche ? "border-blue-600 text-blue-700" : "border-transparent text-slate-600 hover:border-blue-200 hover:text-blue-700" %>">
        Metodiche
      </a>
      <a href="<%= posturacorretta_filosofia_path %>"
         class="border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= is_filosofia ? "border-blue-600 text-blue-700" : "border-transparent text-slate-600 hover:border-blue-200 hover:text-blue-700" %>">
        Libro
      </a>
      
      <a href="<%= posturacorretta_progetti_path %>"
         class="border-b-2 px-0.5 py-1 text-sm font-semibold transition <%= is_progetti ? "border-blue-600 text-blue-700" : "border-transparent text-slate-600 hover:border-blue-200 hover:text-blue-700" %>">
        Progetti
      </a>
    </nav>

    <!-- Mobile Hamburger Toggle Button (hidden on desktop) -->
    <button id="mobile-menu-toggle" type="button" class="md:hidden flex items-center justify-center p-2 rounded-xl text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition focus:outline-none" aria-label="Apri menu">
      <svg class="h-6 w-6 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="hamburger-icon">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg class="h-6 w-6 hidden transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="close-icon">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Dropdown Menu Drawer (hidden on desktop) -->
  <div id="mobile-dropdown-menu" class="hidden md:hidden border-t border-slate-200 bg-white px-6 py-4 shadow-inner space-y-1">
    <a href="<%= posturacorretta_path %>" class="block rounded-xl px-4 py-2.5 text-sm font-bold transition <%= is_home ? "bg-blue-50 text-blue-700" : "text-slate-700 hover:bg-slate-50 hover:text-blue-700" %>">Home</a>
    <a href="<%= posturacorretta_accademia_path %>" class="block rounded-xl px-4 py-2.5 text-sm font-bold transition <%= is_accademia ? "bg-blue-50 text-blue-700" : "text-slate-700 hover:bg-slate-50 hover:text-blue-700" %>">Accademia</a>
    <a href="<%= posturacorretta_percorso_path %>" class="block rounded-xl px-4 py-2.5 text-sm font-bold transition <%= is_percorso ? "bg-blue-50 text-blue-700" : "text-slate-700 hover:bg-slate-50 hover:text-blue-700" %>">Percorso personalizzato</a>
    <a href="<%= posturacorretta_metodiche_path %>" class="block rounded-xl px-4 py-2.5 text-sm font-bold transition <%= is_metodiche ? "bg-blue-50 text-blue-700" : "text-slate-700 hover:bg-slate-50 hover:text-blue-700" %>">Metodiche</a>
    <a href="<%= posturacorretta_contenuti_path %>" class="block rounded-xl px-4 py-2.5 text-sm font-bold transition <%= is_contenuti ? "bg-blue-50 text-blue-700" : "text-slate-700 hover:bg-slate-50 hover:text-blue-700" %>">Contenuti</a>
    <a href="<%= posturacorretta_filosofia_path %>" class="block rounded-xl px-4 py-2.5 text-sm font-bold transition <%= is_filosofia ? "bg-blue-50 text-blue-700" : "text-slate-700 hover:bg-slate-50 hover:text-blue-700" %>">Libro e Visione</a>
    <a href="<%= posturacorretta_eventi_path %>" class="block rounded-xl px-4 py-2.5 text-sm font-bold transition <%= is_eventi ? "bg-blue-50 text-blue-700" : "text-slate-700 hover:bg-slate-50 hover:text-blue-700" %>">Eventi e Community</a>
    <a href="<%= posturacorretta_progetti_path %>" class="block rounded-xl px-4 py-2.5 text-sm font-bold transition <%= is_progetti ? "bg-blue-50 text-blue-700" : "text-slate-700 hover:bg-slate-50 hover:text-blue-700" %>">Progetti</a>
  </div>
</header>

<script>
  (() => {
    const toggleBtn = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-dropdown-menu");
    const hamburgerIcon = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");

    if (toggleBtn && menu) {
      toggleBtn.addEventListener("click", () => {
        const isHidden = menu.classList.contains("hidden");
        if (isHidden) {
          menu.classList.remove("hidden");
          hamburgerIcon.classList.add("hidden");
          closeIcon.classList.remove("hidden");
          toggleBtn.setAttribute("aria-label", "Chiudi menu");
        } else {
          menu.classList.add("hidden");
          hamburgerIcon.classList.remove("hidden");
          closeIcon.classList.add("hidden");
          toggleBtn.setAttribute("aria-label", "Apri menu");
        }
      });
    }
  })();
</script>
