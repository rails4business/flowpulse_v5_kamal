<!DOCTYPE html>
<html lang="it">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PosturaCorretta — Percorso della Salute</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            pcblue: '#2563eb',
            pcink: '#0f172a'
          },
          boxShadow: {
            soft: '0 24px 70px rgba(15, 23, 42, 0.08)'
          }
        }
      }
    }
  </script>

  <style>
    html { scroll-behavior: smooth; }

    section[id],
    main[id] {
      scroll-margin-top: 5rem;
    }

    body {
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #ffffff;
    }

    .glass {
      background: rgba(255, 255, 255, .88);
      backdrop-filter: blur(18px);
    }

    .hero-image {
      background-image:
        linear-gradient(135deg, rgba(37, 99, 235, .10), rgba(15, 23, 42, .10)),
        url('https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=1200&q=80');
      background-size: cover;
      background-position: center;
    }

    .path-image {
      background-image:
        linear-gradient(135deg, rgba(37, 99, 235, .08), rgba(15, 23, 42, .06)),
        url('https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=900&q=80');
      background-size: cover;
      background-position: center;
    }

    .step-line::before {
      content: "";
      position: absolute;
      left: 1.12rem;
      top: 2.8rem;
      bottom: -2.6rem;
      width: 1px;
      background: #dbeafe;
    }

    .step-line:last-child::before { display: none; }
  </style>
</head>

<body class="text-slate-900 antialiased">

  <!-- HEADER -->
  <header class="sticky top-0 z-50 border-b border-slate-200/70 glass">
    <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-5">
      <a href="#top" class="flex items-center gap-3">
        <img src="https://ik.imagekit.io/posturacorretta/logo_pc_scontornato.png?updatedAt=1747975596766" alt="PosturaCorretta" class="h-7 w-auto">
      </a>

      <nav class="hidden h-full items-center gap-6 md:flex">
        <a href="#percorso" class="text-sm font-medium text-slate-600 hover:text-blue-700">Percorso</a>
        <a href="#risorse" class="text-sm font-medium text-slate-600 hover:text-blue-700">Risorse</a>
        <a href="#community" class="text-sm font-medium text-slate-600 hover:text-blue-700">Community</a>
        <a href="#professionisti" class="text-sm font-medium text-slate-600 hover:text-blue-700">Per i professionisti</a>
        <a href="#inizia" class="rounded-full bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-blue-700">Inizia</a>
      </nav>
    </div>
  </header>

  <main id="top">

    <!-- HERO -->
    <section class="px-5 py-16 md:py-24">
      <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[.95fr_1.05fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">
            La salute inizia dalle metodiche posturali
          </p>


          <h1 class="mt-5 max-w-5xl text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl md:leading-[1.04]">
            Non è solo un dolore
            <br>
            <span class="text-blue-700">è il corpo che parla</span>
            
          </h1>

          <p class="mt-8 max-w-3xl text-lg leading-8 text-slate-600">
            Di solito si parte da un problema:
            una visita, una diagnosi, uno specialista,
            un farmaco o un intervento.
          </p>

          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">
            Ma uscire dalla fase acuta è solo il primo passo.
            Dopo serve capire quali sistemi del corpo sono in difficoltà,
            quali abitudini ti stanno influenzando
            e quale percorso può aiutarti a ricostruire salute,
            benessere e consapevolezza.
          </p>

          <div class="mt-9 flex flex-wrap gap-3">
            <a href="#percorso" class="rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-700">
             Inizia il percorso
            </a>
            <!--a href="/diario-della-salute" class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-700 ring-1 ring-slate-200 hover:bg-slate-50">
              Inizia dal diario
            </a-->
          </div>

          <!--div class="mt-10 flex flex-wrap gap-x-6 gap-y-3 text-sm text-slate-500">
            <a href="/eventi" class="hover:text-blue-700">Eventi</a>
            <a href="/manifesto" class="hover:text-blue-700">Manifesto</a>
            <a href="/libro" class="hover:text-blue-700">Libro</a>
            <a href="/rete-professionale" class="hover:text-blue-700">Rete professionale</a>
          </div-->
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-3 shadow-soft">
          <div class="hero-image aspect-[16/9] rounded-[1.55rem]"></div>
        </div>
      </div>
    </section>

  

<!-- PERCORSI + TAB + ADERISCI AL PROGETTO -->
<section id="inizia" class="border-y border-slate-200 bg-slate-50 px-5 py-20 md:py-24">
  <div class="mx-auto max-w-7xl">

    <!-- HERO COMPATTA -->
    <div class="max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">
        Scelta guidata
      </p>

      <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl md:leading-[1.04]">
        Scegli da dove partire.
      </h2>

      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">
        Seleziona la situazione più vicina a te: il percorso sotto si aggiorna
        con tappe, risorse e professionisti più adatti.
      </p>
    </div>

    <!-- TABS / CARD -->
    <div class="mt-12 grid gap-3 md:grid-cols-2 xl:grid-cols-4">

      <button data-tab="rosso"
        class="pc-tab flex min-h-32 items-start gap-4 rounded-2xl border border-red-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-red-300 hover:shadow-md">
        <span class="mt-1 h-4 w-4 shrink-0 rounded-full bg-red-600 ring-4 ring-red-100"></span>
        <span>
          <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-red-700">Rosso</span>
          <span class="mt-2 block text-lg font-semibold leading-6 text-slate-950">Dolori e patologie</span>
          <span class="mt-2 block text-sm leading-6 text-slate-600">Affrontare la fase acuta, cura patologie e dolori, e non solo i sintomi.</span>
          <span class="mt-4 block text-sm font-semibold text-red-700">Scegli questo</span>
        </span>
      </button>

      <button data-tab="verde"
        class="pc-tab flex min-h-32 items-start gap-4 rounded-2xl border border-emerald-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-emerald-300 hover:shadow-md">
        <span class="mt-1 h-4 w-4 shrink-0 rounded-full bg-emerald-600 ring-4 ring-emerald-100"></span>
        <span>
          <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Verde</span>
          <span class="mt-2 block text-lg font-semibold leading-6 text-slate-950">Benessere e Prevenzione</span>
          <span class="mt-2 block text-sm leading-6 text-slate-600">Crea il tuo percorso integrato per migliorare la tua salute e il tuo benessere.</span>
          <span class="mt-4 block text-sm font-semibold text-emerald-700">Scegli questo</span>
        </span>
      </button>

      <button data-tab="blu"
        class="pc-tab flex min-h-32 items-start gap-4 rounded-2xl border border-blue-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-md">
        <span class="mt-1 h-4 w-4 shrink-0 rounded-full bg-blue-600 ring-4 ring-blue-100"></span>
        <span>
          <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Blu</span>
          <span class="mt-2 block text-lg font-semibold leading-6 text-slate-950">Capire meglio il corpo</span>
          <span class="mt-2 block text-sm leading-6 text-slate-600">Impara a conoscere a leggere i segnali e riattivare i tuoi sistemi fisiologici.</span>
          <span class="mt-4 block text-sm font-semibold text-blue-700">Scegli questo</span>
        </span>
      </button>

      <button data-tab="viola"
        class="pc-tab flex min-h-32 items-start gap-4 rounded-2xl border border-violet-200 bg-white p-5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-violet-300 hover:shadow-md">
        <span class="mt-1 h-4 w-4 shrink-0 rounded-full bg-violet-700 ring-4 ring-violet-100"></span>
        <span>
          <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-violet-700">Viola</span>
          <span class="mt-2 block text-lg font-semibold leading-6 text-slate-950">Evoluzione armonica</span>
          <span class="mt-2 block text-sm leading-6 text-slate-600">Scopri le sfere che influenzano la tua vita, e coltivale con eventi e pratiche di benessere.</span>
          <span class="mt-4 block text-sm font-semibold text-violet-700">Scegli questo</span>
        </span>
      </button>

    </div>

    <!-- CONTENUTO DINAMICO -->
    <div class="mt-14 grid gap-10 lg:grid-cols-[0.78fr_1.22fr]">

      <!-- ASIDE -->
      <aside class="lg:sticky lg:top-28 lg:h-fit">
        <p id="path-kicker" class="text-xs font-semibold uppercase tracking-[0.22em] text-red-700">
          Percorso rosso
        </p>

        <h2 id="path-title" class="mt-4 text-3xl font-semibold tracking-tight text-slate-950 md:text-5xl md:leading-[1.05]">
          Dal dolore alla cura guidata.
        </h2>

        <p id="path-description" class="mt-5 text-lg leading-8 text-slate-600">
          Per chi parte da dolore, diagnosi, patologia o fase acuta.
        </p>

      </aside>

      <!-- LISTA PERCORSO -->
      <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-soft md:p-10">
        <div class="mb-10 flex flex-col gap-5 border-b border-slate-100 pb-8 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Tappe consigliate</p>
            <h3 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">Segui il percorso con calma.</h3>
          </div>

          <button id="path-start-link" type="button" disabled aria-disabled="true"
            class="inline-flex items-center justify-center rounded-full bg-red-600 px-6 py-3 text-sm font-semibold text-white opacity-90">
            Inizia il percorso →
          </button>
        </div>

        <div id="path-steps" class="space-y-10"></div>

        <div class="mt-10 flex flex-col gap-4 rounded-2xl border border-slate-100 bg-slate-50 p-6 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Pronto a partire?</p>
            <p id="path-bottom-text" class="mt-2 text-lg font-semibold text-slate-950">Inizia dal percorso rosso.</p>
          </div>

          <button id="path-bottom-start-link" type="button" disabled aria-disabled="true"
            class="inline-flex items-center justify-center rounded-full bg-red-600 px-6 py-3 text-sm font-semibold text-white opacity-90">
            Inizia il percorso →
          </button>
        </div>

        <!-- ADERISCI -->
        <div id="join-box" class="mt-10 rounded-[2rem] border border-red-200 bg-white p-7 shadow-sm">
          <p id="join-kicker" class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">
            Aderisci al progetto
          </p>

          <h3 id="join-title" class="mt-3 text-2xl font-semibold text-slate-950">
            Sei un professionista sanitario?
          </h3>

          <p id="join-description" class="mt-4 text-base leading-7 text-slate-600">
            Se sei fisioterapista, osteopata, medico o professionista sanitario,
            puoi integrare il percorso PosturaCorretta nei tuoi trattamenti.
          </p>

          <div id="join-tags" class="mt-5 flex flex-wrap gap-2"></div>

          <a id="join-link" href="#professionisti"
            class="mt-6 inline-flex rounded-full border border-red-200 px-5 py-3 text-sm font-semibold text-red-700 hover:bg-red-50">
            Scopri come aderire →
          </a>
        </div>
      </div>

    </div>

  </div>
</section>

<script>
  const paths = {
    rosso: {
      color: "red",
      kicker: "Percorso rosso",
      title: "Dal dolore alla cura guidata.",
      description: "Per chi parte da dolore, diagnosi, patologia o fase acuta. Il primo obiettivo è mettere ordine, calmare il dolore e trovare il professionista giusto.",
      joinTitle: "Sei un professionista sanitario?",
      joinDescription: "Per fisioterapisti, osteopati, medici e professionisti sanitari che vogliono integrare il percorso PosturaCorretta nei propri trattamenti e accompagnare le persone oltre la sola gestione del dolore.",
      joinTags: ["Fisioterapia", "Osteopatia", "Medicina", "Riabilitazione"],
      steps: [
        ["Diario della salute", "Stai già facendo qualcosa per la tua salute?", "Registra i tuoi eventi le tue attività, le tue scoperte e i tuoi progetti.", ["Contenuti", "Corso", "Professionisti"]],
        ["Stop al dolore", "Hai già una diagnosi o un piano per uscire dalla fase acuta?", "Ti aiutiamo a orientarti tra professionisti ed esercizi utili per calmare il dolore.", ["Contenuti", "Percorso", "Professionisti"]],
        ["Valutazione PosturaCorretta", "Quali sistemi bloccati hanno favorito i tuoi sintomi?", "Una valutazione per capire quali sistemi sono compromessi e come lavorare in profondità.", ["Valutazione", "Schede", "Professionisti"]],
        ["Percorso terapeutico", "Per andare oltre la fase acuta.", "Costruisci un piano terapeutico con trattamenti, che vanno a curare le cause e non solo i sintomi, recupera la tua funzionalità con la riabilitazione e il recupero guidato.", ["Recupero", "Trattamenti", "Professionisti"]]
      ]
    },

    verde: {
      color: "emerald",
      kicker: "Percorso verde",
      title: "Dalla prevenzione al benessere integrato.",
      description: "Per chi vuole valutare lo stato di salute, migliorare abitudini e costruire un percorso sostenibile.",
      joinTitle: "Sei un professionista del benessere?",
      joinDescription: "Per professionisti del movimento, del benessere e della prevenzione che vogliono facilitare percorsi legati ad equilibrio, salute e qualità della vita.",
      joinTags: ["Movimento", "Prevenzione", "Benessere", "Stile di vita"],
      steps: [
        ["Diario della salute", "Stai già facendo qualcosa per la tua salute?", "Metti ordine tra i tuoi trattamenti e le tue attività.", ["Contenuti", "Corso", "Professionisti"]],
        ["Stato di salute", "Sai davvero qual è il tuo stato di salute?", "Valuta abitudini, rischi, risorse e ambiti della salute da migliorare.", ["Questionari", "Abitudini", "Diario"]],
        ["Benessere integrato", "Sei pronto a costruire un percorso integrato?", "Scopri quale area della salute è prioritaria e costruisci il tuo percorso integrato.", ["Linee guida", "Professionisti", "Percorsi"]]
      ]
    },

    blu: {
      color: "blue",
      kicker: "Percorso blu",
      title: "Dalla postura alla fisiologia.",
      description: "Per chi vuole conoscere il corpo, capire i sistemi fisiologici e imparare pratiche di riattivazione.",
      joinTitle: "Vuoi diventare insegnante?",
      joinDescription: "Per chi vuole insegnare il percorso educativo di Postura e Fisiologia, trasmettendo pratica corporea, consapevolezza e conoscenza dei sistemi fisiologici.",
      joinTags: ["Accademia", "Igiene Posturale", "Didattica", "Fisiologia"],
      steps: [
        ["Diario della salute", "Stai già facendo qualcosa per la tua salute?", "Registra i tuoi progressi e le tue attività.", ["Contenuti", "Corso", "Professionisti"]],
        ["Valutazione PosturaCorretta", "Quali sistemi sono bloccati?", "Le metodiche posturali aiutano a leggere il corpo come sistema integrato.", ["Valutazione", "Schede", "Professionisti"]],
        ["Postura e fisiologia", "Vuoi capire come funziona davvero il tuo corpo?", "Moduli pratici per conoscere e riattivare i sistemi fisiologici.", ["Accademia", "Corsi", "Pratica"]]
      ]
    },

    viola: {
      color: "violet",
      kicker: "Percorso viola",
      title: "Dal corpo allo stile di vita.",
      description: "Per chi vuole trasformare la salute in esperienza, ambiente, natura, relazioni, eventi e comunità.",
      joinTitle: "Vuoi far conoscere la tua attività?",
      joinDescription: "Proponi o organizza un evento. Aiuta le persone a scoprire e coltivare le diverse sfere del corpo: movimento, natura, relazioni, creatività, cibo, musica e stile di vita.",
      joinTags: ["Eventi", "Natura", "Comunità", "Esperienze"],
      steps: [
        ["Diario della salute", "Stai già facendo qualcosa per la tua salute?", "", ["Contenuti", "Corso", "Professionisti"]],
        ["Il Giardino del Corpo", "Vuoi trasformare la salute in un modo di vivere?", "Coltiva le sfere del corpo come un giardino: natura, movimento, relazioni, ritmo e comunità.", ["Eventi", "Natura", "Comunità"]]
      ]
    }
  };

  const colorClasses = {
    red: {
      text: "text-red-700",
      bg: "bg-red-600",
      soft: "bg-red-50",
      border: "border-red-200",
      activeBorder: "border-red-400",
      hover: "hover:bg-red-50",
      ring: "ring-red-500"
    },
    emerald: {
      text: "text-emerald-700",
      bg: "bg-emerald-600",
      soft: "bg-emerald-50",
      border: "border-emerald-200",
      activeBorder: "border-emerald-400",
      hover: "hover:bg-emerald-50",
      ring: "ring-emerald-500"
    },
    blue: {
      text: "text-blue-700",
      bg: "bg-blue-600",
      soft: "bg-blue-50",
      border: "border-blue-200",
      activeBorder: "border-blue-400",
      hover: "hover:bg-blue-50",
      ring: "ring-blue-500"
    },
    violet: {
      text: "text-violet-700",
      bg: "bg-violet-700",
      soft: "bg-violet-50",
      border: "border-violet-200",
      activeBorder: "border-violet-400",
      hover: "hover:bg-violet-50",
      ring: "ring-violet-500"
    }
  };

  const allowedTabs = ["rosso", "verde", "blu", "viola"];

  function renderPath(key) {
    const path = paths[key];
    const c = colorClasses[path.color];

    document.getElementById("path-kicker").textContent = path.kicker;
    document.getElementById("path-kicker").className =
      `text-xs font-semibold uppercase tracking-[0.22em] ${c.text}`;

    document.getElementById("path-title").textContent = path.title;
    document.getElementById("path-description").textContent = path.description;

    document.getElementById("join-box").className =
      `mt-10 rounded-[2rem] border ${c.border} bg-white p-7 shadow-sm`;

    document.getElementById("join-kicker").className =
      `text-xs font-semibold uppercase tracking-[0.18em] ${c.text}`;

    document.getElementById("join-title").textContent = path.joinTitle;
    document.getElementById("join-description").textContent = path.joinDescription;

    document.getElementById("join-link").className =
      `mt-6 inline-flex rounded-full border ${c.border} px-5 py-3 text-sm font-semibold ${c.text} ${c.hover}`;

    document.getElementById("path-start-link").className =
      `inline-flex items-center justify-center rounded-full ${c.bg} px-6 py-3 text-sm font-semibold text-white opacity-90`;
    document.getElementById("path-bottom-start-link").className =
      `inline-flex items-center justify-center rounded-full ${c.bg} px-6 py-3 text-sm font-semibold text-white opacity-90`;
    document.getElementById("path-bottom-text").textContent =
      `Inizia dal ${path.kicker.toLowerCase()}.`;

    const joinTags = document.getElementById("join-tags");
    joinTags.innerHTML = path.joinTags.map(tag => `
      <span class="rounded-full ${c.soft} px-3 py-1 text-xs font-medium ${c.text}">
        ${tag}
      </span>
    `).join("");

    const container = document.getElementById("path-steps");
    container.innerHTML = "";

    path.steps.forEach((step, index) => {
      const [label, title, description, tags] = step;

      container.innerHTML += `
        <article class="${index < path.steps.length - 1 ? "step-line" : ""} relative pl-14">
          <div class="absolute left-0 top-0 grid h-9 w-9 place-items-center rounded-full ${c.bg} text-sm font-semibold text-white">
            ${index + 1}
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] ${c.text}">
              ${label}
            </p>

            <h3 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">
              ${title}
            </h3>

            ${description ? `
              <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">
                ${description}
              </p>
            ` : ""}

            <div class="mt-4 flex flex-wrap gap-2">
              ${tags.map(tag => `
                <span class="rounded-full ${c.soft} px-3 py-1 text-xs font-medium ${c.text}">
                  ${tag}
                </span>
              `).join("")}
            </div>
          </div>
        </article>
      `;
    });

    document.querySelectorAll(".pc-tab").forEach(tab => {
      tab.classList.remove(
        "ring-2",
        "ring-red-500",
        "ring-emerald-500",
        "ring-blue-500",
        "ring-violet-500",
        "bg-red-50",
        "bg-emerald-50",
        "bg-blue-50",
        "bg-violet-50",
        "border-red-400",
        "border-emerald-400",
        "border-blue-400",
        "border-violet-400",
        "shadow-md"
      );
      tab.classList.add("bg-white");
    });

    const activeTab = document.querySelector(`[data-tab="${key}"]`);
    activeTab.classList.remove("bg-white");
    activeTab.classList.add("ring-2", c.ring, c.soft, c.activeBorder, "shadow-md");
  }

  function getInitialTab() {
    const params = new URLSearchParams(window.location.search);
    const urlTab = params.get("tab");

    if (allowedTabs.includes(urlTab)) {
      localStorage.setItem("posturacorretta_active_tab", urlTab);
      return urlTab;
    }

    const savedTab = localStorage.getItem("posturacorretta_active_tab");

    if (allowedTabs.includes(savedTab)) {
      return savedTab;
    }

    return "rosso";
  }

  function updateTabState(key) {
    const url = new URL(window.location);
    url.searchParams.set("tab", key);
    window.history.replaceState({}, "", url);
    localStorage.setItem("posturacorretta_active_tab", key);
  }

  document.querySelectorAll(".pc-tab").forEach(tab => {
    tab.addEventListener("click", () => {
      const key = tab.dataset.tab;
      renderPath(key);
      updateTabState(key);
    });
  });

  renderPath(getInitialTab());
</script>

