<!DOCTYPE html>
<html lang="it">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mark Postura</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
  </style>
</head>

<body class="bg-slate-50 text-slate-900">

  <!-- HEADER -->
  <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur-xl">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4">

      <a href="#top" class="text-sm font-semibold uppercase tracking-[0.24em] text-sky-700">
        Mark Postura
      </a>

      <nav class="hidden items-center gap-6 text-sm font-semibold text-slate-600 md:flex">
        <a href="#come-posso-aiutarti" class="hover:text-slate-950">Come posso aiutarti?</a>
        <a href="#eventi" class="hover:text-slate-950">Eventi</a>
        <a href="#weekplan" class="hover:text-slate-950">Weekplan</a>
        <a href="#portfolio" class="hover:text-slate-950">Portfolio Progetti</a>
        <a href="#libro" class="hover:text-slate-950">Libro</a>
      </nav>

    </div>
  </header>

  <main id="top">

    <!-- HERO -->
    <section class="relative overflow-hidden bg-slate-50 px-5 py-24 md:py-32">
      <div class="absolute inset-x-0 top-0 h-96 bg-gradient-to-b from-sky-100/80 to-transparent"></div>
      <div class="absolute left-1/2 top-24 h-72 w-72 -translate-x-1/2 rounded-full bg-emerald-100/50 blur-3xl"></div>

      <div class="relative mx-auto max-w-5xl text-center">

        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-sky-700">
          Fisioterapia · postura · natura · software
        </p>

        <h1 class="mx-auto mt-5 max-w-4xl text-5xl font-semibold leading-[1] tracking-[-0.04em] text-slate-950 md:text-7xl">
          Il corpo,
          <span class="text-sky-700">un mondo da scoprire.</span>
        </h1>

        <p class="mx-auto mt-8 max-w-3xl text-xl leading-9 text-slate-600">
          Aiuto persone e professionisti a costruire salute,
          esperienze e strumenti per vivere e lavorare in modo più umano.
        </p>

        <div class="mt-10 flex flex-wrap justify-center gap-4">

          <a href="#come-posso-aiutarti"
            class="rounded-full bg-slate-950 px-7 py-4 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800">
            Come posso aiutarti?
          </a>

          <a href="#libro"
            class="rounded-full bg-white px-7 py-4 text-sm font-semibold text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
            Il libro
          </a>

          <a href="/markposturastory"
            class="rounded-full bg-white px-7 py-4 text-sm font-semibold text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
            La mia storia
          </a>

        </div>
      </div>
    </section>


    <!-- COME POSSO AIUTARTI -->
    <section id="come-posso-aiutarti" class="px-5 pb-24">
      <div class="mx-auto max-w-7xl">

        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">
            La mappa operativa
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-5xl">
            Tre porte per entrare nel progetto.
          </h2>
        </div>

        <div class="mt-12 grid gap-6 lg:grid-cols-3">

          <!-- CARD -->
          <a href="#salute"
            class="group overflow-hidden rounded-[2rem] border border-sky-100 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">

            <div class="aspect-[16/9] overflow-hidden bg-sky-100">
              <img src="../images/portfolio/percorso-salute.jpg"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                alt="Percorso Salute">
            </div>

            <div class="p-7">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">
                01 · Salute
              </p>

              <h3 class="mt-3 text-3xl font-semibold text-slate-950">
                Percorso Salute
              </h3>

              <p class="mt-4 text-base leading-7 text-slate-600">
                Postura, fisioterapia e percorsi educativi per il corpo.
              </p>
            </div>
          </a>

          <!-- CARD -->
          <a href="#eventi"
            class="group overflow-hidden rounded-[2rem] border border-emerald-100 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">

            <div class="aspect-[16/9] overflow-hidden bg-emerald-100">
              <img src="../images/portfolio/eventi-esperienze.jpg"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                alt="Eventi ed esperienze">
            </div>

            <div class="p-7">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">
                02 · Esperienze
              </p>

              <h3 class="mt-3 text-3xl font-semibold text-slate-950">
                Eventi & Esperienze
              </h3>

              <p class="mt-4 text-base leading-7 text-slate-600">
                Camminate, pratica, natura e incontri reali.
              </p>
            </div>
          </a>

          <!-- CARD -->
          <a href="#software"
            class="group overflow-hidden rounded-[2rem] border border-amber-100 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">

            <div class="aspect-[16/9] overflow-hidden bg-amber-100">
              <img src="../images/portfolio/progetti-software.jpg"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                alt="Progetti e software">
            </div>

            <div class="p-7">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700">
                03 · Software
              </p>

              <h3 class="mt-3 text-3xl font-semibold text-slate-950">
                Progetti & Software
              </h3>

              <p class="mt-4 text-base leading-7 text-slate-600">
                Flowpulse, Rails4Business e strumenti digitali.
              </p>
            </div>
          </a>

        </div>
      </div>
    </section>


    <!-- WEEKPLAN -->
    <section id="weekplan" class="border-y border-slate-200 bg-white px-5 py-20">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">

        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">
            Weekplan
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-5xl">
            Dal progetto alla settimana.
          </h2>

          <p class="mt-6 text-lg leading-8 text-slate-600">
            Un modo semplice per organizzare salute, eventi,
            lavoro, appuntamenti e tempo reale.
          </p>

          <a href="../viste_html/6_weekplan.html"
            class="mt-8 inline-flex rounded-full bg-slate-950 px-7 py-4 text-sm font-semibold text-white transition hover:bg-slate-800">
            Apri il weekplan
          </a>
        </div>

        <div class="overflow-hidden rounded-[2.5rem] border border-slate-200 bg-slate-100 shadow-sm">
          <div class="aspect-[16/9]"></div>
        </div>

      </div>
    </section>


    <!-- EVENTI -->
    <section id="eventi" class="px-5 py-24">
      <div class="mx-auto max-w-7xl">

        <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-emerald-700">
              Eventi
            </p>

            <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-5xl">
              Prossime esperienze.
            </h2>
          </div>

          <a href="../esperienze" class="text-sm font-semibold text-slate-500 hover:text-slate-950">
            Vedi tutti →
          </a>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-3">

          <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
            <div class="aspect-[16/9] bg-emerald-100"></div>
            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Natura</p>
              <h3 class="mt-2 text-2xl font-semibold text-slate-950">Camminata PosturaCorretta</h3>
            </div>
          </article>

          <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
            <div class="aspect-[16/9] bg-amber-100"></div>
            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700">Corpo & Cibo</p>
              <h3 class="mt-2 text-2xl font-semibold text-slate-950">PosturaCorretta e forchetta</h3>
            </div>
          </article>

          <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
            <div class="aspect-[16/9] bg-sky-100"></div>
            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">Movimento</p>
              <h3 class="mt-2 text-2xl font-semibold text-slate-950">Mobilità e postura</h3>
            </div>
          </article>

        </div>
      </div>
    </section>


    <!-- LIBRO -->
    <section id="libro" class="border-y border-slate-200 bg-white px-5 py-24">
      <div class="mx-auto max-w-5xl text-center">

        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-700">
          Libro guida
        </p>

        <h2 class="mx-auto mt-5 max-w-4xl text-5xl font-semibold tracking-tight text-slate-950 md:text-6xl">
          Il corpo, un mondo da scoprire.
        </h2>

        <p class="mx-auto mt-8 max-w-3xl text-xl leading-9 text-slate-600">
          Il filo narrativo che unisce postura, salute, esperienze,
          natura, tecnologia e modi più umani di vivere.
        </p>

        <a href="#portfolio"
          class="mt-10 inline-flex rounded-full bg-white px-7 py-4 text-sm font-semibold text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
          Esplora i progetti
        </a>

      </div>
    </section>


    <!-- PORTFOLIO -->
    <section id="portfolio" class="bg-slate-50 px-5 py-24">
      <div class="mx-auto max-w-7xl">

        <div class="mb-14 max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">
            Portfolio Progetti
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-5xl">
            Progetti in evoluzione.
          </h2>

          <p class="mt-5 text-lg leading-8 text-slate-600">
            Salute, eventi, natura, software e strumenti che sto costruendo nel tempo.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">

          <a href="#" class="group rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">Accademia</p>
            <h3 class="mt-3 text-2xl font-semibold text-slate-950">Accademia PosturaCorretta</h3>
            <p class="mt-3 leading-7 text-slate-600">Percorsi educativi tra postura e fisiologia.</p>
          </a>

          <a href="#" class="group rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Eventi</p>
            <h3 class="mt-3 text-2xl font-semibold text-slate-950">Spontaneamente</h3>
            <p class="mt-3 leading-7 text-slate-600">Eventi, relazioni reali, natura e comunità.</p>
          </a>

          <a href="#" class="group rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700">Software</p>
            <h3 class="mt-3 text-2xl font-semibold text-slate-950">Flowpulse</h3>
            <p class="mt-3 leading-7 text-slate-600">Organizzazione di eventi, percorsi e progetti.</p>
          </a>

          <a href="#" class="group rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Rails</p>
            <h3 class="mt-3 text-2xl font-semibold text-slate-950">Rails4Business</h3>
            <p class="mt-3 leading-7 text-slate-600">Ruby on Rails e strumenti digitali.</p>
          </a>

          <a href="#" class="group rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-violet-700">Visione</p>
            <h3 class="mt-3 text-2xl font-semibold text-slate-950">Il Giardino del Corpo</h3>
            <p class="mt-3 leading-7 text-slate-600">Il progetto dell’agriturismo rigenerativo.</p>
          </a>

          <a href="#libro" class="group rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700">Libro</p>
            <h3 class="mt-3 text-2xl font-semibold text-slate-950">Il corpo, un mondo da scoprire</h3>
            <p class="mt-3 leading-7 text-slate-600">Il libro che unisce tutto il progetto.</p>
          </a>

        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="border-t border-slate-200 bg-white px-5 py-10">
    <div class="mx-auto flex max-w-7xl flex-col gap-4 text-sm text-slate-500 md:flex-row md:items-center md:justify-between">
      <p class="font-semibold text-slate-900">Mark Postura</p>
      <p>Fisioterapia · metodiche posturali · natura · progetti & software</p>
    </div>
  </footer>

</body>

</html>
