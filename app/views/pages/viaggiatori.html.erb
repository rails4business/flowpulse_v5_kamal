<% content_for :title, "Dashboard Esperienze" %>
<% active_section = params[:section].presence_in(%w[eventi categorie brand]) || "eventi" %>

<header class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-blue-600">Dashboard Viaggiatore</p>
      <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-slate-950 md:text-5xl">Esperienze</h1>
    </header>

    <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-blue-600">Iscrizioni</p>
          <h2 class="mt-1 text-2xl font-extrabold tracking-tight text-slate-950">I tuoi domini</h2>
          <p class="mt-2 text-sm leading-6 text-slate-500">
            <% if @traveler_subscription_scope_domain.present? %>
              Vista filtrata da <strong><%= @traveler_subscription_scope_domain.display_hostname %></strong> e dai domini sotto il suo nodo.
            <% else %>
              Tutte le iscrizioni gratuite collegate ai domini che segui.
            <% end %>
          </p>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-600">
          <%= @traveler_subscriptions.size %> attive
        </span>
      </div>

      <% if @traveler_subscriptions.any? %>
        <div class="mt-5 divide-y divide-slate-100">
          <% @traveler_subscriptions.each do |subscription| %>
            <article class="flex flex-col gap-3 py-4 sm:flex-row sm:items-center sm:justify-between">
              <div class="min-w-0">
                <h3 class="truncate text-base font-extrabold text-slate-900"><%= subscription.domain.display_hostname %></h3>
                <p class="mt-1 truncate text-sm text-slate-500"><%= subscription.node.title %></p>
              </div>
              <div class="flex items-center gap-2">
                <%= link_to "Apri", node_path(subscription.node), class: "rounded-lg border border-slate-200 px-3 py-2 text-xs font-bold text-slate-700 hover:bg-slate-50" %>
                <%= button_to "Rimuovi", traveler_subscription_path(subscription),
                  method: :delete,
                  class: "rounded-lg border border-red-200 px-3 py-2 text-xs font-bold text-red-600 hover:bg-red-50",
                  form: { data: { turbo_confirm: "Rimuovere questa iscrizione?" } } %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="mt-5 rounded-xl border border-dashed border-slate-200 bg-slate-50 p-5 text-sm font-semibold text-slate-500">
          Nessuna iscrizione attiva in questo ramo.
        </div>
      <% end %>
    </section>

    <nav class="mt-4 flex flex-wrap gap-2" aria-label="Sezioni esperienze">
      <% [
        ["eventi", "Eventi"],
        ["categorie", "Categorie"],
        ["brand", "Brand"]
      ].each do |key, title| %>
        <% active = active_section == key %>
        <%= verified_link_to title, viaggiatori_path(section: key), class: "rounded-xl border px-4 py-2 text-sm font-extrabold transition #{active ? 'border-slate-900 bg-slate-900 text-white' : 'border-slate-200 bg-white text-slate-700 hover:bg-slate-50'}" %>
      <% end %>
    </nav>
<% if  0 == 1 %>
    <% if active_section == "eventi" %>
      <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mvp-travel-section__intro">
          <div>
            <h2>Eventi</h2>
            <p>Scegli una categoria, trova un evento, partecipa o organizzalo.</p>
          </div>
          <span class="mvp-pill">Prossimo passo: Esperienze</span>
        </div>

        <div class="mvp-event-grid">
          <article class="mvp-event-card">
            <div class="mvp-event-date mvp-event-date--blue">
              <span class="mvp-event-date__month">MAG</span>
              <strong>16</strong>
              <small>SAB</small>
            </div>
            <div class="mvp-event-card__body">
              <div class="mvp-event-card__chips">
                <span class="mvp-chip mvp-chip--dark">PosturaCorretta</span>
                <span class="mvp-chip mvp-chip--soft-blue">Stop al Dolore</span>
              </div>
              <h3>PosturaCorretta in Vetta</h3>
              <p>Camminata in montagna con esercizi semplici di postura e recupero.</p>
              <div class="mvp-event-card__meta">
                <span>Sab 16 Mag · 09:30</span>
                <span>Monte Maddalena</span>
                <span>Marco</span>
              </div>
            </div>
          </article>

          <article class="mvp-event-card">
            <div class="mvp-event-date mvp-event-date--amber">
              <span class="mvp-event-date__month">MAG</span>
              <strong>23</strong>
              <small>SAB</small>
            </div>
            <div class="mvp-event-card__body">
              <div class="mvp-event-card__chips">
                <span class="mvp-chip mvp-chip--green">Giardino del Corpo</span>
              </div>
              <h3>PosturaCorretta con la Forchetta</h3>
              <p>Prodotti locali, movimento leggero e condivisione.</p>
              <div class="mvp-event-card__meta">
                <span>Sab 23 Mag · 18:30</span>
                <span>Azienda agricola partner</span>
                <span>Da trovare</span>
              </div>
            </div>
          </article>

          <article class="mvp-event-card">
            <div class="mvp-event-date mvp-event-date--rose">
              <span class="mvp-event-date__month">GIU</span>
              <strong>06</strong>
              <small>SAB</small>
            </div>
            <div class="mvp-event-card__body">
              <div class="mvp-event-card__chips">
                <span class="mvp-chip mvp-chip--green">Giardino del Corpo</span>
              </div>
              <h3>Fisarmonica e fuoco</h3>
              <p>Serata semplice con musica, racconti e comunita.</p>
              <div class="mvp-event-card__meta">
                <span>Sab 06 Giu · 20:00</span>
                <span>Location da confermare</span>
                <span>Anna</span>
              </div>
            </div>
          </article>
        </div>
      </section>
    <% elsif active_section == "categorie" %>
      <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mvp-travel-section__intro">
          <div>
            <h2>Categorie</h2>
            <p>Scegli il tipo di esperienza che vuoi vivere o organizzare.</p>
          </div>
          <span class="mvp-pill">8 ingressi</span>
        </div>

        <div class="mvp-category-grid">
          <% [
            ["🚶‍♂️", "Movimento", "4 eventi", "red"],
            ["🍴", "Cibo", "2 eventi", "amber"],
            ["🪗", "Musica", "3 eventi", "rose"],
            ["🧘", "Meditazione", "1 evento", "violet"],
            ["🌲", "Natura", "5 eventi", "green"],
            ["💙", "Postura", "4 eventi", "blue"],
            ["💻", "Lavoro", "2 eventi", "yellow"],
            ["🗺️", "Mappe", "2 eventi", "slate"]
          ].each do |icon, title, count, tone| %>
            <article class="mvp-category-card mvp-category-card--<%= tone %>">
              <span><%= icon %></span>
              <h3><%= title %></h3>
              <p><%= count %></p>
            </article>
          <% end %>
        </div>
      </section>
    <% else %>
      <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mvp-travel-section__intro">
          <div>
            <h2>Brand</h2>
            <p>I brand sono mondi di esperienze. Ogni brand puo avere percorsi o sotto-brand.</p>
          </div>
          <span class="mvp-pill">3 mondi attivi</span>
        </div>

        <div class="mvp-brand-stack">
          <article class="mvp-brand-card">
            <div>
              <span class="mvp-chip mvp-chip--dark">Brand</span>
              <h3>PosturaCorretta</h3>
              <p>Postura, movimento, salute e fisiologia.</p>
              <div class="mvp-brand-tags">
                <span>Stop al Dolore</span>
                <span>Benessere Integrato</span>
                <span>Postura e Fisiologia</span>
              </div>
            </div>
            <strong>💙</strong>
          </article>

          <article class="mvp-brand-card">
            <div>
              <span class="mvp-chip mvp-chip--green">Brand</span>
              <h3>Giardino del Corpo</h3>
              <p>Natura, musica, cibo, comunita e rigenerazione.</p>
            </div>
            <strong>🌿</strong>
          </article>

          <article class="mvp-brand-card">
            <div>
              <span class="mvp-chip mvp-chip--amber">Brand</span>
              <h3>Flowpulse</h3>
              <p>Mappe, creator, lavoro e organizzazione eventi.</p>
            </div>
            <strong>🗺️</strong>
          </article>
        </div>
      </section>
    <% end %>
<% end %>