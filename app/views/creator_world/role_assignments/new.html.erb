<% content_for :title, "Nuova Assegnazione Ruolo" %>

<header class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-blue-600">Nuova assegnazione</p>
  <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-slate-950 md:text-5xl">Assegna Ruolo</h1>
  <span class="mt-4 block max-w-3xl text-base leading-7 text-slate-600">Assegna un ruolo dipendente ad un utente per il canale attivo.</span>
  <span class="mt-3 inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-extrabold text-blue-700 ring-1 ring-blue-100">
    Canale attivo: <%= @active_channel.display_name %>
  </span>
</header>

<section class="mt-6 max-w-2xl rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <% if @role_assignment.errors.any? %>
    <div class="mb-5 rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-700">
      <%= @role_assignment.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= form_with model: @role_assignment, url: creator_world_role_assignments_path, method: :post, class: "grid gap-5" do |form| %>
    <div>
      <%= form.label :username, "Utente (Cerca per Username)", class: "block text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500" %>
      
      <%= form.text_field :username,
        list: "profiles-datalist",
        id: "role_assignment_username",
        class: "mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm font-semibold text-slate-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
        placeholder: "Cerca utente per username...",
        autocomplete: "off",
        value: @role_assignment.profile&.username || params.dig(:role_assignment, :username) %>

      <datalist id="profiles-datalist">
        <% @profiles.each do |profile| %>
          <option value="<%= profile.username %>"><%= profile.display_name %></option>
        <% end %>
      </datalist>
    </div>

    <div>
      <%= form.label :role, "Ruolo da Assegnare", class: "block text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500" %>
      <%= form.select :role,
        options_for_select(@assignable_roles.map { |role| [role.humanize, role] }, @role_assignment.role),
        { prompt: "Seleziona ruolo" },
        id: "role_assignment_role",
        class: "mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="flex flex-wrap items-center gap-3 pt-2">
      <%= form.submit "Assegna", class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2 text-sm font-extrabold text-white shadow-sm transition hover:bg-blue-700" %>
      <%= link_to "Annulla", creator_world_role_assignments_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-extrabold text-slate-700 transition hover:bg-slate-50" %>
    </div>
  <% end %>
</section>
