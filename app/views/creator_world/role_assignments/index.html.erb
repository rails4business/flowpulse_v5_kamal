<% content_for :title, "Gestione Ruoli Canale" %>

<header class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
    <div>
      <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-blue-600">Workspace Creator</p>
      <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-slate-950 md:text-5xl">Gestione Ruoli</h1>
      <span class="mt-4 block max-w-3xl text-base leading-7 text-slate-600">Assegna e gestisci i ruoli dipendenti (Teacher, Tutor, Professionista, etc.) per il tuo canale attivo.</span>
      <span class="mt-3 inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-extrabold text-blue-700 ring-1 ring-blue-100">
        Canale attivo: <%= @active_channel.display_name %>
      </span>
    </div>

    <%= link_to "Nuova Assegnazione", new_creator_world_role_assignment_path, class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2 text-sm font-extrabold text-white shadow-sm transition hover:bg-blue-700" %>
  </div>
</header>

<section class="mt-6 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
      <thead class="sticky top-0 z-10 bg-slate-50 text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500 shadow-[0_1px_0_rgba(226,232,240,1)]">
        <tr>
          <th class="px-4 py-3">Ruolo</th>
          <th class="px-4 py-3">Username</th>
          <th class="px-4 py-3">Nome</th>
          <th class="px-4 py-3">Assegnato Il</th>
          <th class="px-4 py-3 text-right">Azioni</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% if @role_assignments.any? %>
          <% @role_assignments.each do |assignment| %>
            <tr class="align-middle">
              <td class="whitespace-nowrap px-4 py-3 font-bold text-slate-950">
                <span class="inline-flex items-center rounded-md bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
                  <%= assignment.role.humanize %>
                </span>
              </td>
              <td class="whitespace-nowrap px-4 py-3 font-mono text-slate-700">@<%= assignment.profile.username %></td>
              <td class="px-4 py-3 text-slate-600 font-medium"><%= assignment.profile.display_name %></td>
              <td class="whitespace-nowrap px-4 py-3 text-slate-600"><%= l(assignment.created_at, format: :short) %></td>
              <td class="whitespace-nowrap px-4 py-3 text-right">
                <%= button_to "Revoca", creator_world_role_assignment_path(assignment), method: :delete, form: { data: { turbo_confirm: "Sei sicuro di voler revocare questa assegnazione?" } }, class: "inline-flex items-center justify-center rounded-lg border border-red-200 bg-white px-3 py-1.5 text-xs font-extrabold text-red-600 transition hover:bg-red-50" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="px-4 py-8 text-center text-sm font-semibold text-slate-500">Nessun ruolo assegnato per il canale '<%= @active_channel.display_name %>'.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
