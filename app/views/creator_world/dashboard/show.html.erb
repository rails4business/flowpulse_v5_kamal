<% content_for :title, "Dashboard Creator" %>

<header class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-blue-600">Creator</p>
  <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-slate-950 md:text-5xl">Root node e domini</h1>
  <span class="mt-4 block max-w-3xl text-base leading-7 text-slate-600">Canali creator assegnati dal superadmin, con i root node e i domini collegati.</span>
  <% if @creator_domain_context.present? %>
    <span class="mt-3 inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-extrabold text-blue-700 ring-1 ring-blue-100">
      Vista dominio: <%= @creator_domain_context.display_hostname %>
    </span>
  <% end %>
</header>

<section class="mt-6 grid gap-4">
  <% if @creator_assignments.any? %>
    <% @creator_assignments.each do |assignment| %>
      <% all_root_nodes = assignment.nodes.roots.includes(:domains).order(:position, :title).to_a %>
      <% root_nodes = if @creator_domain_context_hosts.any?
        all_root_nodes.select { |node| node.domains.empty? || node.domains.any? { |domain| @creator_domain_context_hosts.include?(domain.hostname) } }
      else
        all_root_nodes
      end %>
      <% base_domain_hosts = %w[flowpulse.net www.flowpulse.net] %>
      <% channel_domains = assignment.domains.order(primary: :desc, hostname: :asc).reject { |domain| base_domain_hosts.include?(domain.hostname) || base_domain_hosts.include?(domain.canonical_host) } %>
      <% aliases_by_canonical = channel_domains.select { |domain| domain.canonical_host.present? }.group_by(&:canonical_host) %>
      <% canonical_hosts = channel_domains.map(&:hostname) %>
      <% visible_domains = channel_domains.reject { |domain| domain.canonical_host.present? && canonical_hosts.include?(domain.canonical_host) } %>
      <% new_domains = visible_domains.select { |domain| domain.node_id.blank? } %>
      <% new_domains = new_domains.select { |domain| @creator_domain_context_hosts.include?(domain.hostname) } if @creator_domain_context_hosts.any? %>

      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="text-[10px] font-extrabold uppercase tracking-[0.14em] text-slate-400">Canale</p>
            <h2 class="mt-1 text-xl font-extrabold text-slate-950"><%= assignment.display_name %></h2>
          </div>

          <%= link_to "New root node", new_creator_world_role_assignment_node_path(assignment), class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2 text-sm font-extrabold text-white shadow-sm transition hover:bg-blue-700" %>
        </div>

        <% if new_domains.any? %>
          <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-4">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
              <h3 class="text-xs font-extrabold uppercase tracking-[0.14em] text-slate-500">I tuoi nuovi domini</h3>
              <span class="text-xs font-bold text-slate-400"><%= new_domains.size %> da configurare</span>
            </div>

            <div class="mt-4 grid gap-3 lg:grid-cols-2">
              <% new_domains.each do |domain| %>
                <% canonical_aliases = aliases_by_canonical[domain.hostname].to_a %>
                <div class="rounded-xl border border-slate-200 bg-white p-4">
                  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                    <div class="min-w-0">
                      <div class="flex flex-wrap items-center gap-2">
                        <%= link_to domain.display_hostname, "https://#{domain.hostname}", target: "_blank", rel: "noopener", class: "font-extrabold text-blue-700 hover:text-blue-500" %>
                        <span class="rounded-full bg-amber-50 px-2 py-0.5 text-[10px] font-extrabold uppercase tracking-wide text-amber-700 ring-1 ring-amber-100">Da collegare</span>
                        <% if canonical_aliases.any? %>
                          <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-extrabold uppercase tracking-wide text-slate-500"><%= pluralize(canonical_aliases.size, "alias") %></span>
                        <% end %>
                      </div>

                      <p class="mt-2 text-xs font-semibold text-amber-700">Nessun nodo iniziale associato.</p>

                      <% if canonical_aliases.any? %>
                        <div class="mt-3 space-y-1 border-l border-slate-200 pl-3 text-xs font-semibold text-slate-500">
                          <% canonical_aliases.each do |domain_alias| %>
                            <div class="flex flex-wrap items-center gap-2">
                              <span>Alias:</span>
                              <%= link_to domain_alias.hostname, "https://#{domain_alias.hostname}", target: "_blank", rel: "noopener", class: "text-slate-700 hover:text-blue-600" %>
                              <span class="text-slate-400">→</span>
                              <span><%= domain.hostname %></span>
                            </div>
                          <% end %>
                        </div>
                      <% elsif domain.canonical_host.present? %>
                        <p class="mt-2 text-xs font-semibold text-amber-700">Canonical verso <%= domain.canonical_host %> non presente in questo canale.</p>
                      <% end %>
                    </div>

                    <%= link_to "Crea root node", new_creator_world_role_assignment_node_path(assignment), class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-3 py-2 text-xs font-extrabold text-white transition hover:bg-blue-700" %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if root_nodes.any? %>
          <div class="mt-5 grid gap-3">
            <% root_nodes.each do |node| %>
              <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                  <div>
                    <h3 class="text-base font-extrabold text-slate-950"><%= node.title %></h3>
                    <p class="mt-1 text-xs font-semibold text-slate-500"><%= node.status.humanize %> · <%= Node.visibility_label(node.visibility) %></p>
                  </div>

                  <%= link_to "Open", tree_creator_world_role_assignment_node_path(assignment, node), class: "inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-3 py-2 text-xs font-extrabold text-slate-700 transition hover:bg-slate-100", data: { turbo: false } %>
                </div>

                <div class="mt-4 flex flex-wrap gap-2">
                  <% if node.domains.any? %>
                    <% node.domains.order(:hostname).each do |domain| %>
                      <span class="rounded-full bg-white px-3 py-1 text-xs font-bold text-slate-600 ring-1 ring-slate-200"><%= domain.hostname %></span>
                    <% end %>
                  <% else %>
                    <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-bold text-amber-700 ring-1 ring-amber-100">Nessun dominio collegato</span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="mt-5 rounded-xl border border-dashed border-slate-300 bg-slate-50 p-5">
            <% if @creator_domain_context.present? %>
              <p class="text-sm font-semibold text-slate-600">Nessun root node libero o collegato a questo dominio.</p>
            <% else %>
              <p class="text-sm font-semibold text-slate-600">Nessun root node creato per questo canale.</p>
            <% end %>
          </div>
        <% end %>
      </article>
    <% end %>
  <% else %>
    <article class="rounded-2xl border border-slate-200 bg-white p-6 text-sm font-semibold text-slate-600 shadow-sm">
      Nessun canale creator assegnato.
    </article>
  <% end %>
</section>
