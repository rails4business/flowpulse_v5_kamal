<% content_for :full_screen, true %>
<% tree_query = params.slice(:editing).permit(:editing).to_h.symbolize_keys %>

<%= turbo_frame_tag "node_workspace" do %>
  <div class="p-6 md:p-8 bg-white min-h-screen">
    <% if @active_tab == "node" %>
      <!-- Obsidian Document Header -->
      <header class="flex flex-col border-b border-slate-100 pb-6 mb-6">
        <div class="inline-flex items-center gap-1.5 text-[11px] font-bold text-blue-600 bg-blue-50 border border-blue-100/50 rounded-full px-2.5 py-0.5 uppercase tracking-wide select-none w-fit mb-3">
          <span>📁</span> <%= @node.node_type.presence || @node.content_type.presence || "node" %>
        </div>

        <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 leading-tight">
          <%= @node.title %>
        </h1>

        <% if @node.description.present? %>
          <p class="mt-3 text-slate-500 text-base leading-relaxed max-w-4xl font-medium">
            <%= @node.description %>
          </p>
        <% end %>
      </header>

      <!-- Obsidian Note Properties (HyperUI Read-Only Table) -->
      <section class="bg-slate-50/50 border border-slate-200/50 rounded-xl p-5 mb-8 max-w-3xl">
        <div class="text-[10px] tracking-wider text-slate-400 font-extrabold uppercase mb-4 select-none">Proprietà nota</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3">
          
          <div class="flex items-center justify-between py-1.5 border-b border-slate-100/70 sm:border-b-0">
            <div class="flex items-center gap-2 text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">🔗</span>
              <span>Slug</span>
            </div>
            <div>
              <span class="font-mono text-xs text-slate-700 bg-white border border-slate-200 rounded px-2 py-0.5"><%= @node.slug %></span>
            </div>
          </div>

          <div class="flex items-center justify-between py-1.5 border-b border-slate-100/70 sm:border-b-0">
            <div class="flex items-center gap-2 text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">📁</span>
              <span>Tipo</span>
            </div>
            <div>
              <span class="text-xs font-bold text-slate-700 uppercase"><%= @node.node_type %></span>
            </div>
          </div>

          <div class="flex items-center justify-between py-1.5 border-b border-slate-100/70 sm:border-b-0">
            <div class="flex items-center gap-2 text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">👁️</span>
              <span>Vista</span>
            </div>
            <div>
              <span class="text-xs font-bold text-slate-700 uppercase"><%= @node.view_type %></span>
            </div>
          </div>

          <div class="flex items-center justify-between py-1.5 border-b border-slate-100/70 sm:border-b-0">
            <div class="flex items-center gap-2 text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">🔢</span>
              <span>Posizione</span>
            </div>
            <div>
              <span class="text-xs font-bold text-slate-700 bg-slate-100 rounded px-2 py-0.5"><%= @node.position || 1 %></span>
            </div>
          </div>

          <div class="flex items-center justify-between py-1.5 border-b border-slate-100/70 sm:border-b-0">
            <div class="flex items-center gap-2 text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">📏</span>
              <span>Profondità</span>
            </div>
            <div>
              <span class="text-xs font-bold text-slate-700"><%= @node.depth || @node.level %></span>
            </div>
          </div>

          <div class="flex items-center justify-between py-1.5 border-b border-slate-100/70 sm:border-b-0">
            <div class="flex items-center gap-2 text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">🌿</span>
              <span>Figli</span>
            </div>
            <div>
              <span class="text-xs font-bold text-slate-700"><%= @children.size %></span>
            </div>
          </div>

          <div class="flex items-center justify-between py-1.5 sm:col-span-2">
            <div class="flex items-center gap-2 text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">📺</span>
              <span>Canale</span>
            </div>
            <div>
              <span class="text-xs font-bold text-slate-700"><%= @role_assignment.display_name %></span>
            </div>
          </div>
        </div>
      </section>

      <!-- Sub-notes (Children Nodi) -->
      <section class="mt-8">
        <div class="flex items-center justify-between border-b border-slate-200 pb-3 mb-4">
          <h3 class="text-xs font-extrabold tracking-wider text-slate-400 uppercase select-none flex items-center gap-1.5">
            <span>🌿</span> Sotto-note (Figli)
          </h3>

          <% unless @node.bridge_node? %>
            <%= link_to "+ Nuovo nodo", new_creator_world_role_assignment_node_path(@role_assignment, parent_id: @node.id),
              class: "inline-flex items-center justify-center rounded-md border border-slate-200 bg-white px-3 py-1.5 text-xs font-bold text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition h-8",
              data: { turbo_frame: "node_workspace" } %>
          <% end %>
        </div>

        <% if @children.any? %>
          <div
            class="space-y-2"
            data-controller="sortable"
            data-role-assignment-id="<%= @role_assignment.id %>"
            data-parent-id="<%= @node.id %>"
          >
            <% @children.each do |child| %>
              <div
                class="flex items-center justify-between bg-white border border-slate-200 rounded-lg p-3 hover:border-slate-300 hover:bg-slate-50/30 transition shadow-sm"
                data-node-id="<%= child.id %>"
              >
                <div class="flex items-center gap-3 min-w-0 flex-1">
                  <!-- Grab handle for sortable -->
                  <span
                    class="tree-edit-control hidden h-7 w-7 cursor-grab items-center justify-center rounded-md border border-slate-200 bg-white text-slate-400 select-none hover:bg-slate-50 transition"
                    data-sortable-handle
                    data-tree-target="orderHandle"
                  >
                    ⋮⋮
                  </span>

                  <!-- Move handle button -->
                  <button
                    type="button"
                    class="tree-edit-control tree-move-handle hidden h-7 items-center justify-center rounded-md border border-slate-200 bg-white px-2 text-[10px] font-bold text-slate-500 hover:border-blue-300 hover:bg-blue-50 hover:text-blue-600 transition"
                    aria-label="Sposta <%= child.title %> in una cartella"
                    title="Sposta in cartella"
                    data-tree-target="moveHandle"
                    data-tree-move-handle
                    data-node-id="<%= child.id %>"
                    data-node-title="<%= child.title %>"
                    data-action="click->tree#selectFolderMove"
                  >
                    Sposta
                  </button>

                  <!-- Node indicator -->
                  <span class="inline-flex h-5 w-5 items-center justify-center rounded bg-slate-100 text-[10px] text-slate-400 select-none font-bold">
                    <%= child.bridge_node? ? '↗' : '◆' %>
                  </span>

                  <div class="min-w-0 flex-1">
                    <%= link_to tree_creator_world_role_assignment_node_path(@role_assignment, child, tree_query.merge(tab: "node")),
                      class: "block truncate font-bold text-slate-800 hover:text-blue-600 transition text-sm",
                      data: { turbo_frame: "node_workspace" } do %>
                      <%= child.title %>
                    <% end %>

                    <div class="flex items-center gap-2 mt-0.5 text-[10px] text-slate-400 font-extrabold uppercase tracking-wider">
                      <span><%= child.content_type.presence || "node" %></span>
                      <span>•</span>
                      <span>Posizione: <%= child.position || 0 %></span>
                      <% if child.bridge_node? %>
                        <span>•</span>
                        <span class="text-[9px] text-blue-600 bg-blue-50 border border-blue-100 rounded px-1.5 lowercase font-normal normal-case">
                          ponte a: <%= child.link_node&.title || "n/d" %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>

                <div class="flex items-center gap-2">
                  <span class="inline-flex h-5 min-w-5 items-center justify-center rounded bg-slate-100 px-1.5 text-[10px] font-bold text-slate-500 select-none">
                    #<%= child.position || 0 %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-xl border border-dashed border-slate-200 bg-slate-50/40 p-6 text-center select-none">
            <p class="text-sm text-slate-400 font-semibold">Nessuna sotto-nota o cartella collegata.</p>
          </div>
        <% end %>
      </section>

    <% else %>
      <!-- Obsidian Content Workspace Tab -->
      <section class="flex flex-col">
        <header class="flex items-center justify-between border-b border-slate-100 pb-3 mb-6">
          <div class="text-[10px] text-slate-400 font-extrabold uppercase tracking-wider select-none flex items-center gap-1.5">
            <span>📄</span> CONTENUTO NOTA
          </div>

          <%= link_to "✍️ Modifica contenuto", edit_creator_world_role_assignment_node_path(@role_assignment, @node),
            class: "inline-flex items-center justify-center rounded-md border border-slate-200 bg-white px-3 py-1.5 text-xs font-bold text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition h-8",
            data: { turbo_frame: "node_workspace" } %>
        </header>

        <% if @node.content&.body_md.present? || @node.content&.body_html.present? %>
          <div class="mb-6 pb-4 border-b border-slate-100 flex items-center justify-between">
            <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 leading-tight">
              <%= @node.title %>
            </h1>
            <div class="text-[10px] font-extrabold text-slate-400 bg-slate-100 border border-slate-200 rounded px-2 py-0.5 select-none uppercase tracking-wide">
              <%= @node.content.editor.presence || "markdown" %> / <%= @node.content.format.presence || "html" %>
            </div>
          </div>

          <!-- Document Canvas (Styled Markdown Preview) -->
          <div class="obsidian-markdown-canvas text-slate-700 leading-relaxed max-w-4xl">
            <% if @node.content.body_md.present? %>
              <%= render_node_markdown(@node.content.body_md) %>
            <% else %>
              <%= sanitize @node.content.body_html %>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-xl border border-dashed border-slate-200 bg-slate-50/30 p-12 text-center max-w-2xl mx-auto mt-12 shadow-sm">
            <span class="text-3xl block mb-4 select-none">✍️</span>
            <h4 class="text-base font-bold text-slate-800 mb-2">Nota vuota</h4>
            <p class="text-sm text-slate-400 mb-5 max-w-sm mx-auto">Questo nodo non contiene testo. Clicca sul pulsante qui sotto per inserire testo in formato Markdown.</p>
            <%= link_to "Scrivi contenuto", edit_creator_world_role_assignment_node_path(@role_assignment, @node),
              class: "inline-flex items-center justify-center rounded-md bg-slate-950 px-4 py-2 text-xs font-bold text-white hover:bg-slate-800 transition h-8 cursor-pointer",
              data: { turbo_frame: "node_workspace" } %>
          </div>
        <% end %>
      </section>
    <% end %>
  </div>
<% end %>
