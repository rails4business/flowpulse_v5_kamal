<%= form_with(model: [:creator_world, @role_assignment, node], class: "node-editor-form obsidian-editor-form flex flex-col h-[calc(100vh-4.5rem)] min-h-0") do |form| %>
  <%= form.hidden_field :parent_id %>
  <%= form.hidden_field :role_assignment_id if node.parent_id.present? %>

  <% if node.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700 mx-6 mt-4 md:mx-8">
      <p class="font-bold flex items-center gap-1.5">
        <span>⚠️</span> Controlla questi campi:
      </p>
      <ul class="list-disc list-inside mt-2 space-y-1">
        <% node.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <input type="checkbox" id="node-settings-toggle" class="node-settings-checkbox hidden" checked />

  <div class="node-compose-layout obsidian-layout grid grid-cols-1 md:grid-cols-[1fr_340px] items-stretch flex-1 min-h-0 overflow-hidden">
    <!-- Main editor canvas -->
    <section class="node-compose-main obsidian-main p-6 md:p-8 overflow-y-auto bg-white flex flex-col gap-4">
      <div class="flex justify-between items-center border-b border-slate-100 pb-3 mb-2">
        <div class="text-[10px] text-slate-400 font-extrabold tracking-wider uppercase select-none flex items-center gap-1">
          <span>📝</span> EDITOR NOTA
        </div>
        <label for="node-settings-toggle" class="node-settings-toggle-btn cursor-pointer inline-flex items-center gap-1.5 text-[11px] font-semibold text-slate-500 hover:text-slate-700 bg-slate-100 hover:bg-slate-200 border border-slate-200 rounded-md px-2.5 py-1.5 transition select-none">
          <span>⚙️ Proprietà</span>
        </label>
      </div>

      <div class="node-title-field obsidian-title-field">
        <%= form.label :title, "Titolo", class: "sr-only" %>
        <%= form.text_field :title,
          class: "w-full border-0 bg-transparent text-4xl sm:text-5xl font-extrabold text-slate-900 placeholder-slate-200 focus:ring-0 focus:outline-none p-0 leading-tight",
          autofocus: true,
          placeholder: "Senza titolo" %>
      </div>

      <div class="node-description-field obsidian-description-field">
        <%= form.label :description, "Descrizione", class: "sr-only" %>
        <%= form.text_area :description,
          rows: 2,
          class: "w-full border-0 bg-transparent text-base text-slate-500 placeholder-slate-200 focus:ring-0 focus:outline-none p-0 resize-none leading-relaxed",
          placeholder: "Scrivi una descrizione breve per questa nota..." %>
      </div>

      <%= form.fields_for :content do |content_form| %>
        <%= content_form.hidden_field :editor, value: "markdown" %>
        <%= content_form.hidden_field :format, value: "markdown" %>

        <div class="node-content-field obsidian-content-field border-t border-slate-100 pt-4 flex flex-col flex-1 min-h-[400px]">
          <div class="node-content-toolbar obsidian-content-toolbar flex items-center gap-2 text-[10px] text-slate-400 font-bold uppercase tracking-wider select-none mb-2">
            <span class="flex items-center gap-1">💻 Markdown</span>
            <span class="text-slate-200">|</span>
            <span>EasyMDE Editor</span>
          </div>

          <%= content_form.text_area :body_md,
            rows: 24,
            class: "node-body-input obsidian-body-input w-full border-0 bg-transparent text-sm font-mono text-slate-800 focus:ring-0 focus:outline-none p-0 leading-relaxed resize-none",
            data: { controller: "markdown-editor" },
            placeholder: "# Titolo\n\nScrivi qui il contenuto del nota." %>
        </div>
      <% end %>
    </section>

    <!-- Obsidian Note Properties Panel -->
    <aside class="node-compose-sidebar obsidian-sidebar bg-slate-50 border-l border-slate-200 p-6 overflow-y-auto flex flex-col gap-6">
      <div>
        <div class="flex items-center justify-between border-b border-slate-100 pb-2 mb-4">
          <span class="text-[11px] font-extrabold tracking-wider text-slate-400 uppercase">Proprietà nota</span>
          <span class="text-[9px] bg-slate-200 text-slate-600 px-1.5 py-0.5 rounded font-bold uppercase select-none">HyperUI</span>
        </div>

        <div class="space-y-3">
          <!-- Property: Canale -->
          <div class="flex items-center justify-between py-1.5 border-b border-slate-100/70">
            <div class="flex items-center gap-2 w-1/3 min-w-[100px] text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">📺</span>
              <span>Canale</span>
            </div>
            <div class="flex-1 min-w-0 text-right">
              <span class="text-xs font-bold text-slate-700 bg-slate-150/60 rounded px-2 py-0.5"><%= @role_assignment.display_name %></span>
            </div>
          </div>

          <!-- Property: Slug -->
          <div class="flex items-center justify-between py-1 border-b border-slate-100/70">
            <div class="flex items-center gap-2 w-1/3 min-w-[100px] text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">🏷️</span>
              <span>Slug</span>
            </div>
            <div class="flex-1 min-w-0">
              <%= form.text_field :slug,
                class: "w-full border border-transparent hover:border-slate-200 focus:border-blue-400 bg-transparent focus:bg-white text-right text-xs font-medium text-slate-800 focus:ring-1 focus:ring-blue-100 rounded px-2 py-1 placeholder-slate-300 transition",
                placeholder: "auto-generato" %>
            </div>
          </div>

          <!-- Property: Bridge/Link Node -->
          <div class="flex flex-col gap-1.5 py-1.5 border-b border-slate-100/70">
            <div class="flex items-center gap-2 text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">↗️</span>
              <span>Node link</span>
            </div>
            <p class="text-[11px] leading-4 text-slate-400">
              Se impostato, questo nodo non può avere figli e nella pagina pubblica apre direttamente il nodo collegato.
            </p>
            
            <div class="w-full">
              <div data-controller="autocomplete" style="position: relative; width: 100%;">
                <%= form.hidden_field :link_node_id, data: { autocomplete_target: "hidden" } %>
                
                <div style="position: relative; display: flex; align-items: center; width: 100%;">
                  <input 
                    type="text" 
                    class="w-full border border-transparent hover:border-slate-200 focus:border-blue-400 bg-transparent focus:bg-white text-xs font-medium text-slate-800 focus:ring-1 focus:ring-blue-100 rounded px-2 py-1 placeholder-slate-400 transition" 
                    placeholder="Cerca un nodo ponte..." 
                    data-autocomplete-target="input" 
                    data-action="input->autocomplete#onInput focus->autocomplete#showResults blur->autocomplete#onBlur"
                    value="<%= node.link_node&.title %>"
                    <%= "disabled" if node.children.exists? %>
                    autocomplete="off"
                    style="padding-right: 2rem;"
                  >
                  
                  <button 
                    type="button" 
                    data-autocomplete-target="clearBtn"
                    data-action="click->autocomplete#clear" 
                    class="hidden"
                    style="position: absolute; right: 0.5rem; border: none; background: transparent; cursor: pointer; color: #94a3b8; font-size: 1.25rem; display: flex; align-items: center; justify-content: center; height: 100%; width: 1.5rem; outline: none;"
                    aria-label="Cancella selezione"
                  >
                    ×
                  </button>
                </div>

                <div 
                  data-autocomplete-target="results" 
                  class="hidden"
                  style="position: absolute; z-index: 50; left: 0; right: 0; margin-top: 0.25rem; max-height: 15rem; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 0.375rem; background-color: #ffffff; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1); padding: 0.25rem 0;"
                >
                  <% link_candidates = node.persisted? ? @role_assignment.nodes.where.not(id: node.self_and_descendants.select(:id)) : @role_assignment.nodes %>
                  <% link_candidates.order(:title).each do |n| %>
                    <div 
                      data-action="mousedown->autocomplete#select" 
                      data-id="<%= n.id %>" 
                      data-title="<%= n.title %>"
                      style="cursor: pointer; padding: 0.5rem 1rem; color: #334155;"
                      onmouseover="this.style.backgroundColor='#f1f5f9'; this.style.color='#1e293b';"
                      onmouseout="this.style.backgroundColor='transparent'; this.style.color='#334155';"
                    >
                      <%= n.title %>
                    </div>
                  <% end %>
                </div>
              </div>
              <% if node.children.exists? %>
                <p class="mt-1 text-[11px] leading-4 text-amber-600">
                  Rimuovi o sposta prima i figli per trasformare questo nodo in node link.
                </p>
              <% elsif node.bridge_node? %>
                <p class="mt-1 text-[11px] leading-4 text-blue-600">
                  Collegato a: <%= node.link_node&.title || "n/d" %>
                </p>
              <% end %>
            </div>
          </div>

          <!-- Property: Tipo Nodo -->
          <div class="flex items-center justify-between py-1 border-b border-slate-100/70">
            <div class="flex items-center gap-2 w-1/3 min-w-[100px] text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">📁</span>
              <span>Tipo nodo</span>
            </div>
            <div class="flex-1 min-w-0">
              <%= form.select :node_type,
                %w[node folder page note section document],
                {},
                class: "w-full border border-transparent hover:border-slate-200 focus:border-blue-400 bg-transparent focus:bg-white text-right text-xs font-semibold text-slate-700 focus:ring-1 focus:ring-blue-100 rounded px-2 py-1 transition cursor-pointer" %>
            </div>
          </div>

          <!-- Property: Vista -->
          <div class="flex items-center justify-between py-1 border-b border-slate-100/70">
            <div class="flex items-center gap-2 w-1/3 min-w-[100px] text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">👁️</span>
              <span>Vista</span>
            </div>
            <div class="flex-1 min-w-0">
              <%= form.select :view_type,
                %w[default document card gallery],
                {},
                class: "w-full border border-transparent hover:border-slate-200 focus:border-blue-400 bg-transparent focus:bg-white text-right text-xs font-semibold text-slate-700 focus:ring-1 focus:ring-blue-100 rounded px-2 py-1 transition cursor-pointer" %>
            </div>
          </div>

          <!-- Property: Stato -->
          <div class="flex items-center justify-between py-1 border-b border-slate-100/70">
            <div class="flex items-center gap-2 w-1/3 min-w-[100px] text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">🚦</span>
              <span>Stato</span>
            </div>
            <div class="flex-1 min-w-0">
              <%= form.select :status,
                Node::STATUSES.map { |status| [status.humanize, status] },
                {},
                class: "w-full border border-transparent hover:border-slate-200 focus:border-blue-400 bg-transparent focus:bg-white text-right text-xs font-semibold text-slate-700 focus:ring-1 focus:ring-blue-100 rounded px-2 py-1 transition cursor-pointer" %>
            </div>
          </div>

          <!-- Property: Visibilità -->
          <div class="flex items-center justify-between py-1 border-b border-slate-100/70">
            <div class="flex items-center gap-2 w-1/3 min-w-[100px] text-xs font-semibold text-slate-400 select-none">
              <span class="text-sm">🔒</span>
              <span>Visibilità</span>
            </div>
            <div class="flex-1 min-w-0">
              <%= form.select :visibility,
                Node::VISIBILITIES.map { |visibility| [Node.visibility_label(visibility), visibility] },
                {},
                class: "w-full border border-transparent hover:border-slate-200 focus:border-blue-400 bg-transparent focus:bg-white text-right text-xs font-semibold text-slate-700 focus:ring-1 focus:ring-blue-100 rounded px-2 py-1 transition cursor-pointer" %>
            </div>
          </div>
        </div>
      </div>

      <!-- File Source Panel -->
      <%= form.fields_for :content do |content_form| %>
        <div>
          <div class="flex items-center justify-between border-b border-slate-100 pb-2 mb-4">
            <span class="text-[11px] font-extrabold tracking-wider text-slate-400 uppercase">Sorgente file</span>
          </div>
          <div class="space-y-3">
            <div class="flex items-center justify-between py-1 border-b border-slate-100/70">
              <div class="flex items-center gap-2 w-1/3 min-w-[100px] text-xs font-semibold text-slate-400 select-none">
                <span class="text-sm">📂</span>
                <span>Percorso</span>
              </div>
              <div class="flex-1 min-w-0">
                <%= content_form.text_field :source_path,
                  class: "w-full border border-transparent hover:border-slate-200 focus:border-blue-400 bg-transparent focus:bg-white text-right text-xs font-medium text-slate-800 focus:ring-1 focus:ring-blue-100 rounded px-2 py-1 placeholder-slate-350 transition",
                  placeholder: "es. docs/guida.md" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Legacy Panel (for Superadmins) -->
      <% if superadmin? %>
        <details class="group mt-2 border-t border-slate-200 pt-4">
          <summary class="flex items-center justify-between cursor-pointer select-none text-[11px] font-extrabold tracking-wider text-slate-400 uppercase">
            <span>⚙️ Configurazione Legacy</span>
            <span class="transition group-open:rotate-180 text-xs">▼</span>
          </summary>
          <div class="space-y-3 mt-3">
            <div class="flex items-center justify-between py-1 border-b border-slate-100/70">
              <div class="flex items-center gap-2 w-1/3 min-w-[100px] text-xs font-semibold text-slate-400 select-none">
                <span class="text-sm">⏳</span>
                <span>Tipo legacy</span>
              </div>
              <div class="flex-1 min-w-0">
                <%= form.select :content_type,
                  %w[world sea nautical_chart archipelago island island_part metro_map metro_line metro_station experience page],
                  {},
                  class: "w-full border border-transparent hover:border-slate-200 focus:border-blue-400 bg-transparent focus:bg-white text-right text-xs font-semibold text-slate-700 focus:ring-1 focus:ring-blue-100 rounded px-2 py-1 transition cursor-pointer" %>
              </div>
            </div>
          </div>
        </details>
      <% end %>
    </aside>
  </div>

  <!-- Obsidian Action Footer Bar (HyperUI Button layout) -->
  <footer class="sticky bottom-0 bg-white/95 border-t border-slate-200 px-6 h-14 flex items-center justify-between backdrop-blur-md z-30">
    <div class="text-[11px] text-slate-400 select-none font-bold tracking-wider uppercase flex items-center gap-1.5">
      <span class="inline-block w-2.5 h-2.5 rounded-full <%= node.new_record? ? 'bg-amber-400 animate-pulse' : 'bg-green-400' %>"></span>
      <span><%= node.new_record? ? "Bozza non salvata" : "Tutti i dati sono salvati" %></span>
    </div>

    <div class="flex items-center gap-3">
      <%= link_to "Annulla",
        node.persisted? ? tree_creator_world_role_assignment_node_path(@role_assignment, node) : creator_world_role_assignment_nodes_path(@role_assignment),
        class: "inline-flex items-center justify-center rounded-md border border-slate-200 bg-white px-4 py-2 text-xs font-bold text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition h-8" %>

      <%= form.submit "Salva", class: "inline-flex items-center justify-center rounded-md bg-slate-950 px-4 py-2 text-xs font-bold text-white hover:bg-slate-800 transition h-8 cursor-pointer" %>
    </div>
  </footer>
<% end %>
