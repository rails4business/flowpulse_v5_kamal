<li class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
  <div class="flex items-center justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-wide text-slate-400">
        <%= node.node_type.presence || node.content_type %>
      </p>

      <%= link_to node.title, flowtree_public_node_path(node),
        class: "text-lg font-semibold text-slate-900 hover:text-blue-600" %>
    </div>

    <span class="text-sm text-slate-400">
      #<%= node.position || 0 %>
    </span>
  </div>

  <% if node.children.any? %>
    <ul class="mt-4 space-y-3 border-l border-slate-200 pl-4">
      <% node.children.order(:position, :title).each do |child| %>
        <%= render "creator_world/nodes/node", node: child %>
      <% end %>
    </ul>
  <% end %>
</li>
